# Garam Masala Dating — Environment Variables
# Copy to .env.local and fill in real values. Never commit .env.local.

# ─── Firebase (Client — PUBLIC_ prefix exposes to browser) ───────────
PUBLIC_FIREBASE_API_KEY=AIza...
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your-project-id
PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# ─── Firebase (Server — used by API endpoints and token verification) ─
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
VITE_FIREBASE_PROJECT_ID=your-project-id

# Script-only, NOT read at runtime: input for `npm run admin:grant-claims`
# (scripts/grant-admin-claims.mjs). Runtime admin auth accepts either a
# verified email on the allowlist in src/lib/adminAllowlist.ts or an `admin`
# custom claim (granted by that script; revoke claims separately when
# offboarding an admin).
ADMIN_UIDS=firebase-auth-admin-uid-1,firebase-auth-admin-uid-2

# ─── Contestant Prep ─────────────────────────────────────────────────
CONTESTANT_PREP_SALT=your-random-salt-string

# ─── Contestant Portal ────────────────────────────────────────────────
CONTESTANT_PORTAL_SECRET=         # HMAC secret for signed portal session tokens (src/lib/portalToken.ts). Required in every runtime that serves portal endpoints (local dev, preview, production); contestant claim endpoints 500 without it. Generate: openssl rand -base64 32

# ─── Email Notifications ─────────────────────────────────────────────
NOTIFICATION_EMAIL=your-email@example.com  # Admin address for new application alerts

# ─── Eventbrite ───────────────────────────────────────────────────────
EVENTBRITE_API_TOKEN=             # Eventbrite private API token (from account settings)

# ─── Kit (ConvertKit) ─────────────────────────────────────────────────
KIT_API_SECRET=                   # Kit (ConvertKit) API secret

# ─── Scheduled / Backfill Jobs ────────────────────────────────────────
CRON_SECRET=                      # Bearer secret for external cron and backfill endpoints

# ─── Contestant Workflow (Zoho SMTP + cal.com) ────────────────────────
ZOHO_SMTP_USER=casting@garammasaladating.com
ZOHO_SMTP_PASS=                   # 16-char Zoho app password (Zoho Mail > Settings > Security > App Passwords)
ZOHO_FROM_NAME=Surbhi from Garam Masala Dating
CAL_INTERVIEW_URL=https://cal.com/garammasala/interview
CAL_WEBHOOK_SECRET=               # matches cal.com webhook signing secret
HOST_BRIEFING_EMAILS=messagesurbhi@gmail.com  # comma-separated list

# ─── Bot Protection (Cloudflare Turnstile) ────────────────────────────
PUBLIC_TURNSTILE_SITE_KEY=        # Cloudflare Turnstile site key (safe to expose; leave blank to disable)
TURNSTILE_SECRET_KEY=             # Cloudflare Turnstile secret key (server-only)
