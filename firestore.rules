rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function validNotification() {
      let d = request.resource.data;
      return d.keys().hasOnly(['email', 'city', 'source', 'createdAt'])
        && d.keys().hasAll(['email', 'city', 'createdAt'])
        && d.email is string && d.email.size() > 0 && d.email.size() <= 320
        && d.city is string && d.city.size() > 0 && d.city.size() <= 100
        && d.createdAt is string && d.createdAt.size() > 0 && d.createdAt.size() <= 30
        && (!('source' in d.keys()) || (d.source is string && d.source.size() > 0 && d.source.size() <= 50));
    }

    function validCityRequest() {
      let d = request.resource.data;
      return d.keys().hasOnly(['city', 'email', 'createdAt'])
        && d.keys().hasAll(['city', 'email', 'createdAt'])
        && d.city is string && d.city.size() > 0 && d.city.size() <= 100
        && d.email is string && d.email.size() > 0 && d.email.size() <= 320
        && d.createdAt is string && d.createdAt.size() > 0 && d.createdAt.size() <= 30;
    }

    function validSubscriber() {
      let d = request.resource.data;
      return d.keys().hasOnly(['email', 'phone', 'source', 'city', 'createdAt'])
        && d.keys().hasAll(['email', 'source', 'createdAt'])
        && d.email is string && d.email.size() > 0 && d.email.size() <= 320
        && d.source is string && d.source.size() > 0 && d.source.size() <= 50
        && d.createdAt is string && d.createdAt.size() > 0 && d.createdAt.size() <= 30
        && (!('phone' in d.keys()) || (d.phone is string && d.phone.size() > 0 && d.phone.size() <= 20))
        && (!('city' in d.keys()) || (d.city is string && d.city.size() > 0 && d.city.size() <= 100));
    }

    match /applications/{doc} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    match /applications/{doc}/{subcollection=**} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    match /notifications/{doc} {
      allow create: if validNotification();
      allow read, update, delete: if request.auth != null;
    }
    match /city_requests/{doc} {
      allow create: if validCityRequest();
      allow read, update, delete: if request.auth != null;
    }
    match /subscribers/{doc} {
      allow create: if validSubscriber();
      allow read, update, delete: if request.auth != null;
    }
  }
}
