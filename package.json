{
  "name": "garam-masala-dating",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "postbuild": "node scripts/ping-indexnow.mjs",
    "preview": "astro preview",
    "lint": "eslint .",
    "check": "astro check",
    "migrate:locations": "npx tsx scripts/migrate-locations.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "images:organize": "node scripts/organize-images.js",
    "images:organize:v": "VERBOSE=1 node scripts/organize-images.js",
    "test:links": "linkinator https://garammasaladating.com --recurse --timeout 30000 --retry --skip 'eventbrite.com|instagram.com|tiktok.com|facebook.com|twitter.com|x.com|youtube.com|linkedin.com'",
    "test:smoke": "playwright test",
    "test:smoke:headed": "playwright test --headed",
    "test:smoke:preview": "PLAYWRIGHT_BASE_URL=$VERCEL_PREVIEW_URL playwright test",
    "test:mutate": "stryker run",
    "test:mutate:incremental": "stryker run --incremental"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.2",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vercel": "^10.0.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "astro": "^6.1.2",
    "country-state-city": "^3.2.1",
    "firebase": "^12.9.0",
    "jose": "^6.2.2",
    "lucide-react": "^0.570.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-loading-skeleton": "^3.5.0",
    "react-select": "^5.10.2",
    "recharts": "^3.8.1",
    "resend": "^6.10.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/jest-runner": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "firebase-tools": "^15.18.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "linkinator": "^7.6.1",
    "lint-staged": "^16.4.0",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^6.3.5",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --no-warn-ignored"
    ],
    "*.{ts,tsx,js,jsx,astro}": [
      "prettier --write"
    ],
    "*.{css,md,json}": [
      "prettier --write"
    ]
  }
}
