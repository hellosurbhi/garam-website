{
  "name": "garam-masala-dating",
  "description": "Website, contestant application system, and admin dashboard for Garam Masala Dating — a live comedy dating show.",
  "private": true,
  "version": "1.0.0",
  "license": "SEE LICENSE",
  "author": "Garam Masala Dating",
  "repository": {
    "type": "git",
    "url": "https://github.com/hellosurbhi/garam-masala-dating.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "postbuild": "node scripts/ping-indexnow.mjs",
    "preview": "astro preview",
    "lint": "eslint .",
    "check": "astro check",
    "migrate:locations": "npx tsx scripts/migrate-locations.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "images:organize": "node scripts/organize-images.js",
    "images:organize:v": "VERBOSE=1 node scripts/organize-images.js",
    "test:links": "linkinator https://garammasaladating.com --recurse --timeout 30000 --retry --skip 'eventbrite.com|instagram.com|tiktok.com|facebook.com|twitter.com|x.com|youtube.com|linkedin.com'",
    "test:smoke": "playwright test",
    "test:smoke:headed": "playwright test --headed",
    "test:smoke:preview": "PLAYWRIGHT_BASE_URL=$VERCEL_PREVIEW_URL playwright test",
    "perf:lighthouse": "node scripts/run-lhci.mjs lighthouserc.cjs",
    "perf:mobile": "node scripts/run-lhci.mjs lighthouserc.mobile.cjs",
    "test:mutate": "stryker run",
    "test:mutate:incremental": "stryker run --incremental"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.7",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^11.0.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "astro": "^7.0.3",
    "country-state-city": "^3.2.1",
    "firebase": "^12.15.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-loading-skeleton": "^3.5.0",
    "react-select": "^5.10.2",
    "recharts": "^3.9.0",
    "resend": "^6.16.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "~7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "firebase-tools": "^15.22.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "linkinator": "^7.6.1",
    "lint-staged": "^17.0.8",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.35.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "path-to-regexp": "^6.3.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --no-warn-ignored"
    ],
    "*.{ts,tsx,js,jsx,astro}": [
      "prettier --write"
    ],
    "*.{css,md,json}": [
      "prettier --write"
    ]
  }
}
