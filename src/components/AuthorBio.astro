---
import { CREATOR_URLS } from '@/data/socials';
---

<div class="author-bio">
  <img src="/images/surbhi.webp" alt="Surbhi" class="author-avatar" width="48" height="48" loading="lazy" />
  <div>
    <a href={CREATOR_URLS.surbhi} target="_blank" rel="noopener noreferrer" class="author-name">Surbhi</a>
    <p class="author-desc">
      Co-creator and host of Garam Masala Dating, NYC's live South Asian
      dating show. Stand-up comedian. Accidentally matched three couples and counting.
    </p>
  </div>
</div>

<style>
  .author-bio {
    margin-top: 32px;
    padding-top: 16px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }
  .author-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 2px solid var(--brand-red);
    flex-shrink: 0;
    object-fit: cover;
  }
  .author-name {
    font-family: var(--font-playfair);
    font-size: 16px;
    font-weight: 600;
    color: var(--charcoal);
    text-decoration: none;
    display: block;
    margin: 0 0 6px;
    transition: color 0.2s;
  }
  .author-name:hover {
    color: var(--brand-red);
  }
  .author-desc {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--text-light);
    line-height: 1.55;
    margin: 0;
  }
</style>
