---
// Zero-visual component: loads the Eventbrite checkout widget script and
// initializes modal checkout for every EB trigger button on the page.
// Drop <EventbriteWidgetInit /> once per page that contains EB modal buttons.
---

<script>
  interface EBWidgetConfig {
    widgetType: string;
    eventId: string;
    modal: boolean;
    modalTriggerElementId: string;
    themeSettings?: Record<string, string>;
    onOrderComplete?: () => void;
  }

  (function initEBWidgets(): void {
    const buttons = Array.from(
      document.querySelectorAll<HTMLElement>(
        '[id^="eventbrite-widget-modal-trigger-"]',
      ),
    );
    if (!buttons.length) return;

    type EBWidgetsAPI = { createWidget: (config: EBWidgetConfig) => void };
    type PostHogAPI = {
      capture: (event: string, props: Record<string, unknown>) => void;
    };
    const w = window as typeof window & {
      EBWidgets: EBWidgetsAPI;
      posthog?: PostHogAPI;
    };

    const configs = buttons.map((btn) => ({
      eventId:
        btn.dataset.ebEventId ??
        btn.id.replace("eventbrite-widget-modal-trigger-", ""),
      triggerId: btn.id,
      fallbackUrl: btn.getAttribute("href") ?? btn.dataset.ebUrl ?? "",
      city: btn.dataset.city ?? "",
    }));

    const rootStyle = getComputedStyle(document.documentElement);
    const brandColor =
      rootStyle.getPropertyValue("--brand-red").trim() || "#DC2626";
    const fontColor =
      rootStyle.getPropertyValue("--charcoal").trim() || "#1A1A1A";
    const bgColor = rootStyle.getPropertyValue("--white").trim() || "#FFFFFF";

    function initWidgets(): void {
      configs.forEach((ev) => {
        const config: EBWidgetConfig = {
          widgetType: "checkout",
          eventId: ev.eventId,
          modal: true,
          modalTriggerElementId: ev.triggerId,
          themeSettings: {
            brandColor,
            fontColor,
            background: bgColor,
          },
          onOrderComplete() {
            w.posthog?.capture("order_complete", {
              event_id: ev.eventId,
              city: ev.city,
            });
          },
        };
        try {
          w.EBWidgets.createWidget(config);
          // Widget bound successfully. Prevent the anchor's native navigation so
          // only the modal fires. If createWidget threw, the anchor href + target="_blank"
          // provide the native fallback without any preventDefault.
          document
            .getElementById(ev.triggerId)
            ?.addEventListener("click", (e) => {
              e.preventDefault();
            });
        } catch (_) {
          // Widget init failed; anchor href + target="_blank" provide native fallback
        }
      });
    }

    const script = document.createElement("script");
    script.src = "https://www.eventbrite.com/static/widgets/eb_widgets.js";
    script.async = true;
    script.onload = initWidgets;
    document.head.appendChild(script);

    // Save scroll position before any EB trigger click so we can restore it
    // after the widget injects its full-screen backdrop (which calls scrollTo(0,0)).
    let savedScrollY = 0;
    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        savedScrollY = window.scrollY;
      });
    });

    // Track whether the History API dummy entry is active so we only push/pop once.
    let historyEntryPushed = false;

    // popstate fires when the user presses the hardware/browser back button.
    // If our dummy entry is active, close the EB modal instead of leaving the page.
    window.addEventListener("popstate", (e: PopStateEvent) => {
      if ((e.state as Record<string, unknown> | null)?.ebModal) {
        historyEntryPushed = false;
        const closeBtn = document.querySelector<HTMLButtonElement>(
          ".eds-modal__close-button button",
        );
        closeBtn?.click();
      }
    });

    // Close EB modal on outside click.
    // The widget injects `div.eds-structure_main` into <body> as the full-screen
    // backdrop. The actual dialog is nested inside as `div.eds-modal`.
    // Clicking eds-structure_main outside the dialog area triggers the close button.
    // We also use this observer to:
    //   - restore scroll after EB scrolls to top (Bug 6)
    //   - push a dummy history entry so the back button closes the modal (Bug 10)
    //   - pop that history entry when the modal closes
    let modalObserverTimeout: ReturnType<typeof setTimeout>;
    const modalObserver = new MutationObserver(() => {
      const ebStructure = document.querySelector<HTMLElement>(
        "div.eds-structure_main",
      );

      if (ebStructure && !ebStructure.dataset.listenerAttached) {
        ebStructure.dataset.listenerAttached = "1";

        // Restore scroll position after EB's internal scrollTo(0,0) fires.
        requestAnimationFrame(() => {
          if (savedScrollY > 0) window.scrollTo({ top: savedScrollY });
        });

        // Push a dummy history entry so the back button intercept works.
        if (!historyEntryPushed) {
          history.pushState({ ebModal: true }, "", location.href);
          historyEntryPushed = true;
        }

        // Outside-click closes the modal.
        const onEBSClick = (e: MouseEvent): void => {
          const target = e.target as HTMLElement;
          if (!target.closest(".eds-modal")) {
            const closeBtn = document.querySelector<HTMLButtonElement>(
              ".eds-modal__close-button button",
            );
            closeBtn?.click();
          }
        };
        ebStructure.addEventListener("click", onEBSClick);

        // Watch for the modal being removed from the DOM (user closed it).
        const closeObserver = new MutationObserver(() => {
          if (!document.querySelector("div.eds-structure_main")) {
            closeObserver.disconnect();
            // Clean up the dummy history entry only if it's still active.
            if (historyEntryPushed) {
              historyEntryPushed = false;
              history.back();
            }
          }
        });
        closeObserver.observe(document.body, {
          childList: true,
          subtree: false,
        });
      }

      if (ebStructure) {
        clearTimeout(modalObserverTimeout);
        modalObserver.disconnect();
      }
    });
    modalObserver.observe(document.body, { childList: true, subtree: true });
    modalObserverTimeout = setTimeout(() => {
      modalObserver.disconnect();
    }, 30_000);
    window.addEventListener("beforeunload", () => {
      clearTimeout(modalObserverTimeout);
      modalObserver.disconnect();
    });
  })();
</script>
