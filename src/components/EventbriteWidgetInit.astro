---
// Zero-visual component: loads the Eventbrite checkout widget script on user intent
// and initializes both modal checkout (trigger buttons) and inline embeds (container divs).
// Drop <EventbriteWidgetInit /> once per page that contains EB widget elements.
---

<script>
  import { buildLeadAttribution } from "@/lib/leadAttribution";
  import { capture } from "@/lib/analyticsCapture";

  interface EBCfg {
    eventId: string;
    triggerId: string | undefined;
    containerId: string | undefined;
    isModal: boolean;
    fallbackUrl: string;
    city: string;
    section: string;
    price: string;
    eventDate: string;
    eventTitle: string;
    destinationUrl: string;
    linkDomain: string;
    ctaText: string;
    ctaPosition: string;
  }

  interface EBWidgetModalConfig {
    widgetType: string;
    eventId: string;
    modal: true;
    modalTriggerElementId: string;
    themeSettings?: Record<string, string>;
    onOrderComplete?: () => void;
  }

  interface EBWidgetEmbedConfig {
    widgetType: string;
    eventId: string;
    iframeContainerId: string;
    iframeContainerHeight?: number;
    themeSettings?: Record<string, string>;
    onOrderComplete?: () => void;
  }

  type EBWidgetConfig = EBWidgetModalConfig | EBWidgetEmbedConfig;

  (function initEBWidgets(): void {
    const modalButtons = Array.from(
      document.querySelectorAll<HTMLElement>(
        '[id^="eventbrite-widget-modal-trigger-"]',
      ),
    );
    const embedContainers = Array.from(
      document.querySelectorAll<HTMLElement>(
        '[id^="eventbrite-widget-container-"]',
      ),
    );

    if (!modalButtons.length && !embedContainers.length) return;
    if (["localhost", "127.0.0.1"].includes(window.location.hostname)) return;

    type EBWidgetsAPI = { createWidget: (config: EBWidgetConfig) => void };
    const w = window as typeof window & {
      EBWidgets: EBWidgetsAPI;
      dataLayer?: Record<string, unknown>[];
    };

    // ── Shared helpers ──────────────────────────────────────────────────────

    function readCfg(el: HTMLElement, isModal: boolean): EBCfg {
      const prefix = isModal
        ? "eventbrite-widget-modal-trigger-"
        : "eventbrite-widget-container-";
      const eventId = el.dataset.ebEventId ?? el.id.replace(prefix, "");
      return {
        eventId,
        triggerId: isModal ? el.id : undefined,
        containerId: isModal ? undefined : el.id,
        isModal,
        fallbackUrl: el.getAttribute("href") ?? el.dataset.ebUrl ?? "",
        city: el.dataset.city ?? el.dataset.phCity ?? "",
        section: el.dataset.phSection ?? "",
        price: el.dataset.phPrice ?? "",
        eventDate: el.dataset.phEventDate ?? "",
        eventTitle: el.dataset.phEventTitle ?? el.dataset.eventTitle ?? "",
        destinationUrl:
          el.dataset.destinationUrl ??
          el.dataset.linkUrl ??
          el.getAttribute("href") ??
          el.dataset.ebUrl ??
          "",
        linkDomain: el.dataset.linkDomain ?? "",
        ctaText: el.dataset.ctaText ?? el.textContent?.trim() ?? "",
        ctaPosition: el.dataset.ctaPosition ?? "",
      };
    }

    function makeOrderCompleteHandler(cfg: EBCfg): () => void {
      return async function onOrderComplete(): Promise<void> {
        const raw = sessionStorage.getItem("eb_cta_source");
        const src = raw ? (JSON.parse(raw) as Record<string, string>) : null;
        sessionStorage.removeItem("eb_cta_source");
        const attr = await buildLeadAttribution({ source: "ticket_purchase" });
        capture("order_complete", {
          event_id: cfg.eventId,
          city: cfg.city,
          event_city: src?.city ?? cfg.city,
          event_date: src?.event_date ?? cfg.eventDate,
          event_title: src?.event_title ?? cfg.eventTitle,
          destination_url: src?.destination_url ?? cfg.destinationUrl,
          link_url: src?.destination_url ?? cfg.destinationUrl,
          link_domain: src?.link_domain ?? cfg.linkDomain,
          cta_text: src?.cta_text ?? cfg.ctaText,
          cta_position: src?.cta_position ?? cfg.ctaPosition,
          source_section: src?.section ?? cfg.section,
          source_page: src?.page ?? "",
          price: src?.price ?? cfg.price,
          landing_page: attr.landingPage,
          referrer_host: attr.referrerHost,
          utm_source: attr.utmSource,
          utm_campaign: attr.utmCampaign,
          utm_medium: attr.utmMedium,
          utm_content: attr.utmContent,
        });
        const price = parseFloat(
          (src?.price ?? cfg.price ?? "").replace(/[^0-9.]/g, "") || "0",
        );
        w.dataLayer = w.dataLayer ?? [];
        w.dataLayer.push({ ecommerce: null });
        w.dataLayer.push({
          event: "purchase",
          ecommerce: {
            currency: "USD",
            value: price,
            items: [
              {
                item_name: `Garam Masala Dating - ${cfg.city}`,
                item_id: String(cfg.eventId),
                price,
                quantity: 1,
              },
            ],
          },
          source_section: src?.section ?? cfg.section,
          source_page: src?.page ?? "",
          landing_page: attr.landingPage,
          referrer_host: attr.referrerHost,
          utm_source: attr.utmSource,
          utm_campaign: attr.utmCampaign,
        });
        window.fbq?.("track", "Purchase", {
          value: price,
          currency: "USD",
          content_ids: [String(cfg.eventId)],
        });
      };
    }

    // ── Theme tokens ────────────────────────────────────────────────────────

    const rootStyle = getComputedStyle(document.documentElement);
    const brandColor =
      rootStyle.getPropertyValue("--brand-red").trim() || "#DC2626";
    const fontColor =
      rootStyle.getPropertyValue("--charcoal").trim() || "#1A1A1A";
    const bgColor = rootStyle.getPropertyValue("--white").trim() || "#FFFFFF";

    // ── Config arrays ───────────────────────────────────────────────────────

    const modalCfgs = modalButtons.map((btn) => readCfg(btn, true));
    const embedCfgs = embedContainers.map((div) => readCfg(div, false));

    let orderCompleted = false;
    let modalOpenedAt = 0;

    // ── Widget initialisation ───────────────────────────────────────────────

    function initWidgets(): void {
      // Modal triggers — unchanged behaviour
      modalCfgs.forEach((cfg) => {
        const config: EBWidgetModalConfig = {
          widgetType: "checkout",
          eventId: cfg.eventId,
          modal: true,
          modalTriggerElementId: cfg.triggerId!,
          themeSettings: { brandColor, fontColor, background: bgColor },
          onOrderComplete: makeOrderCompleteHandler(cfg),
        };
        try {
          w.EBWidgets.createWidget(config);
          document
            .getElementById(cfg.triggerId!)
            ?.addEventListener("click", (e) => {
              e.preventDefault();
            });
        } catch (_) {
          capture("widget_load_failed", {
            event_id: cfg.eventId,
            city: cfg.city,
            event_title: cfg.eventTitle,
            event_date: cfg.eventDate,
            destination_url: cfg.destinationUrl,
            link_domain: cfg.linkDomain,
            page: window.location.pathname,
          });
        }
      });

      // Inline embed containers — non-modal behaviour
      embedCfgs.forEach((cfg) => {
        const containerEl = document.getElementById(cfg.containerId!);
        if (!containerEl) return;
        const config: EBWidgetEmbedConfig = {
          widgetType: "checkout",
          eventId: cfg.eventId,
          iframeContainerId: cfg.containerId!,
          themeSettings: { brandColor, fontColor, background: bgColor },
          onOrderComplete: makeOrderCompleteHandler(cfg),
        };
        try {
          w.EBWidgets.createWidget(config);
          // Triggers CSS: show container, hide fallback link
          containerEl.dataset.ebLoaded = "true";
          capture("checkout_opened", {
            event_id: cfg.eventId,
            city: cfg.city,
            event_city: cfg.city,
            event_date: cfg.eventDate,
            event_title: cfg.eventTitle,
            destination_url: cfg.destinationUrl,
            link_url: cfg.destinationUrl,
            link_domain: cfg.linkDomain,
            cta_text: cfg.ctaText,
            cta_position: cfg.ctaPosition,
            source_section: cfg.section,
            source_page: window.location.pathname,
            price: cfg.price,
          });
        } catch (_) {
          capture("widget_load_failed", {
            event_id: cfg.eventId,
            city: cfg.city,
            event_title: cfg.eventTitle,
            event_date: cfg.eventDate,
            destination_url: cfg.destinationUrl,
            link_domain: cfg.linkDomain,
            page: window.location.pathname,
          });
          // data-eb-loaded never set → fallback link stays visible
        }
      });
    }

    // ── Intent-based script loading ─────────────────────────────────────────
    // Defers eb_widgets.js until first user signal or viewport entry.
    // Guards against concurrent signals triggering a double-injection.

    let scriptInjected = false;
    let io: IntersectionObserver | undefined;

    function loadEBScript(): void {
      if (scriptInjected) return;
      scriptInjected = true;
      io?.disconnect();
      const script = document.createElement("script");
      script.src = "https://www.eventbrite.com/static/widgets/eb_widgets.js";
      script.async = true;
      script.onload = initWidgets;
      document.head.appendChild(script);
    }

    // Modal triggers: hover / touch / focus load the script eagerly
    modalButtons.forEach((btn) => {
      btn.addEventListener("pointerenter", loadEBScript, { passive: true });
      btn.addEventListener("touchstart", loadEBScript, { passive: true });
      btn.addEventListener("focusin", loadEBScript);
    });

    // IO watches modal buttons only — embed containers start display:none so
    // the observer would never fire for them.
    io = new IntersectionObserver(
      (entries) => {
        if (entries.some((e) => e.isIntersecting)) loadEBScript();
      },
      { threshold: 0 },
    );
    modalButtons.forEach((el) => io.observe(el));

    // Inline embeds are the primary page content — load the EB script immediately
    // rather than deferring via IO (the hidden container has no layout size).
    if (embedContainers.length) loadEBScript();

    // ── Modal-only infrastructure ───────────────────────────────────────────
    // Skipped entirely on pages that have only inline embeds (e.g. city pages).

    if (!modalButtons.length) {
      window.addEventListener("pagehide", () => {
        io.disconnect();
      });
      return;
    }

    // Save scroll position before any modal trigger click so we can restore it
    // after the widget injects its full-screen backdrop (which calls scrollTo(0,0)).
    let savedScrollY = 0;

    modalButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        savedScrollY = window.scrollY;
        const cfg = modalCfgs.find((c) => c.triggerId === btn.id);
        sessionStorage.setItem(
          "eb_cta_source",
          JSON.stringify({
            event_id: cfg?.eventId ?? "",
            section: cfg?.section ?? btn.dataset.phSection ?? "",
            page: window.location.pathname,
            city: cfg?.city ?? "",
            price: cfg?.price ?? "",
            event_date: cfg?.eventDate ?? "",
            event_title: cfg?.eventTitle ?? "",
            destination_url: cfg?.destinationUrl ?? "",
            link_domain: cfg?.linkDomain ?? "",
            cta_text: cfg?.ctaText ?? "",
            cta_position: cfg?.ctaPosition ?? "",
          }),
        );
      });
    });

    // Track whether the History API dummy entry is active so we only push/pop once.
    let historyEntryPushed = false;

    // popstate fires when the user presses the hardware/browser back button.
    // If our dummy entry is active, close the EB modal instead of leaving the page.
    window.addEventListener("popstate", (_e: PopStateEvent) => {
      if (historyEntryPushed) {
        historyEntryPushed = false;
        const closeBtn = document.querySelector<HTMLButtonElement>(
          ".eds-modal__close-button button",
        );
        closeBtn?.click();
      }
    });

    // Close EB modal on outside click.
    // The widget injects `div.eds-structure_main` into <body> as the full-screen
    // backdrop. The actual dialog is nested inside as `div.eds-modal`.
    // Clicking eds-structure_main outside the dialog area triggers the close button.
    // We also use this observer to:
    //   - restore scroll after EB scrolls to top (Bug 6)
    //   - push a dummy history entry so the back button closes the modal (Bug 10)
    //   - pop that history entry when the modal closes
    let modalObserverTimeout: ReturnType<typeof setTimeout>;
    const modalObserver = new MutationObserver(() => {
      const ebStructure = document.querySelector<HTMLElement>(
        "div.eds-structure_main",
      );

      if (ebStructure && !ebStructure.dataset.listenerAttached) {
        ebStructure.dataset.listenerAttached = "1";

        orderCompleted = false;
        modalOpenedAt = Date.now();
        const openSrc = sessionStorage.getItem("eb_cta_source");
        const openData = openSrc
          ? (JSON.parse(openSrc) as Record<string, string>)
          : null;
        capture("checkout_opened", {
          event_id: openData?.event_id ?? "",
          city: openData?.city ?? "",
          event_city: openData?.city ?? "",
          event_date: openData?.event_date ?? "",
          event_title: openData?.event_title ?? "",
          destination_url: openData?.destination_url ?? "",
          link_url: openData?.destination_url ?? "",
          link_domain: openData?.link_domain ?? "",
          cta_text: openData?.cta_text ?? "",
          cta_position: openData?.cta_position ?? "",
          source_section: openData?.section ?? "",
          source_page: openData?.page ?? window.location.pathname,
          price: openData?.price ?? "",
        });

        // Restore scroll position after EB's internal scrollTo(0,0) fires.
        requestAnimationFrame(() => {
          if (savedScrollY > 0) window.scrollTo({ top: savedScrollY });
        });

        // Push a dummy history entry so the back button intercept works.
        if (!historyEntryPushed) {
          history.pushState({ ebModal: true }, "", location.href);
          historyEntryPushed = true;
        }

        // Outside-click closes the modal.
        const onEBSClick = (e: MouseEvent): void => {
          const target = e.target as HTMLElement;
          if (!target.closest(".eds-modal")) {
            const closeBtn = document.querySelector<HTMLButtonElement>(
              ".eds-modal__close-button button",
            );
            closeBtn?.click();
          }
        };
        ebStructure.addEventListener("click", onEBSClick);

        // Watch for the modal being removed from the DOM (user closed it).
        const closeObserver = new MutationObserver(() => {
          if (!document.querySelector("div.eds-structure_main")) {
            closeObserver.disconnect();
            // Fire abandonment event if purchase didn't complete.
            if (!orderCompleted) {
              const durationMs = modalOpenedAt ? Date.now() - modalOpenedAt : 0;
              const closeSrc = sessionStorage.getItem("eb_cta_source");
              const closeData = closeSrc
                ? (JSON.parse(closeSrc) as Record<string, string>)
                : null;
              capture("checkout_abandoned", {
                event_id: closeData?.event_id ?? "",
                city: closeData?.city ?? "",
                event_city: closeData?.city ?? "",
                event_date: closeData?.event_date ?? "",
                event_title: closeData?.event_title ?? "",
                destination_url: closeData?.destination_url ?? "",
                link_url: closeData?.destination_url ?? "",
                link_domain: closeData?.link_domain ?? "",
                cta_text: closeData?.cta_text ?? "",
                cta_position: closeData?.cta_position ?? "",
                source_section: closeData?.section ?? "",
                source_page: closeData?.page ?? window.location.pathname,
                price: closeData?.price ?? "",
                duration_seconds: Math.round(durationMs / 1000),
              });
            }
            // Clean up the dummy history entry only if it's still active.
            if (historyEntryPushed) {
              historyEntryPushed = false;
              history.back();
            }
          }
        });
        closeObserver.observe(document.body, {
          childList: true,
          subtree: false,
        });
      }

      if (ebStructure) {
        clearTimeout(modalObserverTimeout);
        modalObserver.disconnect();
      }
    });
    modalObserver.observe(document.body, { childList: true, subtree: true });
    modalObserverTimeout = setTimeout(() => {
      modalObserver.disconnect();
    }, 30_000);
    // pagehide (not beforeunload) keeps the page bfcache-eligible
    window.addEventListener("pagehide", () => {
      clearTimeout(modalObserverTimeout);
      modalObserver.disconnect();
    });
  })();
</script>
