---
/**
 * Reusable lead capture modal with configurable copy.
 * 2-step flow: email → optional phone → success.
 * Writes to Firestore 'leads' collection, tracks via PostHog + GTM.
 *
 * Usage:
 *   <LeadCaptureModal
 *     id="spice-modal"
 *     source="links-page"
 *     heading="Get on the List"
 *     subheading="Cheap and free tickets, exclusive drops."
 *   />
 *
 * Open from JS:
 *   (document.getElementById('spice-modal') as HTMLDialogElement).showModal();
 *
 * Or use a trigger:
 *   <button data-open-modal="spice-modal">Join</button>
 */
import Modal from "@/components/ui/Modal.astro";

interface Props {
  id: string;
  source: string;
  heading?: string;
  subheading?: string;
  submitLabel?: string;
  phoneHeading?: string;
  phoneSubheading?: string;
  phoneSubmitLabel?: string;
  phoneSuccessMessage?: string;
  successMessage?: string;
  /** If true, includes a hidden city field and displays city name in subheading */
  cityMode?: boolean;
  /**
   * If true (and not cityMode), shows a visible optional city input so leads
   * captured outside a city page still carry geography for tour routing.
   */
  collectCity?: boolean;
  /** If true, asks the visitor to type their city/location before email */
  cityInput?: boolean;
  cityPlaceholder?: string;
}

const {
  id,
  source,
  heading = "Join the Spice List",
  subheading = "Get exclusive discount codes for cheaper (and sometimes free) tickets.",
  submitLabel = "Count Me In",
  phoneHeading = "One more thing…",
  phoneSubheading = "Add your number for text-only ticket drops.",
  phoneSubmitLabel = "Send Me Drops",
  successMessage = "You're on the list! We'll let you know.",
  phoneSuccessMessage = "You're on the list! Deals incoming.",
  cityMode = false,
  collectCity = false,
  cityInput = false,
  cityPlaceholder = "City or neighborhood",
} = Astro.props;
const showCityInput = collectCity && !cityMode;
---

<Modal id={id}>
  <div
    class="lc-steps"
    data-lc-source={source}
    data-lc-city-mode={cityMode || cityInput ? "true" : undefined}
  >
    <!-- Step 1: Email -->
    <div data-lc-step="email">
      <h2 class="lc-title">{heading}</h2>
      <p class="lc-subtitle">
        {subheading}{cityMode && <strong data-lc-city-name />}{cityMode && "."}
      </p>
      <form data-lc-form="email" class="lc-form">
        {
          cityInput && (
            <input
              type="text"
              data-lc-city
              placeholder={cityPlaceholder}
              required
              autofocus={cityInput}
              autocomplete="address-level2"
              aria-label="City or location"
              toolparamdescription="City or location where you want Garam Masala Dating to come next"
            />
          )
        }
        <input
          type="email"
          data-lc-email
          autofocus={!cityInput}
          placeholder="Your email"
          required
          aria-label="Email address"
        />
        <input
          type="text"
          data-lc-company
          class="lc-honeypot"
          autocomplete="off"
          tabindex="-1"
          aria-hidden="true"
        />
        {cityMode && !cityInput && <input type="hidden" data-lc-city />}
        {
          showCityInput && !cityInput && (
            <input
              type="text"
              data-lc-city
              placeholder="Your city (optional)"
              aria-label="Your city (optional)"
              autocomplete="address-level2"
              maxlength="100"
            />
          )
        }
        <p data-lc-error class="lc-error" hidden aria-live="assertive"></p>
        <button type="submit" class="lc-submit">{submitLabel}</button>
      </form>
    </div>
    <!-- Step 2: Phone (optional) -->
    <div data-lc-step="phone" hidden>
      <h2 class="lc-title">{phoneHeading}</h2>
      <p class="lc-subtitle">{phoneSubheading}</p>
      <form data-lc-form="phone" class="lc-form">
        <input
          type="tel"
          data-lc-phone
          placeholder="(555) 123-4567"
          aria-label="Phone number"
        />
        <p data-lc-phone-error class="lc-error" hidden aria-live="assertive">
        </p>
        <button type="submit" class="lc-submit">{phoneSubmitLabel}</button>
      </form>
      <button type="button" data-lc-skip class="lc-skip">Maybe later</button>
    </div>
    <!-- Step 3: Success -->
    <div
      data-lc-step="success"
      class="lc-success"
      role="status"
      aria-live="polite"
      tabindex="-1"
      hidden
    >
      <p
        data-lc-success-msg
        data-lc-default-msg={successMessage}
        data-lc-phone-success-msg={phoneSuccessMessage}
      >
        {successMessage}
      </p>
    </div>
  </div>
</Modal>

<style>
  .lc-steps {
    min-height: 260px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .lc-title {
    font-family: var(--font-playfair), serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--charcoal);
    margin-bottom: 8px;
  }
  .lc-subtitle {
    font-size: 15px;
    color: var(--text-light);
    margin-bottom: 24px;
    line-height: 1.5;
  }
  .lc-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .lc-form input {
    padding: 14px 20px;
    border: 1.5px solid var(--border);
    border-radius: 50px;
    font-size: 16px;
    font-family: var(--font-body), sans-serif;
    outline: none;
    transition: border-color 0.2s;
    min-height: var(--touch-target);
  }
  .lc-form input:focus-visible {
    border-color: var(--brand-red);
    outline: 2px solid var(--brand-red);
    outline-offset: -2px;
  }
  .lc-error {
    font-size: 14px;
    color: var(--brand-red);
    margin: 0;
    text-align: center;
  }
  .lc-honeypot {
    position: absolute;
    left: -9999px;
    opacity: 0;
    pointer-events: none;
  }
  .lc-submit {
    background: var(--brand-red);
    color: white;
    border: none;
    padding: 14px;
    border-radius: 50px;
    font-family: var(--font-body), sans-serif;
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition:
      background 0.2s,
      transform 0.06s;
    min-height: var(--touch-target);
    white-space: nowrap;
    width: 100%;
  }
  .lc-submit:hover {
    background: var(--brand-red-dark);
  }
  .lc-submit:active {
    transform: scale(0.97);
  }
  .lc-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
  .lc-skip {
    background: none;
    border: none;
    color: var(--muted);
    font-size: 14px;
    font-family: var(--font-body), sans-serif;
    margin-top: 12px;
    transition:
      color 0.2s,
      transform 0.15s;
    padding: 12px 16px;
    min-height: var(--touch-target);
    cursor: pointer;
  }
  .lc-skip:hover {
    color: var(--charcoal);
  }
  .lc-skip:active {
    transform: scale(0.97);
  }
  .lc-success {
    text-align: center;
    padding: 24px 0;
  }
  .lc-success p {
    font-family: var(--font-cormorant), serif;
    font-size: 18px;
    font-style: italic;
    color: var(--charcoal);
  }
</style>

<script>
  import { cleanPhone } from "@/lib/phone";
  import { identifyLead, trackLeadEvent } from "@/lib/analytics";
  import { buildLeadAttribution } from "@/lib/leadAttribution";
  import {
    captureLead,
    updateLeadPhone,
    type LeadCaptureResult,
    type LeadSubmissionPayload,
  } from "@/lib/leadSubmission";

  // Wire up all LeadCaptureModal instances on the page
  document.querySelectorAll<HTMLElement>(".lc-steps").forEach((root) => {
    const dialog = root.closest("dialog") as HTMLDialogElement;
    if (!dialog) return;

    const source = root.dataset.lcSource ?? "lead-capture";
    const isWaitlistSource =
      /waitlist|notify|city-request|links-page|ticket/i.test(source);
    let leadDocId: LeadCaptureResult | null = null;
    let capturedEmail = "";

    function showStep(step: "email" | "phone" | "success") {
      root.querySelectorAll<HTMLElement>("[data-lc-step]").forEach((el) => {
        if (el.dataset.lcStep === step) {
          el.removeAttribute("hidden");
        } else {
          el.setAttribute("hidden", "");
        }
      });
      if (step === "success") {
        (
          root.querySelector('[data-lc-step="success"]') as HTMLElement
        )?.focus();
      }
    }

    function reset() {
      showStep("email");
      const emailInput = root.querySelector(
        "[data-lc-email]",
      ) as HTMLInputElement | null;
      if (emailInput) emailInput.value = "";
      const phoneInput = root.querySelector(
        "[data-lc-phone]",
      ) as HTMLInputElement | null;
      if (phoneInput) phoneInput.value = "";
      const cityInput = root.querySelector(
        "[data-lc-city]",
      ) as HTMLInputElement | null;
      if (cityInput) cityInput.value = "";
      root.querySelectorAll(".lc-error").forEach((el) => {
        el.textContent = "";
        el.setAttribute("hidden", "");
      });
      // Restore default success message text for next open
      const successMsg = root.querySelector<HTMLElement>(
        "[data-lc-success-msg]",
      );
      if (successMsg)
        successMsg.textContent = successMsg.dataset.lcDefaultMsg ?? "";
      leadDocId = null;
      capturedEmail = "";
    }

    // Reset state when modal opens
    dialog.addEventListener("close", reset);

    // Step 1: Email submit — uses server endpoint (zero client Firebase)
    root
      .querySelector('[data-lc-form="email"]')
      ?.addEventListener("submit", async (e) => {
        e.preventDefault();
        capturedEmail = (
          root.querySelector("[data-lc-email]") as HTMLInputElement
        ).value;
        const city =
          (
            root.querySelector("[data-lc-city]") as HTMLInputElement | null
          )?.value.trim() ?? "";
        const company = (
          root.querySelector("[data-lc-company]") as HTMLInputElement | null
        )?.value;
        const submitBtn = (
          e.target as HTMLFormElement
        ).querySelector<HTMLButtonElement>('[type="submit"]');
        const errorEl = root.querySelector(
          "[data-lc-error]",
        ) as HTMLElement | null;
        const originalBtnText = submitBtn?.textContent ?? "";
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = "Sending...";
        }

        try {
          const attribution = await buildLeadAttribution({ source });
          const payload: LeadSubmissionPayload = {
            email: capturedEmail,
            ...attribution,
            company,
          };
          if (city) payload.city = city;

          const captured = await captureLead(payload);
          leadDocId = captured.id ? captured : null;

          identifyLead(capturedEmail, {
            ...attribution,
            ...(city ? { city } : {}),
          });
          trackLeadEvent("lead_email_submitted", {
            ...attribution,
            ...(city ? { city } : {}),
          });
          trackLeadEvent("email_signup", {
            ...attribution,
            ...(city ? { city } : {}),
          });
          if (isWaitlistSource) {
            trackLeadEvent("waitlist_submit", {
              ...attribution,
              ...(city ? { city } : {}),
            });
          }
          if (errorEl) {
            errorEl.textContent = "";
            errorEl.setAttribute("hidden", "");
          }
          showStep("phone");
          (
            root.querySelector("[data-lc-phone]") as HTMLInputElement | null
          )?.focus();
        } catch {
          if (errorEl) {
            errorEl.textContent = "Something went wrong. Please try again.";
            errorEl.removeAttribute("hidden");
          }
        } finally {
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = originalBtnText;
          }
        }
      });

    // Step 2: Phone submit — uses server endpoint
    root
      .querySelector('[data-lc-form="phone"]')
      ?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const raw = (root.querySelector("[data-lc-phone]") as HTMLInputElement)
          .value;
        const cleaned = cleanPhone(raw);
        const phoneErrorEl = root.querySelector(
          "[data-lc-phone-error]",
        ) as HTMLElement | null;

        if (!raw.trim()) {
          showStep("success");
          return;
        }

        if (!cleaned) {
          if (phoneErrorEl) {
            phoneErrorEl.textContent = "Please enter a valid phone number.";
            phoneErrorEl.removeAttribute("hidden");
          }
          return;
        }

        const submitBtn = (
          e.target as HTMLFormElement
        ).querySelector<HTMLButtonElement>('[type="submit"]');
        const originalBtnText = submitBtn?.textContent ?? "";
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = "Sending...";
        }
        try {
          if (leadDocId) {
            await updateLeadPhone(leadDocId, cleaned);
          } else {
            const attribution = await buildLeadAttribution({ source });
            await captureLead({
              email: capturedEmail,
              phone: cleaned,
              ...attribution,
            });
          }
          trackLeadEvent("lead_phone_submitted", {
            source,
            sourcePage: window.location.pathname,
          });
          const successMsg = root.querySelector<HTMLElement>(
            "[data-lc-success-msg]",
          );
          if (successMsg)
            successMsg.textContent =
              successMsg.dataset.lcPhoneSuccessMsg ??
              successMsg.dataset.lcDefaultMsg ??
              "You're on the list! Deals incoming.";
          showStep("success");
        } catch {
          if (phoneErrorEl) {
            phoneErrorEl.textContent =
              "Something went wrong. Please try again or skip.";
            phoneErrorEl.removeAttribute("hidden");
          }
        } finally {
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = originalBtnText;
          }
        }
      });

    // Skip phone
    root.querySelector("[data-lc-skip]")?.addEventListener("click", () => {
      trackLeadEvent("lead_phone_skipped", {
        source,
        sourcePage: window.location.pathname,
      });
      showStep("success");
    });
  });

  // Wire up [data-open-modal] triggers anywhere on the page
  document.querySelectorAll<HTMLElement>("[data-open-modal]").forEach((el) => {
    const open = () => {
      const targetId = el.dataset.openModal;
      if (!targetId) return;
      const dialog = document.getElementById(
        targetId,
      ) as HTMLDialogElement | null;
      if (!dialog) return;

      // If city mode, populate the city name
      const city = el.dataset.openModalCity;
      if (city) {
        const root = dialog.querySelector(".lc-steps");
        const nameEl = root?.querySelector("[data-lc-city-name]");
        if (nameEl) nameEl.textContent = city;
        const cityInput = root?.querySelector(
          "[data-lc-city]",
        ) as HTMLInputElement | null;
        if (cityInput) cityInput.value = city;
      }

      const root = dialog.querySelector<HTMLElement>(".lc-steps");
      const modalSource = root?.dataset.lcSource ?? "lead-capture";
      const modalCity = el.dataset.openModalCity;
      trackLeadEvent("lead_capture_modal_opened", {
        source: modalSource,
        sourcePage: window.location.pathname,
        ...(modalCity ? { city: modalCity } : {}),
      });
      if (/waitlist|notify|city-request|links-page|ticket/i.test(modalSource)) {
        trackLeadEvent("waitlist_modal_opened", {
          source: modalSource,
          sourcePage: window.location.pathname,
          ...(modalCity ? { city: modalCity } : {}),
        });
      }
      dialog.showModal();
      (
        dialog.querySelector<HTMLInputElement>("[data-lc-city]") ??
        dialog.querySelector<HTMLInputElement>("[data-lc-email]") ??
        dialog
      ).focus();
    };
    el.addEventListener("click", open);
    el.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        open();
      }
    });
  });
</script>
