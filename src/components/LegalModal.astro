---
import { LEGAL_DOCS } from "@/data/legal";
---

<dialog
  id="legal-modal"
  class="legal-dialog"
  role="dialog"
  aria-modal="true"
  aria-labelledby="legal-modal-title"
  tabindex="-1"
>
  <div class="legal-inner">
    <button type="button" class="legal-close" aria-label="Close">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg
      >
    </button>
    <h2 id="legal-modal-title" class="legal-title"></h2>
    <p class="legal-updated"></p>
    <div class="legal-body"></div>
  </div>
</dialog>

{
  Object.values(LEGAL_DOCS).map((doc) => (
    <template
      id={`legal-tpl-${doc.id}`}
      data-title={doc.title}
      data-updated={doc.lastUpdated}
    >
      {doc.sections.map((section) => (
        <Fragment>
          <h2>{section.heading}</h2>
          {section.blocks.map((block) =>
            block.type === "p" ? (
              <p set:html={block.text} />
            ) : (
              <ul>
                {block.items.map((item) => (
                  <li set:html={item} />
                ))}
              </ul>
            ),
          )}
        </Fragment>
      ))}
    </template>
  ))
}

<script>
  const dialog = document.getElementById("legal-modal") as HTMLDialogElement;
  if (dialog) {
    let openerEl: HTMLElement | null = null;

    function openLegal(docId: string) {
      const tpl = document.getElementById(
        `legal-tpl-${docId}`,
      ) as HTMLTemplateElement | null;
      if (!tpl) return;

      const titleEl = dialog.querySelector("#legal-modal-title");
      const updatedEl = dialog.querySelector(".legal-updated");
      const bodyEl = dialog.querySelector(".legal-body");

      if (titleEl) titleEl.textContent = tpl.dataset.title ?? "";
      if (updatedEl)
        updatedEl.textContent = `Last updated: ${tpl.dataset.updated ?? ""}`;
      if (bodyEl) {
        bodyEl.innerHTML = "";
        bodyEl.appendChild(tpl.content.cloneNode(true));
      }

      openerEl = document.activeElement as HTMLElement;
      dialog.showModal();
      dialog.focus();
    }

    dialog.addEventListener("close", () => {
      openerEl?.focus();
      openerEl = null;
    });

    dialog
      .querySelector(".legal-close")
      ?.addEventListener("click", () => dialog.close());
    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) dialog.close();
    });

    document
      .querySelectorAll<HTMLElement>("[data-legal-modal]")
      .forEach((el) => {
        el.addEventListener("click", (e) => {
          e.preventDefault();
          openLegal(el.dataset.legalModal!);
        });
      });
  }
</script>

<style>
  .legal-dialog {
    border: none;
    background: transparent;
    padding: 24px;
    max-width: 100%;
    max-height: 100vh;
    width: 100%;
    height: 100%;
    overflow: visible;
    outline: none;
  }
  .legal-dialog:focus-visible {
    outline: 2px solid var(--brand-red);
    outline-offset: 2px;
  }
  .legal-dialog::backdrop {
    background: rgba(
      0,
      0,
      0,
      0.5
    ); /* backdrop requires literal rgba — no token */
  }
  .legal-dialog[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .legal-inner {
    width: 100%;
    max-width: 640px;
    max-height: 85vh;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    background: var(--off-white);
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 20px;
    padding: 32px 24px;
    position: relative;
    animation: legalIn 0.25s ease-out both;
    text-align: left;
  }
  @keyframes legalIn {
    from {
      opacity: 0;
      transform: scale(0.95) translateY(8px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }
  .legal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    min-width: var(--touch-target);
    min-height: var(--touch-target);
    padding: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
  }
  .legal-close:hover {
    color: var(--charcoal);
  }
  .legal-title {
    font-family: var(--font-playfair), serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--charcoal);
    margin-bottom: 4px;
    padding-right: 48px;
  }
  .legal-updated {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 32px;
  }

  /* Content styles — :global() because content is cloned from <template> */
  .legal-body :global(h2) {
    font-family: var(--font-playfair), serif;
    font-size: 20px;
    font-weight: 700;
    color: var(--charcoal);
    margin-top: 32px;
    margin-bottom: 12px;
  }
  .legal-body :global(p) {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 16px;
  }
  .legal-body :global(ul) {
    padding-left: 20px;
    margin-bottom: 16px;
  }
  .legal-body :global(li) {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 6px;
  }
  .legal-body :global(a) {
    color: var(--brand-red);
    font-size: 16px;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
