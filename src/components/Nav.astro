---
import { SOCIAL_URLS } from '@/data/socials';

const socials = [
  { label: 'Instagram', href: SOCIAL_URLS.instagram },
  { label: 'TikTok', href: SOCIAL_URLS.tiktok },
  { label: 'YouTube', href: SOCIAL_URLS.youtube },
];
---

<nav class="nav">
  <div class="left">
    <span class="brand">Garam Masala</span>
    <span class="season">Season 2026</span>
  </div>
  <div class="right">
    <div class="follow-wrap" id="follow-wrap">
      <button class="btn-outline" id="follow-btn" aria-expanded="false">Follow</button>
      <div class="dropdown" id="follow-dropdown" hidden>
        {socials.map(({ label, href }) => (
          <a href={href} target="_blank" rel="noopener noreferrer" class="drop-item">{label}</a>
        ))}
      </div>
    </div>
    <a href="/apply" class="btn-solid">Apply</a>
  </div>
</nav>

<script>
  const btn = document.getElementById('follow-btn');
  const dropdown = document.getElementById('follow-dropdown');
  const wrap = document.getElementById('follow-wrap');

  btn?.addEventListener('click', () => {
    const open = dropdown?.hidden === false;
    dropdown!.hidden = open;
    btn.setAttribute('aria-expanded', String(!open));
  });

  document.addEventListener('mousedown', (e) => {
    if (wrap && !wrap.contains(e.target as Node)) {
      dropdown!.hidden = true;
      btn?.setAttribute('aria-expanded', 'false');
    }
  });
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 40px;
    animation: fadeDown 1s ease-out both;
    animation-delay: 0.2s;
  }
  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .left {
    display: flex;
    align-items: baseline;
    gap: 14px;
  }
  .brand {
    font-family: var(--font-cormorant), serif;
    font-size: 1.15rem;
    font-weight: 500;
    color: #fff;
    letter-spacing: 0.02em;
  }
  .season {
    font-family: var(--font-jetbrains), monospace;
    font-size: 10px;
    font-weight: 400;
    color: var(--gold-dark);
    letter-spacing: 0.25em;
    text-transform: uppercase;
  }
  .right {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .follow-wrap {
    position: relative;
  }
  .dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: rgba(10, 10, 10, 0.45);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 10px;
    overflow: hidden;
    min-width: 148px;
    animation: dropIn 0.18s ease-out both;
    z-index: 200;
  }
  .dropdown[hidden] { display: none; }
  @keyframes dropIn {
    from { opacity: 0; transform: translateY(-6px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .drop-item {
    display: block;
    padding: 10px 16px;
    font-family: var(--font-dm-sans), sans-serif;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .drop-item:hover {
    background: rgba(255, 255, 255, 0.07);
    color: var(--accent-pink);
  }
  .btn-outline,
  .btn-solid {
    font-family: var(--font-dm-sans), sans-serif;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    padding: 8px 22px;
    border-radius: 100px;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.3s ease;
    -webkit-appearance: none;
    appearance: none;
  }
  .btn-outline {
    color: var(--text-ivory);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .btn-outline:hover {
    border-color: var(--accent-pink);
    color: var(--accent-pink);
  }
  .btn-solid {
    color: var(--surface-dark);
    background: var(--text-ivory);
    border: 1px solid var(--text-ivory);
  }
  .btn-solid:hover {
    background: var(--accent-pink);
    border-color: var(--accent-pink);
    color: #fff;
  }
  @media (max-width: 600px) {
    .nav { padding: 16px 20px; }
    .brand { font-size: 0.95rem; }
    .season { display: none; }
    .btn-outline, .btn-solid { font-size: 0.74rem; padding: 11px 18px; }
  }
</style>
