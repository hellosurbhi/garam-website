---
interface Props {
  source?: string;
}
const { source = "notify-modal" } = Astro.props;
---

<dialog
  id="notify-modal"
  class="modal-dialog"
  role="dialog"
  aria-modal="true"
  aria-labelledby="notify-modal-title"
  data-source={source}
  tabindex="-1"
>
  <div class="modal-inner">
    <button type="button" class="modal-close" aria-label="Close">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg
      >
    </button>
    <!-- min-height prevents CLS when switching between steps -->
    <div class="notify-steps-wrapper">
      <div id="notify-form-view">
        <h2 id="notify-modal-title" class="modal-title">Get Notified</h2>
        <p id="notify-subtitle-default" class="modal-subtitle">
          We'll email you when tickets drop for <strong id="notify-city-name"
          ></strong>.
        </p>
        <p id="notify-subtitle-presale" class="modal-subtitle" hidden>
          Tickets go on sale <strong id="notify-on-sale-date"></strong>. We'll
          email you the moment they drop.
        </p>
        <form
          id="notify-form"
          class="modal-form"
          toolname="subscribe-to-ticket-drop-alerts"
          tooldescription="Get notified by email when tickets drop for Garam Masala Dating in a specific city. Provide email address."
        >
          <input
            type="email"
            id="notify-email"
            class="ph-mask"
            data-testid="notify-email-input"
            placeholder="Your email"
            required
            aria-label="Email address"
            toolparamdescription="Email address to receive ticket drop notifications for this city"
          />
          <input type="hidden" id="notify-city" />
          <input type="hidden" id="notify-city-slug" />
          <p id="notify-error" class="modal-error" hidden aria-live="assertive">
          </p>
          <button type="submit" class="modal-submit" data-testid="notify-submit"
            >Notify Me</button
          >
        </form>
      </div>
      <div id="notify-phone-view" hidden>
        <h2 class="modal-title">One more thing…</h2>
        <p class="modal-subtitle">
          Add your number for text-only ticket drops.
        </p>
        <form
          id="notify-phone-form"
          class="modal-form"
          toolname="add-phone-to-ticket-alerts"
          tooldescription="Add a phone number for SMS ticket drop alerts for a specific city (optional step after email signup)."
        >
          <input
            type="tel"
            id="notify-phone"
            class="ph-mask"
            placeholder="(555) 123-4567"
            aria-label="Phone number"
            toolparamdescription="Mobile phone number for SMS-only ticket drop alerts (optional)"
          />
          <p
            id="notify-phone-error"
            class="modal-error"
            hidden
            aria-live="assertive"
          >
          </p>
          <button type="submit" class="modal-submit">Send Me Drops</button>
        </form>
        <button type="button" id="notify-skip" class="modal-skip"
          >Maybe later</button
        >
      </div>
      <div
        id="notify-success"
        data-testid="notify-success"
        class="modal-success"
        role="status"
        aria-live="polite"
        tabindex="-1"
        hidden
      >
        <p id="notify-success-text">
          You're on the list! Check your email when tickets drop.
        </p>
      </div>
    </div>
  </div>
</dialog>

<script>
  import { initNotifyModal } from "@/lib/notifyModalInit";
  initNotifyModal();
</script>

<style>
  .modal-dialog {
    border: none;
    background: transparent;
    padding: 24px;
    max-width: 100%;
    max-height: 100vh;
    width: 100%;
    height: 100%;
    overflow: visible;
  }
  .modal-dialog:focus-visible {
    outline: 3px solid var(--brand-red);
    outline-offset: 2px;
  }
  .modal-dialog::backdrop {
    background: rgba(0, 0, 0, 0.5);
  }
  .modal-dialog[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .modal-inner {
    width: 100%;
    max-width: 400px;
    max-height: 80vh;
    overflow-y: auto;
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 20px;
    padding: 24px;
    position: relative;
    animation: modalIn 0.25s ease-out both;
    text-align: center;
  }
  @keyframes modalIn {
    from {
      opacity: 0;
      transform: scale(0.95) translateY(8px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }
  /* Prevent CLS when switching between steps */
  .notify-steps-wrapper {
    min-height: 260px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    min-width: var(--touch-target);
    min-height: var(--touch-target);
    padding: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
  }
  .modal-close:hover {
    color: var(--charcoal);
  }
  .modal-title {
    font-family: var(--font-playfair), serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--charcoal);
    margin-bottom: 8px;
  }
  .modal-subtitle {
    font-size: 15px;
    color: var(--text-light);
    margin-bottom: 24px;
    line-height: 1.5;
  }
  .modal-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .modal-form input {
    padding: 14px 20px;
    border: 1.5px solid rgba(0, 0, 0, 0.1);
    border-radius: 50px;
    font-size: 16px;
    font-family: var(--font-body), sans-serif;
    outline: none;
    transition: border-color 0.2s;
    min-height: var(--touch-target);
  }
  .modal-form input:focus {
    border-color: var(--brand-red);
  }
  .modal-error {
    font-size: 14px;
    color: var(--brand-red);
    margin: 0;
    text-align: center;
  }
  .modal-submit {
    background: var(--brand-red);
    color: white;
    border: none;
    padding: 14px;
    border-radius: 50px;
    font-family: var(--font-body), sans-serif;
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition:
      background 0.2s,
      transform 0.06s;
    min-height: var(--touch-target);
    white-space: nowrap;
    width: 100%;
  }
  .modal-submit:hover {
    background: var(--brand-red-dark);
  }
  .modal-submit:active {
    transform: scale(0.97);
  }
  .modal-skip {
    background: none;
    border: none;
    color: var(--muted);
    font-size: 14px;
    font-family: var(--font-body), sans-serif;
    margin-top: 12px;
    transition:
      color 0.2s,
      transform 0.06s;
    padding: 12px 16px;
    min-height: var(--touch-target);
    cursor: pointer;
  }
  .modal-skip:hover {
    color: var(--charcoal);
  }
  .modal-skip:active {
    transform: scale(0.97);
  }
  .modal-success {
    text-align: center;
    padding: 24px 0;
  }
  .modal-success p {
    font-family: var(--font-cormorant), serif;
    font-size: 18px;
    font-style: italic;
    color: var(--charcoal);
  }
</style>
