---
interface Props {
  source?: string;
}
const { source = "notify-modal" } = Astro.props;
---

<dialog
  id="notify-modal"
  class="modal-dialog"
  role="dialog"
  aria-modal="true"
  aria-labelledby="notify-modal-title"
  data-source={source}
>
  <div class="modal-inner">
    <button type="button" class="modal-close" aria-label="Close">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg
      >
    </button>
    <!-- min-height prevents CLS when switching between steps -->
    <div class="notify-steps-wrapper">
      <div id="notify-form-view">
        <h2 id="notify-modal-title" class="modal-title">Get Notified</h2>
        <p class="modal-subtitle">
          We'll email you when tickets drop for <strong id="notify-city-name"
          ></strong>.
        </p>
        <form
          id="notify-form"
          class="modal-form"
          toolname="subscribe-to-ticket-drop-alerts"
          tooldescription="Get notified by email when tickets drop for Garam Masala Dating in a specific city. Provide email address."
        >
          <input
            type="email"
            id="notify-email"
            class="ph-mask"
            placeholder="Your email"
            required
            aria-label="Email address"
            toolparamdescription="Email address to receive ticket drop notifications for this city"
          />
          <input type="hidden" id="notify-city" />
          <p id="notify-error" class="modal-error" hidden aria-live="assertive">
          </p>
          <button type="submit" class="modal-submit">Notify Me</button>
        </form>
      </div>
      <div id="notify-phone-view" hidden>
        <h2 class="modal-title">One more thing…</h2>
        <p class="modal-subtitle">
          Add your number for text-only ticket drops.
        </p>
        <form
          id="notify-phone-form"
          class="modal-form"
          toolname="add-phone-to-ticket-alerts"
          tooldescription="Add a phone number for SMS ticket drop alerts for a specific city (optional step after email signup)."
        >
          <input
            type="tel"
            id="notify-phone"
            class="ph-mask"
            placeholder="(555) 123-4567"
            aria-label="Phone number"
            toolparamdescription="Mobile phone number for SMS-only ticket drop alerts (optional)"
          />
          <p
            id="notify-phone-error"
            class="modal-error"
            hidden
            aria-live="assertive"
          >
          </p>
          <button type="submit" class="modal-submit">Send Me Drops</button>
        </form>
        <button type="button" id="notify-skip" class="modal-skip"
          >Maybe later</button
        >
      </div>
      <div
        id="notify-success"
        class="modal-success"
        role="status"
        aria-live="polite"
        tabindex="-1"
        hidden
      >
        <p>You're on the list! We'll let you know.</p>
      </div>
    </div>
  </div>
</dialog>

<script>
  import { getFirebaseDb } from "@/lib/firebase";
  import {
    collection,
    addDoc,
    updateDoc,
    type DocumentReference,
  } from "firebase/firestore";
  import { cleanPhone } from "@/lib/phone";
  import { identifyLead, trackLeadEvent } from "@/lib/analytics";
  import { buildLeadAttribution } from "@/lib/leadAttribution";

  const dialog = document.getElementById("notify-modal") as HTMLDialogElement;
  if (dialog) {
    const source = (dialog as HTMLElement).dataset.source ?? "notify-modal";
    let openerEl: HTMLElement | null = null;
    let notifyDocRef: DocumentReference | null = null;
    let notifyEmail = "";

    // Restore focus to the element that opened the modal
    dialog.addEventListener("close", () => {
      openerEl?.focus();
      openerEl = null;
    });

    // Wire up any [data-notify-city] trigger elements on the page
    document
      .querySelectorAll<HTMLElement>("[data-notify-city]")
      .forEach((el) => {
        const open = () => {
          const city = el.dataset.notifyCity ?? "";
          const nameEl = document.getElementById("notify-city-name");
          const cityInput = document.getElementById(
            "notify-city",
          ) as HTMLInputElement;
          if (nameEl) nameEl.textContent = city;
          if (cityInput) cityInput.value = city;
          // Reset to form state
          document
            .getElementById("notify-form-view")
            ?.removeAttribute("hidden");
          document
            .getElementById("notify-phone-view")
            ?.setAttribute("hidden", "");
          document.getElementById("notify-success")?.setAttribute("hidden", "");
          const errorEl = document.getElementById("notify-error");
          if (errorEl) {
            errorEl.textContent = "";
            errorEl.setAttribute("hidden", "");
          }
          notifyDocRef = null;
          openerEl = document.activeElement as HTMLElement;
          trackLeadEvent("notify_modal_opened", {
            source,
            sourcePage: window.location.pathname,
            city,
          });
          dialog.showModal();
          (dialog.querySelector(".modal-close") as HTMLElement | null)?.focus();
        };
        el.addEventListener("click", open);
        el.addEventListener("keydown", (e) => {
          if (e.key === "Enter" || e.key === " ") {
            e.preventDefault();
            open();
          }
        });
      });

    // Close on button or backdrop click
    dialog
      .querySelector(".modal-close")
      ?.addEventListener("click", () => dialog.close());
    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) dialog.close();
    });

    // Step 1: email form
    document
      .getElementById("notify-form")
      ?.addEventListener("submit", async (e) => {
        e.preventDefault();
        notifyEmail = (
          document.getElementById("notify-email") as HTMLInputElement
        ).value;
        const city = (
          document.getElementById("notify-city") as HTMLInputElement
        ).value;
        const submitBtn = (
          e.target as HTMLFormElement
        ).querySelector<HTMLButtonElement>('[type="submit"]');
        const errorEl = document.getElementById("notify-error");
        if (submitBtn) submitBtn.disabled = true;
        try {
          const db = getFirebaseDb();
          const attribution = buildLeadAttribution({ source });
          const data: Record<string, string> = {
            email: notifyEmail,
            city,
            ...attribution,
            createdAt: new Date().toISOString(),
          };
          notifyDocRef = await addDoc(collection(db, "leads"), data);
          identifyLead(notifyEmail, { ...attribution, city });
          trackLeadEvent("lead_email_submitted", { ...attribution, city });
          if (errorEl) {
            errorEl.textContent = "";
            errorEl.setAttribute("hidden", "");
          }
          document
            .getElementById("notify-form-view")
            ?.setAttribute("hidden", "");
          document
            .getElementById("notify-phone-view")
            ?.removeAttribute("hidden");
          (
            document.getElementById("notify-phone") as HTMLInputElement | null
          )?.focus();
        } catch {
          if (errorEl) {
            errorEl.textContent = "Something went wrong. Please try again.";
            errorEl.removeAttribute("hidden");
          }
        } finally {
          if (submitBtn) submitBtn.disabled = false;
        }
      });

    // Step 2: phone form
    document
      .getElementById("notify-phone-form")
      ?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const raw = (
          document.getElementById("notify-phone") as HTMLInputElement
        ).value;
        const cleaned = cleanPhone(raw);
        const phoneErrorEl = document.getElementById("notify-phone-error");

        if (!raw.trim()) {
          // Empty — show success
          document
            .getElementById("notify-phone-view")
            ?.setAttribute("hidden", "");
          const successEl = document.getElementById(
            "notify-success",
          ) as HTMLElement | null;
          successEl?.removeAttribute("hidden");
          successEl?.focus();
          return;
        }

        if (!cleaned) {
          if (phoneErrorEl) {
            phoneErrorEl.textContent = "Please enter a valid phone number.";
            phoneErrorEl.removeAttribute("hidden");
          }
          return;
        }

        const submitBtn = (
          e.target as HTMLFormElement
        ).querySelector<HTMLButtonElement>('[type="submit"]');
        if (submitBtn) submitBtn.disabled = true;
        try {
          const db = getFirebaseDb();
          if (notifyDocRef) {
            await updateDoc(notifyDocRef, { phone: cleaned });
          } else {
            const attribution = buildLeadAttribution({ source });
            const data: Record<string, string> = {
              email: notifyEmail,
              city: (document.getElementById("notify-city") as HTMLInputElement)
                .value,
              phone: cleaned,
              ...attribution,
              createdAt: new Date().toISOString(),
            };
            await addDoc(collection(db, "leads"), data);
          }
          trackLeadEvent("lead_phone_submitted", {
            source,
            sourcePage: window.location.pathname,
          });
          document
            .getElementById("notify-phone-view")
            ?.setAttribute("hidden", "");
          const successEl = document.getElementById(
            "notify-success",
          ) as HTMLElement | null;
          successEl?.removeAttribute("hidden");
          successEl?.focus();
        } catch (err) {
          if (phoneErrorEl) {
            phoneErrorEl.textContent =
              "Something went wrong. Please try again or skip.";
            phoneErrorEl.removeAttribute("hidden");
          }
        } finally {
          if (submitBtn) submitBtn.disabled = false;
        }
      });

    // Skip phone step
    document.getElementById("notify-skip")?.addEventListener("click", () => {
      document.getElementById("notify-phone-view")?.setAttribute("hidden", "");
      const successEl = document.getElementById(
        "notify-success",
      ) as HTMLElement | null;
      successEl?.removeAttribute("hidden");
      successEl?.focus();
    });
  }
</script>

<style>
  .modal-dialog {
    border: none;
    background: transparent;
    padding: 24px;
    max-width: 100%;
    max-height: 100vh;
    width: 100%;
    height: 100%;
    overflow: visible;
  }
  .modal-dialog::backdrop {
    background: rgba(0, 0, 0, 0.5);
  }
  .modal-dialog[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .modal-inner {
    width: 100%;
    max-width: 400px;
    max-height: 80vh;
    overflow-y: auto;
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 20px;
    padding: 32px 24px;
    position: relative;
    animation: modalIn 0.25s ease-out both;
    text-align: center;
  }
  @keyframes modalIn {
    from {
      opacity: 0;
      transform: scale(0.95) translateY(8px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }
  /* Prevent CLS when switching between steps */
  .notify-steps-wrapper {
    min-height: 260px;
  }
  .modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    min-width: var(--touch-target);
    min-height: var(--touch-target);
    padding: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
  }
  .modal-close:hover {
    color: var(--charcoal);
  }
  .modal-title {
    font-family: var(--font-playfair), serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--charcoal);
    margin-bottom: 8px;
  }
  .modal-subtitle {
    font-size: 15px;
    color: var(--text-light);
    margin-bottom: 24px;
    line-height: 1.5;
  }
  .modal-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .modal-form input {
    padding: 14px 20px;
    border: 1.5px solid rgba(0, 0, 0, 0.1);
    border-radius: 50px;
    font-size: 16px;
    font-family: var(--font-body), sans-serif;
    outline: none;
    transition: border-color 0.2s;
    min-height: var(--touch-target);
  }
  .modal-form input:focus {
    border-color: var(--brand-red);
  }
  .modal-error {
    font-size: 14px;
    color: var(--brand-red);
    margin: 0;
    text-align: center;
  }
  .modal-submit {
    background: var(--brand-red);
    color: white;
    border: none;
    padding: 14px;
    border-radius: 50px;
    font-family: var(--font-body), sans-serif;
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: background 0.2s;
    min-height: var(--touch-target);
    white-space: nowrap;
    width: 100%;
  }
  .modal-submit:hover {
    background: var(--brand-red-dark);
  }
  .modal-skip {
    background: none;
    border: none;
    color: var(--muted);
    font-size: 14px;
    font-family: var(--font-body), sans-serif;
    margin-top: 12px;
    transition: color 0.2s;
    padding: 12px 16px;
    min-height: var(--touch-target);
    cursor: pointer;
  }
  .modal-skip:hover {
    color: var(--charcoal);
  }
  .modal-success {
    text-align: center;
    padding: 24px 0;
  }
  .modal-success p {
    font-family: var(--font-cormorant), serif;
    font-size: 18px;
    font-style: italic;
    color: var(--charcoal);
  }
</style>
