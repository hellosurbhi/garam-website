---
import type { EventEntry } from "@/data/events";
import { buildTicketUrl } from "@/utils/eventUrl";
import { formatEventLocation } from "@/utils/eventCity";
import { domainFromUrl, vendorFromUrl } from "@/lib/analyticsCapture";
import { EVENTS } from "@/data/copy";

interface Props {
  event: EventEntry;
  citySlug: string;
}

const { event, citySlug } = Astro.props;

const isSoldOut = event.soldOut ?? false;
const eventLocation = formatEventLocation(event);
const ticketUrl = buildTicketUrl(event.url, "cities", citySlug);
const eventTitle = `Garam Masala Dating - ${eventLocation} - ${event.date}`;
const ctaText = isSoldOut ? "Sold Out" : `${event.date}: ${EVENTS.ticketCta}`;

const containerId = event.eventbriteId
  ? `eventbrite-widget-container-${event.eventbriteId}`
  : undefined;

const sharedAttrs = {
  "data-ph-capture": "ticket_click",
  "data-ph-cta": "city_hero_embed",
  "data-ph-section": "cities",
  "data-ph-price": event.price,
  "data-ph-event-date": event.isoDate ?? event.date,
  "data-ph-event-title": eventTitle,
  "data-cta-position": "city_hero_embed",
  "data-cta-text": ctaText,
  "data-destination-url": ticketUrl,
  "data-link-url": ticketUrl,
  "data-link-domain": domainFromUrl(ticketUrl),
  "data-event-city": eventLocation,
  "data-event-date": event.isoDate ?? event.date,
  "data-event-title": eventTitle,
  "data-event-vendor": vendorFromUrl(ticketUrl),
  "data-city-slug": citySlug,
};

const arrowPath1 = "M5 12h14";
const arrowPath2 = "m12 5 7 7-7 7";
---

{
  containerId && !isSoldOut ? (
    <div class="eb-embed" id={`buy-${event.eventbriteId}`}>
      <div
        id={containerId}
        class="eb-embed__container"
        data-eb-event-id={event.eventbriteId}
        data-eb-url={ticketUrl}
        data-city={eventLocation}
        {...sharedAttrs}
      />
      {/* Hidden; shown centered within the 425px box only if widget fails to load */}
      <a
        href={ticketUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="eb-embed__fallback city-cta city-cta--primary"
        {...sharedAttrs}
      >
        <span>{ctaText}</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="city-cta__arrow"
          aria-hidden="true"
        >
          <path d={arrowPath1} />
          <path d={arrowPath2} />
        </svg>
      </a>
      {/* No-JS: neither the container nor the JS-hidden fallback renders, so give a plain link */}
      <noscript>
        <a
          href={ticketUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="city-cta city-cta--primary eb-embed__noscript"
        >
          <span>{ctaText}</span>
        </a>
      </noscript>
    </div>
  ) : (
    <a
      href={ticketUrl}
      target="_blank"
      rel="noopener noreferrer"
      class={`city-cta city-cta--primary${isSoldOut ? " city-cta--soldout" : ""}`}
      {...sharedAttrs}
    >
      <span>{ctaText}</span>
      {!isSoldOut && (
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="city-cta__arrow"
          aria-hidden="true"
        >
          <path d={arrowPath1} />
          <path d={arrowPath2} />
        </svg>
      )}
    </a>
  )
}

<style>
  /*
   * Scroll-anchor wrapper. position:relative lets the failure-state overlay
   * center itself within the reserved box without shifting layout.
   */
  .eb-embed {
    position: relative;
    scroll-margin-top: 80px;
  }

  /*
   * Height driven by --eb-embed-height (src/index.css :root). The JS widget
   * init reads the same variable at runtime, so there is one source of truth.
   * Fixed height (not min) = zero CLS: the slot is reserved at its final size
   * before the Eventbrite script even loads.
   *
   * Loading skeleton: neutral grey sweep (not red-tint) so it reads as a clean
   * placeholder on a white page. Covered by the opaque EB iframe once mounted.
   */
  .eb-embed__container {
    display: block;
    height: var(--eb-embed-height);
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    background: linear-gradient(
      90deg,
      rgba(0, 0, 0, 0.04) 25%,
      rgba(0, 0, 0, 0.07) 50%,
      rgba(0, 0, 0, 0.04) 75%
    );
    background-size: 200% 100%;
  }

  /* Shimmer sweep. :has() is in all 2026 browsers — stops animation once the
     injected iframe is in the DOM. Skipped entirely for prefers-reduced-motion. */
  @media (prefers-reduced-motion: no-preference) {
    .eb-embed__container:not(:has(> iframe)) {
      animation: eb-shimmer 1.8s ease-in-out infinite;
    }
  }

  @keyframes eb-shimmer {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }

  /* JS adds .eb-embed--loaded when iframe is confirmed mounted: cleans up animation */
  .eb-embed--loaded .eb-embed__container {
    animation: none;
    background: transparent;
  }

  /*
   * Failure state: stop animation, keep static tint so the box reads as
   * "something's here" not a blank hole, and surface the fallback link
   * centered within the same 425px space. Nothing shifts layout.
   */
  .eb-embed--failed .eb-embed__container {
    animation: none;
    background: rgba(0, 0, 0, 0.04);
  }

  /*
   * Specificity is (0,2,0) — beats .city-cta { display: flex } which is (0,1,0).
   * Without the .eb-embed scope, .city-cta's later source-order would win and the
   * button would show permanently, even when the embed loads successfully.
   */
  .eb-embed .eb-embed__fallback {
    display: none;
  }

  /* On failure: overlay the box, centered, compact width */
  .eb-embed--failed .eb-embed__fallback {
    display: inline-flex;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: auto;
    white-space: nowrap;
  }

  /* Keep centering transform under press feedback */
  .eb-embed--failed .eb-embed__fallback:active {
    transform: translate(-50%, -50%) scale(0.97);
  }

  .city-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 22px;
    border-radius: 14px;
    border: 1px solid;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    text-decoration: none;
    appearance: none;
    cursor: pointer;
    transition:
      background 0.15s,
      border-color 0.15s,
      transform 0.15s;
    width: 100%;
    text-align: left;
  }

  .city-cta:active {
    transform: scale(0.97);
  }

  .city-cta--primary {
    border-color: rgba(var(--brand-red-rgb), 0.5);
    background: rgba(var(--brand-red-rgb), 0.1);
    color: var(--brand-red);
  }

  .city-cta--primary:hover {
    border-color: rgba(var(--brand-red-rgb), 0.7);
    background: rgba(var(--brand-red-rgb), 0.15);
  }

  .city-cta--soldout {
    border-color: rgba(0, 0, 0, 0.08);
    background: rgba(0, 0, 0, 0.04);
    color: var(--muted);
    cursor: default;
  }

  .city-cta__arrow {
    flex-shrink: 0;
  }
</style>
