---
import type { EventEntry } from "@/data/events";
import { buildTicketUrl } from "@/utils/eventUrl";
import { formatEventLocation } from "@/utils/eventCity";
import { formatDisplayTime } from "@/utils/eventDate";
import { domainFromUrl, vendorFromUrl } from "@/lib/analyticsCapture";
import { EVENTS } from "@/data/copy";

interface Props {
  event: EventEntry;
  citySlug: string;
}

const { event, citySlug } = Astro.props;

const isSoldOut = event.soldOut ?? false;
const eventLocation = formatEventLocation(event);
const ticketUrl = buildTicketUrl(event.url, "cities", citySlug);
const eventTitle = `Garam Masala Dating - ${eventLocation} - ${event.date}`;
const ctaText = isSoldOut ? "Sold Out" : `${event.date}: ${EVENTS.ticketCta}`;

const containerId = event.eventbriteId
  ? `eventbrite-widget-container-${event.eventbriteId}`
  : undefined;

/*
 * Card display data for the fallback layer.
 * Strip bureaucratic "Township" suffix so "North Brunswick Township" reads
 * as "North Brunswick" to the user.
 */
const venueTown = (event.venue?.addressLocality ?? "").replace(
  /\s+Township$/,
  "",
);
const venueDisplay = event.venue?.name
  ? venueTown
    ? `${event.venue.name}, ${venueTown}`
    : event.venue.name
  : eventLocation;
const timeDisplay = event.startTime ? formatDisplayTime(event.startTime) : null;

const sharedAttrs = {
  "data-ph-capture": "ticket_click",
  "data-ph-cta": "city_hero_embed",
  "data-ph-section": "cities",
  "data-ph-price": event.price,
  "data-ph-event-date": event.isoDate ?? event.date,
  "data-ph-event-title": eventTitle,
  "data-cta-position": "city_hero_embed",
  "data-cta-text": ctaText,
  "data-destination-url": ticketUrl,
  "data-link-url": ticketUrl,
  "data-link-domain": domainFromUrl(ticketUrl),
  "data-event-city": eventLocation,
  "data-event-date": event.isoDate ?? event.date,
  "data-event-title": eventTitle,
  "data-event-vendor": vendorFromUrl(ticketUrl),
  "data-city-slug": citySlug,
};

const arrowPath1 = "M5 12h14";
const arrowPath2 = "m12 5 7 7-7 7";
---

{
  containerId && !isSoldOut ? (
    /*
     * Progressive enhancement: the card layer is always rendered as baseline HTML.
     * Eventbrite injects an opaque iframe into the container layer on top of it.
     * The card shows as loading skeleton, failure fallback and no-JS fallback all
     * in one element; no JS class toggling needed.
     *
     * .eb-embed height is fixed at 425px to prevent CLS. Both layers are
     * position:absolute and fill that reserved space.
     */
    <div class="eb-embed" id={`buy-${event.eventbriteId}`}>
      {/* Baseline info card: visible until the iframe covers it */}
      <div class="eb-embed__card">
        <p class="eb-embed__card-name">{EVENTS.showName}</p>
        <p class="eb-embed__card-details">
          {event.date}
          {timeDisplay && <> · Doors {timeDisplay}</>}
        </p>
        <p class="eb-embed__card-venue">{venueDisplay}</p>
        <p class="eb-embed__card-price">Tickets from ${event.price}</p>
        <a
          href={ticketUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="city-cta city-cta--primary eb-embed__card-cta"
          {...sharedAttrs}
        >
          <span>Get tickets</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="city-cta__arrow"
            aria-hidden="true"
          >
            <path d={arrowPath1} />
            <path d={arrowPath2} />
          </svg>
        </a>
      </div>
      {/* Container layer: Eventbrite injects an opaque iframe here, covering the card */}
      <div
        id={containerId}
        class="eb-embed__container"
        data-eb-event-id={event.eventbriteId}
        data-eb-url={ticketUrl}
        data-city={eventLocation}
        {...sharedAttrs}
      />
    </div>
  ) : (
    <a
      href={ticketUrl}
      target="_blank"
      rel="noopener noreferrer"
      class={`city-cta city-cta--primary${isSoldOut ? " city-cta--soldout" : ""}`}
      {...sharedAttrs}
    >
      <span>{ctaText}</span>
      {!isSoldOut && (
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="city-cta__arrow"
          aria-hidden="true"
        >
          <path d={arrowPath1} />
          <path d={arrowPath2} />
        </svg>
      )}
    </a>
  )
}

<style>
  /*
   * Wrapper: fixed height prevents CLS. Both child layers are position:absolute
   * and fill this reserved space. Height must match iframeContainerHeight in
   * EventbriteWidgetInit.astro (425). Scroll anchor clears the sticky nav.
   */
  .eb-embed {
    position: relative;
    height: var(--eb-embed-height);
    scroll-margin-top: 80px;
  }

  /*
   * Baseline info card. Sits at z-index 0, always visible as static HTML.
   * Shows show name, date, venue and price so the user has all the info
   * even before the Eventbrite script loads or if it never loads.
   */
  .eb-embed__card {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 24px;
    text-align: center;
  }

  .eb-embed__card-name {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brand-red);
    margin: 0;
  }

  .eb-embed__card-details {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 600;
    color: var(--charcoal);
    margin: 0;
  }

  .eb-embed__card-venue {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 400;
    color: var(--muted);
    margin: 0;
  }

  .eb-embed__card-price {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: var(--charcoal);
    margin: 0 0 10px;
  }

  /* Card CTA: auto-width so it does not stretch full card width */
  .eb-embed__card-cta {
    width: auto;
    white-space: nowrap;
  }

  /*
   * Container layer: Eventbrite injects an opaque iframe here at z-index 1.
   * The iframe covers the card once EB loads; the card stays below as the
   * permanent fallback if EB never loads. overflow:hidden clips iframe corners
   * to match the border-radius.
   */
  .eb-embed__container {
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: 12px;
    overflow: hidden;
  }

  .city-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 22px;
    border-radius: 14px;
    border: 1px solid;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    text-decoration: none;
    appearance: none;
    cursor: pointer;
    transition:
      background 0.15s,
      border-color 0.15s,
      transform 0.15s;
    width: 100%;
    text-align: left;
  }

  .city-cta:active {
    transform: scale(0.97);
  }

  .city-cta--primary {
    border-color: rgba(var(--brand-red-rgb), 0.5);
    background: rgba(var(--brand-red-rgb), 0.1);
    color: var(--brand-red);
  }

  .city-cta--primary:hover {
    border-color: rgba(var(--brand-red-rgb), 0.7);
    background: rgba(var(--brand-red-rgb), 0.15);
  }

  .city-cta--soldout {
    border-color: rgba(0, 0, 0, 0.08);
    background: rgba(0, 0, 0, 0.04);
    color: var(--muted);
    cursor: default;
  }

  .city-cta__arrow {
    flex-shrink: 0;
  }
</style>
