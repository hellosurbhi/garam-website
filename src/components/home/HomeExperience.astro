---
import { EXPERIENCE_STEPS, SITE } from '@/data/copy';
const steps = EXPERIENCE_STEPS;
---

<section class="experience" id="experience" aria-labelledby="exp-heading" data-reveal>
  <div class="experience-inner">
    <div class="experience-left">
      <h2 id="exp-heading">NYC's #1 <em>Live</em> South Asian Dating Show</h2>
      <p class="lead">Imagine The Bachelor meets Indian Matchmaking, but live on stage in New York City, hosted by two comedians who are deeply unqualified and absolutely thriving.</p>
      <p>{SITE.description}</p>
      <p>Whether you're South Asian or not, curious, single, coupled up, or just need a Friday night story, this is the most fun you'll have watching two people fall in love (or spectacularly not) in real time.</p>
    </div>
    <div class="experience-steps">
      {steps.map((step, i) => (
        <div class="exp-step">
          <div class="exp-visual">
            <picture>
              <source srcset={`${step.image}.avif`} type="image/avif" />
              <source srcset={`${step.image}.webp`} type="image/webp" />
              <img
                src={`${step.image}.jpg`}
                alt={step.alt}
                width="120"
                height="120"
                loading="lazy"
                style={`object-position: ${step.pos};`}
              />
            </picture>
            <span class="exp-num">{String(i + 1).padStart(2, '0')}</span>
          </div>
          <div>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .experience {
    padding: 80px 20px;
    background: var(--off-white);
  }
  .experience-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }
  .experience-left h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(32px, 5vw, 64px);
    font-weight: 900;
    line-height: 1.0;
    color: var(--charcoal);
    margin-bottom: 20px;
    letter-spacing: -1px;
  }
  .experience-left h2 em { color: var(--brand-red); font-style: italic; }
  .experience-left .lead {
    font-family: var(--font-cormorant), serif;
    font-size: 18px;
    font-style: italic;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 24px;
  }
  .experience-left p {
    font-size: 16px;
    color: var(--text-light);
    line-height: 1.8;
    margin-bottom: 16px;
  }
  .experience-steps {
    display: flex;
    flex-direction: column;
  }
  .exp-step {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: 16px;
    padding: 24px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    align-items: start;
  }
  .exp-step:last-child { border-bottom: none; }

  .exp-visual {
    position: relative;
    width: 72px;
    height: 72px;
    border-radius: 14px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .exp-visual picture {
    position: absolute;
    inset: 0;
  }
  .exp-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .exp-num {
    position: absolute;
    bottom: 4px;
    left: 4px;
    font-family: var(--font-playfair), serif;
    font-size: 16px;
    font-weight: 900;
    color: white;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    width: 28px;
    height: 28px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  .exp-step h3 {
    font-family: var(--font-playfair), serif;
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 6px;
    color: var(--charcoal);
  }
  .exp-step p {
    font-size: 15px;
    color: var(--text-tertiary);
    line-height: 1.65;
  }

  @media (min-width: 768px) {
    .experience { padding: 120px 48px; }
    .experience-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: start;
    }
    .experience-left .lead { font-size: 20px; margin-bottom: 32px; }
    .exp-step { grid-template-columns: 88px 1fr; gap: 20px; padding: 28px 0; }
    .exp-visual { width: 88px; height: 88px; border-radius: 16px; }
    .exp-num { font-size: 18px; width: 32px; height: 32px; }
    .exp-step h3 { font-size: 20px; }
  }
</style>
