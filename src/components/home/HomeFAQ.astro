---
import { HOME_FAQS as faqs } from '@/data/copy';
---

<section class="faq" id="faq" aria-labelledby="faq-heading">
  <div class="faq-inner">
    <div class="faq-eyebrow" data-reveal>Frequently Asked Questions</div>
    <h2 id="faq-heading" data-reveal>Everything You<br />Need to Know</h2>
    <div class="faq-list">
      {faqs.map((faq) => (
        <details class="faq-item" data-reveal>
          <summary class="faq-q">
            {faq.q}
            <span class="faq-toggle">+</span>
          </summary>
          <div class="faq-answer">
            <p class="faq-answer-summary" set:html={faq.short} />
            <p class="faq-answer-detail" set:html={faq.long} />
          </div>
        </details>
      ))}
    </div>
    <div class="faq-cta" data-reveal>
      <a href="/tickets" class="faq-cta-btn">Get Tickets</a>
      <a href="/apply" class="faq-cta-link">or Apply for the Show →</a>
    </div>
  </div>
</section>

<script>
  // Single-open: close siblings when one opens
  document.querySelectorAll('.faq-item').forEach((details) => {
    details.addEventListener('toggle', () => {
      if ((details as HTMLDetailsElement).open) {
        document.querySelectorAll('.faq-item').forEach((other) => {
          if (other !== details && (other as HTMLDetailsElement).open) {
            (other as HTMLDetailsElement).open = false;
          }
        });
      }
    });
  });
</script>

<style>
  .faq {
    padding: 56px 20px;
    background: #FFF0E2;
  }
  .faq-inner {
    max-width: 800px;
    margin: 0 auto;
  }
  .faq-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--brand-red);
    margin-bottom: 16px;
  }
  .faq-inner > h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(30px, 4vw, 52px);
    font-weight: 900;
    color: var(--charcoal);
    margin-bottom: 48px;
    line-height: 1.05;
  }
  .faq-list { display: flex; flex-direction: column; }
  .faq-item { border-bottom: 1.5px solid #eee; }
  .faq-item:first-child { border-top: 1.5px solid #eee; }
  .faq-q {
    font-family: var(--font-cormorant), serif;
    font-size: 25px;
    font-weight: 700;
    text-transform: none;
    letter-spacing: 0.25px;
    color: var(--charcoal);
    padding: 24px 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    transition: color 0.2s;
    gap: 16px;
    list-style: none;
    min-height: var(--touch-target);
  }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-q::marker { display: none; content: ''; }
  .faq-q:hover { color: var(--brand-red); }
  .faq-toggle {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: var(--off-white);
    border: 1.5px solid #ddd;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 24px;
    color: var(--brand-red);
    transition: transform 0.3s, background 0.3s;
    line-height: 1;
  }
  .faq-item[open] .faq-toggle {
    transform: rotate(45deg);
    background: var(--brand-red);
    color: white;
    border-color: var(--brand-red);
  }
  .faq-answer {
    overflow: hidden;
  }
  .faq-answer-summary {
    font-family: var(--font-cormorant), serif;
    font-size: 17px;
    font-style: italic;
    font-weight: 500;
    color: var(--charcoal);
    line-height: 1.7;
    margin-bottom: 12px;
  }
  .faq-answer-detail {
    font-size: 15px;
    color: var(--text-light);
    line-height: 1.8;
    padding-bottom: 24px;
  }
  .faq-answer a {
    color: var(--brand-red);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }
  .faq-answer a:hover {
    color: var(--brand-red-dark);
  }

  .faq-cta {
    text-align: center;
    margin-top: 48px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 16px;
  }
  .faq-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--brand-red);
    color: white;
    font-family: var(--font-body), sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    padding: 14px 32px;
    border-radius: 50px;
    text-decoration: none;
    min-height: var(--touch-target);
    transition: background 0.2s;
  }
  .faq-cta-btn:hover { background: var(--brand-red-dark); }
  .faq-cta-link {
    font-family: var(--font-cormorant), serif;
    font-size: 22px;
    font-style: italic;
    color: var(--brand-red);
    text-decoration: none;
    transition: color 0.2s;
  }
  .faq-cta-link:hover { color: var(--brand-red-dark); }

  @media (min-width: 768px) {
    .faq { padding: 80px 48px; }
    .faq-inner > h2 { margin-bottom: 64px; }
    .faq-q { font-size: 25px; padding: 28px 0; gap: 20px; }
    .faq-answer-summary { font-size: 18px; }
    .faq-answer-detail { padding-bottom: 28px; }
  }
</style>
