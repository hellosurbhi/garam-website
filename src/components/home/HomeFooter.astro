---
import { SOCIAL_URLS } from '@/data/socials';
import { SOCIAL_ICON_SVGS } from '@/data/icons';

const showLinks = [
  { label: 'New York City', href: '/cities/manhattan' },
  { label: 'Jersey City', href: '/cities/jersey-city' },
  { label: 'Los Angeles', href: '/cities/los-angeles' },
  { label: 'San Francisco', href: '/cities/san-francisco' },
  { label: 'San Diego', href: '/cities/san-diego' },
  { label: 'All Cities', href: '/cities' },
];

const involvedLinks = [
  { label: 'Apply to Date on Stage', href: '/apply' },
  { label: 'Buy Tickets', href: '/tickets' },
  { label: 'Brand Partnerships', href: `mailto:${SOCIAL_URLS.email.replace('mailto:', '')}` },
];

const exploreLinks = [
  { label: 'FAQ', href: '/faq' },
  { label: 'The Journal', href: '/journal' },
  { label: 'Meet the Hosts', href: '/hosts' },
  { label: 'Contact', href: `mailto:${SOCIAL_URLS.email.replace('mailto:', '')}` },
];

const socials = [
  { icon: 'instagram', aria: 'Instagram', href: SOCIAL_URLS.instagram },
  { icon: 'tiktok', aria: 'TikTok', href: SOCIAL_URLS.tiktok },
  { icon: 'youtube', aria: 'YouTube', href: SOCIAL_URLS.youtube },
  { icon: 'threads', aria: 'Threads', href: SOCIAL_URLS.threads },
  { icon: 'x', aria: 'X (Twitter)', href: SOCIAL_URLS.x },
  { icon: 'facebook', aria: 'Facebook', href: SOCIAL_URLS.facebook },
];
---

<footer role="contentinfo">
  <div class="footer-top">
    <div class="footer-brand">
      <a href="/" aria-label="Garam Masala Dating Home">
        <img src="/images/logo.svg" alt="Garam Masala Dating Show" class="footer-logo" width="160" height="82" loading="lazy" />
      </a>
      <p>NYC's #1 live South Asian comedy dating show. Hosted by Surbhi & Wyatt.</p>
      <div class="footer-social">
        {socials.map((s) => (
          <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.aria}><Fragment set:html={SOCIAL_ICON_SVGS[s.icon]} /></a>
        ))}
      </div>
    </div>
    <div class="footer-col">
      <h4>Shows</h4>
      <ul>
        {showLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>
    <div class="footer-col">
      <h4>Get Involved</h4>
      <ul>
        {involvedLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>
    <div class="footer-col">
      <h4>Explore</h4>
      <ul>
        {exploreLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="footer-copy">&copy; 2026 Garam Masala Dating. All rights reserved.</div>
    <div class="footer-legal">
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--ink);
    padding: 60px 20px 32px;
  }
  .footer-top {
    display: flex;
    flex-direction: column;
    gap: 40px;
    max-width: 1200px;
    margin: 0 auto;
    padding-bottom: 40px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .footer-logo {
    height: 48px;
    width: auto;
    margin-bottom: 12px;
    filter: brightness(0) invert(1);
  }
  .footer-brand p {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.7;
    margin-bottom: 20px;
    max-width: 280px;
  }
  .footer-social { display: flex; gap: 12px; }
  .footer-social a {
    width: 40px;
    height: 40px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
    min-height: 48px;
    min-width: 48px;
  }
  .footer-social a:hover {
    border-color: var(--hot-pink);
    color: var(--hot-pink);
  }
  .footer-col h4 {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 16px;
  }
  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-col ul li a {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    font-size: 14px;
    transition: color 0.2s;
    padding: 4px 0;
    display: inline-block;
  }
  .footer-col ul li a:hover { color: white; }
  .footer-bottom {
    max-width: 1200px;
    margin: 0 auto;
    padding-top: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .footer-copy {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.45);
  }
  .footer-legal {
    display: flex;
    gap: 24px;
  }
  .footer-legal a {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-legal a:hover {
    color: white;
  }

  @media (min-width: 768px) {
    footer { padding: 80px 48px 40px; }
    .footer-top {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 60px;
      padding-bottom: 60px;
    }
    .footer-logo { height: 56px; }
    .footer-brand p { margin-bottom: 24px; }
    .footer-col h4 { margin-bottom: 20px; }
    .footer-col ul { gap: 12px; }
    .footer-bottom { padding-top: 32px; }
  }
</style>
