---
import { SITE } from "@/data/copy";
import type { EventEntry } from "@/data/events";
import { buildTicketUrl } from "@/utils/eventUrl";
import { formatEventLocation } from "@/utils/eventCity";

interface Props {
  ticketsUrl: string;
  heroEvents: EventEntry[];
}

const { ticketsUrl, heroEvents } = Astro.props;

function formatTime(t: string): string {
  const h = parseInt(t.split(":")[0]);
  const hour12 = h === 0 ? 12 : h > 12 ? h - 12 : h;
  return `${hour12} ${h >= 12 ? "PM" : "AM"}`;
}

function getHeroCity(city: string): string {
  const primary = city.split(",")[0].trim();
  const nycBoroughs = [
    "Manhattan",
    "Brooklyn",
    "Queens",
    "Bronx",
    "The Bronx",
    "Staten Island",
  ];
  return nycBoroughs.includes(primary) ? "NYC" : primary;
}
---

<section class="hero" aria-label="Hero">
  <div class="hero-bg" aria-hidden="true"></div>

  <div class="hero-content">
    <div class="hero-eyebrow">
      <span class="eyebrow-line"></span>
      <span>{SITE.heroEyebrow}</span>
      <span class="eyebrow-line"></span>
    </div>

    <h1>
      Garam<br />
      Mas<em>ala</em><br />
      <span class="h1-sub">Dating Show</span>
    </h1>

    <p class="hero-sub">
      Real singles. Real sparks. Real chaos.
    </p>

    {
      heroEvents.length > 0 && (
        <div class="pill-slot">
          {heroEvents.map((event) => {
            const isSoldOut = event.soldOut ?? false;
            const cityLabel = formatEventLocation(event);
            const pillInner = (
              <>
                <span class="pill-date">
                  {event.date.split(" ")[0]} {event.date.split(" ")[1]}
                </span>
                <span class="pill-sep" aria-hidden="true">·</span>
                <span>{getHeroCity(cityLabel)}</span>
                <span class="pill-sep" aria-hidden="true">·</span>
                <span>{formatTime(event.startTime ?? "20:00")}</span>
                <span class="pill-arrow" aria-hidden="true">→</span>
              </>
            );
            return event.eventbriteId && !isSoldOut ? (
              <a
                href={buildTicketUrl(event.url, "home", "hero")}
                target="_blank"
                rel="noopener noreferrer"
                id={`eventbrite-widget-modal-trigger-${event.eventbriteId}`}
                data-eb-event-id={event.eventbriteId}
                class="next-show-pill"
                hidden
                data-iso-date={event.isoDate}
                data-start-time={event.startTime ?? "20:00"}
                data-end-time={event.endTime ?? "22:00"}
                data-city={cityLabel}
                data-ph-section="hero"
                data-ph-price={event.price}
                data-ph-event-date={event.date}
              >
                {pillInner}
              </a>
            ) : (
              <a
                href={buildTicketUrl(event.url, "home", "hero")}
                target="_blank"
                rel="noopener noreferrer"
                class="next-show-pill"
                hidden
                data-iso-date={event.isoDate}
                data-start-time={event.startTime ?? "20:00"}
                data-end-time={event.endTime ?? "22:00"}
                data-city={cityLabel}
              >
                {pillInner}
              </a>
            );
          })}
        </div>
      )
    }

    <div class="hero-ctas">
      <a
        href={ticketsUrl}
        class="btn btn-hot"
        data-ph-capture="cta_clicked"
        data-ph-cta="get_tickets"
        data-ph-section="hero">Grab My Spot</a
      >
      <a
        href="/apply"
        class="btn btn-outline"
        data-ph-capture="cta_clicked"
        data-ph-cta="apply"
        data-ph-section="hero">Apply to the Show</a
      >
    </div>
  </div>

  <div class="scroll-cue" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18">
      <path d="M12 5v14M5 12l7 7 7-7"></path>
    </svg>
  </div>
</section>

<script>
  const BUFFER_H = 1;
  const pills = Array.from(
    document.querySelectorAll<HTMLElement>(".next-show-pill[data-iso-date]"),
  );

  function getEventEnd(isoDate: string, endTime: string): Date {
    const [h, m] = endTime.split(":").map(Number);
    const d = new Date(isoDate + "T00:00:00");
    d.setHours(h + BUFFER_H, m, 0, 0);
    return d;
  }

  function showNextPill(): void {
    const now = new Date();
    for (const pill of pills) {
      const isoDate = pill.dataset.isoDate!;
      const endTime = pill.dataset.endTime ?? "22:00";
      const end = getEventEnd(isoDate, endTime);
      if (now < end) {
        pill.removeAttribute("hidden");
        const msUntilEnd = end.getTime() - now.getTime();
        setTimeout(() => {
          pill.setAttribute("hidden", "");
          showNextPill();
        }, msUntilEnd);
        return;
      }
    }
  }

  showNextPill();
</script>

<style>
  .hero {
    display: grid;
    place-items: center;
    position: relative;
    overflow: hidden;
    background: var(--ink);
    min-height: 100svh;
    padding: 100px 20px 80px;
  }

  /* Hot-club lighting: colored light spills on dark stage */
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 15% 55%, rgba(220, 38, 38, 0.28) 0%, transparent 55%),
      radial-gradient(ellipse at 85% 25%, rgba(196, 153, 42, 0.18) 0%, transparent 50%),
      radial-gradient(ellipse at 55% 85%, rgba(255, 92, 0, 0.12) 0%, transparent 45%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 900px;
    width: 100%;
  }

  /* Eyebrow: two short lines flanking the text */
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-family: var(--font-body), sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 28px;
    animation: fadeUp 0.7s ease-out both;
  }
  .eyebrow-line {
    display: block;
    width: 32px;
    height: 1px;
    background: var(--gold);
    opacity: 0.6;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  h1 {
    font-family: var(--font-display), sans-serif;
    font-size: clamp(76px, 13vw, 148px);
    font-weight: 400; /* Anton only has weight 400 */
    line-height: 0.88;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: white;
    margin-bottom: 24px;
    animation: fadeUp 0.85s ease-out 0.15s both;
  }

  h1 em {
    color: var(--brand-red);
    font-style: normal; /* Anton has no italic; use color accent instead */
  }

  .h1-sub {
    display: block;
    font-family: var(--font-serif), serif;
    font-style: italic;
    font-size: clamp(28px, 4.5vw, 54px);
    font-weight: 400;
    line-height: 1.1;
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 0.02em;
    text-transform: none;
    margin-top: 8px;
  }

  .hero-sub {
    font-family: var(--font-body), sans-serif;
    font-size: 16px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    margin-bottom: 32px;
    animation: fadeUp 0.85s ease-out 0.3s both;
  }

  /* Next show pill */
  .pill-slot {
    min-height: 40px;
    margin-bottom: 32px;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .next-show-pill[hidden] {
    display: none !important;
  }
  .next-show-pill {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.85);
    font-family: var(--font-body), sans-serif;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.08em;
    padding: 12px 24px;
    border-radius: 2px;
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s;
    animation: fadeUp 0.85s ease-out 0.4s both;
  }
  .next-show-pill:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
  }
  .pill-date {
    color: var(--electric-yellow);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .pill-sep {
    color: rgba(255, 255, 255, 0.25);
  }
  .pill-arrow {
    color: var(--brand-red);
    margin-left: 4px;
  }

  /* CTAs */
  .hero-ctas {
    display: flex;
    gap: 12px;
    flex-direction: column;
    align-items: stretch;
    animation: fadeUp 0.85s ease-out 0.5s both;
  }

  /* Scroll cue */
  .scroll-cue {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.2);
    animation: bounce 2.5s ease-in-out infinite;
    z-index: 2;
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); opacity: 0.2; }
    50%       { transform: translateX(-50%) translateY(8px); opacity: 0.4; }
  }

  /* Desktop */
  @media (min-width: 768px) {
    .hero {
      padding: 120px 48px 100px;
    }
    .hero-sub {
      font-size: 13px;
    }
  }

  @media (min-width: 1025px) {
    .hero-ctas {
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
    }
    .btn {
      display: inline-flex;
      width: auto;
    }
  }

  @media (max-width: 1024px) {
    .scroll-cue { display: none; }
  }

  /* Narrow phones */
  @media (max-width: 390px) {
    h1 { font-size: clamp(58px, 18vw, 80px); }
    .h1-sub { font-size: clamp(22px, 6vw, 32px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-cue { animation: none; }
    .hero-eyebrow,
    h1,
    .hero-sub,
    .next-show-pill,
    .hero-ctas {
      animation: none;
      opacity: 1;
    }
  }
</style>
