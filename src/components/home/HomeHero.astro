---
import type { EventEntry } from '@/data/events';

interface Props {
  ticketsUrl: string;
  nextEvent?: EventEntry;
}

const { ticketsUrl, nextEvent } = Astro.props;

function formatTime(t?: string): string {
  if (!t) return '';
  const h = parseInt(t.split(':')[0]);
  return `${h > 12 ? h - 12 : h} ${h >= 12 ? 'PM' : 'AM'}`;
}
---

<section class="hero" aria-label="Hero">
  <canvas id="glCanvas" class="hero-shader" aria-hidden="true"></canvas>

  <div class="hero-content">
    <div class="hero-eyebrow">NYC's #1 Live South Asian Dating Show</div>
    <h1>
      Garam<br />
      Mas<em>ala</em><br />
      <span class="line-accent">Dating Show</span>
    </h1>
    <p class="hero-sub">
      New York City's live South Asian comedy dating show.<br />
      Real singles. Real sparks. Real chaos.
    </p>
    {nextEvent && (
      <a href={nextEvent.url} target="_blank" rel="noopener noreferrer" class="next-show">
        <div class="next-show-date">
          <span class="next-show-month">{nextEvent.date.split(' ')[0]}</span>
          <span class="next-show-day">{nextEvent.date.split(' ')[1]}</span>
        </div>
        <div class="next-show-info">
          <span class="next-show-city">{nextEvent.city.split(',')[0]}</span>
          <span class="next-show-venue">
            {nextEvent.venue?.name ?? ''}{nextEvent.startTime && ` · ${formatTime(nextEvent.startTime)}`}
          </span>
        </div>
        <span class="next-show-btn">Tickets</span>
      </a>
    )}
    <div class="hero-ctas">
      <a href={ticketsUrl} class="btn btn-hot">Get Tickets</a>
      <a href="/apply" class="btn btn-outline">Apply for the Show</a>
    </div>
  </div>

  <div class="scroll-cue" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
      <path d="M12 5v14M5 12l7 7 7-7" />
    </svg>
    <span>scroll</span>
  </div>
</section>

<script src="/js/shader-app.js" defer></script>

<style>
  .hero {
    min-height: 100vh;
    min-height: 100dvh;
    display: grid;
    place-items: center;
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(ellipse at 30% 50%, rgba(220, 38, 38, 0.15) 0%, transparent 60%),
      radial-gradient(ellipse at 70% 40%, rgba(255, 214, 0, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 60%, rgba(185, 28, 28, 0.1) 0%, transparent 55%),
      #fff;
    padding: 80px 20px 60px;
  }

  /* Shader fills hero — subtle wash over white bg */
  .hero-shader {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    opacity: 0.5;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 980px;
    padding: 40px 16px;
    background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.6) 0%, rgba(255, 255, 255, 0) 70%);
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: var(--brand-red);
    font-family: var(--font-body), sans-serif;
    font-size: 12px;
    font-weight: 700;
    font-style: italic;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    padding: 12px 24px;
    border-radius: 50px;
    margin-bottom: 24px;
    animation: pop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  @keyframes pop {
    from { opacity: 0; transform: scale(0.8); }
    to { opacity: 1; transform: scale(1); }
  }

  .hero h1 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(70px, 11vw, 116px);
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: -2px;
    color: var(--charcoal);
    margin-bottom: 24px;
    animation: rise 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.2s both;
  }

  @keyframes rise {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero h1 em {
    color: var(--brand-red);
    font-style: italic;
  }

  .line-accent {
    display: block;
    font-size: 0.55em;
    font-weight: 400;
    font-style: italic;
    color: #333;
    letter-spacing: 0;
    margin-top: 4px;
  }

  .hero-sub {
    font-family: var(--font-cormorant), serif;
    font-size: 20px;
    font-style: italic;
    color: var(--charcoal);
    margin-bottom: 36px;
    line-height: 1.5;
    animation: rise 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.35s both;
  }

  .next-show {
    display: flex;
    align-items: center;
    gap: 16px;
    background: none;
    border: none;
    border-radius: 0;
    padding: 12px 0;
    text-decoration: none;
    margin-bottom: 24px;
    max-width: 420px;
    width: 100%;
    animation: rise 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.45s both;
    transition: opacity 0.2s;
    box-shadow: none;
  }
  .next-show:hover { opacity: 0.8; }
  .next-show-date {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    min-width: 44px;
  }
  .next-show-month {
    font-family: var(--font-body), sans-serif;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--brand-red);
  }
  .next-show-day {
    font-family: var(--font-playfair), serif;
    font-size: 32px;
    font-weight: 900;
    line-height: 1;
    color: var(--charcoal);
  }
  .next-show-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }
  .next-show-city {
    font-family: var(--font-playfair), serif;
    font-size: 16px;
    font-weight: 700;
    color: var(--charcoal);
  }
  .next-show-venue {
    font-family: var(--font-body), sans-serif;
    font-size: 13px;
    color: #888;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .next-show-btn {
    flex-shrink: 0;
    background: var(--brand-red);
    color: white;
    font-family: var(--font-body), sans-serif;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 10px 20px;
    border-radius: 50px;
  }

  .hero-ctas {
    display: flex;
    gap: 12px;
    flex-direction: column;
    align-items: stretch;
    animation: rise 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.5s both;
  }

  .btn {
    font-family: var(--font-body), sans-serif;
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 16px 24px;
    border-radius: 50px;
    border: 2px solid transparent;
    transition: all 0.25s cubic-bezier(0.34, 1.3, 0.64, 1);
    min-height: var(--touch-target);
    white-space: nowrap;
  }

  .btn-hot {
    background: var(--brand-red);
    color: white;
    border-color: var(--brand-red);
  }

  .btn-hot:hover {
    background: var(--brand-red-dark);
    border-color: var(--brand-red-dark);
    transform: translateY(-3px);
  }

  .btn-hot:focus-visible {
    background: var(--brand-red-dark);
    border-color: var(--brand-red-dark);
    outline: 2px solid var(--brand-red-dark);
    outline-offset: 3px;
  }

  .btn-outline {
    background: transparent;
    color: var(--charcoal);
    border-color: rgba(26, 26, 26, 0.25);
  }

  .btn-outline:hover {
    border-color: var(--charcoal);
    transform: translateY(-3px);
  }

  .btn-outline:focus-visible {
    border-color: var(--charcoal);
    outline: 2px solid var(--charcoal);
    outline-offset: 3px;
  }

  .scroll-cue {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    opacity: 0.45;
    animation: bounce 2s ease-in-out infinite;
    z-index: 2;
    color: rgba(26, 26, 26, 0.4);
  }

  .scroll-cue span {
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  @media (min-width: 768px) {
    .hero { padding: 100px 48px 60px; }
    .hero-content { padding: 60px 48px; }
    .hero-eyebrow { font-size: 14px; padding: 16px 36px; }
    .hero-sub { font-size: 22px; margin-bottom: 44px; }
    .hero-ctas { flex-direction: row; flex-wrap: wrap; align-items: center; }
    .btn { font-size: 16px; padding: 18px 44px; display: inline-flex; width: auto; }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-cue { animation: none; }
    .hero-eyebrow, .hero h1, .hero-sub, .hero-ctas { animation: none; opacity: 1; }
  }
</style>
