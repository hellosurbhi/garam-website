---
interface Props {
  ticketsUrl: string;
}

const { ticketsUrl } = Astro.props;
---

<section class="hero" aria-label="Hero">
  <canvas id="glCanvas" class="hero-shader"></canvas>

  <div class="hero-content">
    <div class="hero-eyebrow">🌶️ NYC's #1 Live Dating Show · Now Expanding Nationwide</div>
    <h1>
      Garam<br />
      Mas<em>ala</em><br />
      <span class="line-accent">Dating Show</span>
    </h1>
    <p class="hero-sub">
      New York City's live South Asian comedy dating show.<br />
      Real singles. Real sparks. Real chaos.
    </p>
    <div class="hero-ctas">
      <a href={ticketsUrl} target="_blank" rel="noopener noreferrer" class="btn btn-hot">Get Tickets</a>
      <a href="/apply" class="btn btn-outline">Apply for the Show</a>
    </div>
  </div>

  <div class="scroll-cue" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
      <path d="M12 5v14M5 12l7 7 7-7" />
    </svg>
    <span>scroll</span>
  </div>
</section>

<script src="/js/shader-app.js" defer></script>

<style>
  .hero {
    min-height: 100vh;
    min-height: 100dvh;
    display: grid;
    place-items: center;
    position: relative;
    overflow: hidden;
    background: #fff;
    padding: 80px 20px 60px;
  }

  /* Shader fills hero — subtle wash over white bg */
  .hero-shader {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    opacity: 0.5;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 980px;
    padding: 60px 48px;
    background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.6) 0%, rgba(255, 255, 255, 0) 70%);
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--electric-yellow);
    color: var(--charcoal);
    font-weight: 700;
    font-size: 10px;
    position: relative;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    padding: 8px 18px;
    border-radius: 50px;
    margin-bottom: 24px;
    animation: pop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  @keyframes pop {
    from { opacity: 0; transform: scale(0.8); }
    to { opacity: 1; transform: scale(1); }
  }

  .hero h1 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(56px, 11vw, 116px);
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: -2px;
    color: var(--charcoal);
    margin-bottom: 24px;
    animation: rise 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.2s both;
  }

  @keyframes rise {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero h1 em {
    color: var(--hot-pink);
    font-style: italic;
  }

  .line-accent {
    display: block;
    font-size: 0.55em;
    font-weight: 400;
    font-style: italic;
    color: #333;
    letter-spacing: 0;
    margin-top: 4px;
  }

  .hero-sub {
    font-family: var(--font-cormorant), serif;
    font-size: 18px;
    font-style: italic;
    color: var(--charcoal);
    margin-bottom: 36px;
    line-height: 1.5;
    animation: rise 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.35s both;
  }

  .hero-ctas {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-direction: column;
    align-items: center;
    animation: rise 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.5s both;
  }

  .btn {
    font-family: var(--font-body), sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 36px;
    border-radius: 50px;
    border: 2px solid transparent;
    transition: all 0.25s cubic-bezier(0.34, 1.3, 0.64, 1);
    min-height: 48px;
  }

  .btn-hot {
    background: var(--hot-pink);
    color: white;
    border-color: var(--hot-pink);
  }

  .btn-hot:hover {
    background: var(--deep-magenta);
    border-color: var(--deep-magenta);
    transform: translateY(-3px);
  }

  .btn-outline {
    background: transparent;
    color: var(--charcoal);
    border-color: rgba(26, 26, 26, 0.25);
  }

  .btn-outline:hover {
    background: var(--charcoal);
    color: white;
    border-color: var(--charcoal);
    transform: translateY(-3px);
  }

  .scroll-cue {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    opacity: 0.45;
    animation: bounce 2s ease-in-out infinite;
    z-index: 2;
    color: rgba(26, 26, 26, 0.4);
  }

  .scroll-cue span {
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  @media (min-width: 768px) {
    .hero { padding: 100px 48px 60px; }
    .hero-eyebrow { font-size: 11px; padding: 8px 22px; }
    .hero-sub { font-size: 22px; margin-bottom: 44px; }
    .hero-ctas { flex-direction: row; flex-wrap: wrap; }
    .btn { padding: 18px 44px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-cue { animation: none; }
    .hero-eyebrow, .hero h1, .hero-sub, .hero-ctas { animation: none; opacity: 1; }
  }
</style>
