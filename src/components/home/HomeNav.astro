---
interface Props {
  ticketsUrl: string;
}

const { ticketsUrl } = Astro.props;
const pathname = Astro.url.pathname;
---

<nav class="home-nav" id="home-nav" aria-label="Main navigation">
  <a href="/" class="nav-logo" aria-label="Garam Masala Dating Home">
    <div class="nav-logo-mask" role="img" aria-hidden="true"></div>
  </a>
  <div class="nav-right">
    <a
      href="/apply"
      class="nav-link"
      aria-current={pathname.startsWith("/apply") ? "page" : undefined}
      data-ph-capture="nav_clicked"
      data-ph-destination="/apply">Apply</a
    >
    <a
      href={ticketsUrl}
      class="nav-pill"
      data-ph-capture="nav_clicked"
      data-ph-destination="/tickets">Get Tickets</a
    >
  </div>
</nav>

<script>
  const nav = document.getElementById("home-nav");
  const marquee = document.querySelector(".marquee") as HTMLElement;
  if (nav && marquee) {
    const update = () => {
      const navH = nav.offsetHeight;
      const trigger = marquee.offsetTop - navH;
      nav.classList.toggle("scrolled", window.scrollY >= trigger);
    };
    window.addEventListener("scroll", update, { passive: true });
    update();
  }
</script>

<style>
  .home-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 500;
    padding: 20px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: background 0.35s ease, border-color 0.35s ease, padding 0.35s ease;
    border-bottom: 1px solid transparent;
    background: transparent;
  }
  .home-nav.scrolled {
    background: rgba(253, 248, 242, 0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom-color: rgba(0, 0, 0, 0.06);
    padding: 14px 20px;
  }

  /* Logo: mask approach so we can recolor via background-color */
  .nav-logo {
    text-decoration: none;
    display: flex;
    align-items: center;
    min-height: var(--touch-target);
  }
  .nav-logo-mask {
    height: 28px;
    width: 120px;
    background-color: white; /* white on dark hero */
    -webkit-mask-image: url(/images/logo.svg);
    mask-image: url(/images/logo.svg);
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    transition: background-color 0.35s ease;
  }
  .home-nav.scrolled .nav-logo-mask {
    background-color: var(--brand-red); /* red on cream */
  }
  .nav-logo:hover .nav-logo-mask {
    opacity: 0.75;
  }

  /* Text nav link */
  .nav-link {
    font-family: var(--font-body), sans-serif;
    font-size: 16px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.7);
    padding: 10px 14px;
    border-radius: 3px;
    transition: color 0.2s;
    display: inline-flex;
    align-items: center;
    min-height: var(--touch-target);
  }
  .nav-link:hover {
    color: white;
  }
  .home-nav.scrolled .nav-link {
    color: var(--charcoal);
  }
  .home-nav.scrolled .nav-link:hover {
    color: var(--brand-red);
  }

  /* Tickets button */
  .nav-pill {
    font-family: var(--font-body), sans-serif;
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    text-decoration: none;
    color: white;
    background: var(--brand-red);
    padding: 10px 18px;
    border-radius: 3px;
    transition: background 0.2s;
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    min-height: var(--touch-target);
  }
  .nav-pill:hover {
    background: var(--brand-red-dark);
  }
  .nav-pill:active {
    transform: scale(0.97);
  }
  .nav-pill:focus-visible {
    outline: 2px solid var(--brand-red);
    outline-offset: 2px;
  }
  .nav-link:focus-visible {
    outline: 2px solid var(--brand-red);
    outline-offset: 2px;
  }

  @media (min-width: 768px) {
    .home-nav { padding: 24px 48px; }
    .home-nav.scrolled { padding: 16px 48px; }
    .nav-logo-mask { height: 36px; width: 160px; }
    .nav-link { font-size: 16px; padding: 12px 18px; }
    .nav-pill { font-size: 16px; padding: 12px 24px; }
  }
</style>
