---

<section class="newsletter" aria-labelledby="newsletter-heading">
  <h2 id="newsletter-heading" data-reveal>Join the Spice List</h2>
  <p data-reveal>Subscribers get exclusive discount codes for cheaper (and sometimes free) tickets.</p>
  <form class="newsletter-form" data-reveal>
    <input type="email" placeholder="Your email" required aria-label="Email address" />
    <button type="submit">Get My Discount Code</button>
  </form>
  <p class="newsletter-trust" data-reveal>No spam. Just discounts and show dates.</p>
</section>

<style>
  .newsletter {
    padding: 56px 20px;
    background: var(--hot-pink);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .newsletter h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(30px, 5vw, 60px);
    font-weight: 900;
    color: white;
    margin-bottom: 12px;
    position: relative;
  }
  .newsletter p {
    color: rgba(255, 255, 255, 0.85);
    font-size: 16px;
    margin-bottom: 36px;
    font-family: var(--font-cormorant), serif;
    font-style: italic;
    position: relative;
  }
  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 420px;
    margin: 0 auto;
    position: relative;
  }
  .newsletter-form input {
    padding: 16px 24px;
    border: 1.5px solid rgba(255, 255, 255, 0.4);
    border-radius: 50px;
    background: rgba(255, 255, 255, 0.15);
    color: white;
    font-size: 16px;
    font-family: var(--font-body), sans-serif;
    outline: none;
    transition: border-color 0.2s;
    min-height: 48px;
  }
  .newsletter-form input::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }
  .newsletter-form input:focus {
    border-color: var(--electric-yellow);
  }
  .newsletter-form button {
    background: white;
    color: var(--hot-pink);
    border: none;
    padding: 16px;
    border-radius: 50px;
    font-family: var(--font-playfair), serif;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    min-height: 48px;
  }
  .newsletter-form button:hover {
    background: var(--electric-yellow);
    color: var(--charcoal);
  }
  .newsletter-trust {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 0;
    margin-top: 16px;
    font-style: normal;
    font-family: var(--font-body), sans-serif;
  }

  @media (min-width: 768px) {
    .newsletter { padding: 80px 48px; }
    .newsletter p { font-size: 17px; margin-bottom: 48px; }
    .newsletter-form input { padding: 18px 28px; }
    .newsletter-form button { padding: 18px; }
  }
</style>
