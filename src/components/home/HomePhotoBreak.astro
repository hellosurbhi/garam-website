---
interface Photo {
  src: string;
  alt: string;
  position?: string;
}

interface Props {
  left: Photo;
  right: Photo;
}

const { left, right } = Astro.props;
---

<div class="photo-pair">
  <div class="photo-pair-item">
    <img
      src={`/images/${left.src}.webp`}
      alt={left.alt}
      width="1200"
      height="800"
      loading="lazy"
      style={`object-position: ${left.position ?? 'center 40%'};`}
    />
  </div>
  <div class="photo-pair-item">
    <img
      src={`/images/${right.src}.webp`}
      alt={right.alt}
      width="1200"
      height="800"
      loading="lazy"
      style={`object-position: ${right.position ?? 'center 40%'};`}
    />
  </div>
</div>

<style>
  .photo-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
  }
  .photo-pair-item {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 2;
  }
  .photo-pair-item img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (min-width: 768px) {
    .photo-pair { gap: 6px; }
    .photo-pair-item { aspect-ratio: 16 / 9; }
  }
</style>
