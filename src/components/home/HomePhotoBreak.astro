---
interface Photo {
  src: string;
  alt: string;
  position?: string;
}

interface Props {
  left: Photo;
  right: Photo;
}

const { left, right } = Astro.props;
---

<div class="photo-pair">
  <div class="photo-pair-item">
    <picture>
      <source srcset={`${left.src}.avif`} type="image/avif" />
      <source srcset={`${left.src}.webp`} type="image/webp" />
      <img
        src={`${left.src}.jpg`}
        alt={left.alt}
        width="1200"
        height="800"
        loading="lazy"
        style={`object-position: ${left.position ?? 'center 40%'};`}
      />
    </picture>
  </div>
  <div class="photo-pair-item">
    <picture>
      <source srcset={`${right.src}.avif`} type="image/avif" />
      <source srcset={`${right.src}.webp`} type="image/webp" />
      <img
        src={`${right.src}.jpg`}
        alt={right.alt}
        width="1200"
        height="800"
        loading="lazy"
        style={`object-position: ${right.position ?? 'center 40%'};`}
      />
    </picture>
  </div>
</div>

<style>
  .photo-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
  }
  .photo-pair-item {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 2;
  }
  .photo-pair-item picture {
    position: absolute;
    inset: 0;
  }
  .photo-pair-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (min-width: 768px) {
    .photo-pair { gap: 6px; }
    .photo-pair-item { aspect-ratio: 16 / 9; }
  }
</style>
