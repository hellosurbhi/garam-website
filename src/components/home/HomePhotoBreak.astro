---
interface Props {
  src: string;
  alt: string;
  position?: string;
}

const { src, alt, position = 'center 40%' } = Astro.props;
---

<div class="photo-break" data-reveal>
  <picture>
    <source srcset={`/images/gallery/${src}.avif`} type="image/avif" />
    <source srcset={`/images/gallery/${src}.webp`} type="image/webp" />
    <img
      src={`/images/gallery/${src}.jpg`}
      alt={alt}
      width="1200"
      height="800"
      loading="lazy"
      style={`object-position: ${position};`}
    />
  </picture>
</div>

<style>
  .photo-break {
    width: 100%;
    height: 280px;
    overflow: hidden;
    position: relative;
  }
  .photo-break picture {
    position: absolute;
    inset: 0;
  }
  .photo-break img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (min-width: 768px) {
    .photo-break {
      height: 420px;
    }
  }
</style>
