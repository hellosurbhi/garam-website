---
const photos = [
  {
    label: "On Stage",
    src: "on-stage.webp",
    w: 1200,
    h: 800,
    pos: "center 40%",
    span: true,
    alt: "Contestants and hosts laughing during a blindfolded dating round at Top Secret Comedy Club",
  },
  {
    label: "The Match",
    src: "the-match.webp",
    w: 1200,
    h: 800,
    pos: "center 45%",
    alt: "A matched couple laughing together on stage after the blindfold reveal",
  },
  {
    label: "Hosts",
    src: "hosts.webp",
    w: 733,
    h: 1200,
    pos: "center 30%",
    alt: "Hosts Surbhi and Wyatt sitting together on stage",
  },
  {
    label: "The Crowd",
    src: "the-crowd.webp",
    w: 800,
    h: 1200,
    pos: "center 40%",
    alt: "Audience members laughing together during a Garam Masala Dating show",
  },
  {
    label: "Pure Chaos",
    src: "pure-chaos.webp",
    w: 1200,
    h: 800,
    pos: "center 35%",
    alt: "A contestant lifting another person on stage during a high-energy moment",
  },
  {
    label: "After Party",
    src: "after-party.webp",
    w: 1200,
    h: 800,
    pos: "center center",
    alt: "Audience clapping and celebrating during the show",
  },
  {
    label: "Magic Moment",
    src: "magic-moment.webp",
    w: 800,
    h: 1200,
    pos: "center 30%",
    alt: "A contestant sharing an intimate moment with their date on stage",
  },
];
---

<section class="photos" id="gallery" aria-label="Show gallery">
  <div class="photos-header" data-reveal>
    <h2>The Vibes</h2>
    <p>What happens when 250 strangers pick your date</p>
  </div>
  <div class="photo-grid">
    {
      photos.map((photo) => (
        <div class:list={["photo", { "photo--wide": photo.span }]} data-reveal>
          <img
            src={`/images/${photo.src}`}
            alt={photo.alt}
            width={photo.w}
            height={photo.h}
            loading="lazy"
            style={`object-position: ${photo.pos};`}
          />
          <div class="photo-label">{photo.label}</div>
        </div>
      ))
    }
  </div>
</section>

<script>
  import { trackLeadEvent } from "@/lib/analytics";

  const gallery = document.getElementById("gallery");
  if (gallery) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          trackLeadEvent("gallery_viewed", {
            photo_count: gallery.querySelectorAll(".photo").length,
            page: window.location.pathname,
          });
          observer.disconnect();
        }
      },
      { threshold: 0.3 },
    );
    observer.observe(gallery);
  }
</script>

<style>
  .photos {
    padding: 60px 16px;
    background: var(--charcoal);
  }
  .photos-header {
    max-width: 1200px;
    margin: 0 auto 36px;
  }
  .photos-header h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(32px, 5vw, 60px);
    font-weight: 900;
    color: white;
    line-height: 1;
  }
  .photos-header p {
    color: rgba(255, 255, 255, 0.4);
    font-size: 14px;
    margin-top: 8px;
  }
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 6px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .photo {
    border-radius: 12px;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    position: relative;
    overflow: hidden;
    transition:
      transform 0.35s cubic-bezier(0.34, 1.3, 0.64, 1),
      filter 0.3s;
    aspect-ratio: 1;
    padding: 10px;
  }
  .photo img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .photo:hover {
    transform: scale(1.025);
    filter: brightness(1.08);
  }
  .photo--wide {
    display: none;
  }
  .photo-label {
    position: relative;
    z-index: 1;
    color: white;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(6px);
    padding: 5px 12px;
    border-radius: 50px;
  }

  @media (min-width: 768px) {
    .photos {
      padding: 100px 48px;
    }
    .photos-header {
      margin-bottom: 48px;
    }
    .photo-grid {
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: 300px 220px;
      gap: 10px;
    }
    .photo {
      aspect-ratio: auto;
    }
    .photo--wide {
      display: flex;
      grid-column: span 2;
      grid-row: span 2;
    }
    .photo-label {
      font-size: 11px;
    }
  }
</style>
