---
const photos = [
  { label: 'On Stage', gradient: 'linear-gradient(145deg, var(--hot-pink), var(--spice-orange))', span: true },
  { label: 'The Match', gradient: 'linear-gradient(135deg, var(--electric-yellow), #FF9800)' },
  { label: 'Hosts', gradient: 'linear-gradient(135deg, var(--rich-red), var(--deep-magenta))' },
  { label: 'After Party', gradient: 'linear-gradient(135deg, var(--spice-orange), #FFB300)' },
  { label: 'The Crowd', gradient: 'linear-gradient(135deg, var(--deep-magenta), var(--rich-red))' },
  { label: 'Pure Chaos', gradient: 'linear-gradient(135deg, #1A237E, var(--deep-magenta))' },
  { label: 'Dance Off', gradient: 'linear-gradient(135deg, var(--hot-pink), #FF1744)' },
  { label: 'Magic Moment', gradient: 'linear-gradient(135deg, #FF9800, var(--spice-orange))' },
];
---

<section class="photos" id="gallery" aria-label="Show gallery">
  <div class="photos-header" data-reveal>
    <h2>The Vibes</h2>
    <p>Your photos go here</p>
  </div>
  <div class="photo-grid">
    {photos.map((photo) => (
      <div class:list={['ph', { 'ph-span': photo.span }]} style={`background: ${photo.gradient}`} data-reveal>
        <div class="ph-label">{photo.label}</div>
      </div>
    ))}
  </div>
</section>

<style>
  .photos {
    padding: 80px 20px;
    background: white;
  }
  .photos-header {
    max-width: 1200px;
    margin: 0 auto 36px;
  }
  .photos-header h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(32px, 5vw, 60px);
    font-weight: 900;
    color: var(--charcoal);
    line-height: 1;
  }
  .photos-header p {
    color: #999;
    font-size: 14px;
    margin-top: 8px;
  }
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .ph {
    border-radius: 12px;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    position: relative;
    overflow: hidden;
    transition: transform 0.35s cubic-bezier(0.34, 1.3, 0.64, 1), filter 0.3s;
    aspect-ratio: 1;
    padding: 14px;
  }
  .ph:hover {
    transform: scale(1.025);
    filter: brightness(1.08);
  }
  .ph-span { display: none; }
  .ph-label {
    color: white;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(6px);
    padding: 5px 12px;
    border-radius: 50px;
  }

  @media (min-width: 768px) {
    .photos { padding: 100px 48px; }
    .photos-header { margin-bottom: 48px; }
    .photo-grid {
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: 300px 220px;
      gap: 10px;
    }
    .ph { aspect-ratio: auto; }
    .ph-span {
      display: flex;
      grid-column: span 2;
      grid-row: span 2;
    }
    .ph-label { font-size: 11px; }
  }
</style>
