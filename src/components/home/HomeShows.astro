---
import type { EventEntry } from "@/data/events";
import NotifyModal from "@/components/NotifyModal.astro";
import { buildTicketUrl } from "@/utils/eventUrl";
import { parseMonth, parseDay, formatOnSaleDate } from "@/utils/eventDate";
import { buildTaglineMap } from "@/utils/eventTaglines";
import { formatEventLocation } from "@/utils/eventCity";

interface Props {
  events: EventEntry[];
}

const { events } = Astro.props;
const taglineMap = buildTaglineMap(events);
---

<section class="shows" id="shows" aria-labelledby="shows-heading">
  <div class="shows-header" data-reveal>
    <h2 id="shows-heading">Grab Your Seat</h2>
    <p>Tickets always sell out. You've been warned.</p>
    <p class="shows-proof">
      40+ shows sold out · 2,000+ audience members · 13 couples matched
    </p>
  </div>
  <div class="shows-list" data-reveal-stagger>
    {
      events.map((event) => {
        const isPresale =
          Boolean(event.onSaleAt) && new Date(event.onSaleAt!) > new Date();
        const isLive = Boolean(event.url);
        const isSoldOut = event.soldOut ?? false;
        const hasWidget =
          isLive && Boolean(event.eventbriteId) && !isSoldOut && !isPresale;
        const cityLabel = formatEventLocation(event);
        const onSaleLabel = event.onSaleAt
          ? formatOnSaleDate(event.onSaleAt)
          : "";
        const cardInner = (
          <>
            <div class="show-date-block">
              <div class="month">{parseMonth(event.date)}</div>
              <div class="day">{parseDay(event.date)}</div>
            </div>
            <div class="show-info">
              <h3>{cityLabel}</h3>
              <span>
                {isSoldOut
                  ? (event.tagline ?? "Sold out")
                  : (taglineMap.get(event.url) ?? "On sale now")}
              </span>
            </div>
            <span
              class={`ticket-label${isSoldOut ? " ticket-label--soldout" : ""}`}
            >
              {isSoldOut ? "Sold Out" : "Grab My Spot"}
            </span>
          </>
        );
        return hasWidget ? (
          <button
            type="button"
            id={`eventbrite-widget-modal-trigger-home-shows-${event.eventbriteId}`}
            data-eb-event-id={event.eventbriteId}
            class="show-card show-card--live"
            data-reveal
            data-ph-capture="cta_clicked"
            data-ph-cta="get_tickets"
            data-ph-section="shows"
            data-ph-city={cityLabel}
            data-ph-event-date={event.date}
            data-ph-price={event.price}
            data-eb-url={buildTicketUrl(event.url, "home", "shows")}
            data-city={cityLabel}
          >
            {cardInner}
          </button>
        ) : isPresale ? (
          <>
            <button
              type="button"
              class="show-card show-card--notify"
              data-notify-city={cityLabel}
              data-notify-city-slug={`presale-${event.isoDate}`}
              data-notify-on-sale-at={event.onSaleAt}
              data-presale-notify={event.onSaleAt}
              data-reveal
              data-ph-capture="cta_clicked"
              data-ph-cta="notify_me"
              data-ph-section="shows"
              data-ph-city={cityLabel}
            >
              <div class="show-date-block">
                <div class="month">{parseMonth(event.date)}</div>
                <div class="day">{parseDay(event.date)}</div>
              </div>
              <div class="show-info">
                <h3>{cityLabel}</h3>
                <span>On sale {onSaleLabel}</span>
              </div>
              <span class="ticket-label ticket-label--notify">Notify Me</span>
            </button>
            <a
              href={buildTicketUrl(event.url, "home", "shows")}
              target="_blank"
              rel="noopener noreferrer"
              class="show-card show-card--live"
              data-presale-live
              hidden
              data-ph-capture="cta_clicked"
              data-ph-cta="get_tickets"
              data-ph-section="shows"
              data-ph-city={cityLabel}
              data-ph-event-date={event.date}
              data-ph-price={event.price}
            >
              {cardInner}
            </a>
          </>
        ) : isLive ? (
          <a
            href={buildTicketUrl(event.url, "home", "shows")}
            target="_blank"
            rel="noopener noreferrer"
            class="show-card show-card--live"
            data-reveal
            data-ph-capture="cta_clicked"
            data-ph-cta="get_tickets"
            data-ph-section="shows"
            data-ph-city={cityLabel}
            data-ph-event-date={event.date}
            data-ph-price={event.price}
          >
            {cardInner}
          </a>
        ) : (
          <button
            type="button"
            class="show-card show-card--notify"
            data-notify-city={cityLabel}
            data-notify-city-slug={event.citySlug}
            data-reveal
            data-ph-capture="cta_clicked"
            data-ph-cta="notify_me"
            data-ph-section="shows"
            data-ph-city={cityLabel}
          >
            <div class="show-date-block">
              {parseDay(event.date) !== "" ? (
                <>
                  <div class="month">{parseMonth(event.date)}</div>
                  <div class="day">{parseDay(event.date)}</div>
                </>
              ) : (
                <div class="day day--tba">TBA</div>
              )}
            </div>
            <div class="show-info">
              <h3>{cityLabel}</h3>
              <span>Dates to be announced</span>
            </div>
            <span class="ticket-label ticket-label--notify">Notify Me</span>
          </button>
        );
      })
    }
  </div>
  <div class="request-city" data-reveal>
    <button
      type="button"
      id="request-city-trigger"
      data-ph-capture="cta_clicked"
      data-ph-cta="request_city"
      data-ph-section="shows">Don't see your city? Request it →</button
    >
  </div>

  <NotifyModal />

  <!-- Request City Modal -->
  <dialog id="request-city-modal" class="modal-dialog">
    <div class="modal-inner">
      <button type="button" class="modal-close" aria-label="Close">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          ><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg
        >
      </button>
      <div id="city-form-view">
        <h2 class="modal-title">Request Your City</h2>
        <p class="modal-subtitle">
          Tell us where you want Garam Masala Dating and we'll make it happen.
        </p>
        <form
          id="city-form"
          class="modal-form"
          toolname="request-show-in-my-city"
          tooldescription="Request Garam Masala Dating to bring a live show to your city. Provide city name and email address to join the city interest list."
        >
          <input
            type="text"
            id="city-name"
            placeholder="Your city"
            aria-label="City name"
            autocomplete="off"
            required
            toolparamdescription="Name of the city where you want Garam Masala Dating to perform"
          />
          <input
            type="email"
            id="city-email"
            class="ph-mask"
            placeholder="Your email"
            required
            aria-label="Email address"
            toolparamdescription="Email address to be notified when the show comes to your city"
          />
          <p id="city-form-error" class="modal-error" hidden role="alert"></p>
          <button type="submit" class="modal-submit">Submit Request</button>
        </form>
      </div>
      <div id="city-success" class="modal-success" hidden>
        <p>Request received! We'll keep you posted.</p>
      </div>
    </div>
  </dialog>
</section>

<script>
  import "@/lib/presaleReveal";
</script>

<script>
  import { identifyLead, trackLeadEvent } from "@/lib/analytics";
  import { buildLeadAttribution } from "@/lib/leadAttribution";
  import {
    captureLead,
    type LeadSubmissionPayload,
  } from "@/lib/leadSubmission";

  // Request City modal
  const cityDialog = document.getElementById(
    "request-city-modal",
  ) as HTMLDialogElement;
  if (cityDialog) {
    const cityInput = document.getElementById(
      "city-name",
    ) as HTMLInputElement | null;
    const errorEl = document.getElementById("city-form-error");

    document
      .getElementById("request-city-trigger")
      ?.addEventListener("click", () => {
        // Reset to form state before opening
        document.getElementById("city-form-view")?.removeAttribute("hidden");
        document.getElementById("city-success")?.setAttribute("hidden", "");
        const emailInput = document.getElementById(
          "city-email",
        ) as HTMLInputElement;
        if (cityInput) cityInput.value = "";
        if (emailInput) emailInput.value = "";
        if (errorEl) {
          errorEl.textContent = "";
          errorEl.setAttribute("hidden", "");
        }
        trackLeadEvent("request_city_opened", {
          source: "request-city",
          sourcePage: window.location.pathname,
        });
        cityDialog.showModal();
      });

    let isClosing = false;
    const closeCityDialog = () => {
      if (isClosing) return;
      const inner = cityDialog.querySelector(
        ".modal-inner",
      ) as HTMLElement | null;
      const reduced = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;
      if (!inner || reduced) {
        cityDialog.close();
        return;
      }
      isClosing = true;
      cityDialog.classList.add("closing");
      inner.addEventListener(
        "animationend",
        () => {
          cityDialog.classList.remove("closing");
          isClosing = false;
          cityDialog.close();
        },
        { once: true },
      );
    };

    cityDialog
      .querySelector(".modal-close")
      ?.addEventListener("click", closeCityDialog);
    cityDialog.addEventListener("click", (e) => {
      if (e.target === cityDialog) closeCityDialog();
    });
    cityDialog.addEventListener("cancel", (e) => {
      e.preventDefault();
      closeCityDialog();
    });

    document
      .getElementById("city-form")
      ?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const submitBtn = (
          e.target as HTMLFormElement
        ).querySelector<HTMLButtonElement>('[type="submit"]');
        const originalBtnText = submitBtn?.textContent ?? "";
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = "Submitting...";
        }
        try {
          const city = (cityInput?.value ?? "").trim();
          const email = (
            document.getElementById("city-email") as HTMLInputElement
          ).value;
          const attribution = await buildLeadAttribution({
            source: "request-city",
          });
          const payload: LeadSubmissionPayload = {
            email,
            ...attribution,
          };
          if (city) payload.city = city;
          await captureLead(payload);
          const cityProp = city ? { city } : {};
          identifyLead(email, { ...attribution, ...cityProp });
          trackLeadEvent("lead_email_submitted", {
            ...attribution,
            ...cityProp,
          });
          trackLeadEvent("email_signup", { ...attribution, ...cityProp });
          trackLeadEvent("waitlist_submit", { ...attribution, ...cityProp });
          document.getElementById("city-form-view")?.setAttribute("hidden", "");
          document.getElementById("city-success")?.removeAttribute("hidden");
        } catch {
          if (errorEl) {
            errorEl.textContent = "Something went wrong. Please try again.";
            errorEl.removeAttribute("hidden");
          }
        } finally {
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = originalBtnText;
          }
        }
      });
  }
</script>

<style>
  .shows {
    padding: 64px 16px;
    background: var(--ink);
    position: relative;
  }
  .shows-header {
    max-width: 1200px;
    margin: 0 auto 48px;
  }
  .shows-header h2 {
    font-family: var(--font-display), sans-serif;
    font-size: clamp(40px, 7vw, 80px);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: white;
    line-height: 0.9;
  }
  .shows-header p {
    font-family: var(--font-serif), serif;
    font-style: italic;
    color: rgba(255, 255, 255, 0.6);
    font-size: 18px;
    margin-top: 12px;
  }
  .shows-proof {
    font-family: var(--font-body), sans-serif;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-style: normal;
    color: var(--gold);
    margin-top: 12px;
  }
  .shows-list {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
  }
  .show-card {
    background: none;
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    padding: 24px 0;
    display: grid;
    grid-template-columns: 48px 1fr auto;
    gap: 16px;
    align-items: center;
    transition:
      background 0.25s ease,
      transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
    text-decoration: none;
    cursor: pointer;
    color: white;
    width: 100%;
    font: inherit;
    text-align: left;
  }
  .show-card[hidden] {
    display: none;
  }
  .show-card:last-child {
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  }
  .show-card:hover,
  .show-card:focus-within {
    background: rgba(255, 255, 255, 0.04);
  }
  .show-card:hover .ticket-label,
  .show-card:focus-within .ticket-label {
    letter-spacing: 2.5px;
    color: white;
  }
  @media (prefers-reduced-motion: no-preference) {
    .show-card:hover,
    .show-card:focus-within {
      transform: translateX(4px);
    }
  }
  .show-date-block {
    text-align: center;
  }
  .show-date-block .month {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--electric-yellow);
  }
  .show-date-block .day {
    font-family: var(--font-display), sans-serif;
    font-size: 36px;
    font-weight: 400;
    line-height: 1;
    color: white;
    letter-spacing: -0.01em;
  }
  .show-date-block .day--tba {
    font-size: 20px;
    font-family: var(--font-body), sans-serif;
    font-weight: 900;
    color: var(--electric-yellow);
    letter-spacing: 3px;
  }
  .show-info h3 {
    font-family: var(--font-body), sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: white;
    margin-bottom: 2px;
  }
  .show-info span {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.55);
  }
  .ticket-label {
    background: none;
    color: var(--electric-yellow);
    border: none;
    padding: 0;
    font-family: var(--font-body), sans-serif;
    font-weight: 700;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    text-align: right;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    pointer-events: none;
    transition:
      letter-spacing 0.25s ease,
      color 0.25s ease;
  }
  .ticket-label--notify {
    color: rgba(255, 255, 255, 0.45);
  }
  .ticket-label--soldout {
    color: rgba(255, 255, 255, 0.35);
  }
  .request-city {
    text-align: center;
    margin-top: 36px;
  }
  .request-city button {
    color: var(--electric-yellow);
    font-weight: bold;
    font-size: 22px;
    background: none;
    border: none;
    min-height: var(--touch-target);
    border-bottom: 1px solid rgba(255, 214, 0, 0.4);
    font-family: var(--font-cormorant), serif;
    font-style: italic;
    transition: border-color 0.2s;
    padding: 0;
    cursor: pointer;
  }
  .request-city button:hover {
    border-color: var(--electric-yellow);
  }

  @media (min-width: 768px) {
    .shows {
      padding: 75px 36px;
    }
    .shows-header {
      margin-bottom: 56px;
    }
    .show-card {
      grid-template-columns: 80px 1fr auto;
      padding: 28px 0;
    }
    .show-date-block .day {
      font-size: 48px;
    }
    .show-date-block .day--tba {
      font-size: 20px;
    }
    .show-info h3 {
      font-size: 24px;
      margin-bottom: 4px;
    }
    .ticket-label {
      font-size: 13px;
    }
  }

  /* ─── Request City Modal ─────────────────────────────────────── */
  .modal-dialog {
    border: none;
    background: transparent;
    padding: 24px;
    max-width: 100%;
    max-height: 100vh;
    width: 100%;
    height: 100%;
    overflow: visible;
  }
  .modal-dialog::backdrop {
    background: rgba(0, 0, 0, 0.5);
  }
  .modal-dialog[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .modal-inner {
    width: 100%;
    max-width: 400px;
    max-height: 80vh;
    overflow-y: auto;
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 20px;
    padding: 24px;
    position: relative;
    animation: modalIn 0.25s ease-out both;
    text-align: center;
  }
  @keyframes modalIn {
    from {
      opacity: 0;
      transform: scale(0.95) translateY(8px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }
  .modal-dialog.closing .modal-inner {
    animation: dialog-out 0.2s ease-in forwards;
  }
  .modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    padding: 12px;
    min-width: var(--touch-target);
    min-height: var(--touch-target);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
  }
  .modal-close:hover {
    color: var(--charcoal);
  }
  .modal-close:focus-visible {
    outline: 2px solid var(--brand-red);
    outline-offset: 2px;
    color: var(--charcoal);
  }
  .modal-title {
    font-family: var(--font-display), sans-serif;
    font-size: 22px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--charcoal);
    margin-bottom: 8px;
  }
  .modal-subtitle {
    font-size: 15px;
    color: var(--muted);
    margin-bottom: 24px;
    line-height: 1.5;
  }
  .modal-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .modal-form input {
    padding: 14px 20px;
    border: 1.5px solid rgba(0, 0, 0, 0.1);
    border-radius: 4px;
    font-size: 16px;
    font-family: var(--font-body), sans-serif;
    outline: none;
    transition: border-color 0.2s;
    min-height: var(--touch-target);
  }
  .modal-form input:focus-visible {
    border-color: var(--brand-red);
    outline: 2px solid var(--brand-red);
    outline-offset: -2px;
  }
  .modal-submit {
    background: var(--brand-red);
    color: white;
    border: none;
    padding: 14px;
    border-radius: 4px;
    font-family: var(--font-body), sans-serif;
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition:
      background 0.2s,
      transform 0.06s;
    min-height: var(--touch-target);
    width: 100%;
  }
  .modal-submit:hover {
    background: var(--brand-red-dark);
  }
  .modal-submit:active {
    transform: scale(0.97);
  }
  .modal-success {
    text-align: center;
    padding: 24px 0;
  }
  .modal-success p {
    font-family: var(--font-cormorant), serif;
    font-size: 18px;
    font-style: italic;
    color: var(--charcoal);
  }
</style>
