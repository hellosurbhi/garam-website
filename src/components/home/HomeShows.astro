---
import type { EventEntry } from '@/data/events';
import NotifyModal from '@/components/NotifyModal.astro';

interface Props {
  events: EventEntry[];
}

const { events } = Astro.props;

function parseMonth(dateStr: string): string {
  return dateStr.split(' ')[0];
}

function parseDay(dateStr: string): string {
  const parts = dateStr.split(' ');
  const day = parts[1] ?? '—';
  return /^\d{1,2}$/.test(day) ? day : '—';
}
---

<section class="shows" id="shows" aria-labelledby="shows-heading">
  <div class="shows-header" data-reveal>
    <div>
      <h2 id="shows-heading">Grab Your Seat</h2>
      <p>Tickets always sell out. You've been warned.</p>
    </div>
  </div>
  <div class="shows-list">
    {events.map((event) => {
      const isLive = Boolean(event.url);
      return isLive ? (
        <a href={event.url} target="_blank" rel="noopener noreferrer" class="show-card show-card--live" data-reveal>
          <div class="show-date-block">
            <div class="mo">{parseMonth(event.date)}</div>
            <div class="dy">{parseDay(event.date)}</div>
          </div>
          <div class="show-info">
            <h3>{event.city}</h3>
            <span>{event.tagline ?? 'On sale now'}</span>
          </div>
          <span class="ticket-label">Get Tickets</span>
        </a>
      ) : (
        <div class="show-card show-card--notify" role="button" tabindex="0" data-notify-city={event.city} data-reveal>
          <div class="show-date-block">
            {parseDay(event.date) !== '—' ? (
              <><div class="mo">{parseMonth(event.date)}</div><div class="dy">{parseDay(event.date)}</div></>
            ) : (
              <div class="dy dy--tba">TBA</div>
            )}
          </div>
          <div class="show-info">
            <h3>{event.city}</h3>
            <span>Dates to be announced</span>
          </div>
          <span class="ticket-label ticket-label--notify">Notify Me</span>
        </div>
      );
    })}
  </div>
  <div class="request-city" data-reveal>
    <button type="button" id="request-city-trigger">Don't see your city? Request it →</button>
  </div>

  <NotifyModal />

  <!-- Request City Modal -->
  <dialog id="request-city-modal" class="modal-dialog">
    <div class="modal-inner">
      <button type="button" class="modal-close" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
      <div id="city-form-view">
        <h2 class="modal-title">Request Your City</h2>
        <p class="modal-subtitle">Tell us where you want Garam Masala Dating and we'll make it happen.</p>
        <form id="city-form" class="modal-form">
          <input type="text" id="city-name" placeholder="e.g., Austin, TX" required aria-label="City name" />
          <input type="email" id="city-email" placeholder="Your email" required aria-label="Email address" />
          <button type="submit" class="modal-submit">Submit Request</button>
        </form>
      </div>
      <div id="city-success" class="modal-success" hidden>
        <p>Request received! We'll keep you posted.</p>
      </div>
    </div>
  </dialog>
</section>

<script>
  import { getFirebaseDb } from '@/lib/firebase';
  import { collection, addDoc } from 'firebase/firestore';

  // Request City modal
  const cityDialog = document.getElementById('request-city-modal') as HTMLDialogElement;
  if (cityDialog) {
    document.getElementById('request-city-trigger')?.addEventListener('click', () => {
      cityDialog.showModal();
    });

    cityDialog.querySelector('.modal-close')?.addEventListener('click', () => cityDialog.close());
    cityDialog.addEventListener('click', (e) => {
      if (e.target === cityDialog) cityDialog.close();
    });

    document.getElementById('city-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const city = (document.getElementById('city-name') as HTMLInputElement).value;
      const email = (document.getElementById('city-email') as HTMLInputElement).value;
      try {
        const db = getFirebaseDb();
        await addDoc(collection(db, 'city_requests'), {
          city,
          email,
          createdAt: new Date().toISOString(),
        });
      } catch { /* fail silently */ }
      document.getElementById('city-form-view')?.setAttribute('hidden', '');
      document.getElementById('city-success')?.removeAttribute('hidden');
    });
  }
</script>

<style>
  .shows {
    padding: 60px 16px;
    background: var(--brand-red);
    position: relative;
  }
  .shows::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 5px;
    background: repeating-linear-gradient(90deg, var(--electric-yellow) 0, var(--electric-yellow) 20px, var(--brand-red) 20px, var(--brand-red) 40px);
  }
  .shows-header {
    max-width: 1200px;
    margin: 0 auto 40px;
  }
  .shows-header h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(32px, 5vw, 60px);
    font-weight: 900;
    color: white;
    line-height: 1;
  }
  .shows-header p {
    color: rgba(255, 255, 255, 0.7);
    font-size: 18px;
    margin-top: 8px;
  }
  .shows-list {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .show-card {
    background: white;
    border-radius: 16px;
    padding: 20px;
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 16px;
    align-items: center;
    transition: transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
    cursor: pointer;
    color: inherit;
  }
  .show-card:hover {
    transform: translateX(6px);
    box-shadow: -6px 0 0 var(--electric-yellow);
  }
  .show-date-block { text-align: center; }
  .show-date-block .mo {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--brand-red);
  }
  .show-date-block .dy {
    font-family: var(--font-playfair), serif;
    font-size: 36px;
    font-weight: 900;
    line-height: 1;
    color: var(--charcoal);
  }
  .show-date-block .dy--tba {
    font-size: 20px;
    font-family: var(--font-body), sans-serif;
    font-weight: 900;
    color: var(--brand-red);
    letter-spacing: 3px;
  }
  .show-info h3 {
    font-family: var(--font-playfair), serif;
    font-size: 18px;
    font-weight: 700;
    color: var(--charcoal);
    margin-bottom: 2px;
  }
  .show-info span {
    font-size: 13px;
    color: var(--muted);
  }
  .ticket-label {
    background: var(--brand-red);
    color: white;
    border: none;
    padding: 12px 24px;
    border-radius: 50px;
    font-family: var(--font-body), sans-serif;
    font-weight: 700;
    font-size: 16px;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: background 0.2s;
    text-align: center;
    min-height: 48px;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    grid-column: 1 / -1;
    pointer-events: none;
  }
  .show-card--live:hover .ticket-label { background: var(--brand-red-dark); }
  .ticket-label--notify {
    background: var(--electric-yellow);
    color: var(--charcoal);
  }
  .show-card--notify:hover .ticket-label--notify { background: var(--electric-yellow); }
  .request-city {
    text-align: center;
    margin-top: 36px;
  }
  .request-city button {
    color: var(--electric-yellow);
    font-weight: bold;
    font-size: 22px;
    background: none;
    border: none;
    min-height: 48px;
    border-bottom: 1px solid rgba(255, 214, 0, 0.4);
    font-family: var(--font-cormorant), serif;
    font-style: italic;
    transition: border-color 0.2s;
    padding: 0;
  }
  .request-city button:hover { border-color: var(--electric-yellow); }


  @media (min-width: 768px) {
    .shows { padding: 80px 36px; }
    .shows-header { margin-bottom: 56px; }
    .show-card {
      grid-template-columns: 80px 1fr auto;
      padding: 24px 32px;
    }
    .show-date-block .dy { font-size: 42px; }
    .show-date-block .dy--tba { font-size: 20px; }
    .show-info h3 { font-size: 22px; margin-bottom: 4px; }
    .ticket-label {
      padding: 12px 28px;
      grid-column: auto;
    }
  }

  /* ─── Request City Modal ─────────────────────────────────────── */
  .modal-dialog {
    border: none;
    background: transparent;
    padding: 24px;
    max-width: 100%;
    max-height: 100vh;
    width: 100%;
    height: 100%;
    overflow: visible;
  }
  .modal-dialog::backdrop { background: rgba(0, 0, 0, 0.5); }
  .modal-dialog[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .modal-inner {
    width: 100%;
    max-width: 400px;
    max-height: 80vh;
    overflow-y: auto;
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 20px;
    padding: 32px 24px;
    position: relative;
    animation: modalIn 0.25s ease-out both;
    text-align: center;
  }
  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.95) translateY(8px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }
  .modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
  }
  .modal-close:hover { color: var(--charcoal); }
  .modal-title {
    font-family: var(--font-playfair), serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--charcoal);
    margin-bottom: 8px;
  }
  .modal-subtitle {
    font-size: 15px;
    color: var(--muted);
    margin-bottom: 24px;
    line-height: 1.5;
  }
  .modal-form { display: flex; flex-direction: column; gap: 12px; }
  .modal-form input {
    padding: 14px 20px;
    border: 1.5px solid rgba(0, 0, 0, 0.1);
    border-radius: 50px;
    font-size: 16px;
    font-family: var(--font-body), sans-serif;
    outline: none;
    transition: border-color 0.2s;
    min-height: 48px;
  }
  .modal-form input:focus { border-color: var(--brand-red); }
  .modal-submit {
    background: var(--brand-red);
    color: white;
    border: none;
    padding: 14px;
    border-radius: 50px;
    font-family: var(--font-body), sans-serif;
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: background 0.2s;
    min-height: 48px;
    width: 100%;
  }
  .modal-submit:hover { background: var(--brand-red-dark); }
  .modal-success { text-align: center; padding: 24px 0; }
  .modal-success p {
    font-family: var(--font-cormorant), serif;
    font-size: 18px;
    font-style: italic;
    color: var(--charcoal);
  }
</style>
