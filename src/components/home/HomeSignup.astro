---

---

<section class="spicelist" aria-labelledby="spicelist-heading">
  <h2 id="spicelist-heading" data-reveal>Join the Spice List</h2>
  <p data-reveal>Get exclusive discount codes for cheaper (and sometimes free) tickets.</p>

  <div id="nl-step-1" data-reveal>
    <form id="nl-email-form" class="spicelist-form">
      <input type="email" id="nl-email" placeholder="Your email" required aria-label="Email address" />
      <button type="submit">Get My Discount Code</button>
    </form>
    <p class="spicelist-trust">Just discount codes and show announcements.</p>
  </div>

  <div id="nl-step-2" hidden data-reveal>
    <p class="nl-step2-text">Add your number for text-only discounts and free ticket drops.</p>
    <form id="nl-phone-form" class="spicelist-form">
      <input type="tel" id="nl-phone" placeholder="Your phone number" aria-label="Phone number" />
      <button type="submit">Send Me Deals</button>
    </form>
    <button type="button" id="nl-skip" class="spicelist-skip">Maybe later</button>
  </div>

  <div id="nl-success" hidden data-reveal>
    <p class="nl-done-text">You're on the list!</p>
  </div>
</section>

<script>
  import { getFirebaseDb } from '@/lib/firebase';
  import { collection, addDoc } from 'firebase/firestore';

  let savedEmail = '';

  document.getElementById('nl-email-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    savedEmail = (document.getElementById('nl-email') as HTMLInputElement).value;
    try {
      const db = getFirebaseDb();
      await addDoc(collection(db, 'subscribers'), {
        email: savedEmail,
        source: 'spice-list',
        createdAt: new Date().toISOString(),
      });
    } catch { /* fail silently */ }
    document.getElementById('nl-step-1')?.setAttribute('hidden', '');
    document.getElementById('nl-step-2')?.removeAttribute('hidden');
  });

  document.getElementById('nl-phone-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const phone = (document.getElementById('nl-phone') as HTMLInputElement).value;
    if (phone) {
      try {
        const db = getFirebaseDb();
        await addDoc(collection(db, 'subscribers'), {
          email: savedEmail,
          phone,
          source: 'spice-list-phone',
          createdAt: new Date().toISOString(),
        });
      } catch { /* fail silently */ }
    }
    document.getElementById('nl-step-2')?.setAttribute('hidden', '');
    document.getElementById('nl-success')?.removeAttribute('hidden');
  });

  document.getElementById('nl-skip')?.addEventListener('click', () => {
    document.getElementById('nl-step-2')?.setAttribute('hidden', '');
    document.getElementById('nl-success')?.removeAttribute('hidden');
  });
</script>

<style>
  .spicelist {
    padding: 56px 20px;
    background: var(--hot-pink);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .spicelist h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(30px, 5vw, 60px);
    font-weight: 900;
    color: white;
    margin-bottom: 12px;
    position: relative;
  }
  .spicelist p {
    color: rgba(255, 255, 255, 0.85);
    font-size: 16px;
    margin-bottom: 36px;
    font-family: var(--font-cormorant), serif;
    font-style: italic;
    position: relative;
  }
  .spicelist-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 420px;
    margin: 0 auto;
    position: relative;
  }
  .spicelist-form input {
    padding: 16px 24px;
    border: 1.5px solid rgba(255, 255, 255, 0.4);
    border-radius: 50px;
    background: rgba(255, 255, 255, 0.15);
    color: white;
    font-size: 16px;
    font-family: var(--font-body), sans-serif;
    outline: none;
    transition: border-color 0.2s;
    min-height: 48px;
  }
  .spicelist-form input::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }
  .spicelist-form input:focus {
    border-color: var(--electric-yellow);
  }
  .spicelist-form button {
    background: var(--electric-yellow);
    color: var(--charcoal);
    border: none;
    padding: 16px;
    border-radius: 50px;
    font-family: var(--font-body), sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    transition: background 0.2s, color 0.2s;
    min-height: 48px;
  }
  .spicelist-form button:hover {
    background: white;
    color: var(--hot-pink);
  }
  .spicelist-trust {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 0;
    margin-top: 16px;
    font-style: normal;
    font-family: var(--font-body), sans-serif;
  }

  .nl-step2-text {
    color: rgba(255, 255, 255, 0.85);
    font-size: 16px;
    margin-bottom: 20px;
    font-family: var(--font-cormorant), serif;
    font-style: italic;
  }
  .spicelist-skip {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.5);
    font-size: 14px;
    font-family: var(--font-body), sans-serif;
    margin-top: 12px;
    transition: color 0.2s;
    padding: 4px;
  }
  .spicelist-skip:hover { color: white; }
  .nl-done-text {
    color: white;
    font-family: var(--font-cormorant), serif;
    font-size: 22px;
    font-style: italic;
  }

  @media (min-width: 768px) {
    .spicelist { padding: 80px 48px; }
    .spicelist p { font-size: 17px; margin-bottom: 48px; }
    .spicelist-form input { padding: 18px 28px; }
    .spicelist-form button { padding: 18px; }
  }
</style>
