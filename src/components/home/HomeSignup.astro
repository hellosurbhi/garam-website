---
// Derive a readable page name from the current URL so every Spice List
// submission is attributed to the page it came from (e.g. "home", "apply",
// "cities-nyc"). The Spice List is rendered by BaseLayout on every page, so
// this is the single source of truth for that attribution.
const rawPath = Astro.url.pathname.replace(/^\/+|\/+$/g, "");
const pageName = rawPath === "" ? "home" : rawPath.replace(/\//g, "-");
const leadSource = `spice-list-${pageName}`;
---

<section
  class="spicelist"
  aria-labelledby="spicelist-heading"
  data-lead-source={leadSource}
>
  <h2 id="spicelist-heading" data-reveal>Join the Spice List</h2>
  <p data-reveal>
    Get exclusive discount codes for cheaper (and sometimes free) tickets.
  </p>

  <!-- min-height prevents CLS when switching between steps -->
  <div class="nl-steps-wrapper" data-reveal>
    <div id="nl-step-1">
      <form
        id="nl-email-form"
        class="spicelist-form"
        toolname="subscribe-to-spice-list"
        tooldescription="Subscribe to the Garam Masala Dating Spice List for exclusive discount codes and free ticket drops. Provide an email address."
      >
        <input
          type="email"
          id="nl-email"
          class="ph-mask"
          placeholder="Your email"
          required
          aria-label="Email address"
          toolparamdescription="Email address to receive discount codes and show announcements"
        />
        <p id="nl-email-error" class="spicelist-error" hidden role="alert"></p>
        <button type="submit">Get My Discount Code</button>
      </form>
      <p class="spicelist-trust">Just discount codes and show announcements.</p>
    </div>

    <div id="nl-step-2" hidden aria-live="polite">
      <p class="nl-step2-text">
        Add your number for text-only discounts and free ticket drops.
      </p>
      <form
        id="nl-phone-form"
        class="spicelist-form"
        toolname="add-phone-to-spice-list"
        tooldescription="Add a mobile phone number to the Spice List subscription for SMS-only ticket drops and deals."
      >
        <input
          type="tel"
          id="nl-phone"
          class="ph-mask"
          placeholder="(555) 123-4567"
          aria-label="Phone number"
          toolparamdescription="Mobile phone number for SMS-only deals (optional, can be skipped)"
        />
        <p id="nl-phone-error" class="spicelist-error" hidden role="alert"></p>
        <button type="submit">Send Me Deals</button>
      </form>
      <button type="button" id="nl-skip" class="spicelist-skip"
        >Maybe later</button
      >
    </div>

    <div id="nl-success" hidden role="status" aria-live="polite">
      <p class="nl-done-text">You're on the list!</p>
    </div>
  </div>
</section>

<script>
  import { getFirebaseDb } from "@/lib/firebase";
  import {
    collection,
    addDoc,
    updateDoc,
    type DocumentReference,
  } from "firebase/firestore";
  import { cleanPhone } from "@/lib/phone";
  import { identifyLead, trackLeadEvent } from "@/lib/analytics";
  import { buildLeadAttribution } from "@/lib/leadAttribution";

  let savedEmail = "";
  let nlDocRef: DocumentReference | null = null;

  // Per-page source set by the Astro frontmatter (e.g. "spice-list-home",
  // "spice-list-apply"). Falls back to the bare component name only if the
  // data attribute is missing, which should never happen in practice.
  const leadSource =
    document.querySelector<HTMLElement>(".spicelist[data-lead-source]")?.dataset
      .leadSource ?? "spice-list";

  document
    .getElementById("nl-email-form")
    ?.addEventListener("submit", async (e) => {
      e.preventDefault();
      savedEmail = (document.getElementById("nl-email") as HTMLInputElement)
        .value;
      const errorEl = document.getElementById("nl-email-error");
      const submitBtn = (
        e.target as HTMLFormElement
      ).querySelector<HTMLButtonElement>('[type="submit"]');
      const originalBtnText = submitBtn?.textContent ?? "";
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = "Sending...";
      }
      try {
        const db = getFirebaseDb();
        const attribution = buildLeadAttribution({ source: leadSource });
        nlDocRef = await addDoc(collection(db, "leads"), {
          email: savedEmail,
          ...attribution,
          createdAt: new Date().toISOString(),
        });
        localStorage.setItem("gmd-popup-subscribed", "true");
        identifyLead(savedEmail, attribution);
        trackLeadEvent("lead_email_submitted", attribution);
        if (errorEl) {
          errorEl.textContent = "";
          errorEl.setAttribute("hidden", "");
        }
        document.getElementById("nl-step-1")?.setAttribute("hidden", "");
        document.getElementById("nl-step-2")?.removeAttribute("hidden");
      } catch (err) {
        if (errorEl) {
          errorEl.textContent = "Something went wrong. Please try again.";
          errorEl.removeAttribute("hidden");
        }
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = originalBtnText;
        }
      }
    });

  document
    .getElementById("nl-phone-form")
    ?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const raw = (document.getElementById("nl-phone") as HTMLInputElement)
        .value;
      const cleaned = cleanPhone(raw);
      const phoneErrorEl = document.getElementById("nl-phone-error");

      if (!raw.trim()) {
        // Empty — treat as skip
        document.getElementById("nl-step-2")?.setAttribute("hidden", "");
        const successEl = document.getElementById("nl-success");
        const doneText = successEl?.querySelector(".nl-done-text");
        if (doneText)
          doneText.textContent =
            "You're on the list! Check your email for discount codes.";
        successEl?.removeAttribute("hidden");
        return;
      }

      if (!cleaned) {
        if (phoneErrorEl) {
          phoneErrorEl.textContent = "Please enter a valid phone number.";
          phoneErrorEl.removeAttribute("hidden");
        }
        return;
      }

      const submitBtn = (
        e.target as HTMLFormElement
      ).querySelector<HTMLButtonElement>('[type="submit"]');
      const originalBtnText = submitBtn?.textContent ?? "";
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = "Sending...";
      }
      try {
        const db = getFirebaseDb();
        if (nlDocRef) {
          await updateDoc(nlDocRef, { phone: cleaned });
        } else {
          const attribution = buildLeadAttribution({ source: leadSource });
          await addDoc(collection(db, "leads"), {
            email: savedEmail,
            phone: cleaned,
            ...attribution,
            createdAt: new Date().toISOString(),
          });
        }
        trackLeadEvent("lead_phone_submitted", {
          source: leadSource,
          sourcePage: window.location.pathname,
        });
        document.getElementById("nl-step-2")?.setAttribute("hidden", "");
        const successEl = document.getElementById("nl-success");
        const doneText = successEl?.querySelector(".nl-done-text");
        if (doneText)
          doneText.textContent =
            "You're on the list! We'll text you exclusive ticket drops.";
        successEl?.removeAttribute("hidden");
      } catch (err) {
        if (phoneErrorEl) {
          phoneErrorEl.textContent =
            "Something went wrong. Please try again or skip.";
          phoneErrorEl.removeAttribute("hidden");
        }
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = originalBtnText;
        }
      }
    });

  document.getElementById("nl-skip")?.addEventListener("click", () => {
    document.getElementById("nl-step-2")?.setAttribute("hidden", "");
    const successEl = document.getElementById("nl-success");
    const doneText = successEl?.querySelector(".nl-done-text");
    if (doneText)
      doneText.textContent =
        "You're on the list! Check your email for discount codes.";
    successEl?.removeAttribute("hidden");
  });
</script>

<style>
  .spicelist {
    padding: 24px 16px 24px;
    background: var(--brand-red);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .spicelist h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(30px, 5vw, 60px);
    font-weight: 900;
    color: white;
    margin-bottom: 12px;
    position: relative;
  }
  .spicelist p {
    color: rgba(255, 255, 255, 0.85);
    font-size: 21px;
    margin-bottom: 20px;
    font-family: var(--font-cormorant), serif;
    font-style: italic;
    position: relative;
  }
  /* Prevent CLS when switching between steps */
  .nl-steps-wrapper {
    min-height: 160px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .spicelist-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 420px;
    margin: 0 auto;
    position: relative;
  }
  .spicelist-form input {
    padding: 16px 24px;
    border: 1.5px solid rgba(255, 255, 255, 0.4);
    border-radius: 50px;
    background: rgba(255, 255, 255, 0.15);
    color: white;
    font-size: 16px;
    font-family: var(--font-body), sans-serif;
    outline: none;
    transition: border-color 0.2s;
    min-height: var(--touch-target);
  }
  .spicelist-form input::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }
  .spicelist-form input:focus {
    border-color: var(--electric-yellow);
  }
  .spicelist-form button {
    background: var(--electric-yellow);
    color: var(--charcoal);
    border: none;
    padding: 16px;
    border-radius: 50px;
    font-family: var(--font-body), sans-serif;
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    cursor: pointer;
    transition:
      background 0.2s,
      color 0.2s;
    min-height: var(--touch-target);
    white-space: nowrap;
  }
  .spicelist-form button:hover {
    background: white;
    color: var(--charcoal);
  }
  .spicelist-form button:focus-visible {
    outline: 2px solid white;
    outline-offset: 2px;
  }
  .spicelist-error {
    font-size: 13px;
    color: var(--electric-yellow);
    text-align: center;
    margin: 0;
    font-family: var(--font-body), sans-serif;
    font-style: normal;
  }
  .spicelist-trust {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 0;
    margin-top: 16px;
    font-style: normal;
    font-family: var(--font-body), sans-serif;
  }

  .nl-step2-text {
    color: rgba(255, 255, 255, 0.85);
    font-size: 16px;
    margin-bottom: 20px;
    font-family: var(--font-cormorant), serif;
    font-style: italic;
  }
  .spicelist-skip {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.5);
    font-size: 16px;
    font-family: var(--font-body), sans-serif;
    margin-top: 12px;
    transition: color 0.2s;
    padding: 12px 16px;
    min-height: var(--touch-target);
    cursor: pointer;
  }
  .spicelist-skip:hover,
  .spicelist-skip:focus-visible {
    color: white;
  }
  @keyframes spiceSuccess {
    0% {
      opacity: 0;
      transform: scale(0.95) translateY(6px);
    }
    70% {
      transform: scale(1.03) translateY(0);
    }
    100% {
      opacity: 1;
      transform: scale(1);
    }
  }
  .nl-done-text {
    color: white;
    font-family: var(--font-cormorant), serif;
    font-size: 22px;
    font-style: italic;
    animation: spiceSuccess 0.45s ease-out both;
  }

  @media (min-width: 768px) {
    .spicelist {
      padding: 40px 32px 36px;
    }
    .spicelist p {
      font-size: 22px;
      margin-bottom: 28px;
    }
    .spicelist-form input {
      padding: 18px 28px;
    }
    .spicelist-form button {
      padding: 18px;
    }
  }
</style>
