---
// Derive a readable page name from the current URL so every Spice List
// submission is attributed to the page it came from (e.g. "home", "apply",
// "cities-nyc"). The Spice List is rendered by BaseLayout on every page, so
// this is the single source of truth for that attribution.
const rawPath = Astro.url.pathname.replace(/^\/+|\/+$/g, "");
const pageName = rawPath === "" ? "home" : rawPath.replace(/\//g, "-");
const leadSource = `spice-list-${pageName}`;
---

<section
  class="spicelist"
  aria-labelledby="spicelist-heading"
  data-lead-source={leadSource}
>
  <h2 id="spicelist-heading" data-reveal>Join the Spice List</h2>

  <!-- min-height prevents CLS when switching between steps -->
  <div class="nl-steps-wrapper" data-reveal>
    <div id="nl-already-subscribed" class="nl-alt-cta" hidden>
      <p>You're already on the list!</p>
      <a href="/apply" class="spicelist-alt-btn">Apply to Be on Stage!</a>
    </div>
    <div id="nl-step-1">
      <p>
        Get exclusive discount codes for cheaper (and sometimes free) tickets.
      </p>
      <form
        id="nl-email-form"
        class="spicelist-form"
        toolname="subscribe-to-spice-list"
        tooldescription="Subscribe to the Garam Masala Dating Spice List for exclusive discount codes and free ticket drops. Provide an email address."
      >
        <input
          type="email"
          id="nl-email"
          class="ph-mask"
          data-testid="signup-email-input"
          placeholder="Your email"
          required
          aria-label="Email address"
          toolparamdescription="Email address to receive discount codes and show announcements"
        />
        <input
          type="text"
          id="nl-city"
          class="ph-mask"
          placeholder="Your city (optional)"
          aria-label="City (optional)"
          autocomplete="address-level2"
          toolparamdescription="City the subscriber lives in, used to alert them when a show comes near them (optional)"
        />
        <p id="nl-email-error" class="spicelist-error" hidden role="alert"></p>
        <button type="submit" data-testid="signup-submit"
          >Get My Discount Code!</button
        >
      </form>
      <p class="spicelist-trust">Just discount codes and show announcements.</p>
    </div>

    <div id="nl-step-2" hidden aria-live="polite">
      <p class="nl-step2-text">
        Add your number for text-only discounts and free ticket drops.
      </p>
      <form
        id="nl-phone-form"
        class="spicelist-form"
        toolname="add-phone-to-spice-list"
        tooldescription="Add a mobile phone number to the Spice List subscription for SMS-only ticket drops and deals."
      >
        <input
          type="tel"
          id="nl-phone"
          class="ph-mask"
          placeholder="(555) 123-4567"
          aria-label="Phone number"
          toolparamdescription="Mobile phone number for SMS-only deals (optional, can be skipped)"
        />
        <p id="nl-phone-error" class="spicelist-error" hidden role="alert"></p>
        <button type="submit">Send Me Deals!</button>
      </form>
      <button type="button" id="nl-skip" class="spicelist-skip"
        >Maybe later</button
      >
    </div>

    <div
      id="nl-success"
      data-testid="signup-success"
      hidden
      role="status"
      aria-live="polite"
    >
      <p class="nl-done-text">You're on the list!</p>
    </div>
  </div>
</section>

<script>
  import { initHomeSignup } from "@/lib/homeSignupInit";
  initHomeSignup();
</script>


<style>
  .nl-alt-cta {
    padding: 16px 0;
  }
  .nl-alt-cta p {
    color: white;
    font-family: var(--font-cormorant), serif;
    font-size: 18px;
    font-style: italic;
    margin-bottom: 16px;
  }
  .spicelist-alt-btn {
    display: inline-block;
    background: white;
    color: var(--brand-red);
    font-family: var(--font-body), sans-serif;
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 14px 32px;
    border-radius: 50px;
    text-decoration: none;
    transition: transform 0.06s;
    min-height: 48px;
  }
  .spicelist-alt-btn:active {
    transform: scale(0.97);
  }
  .spicelist {
    padding: 24px 16px 24px;
    background: var(--brand-red);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .spicelist h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(30px, 5vw, 60px);
    font-weight: 900;
    color: white;
    margin-bottom: 12px;
    position: relative;
  }
  .spicelist p {
    color: rgba(255, 255, 255, 0.85);
    font-size: 21px;
    margin-bottom: 20px;
    font-family: var(--font-cormorant), serif;
    font-style: italic;
    position: relative;
  }
  /* Prevent CLS when switching between steps.
     min-height must cover the tallest step (step 2: ~230px) so the
     wrapper never grows or shrinks between transitions. */
  .nl-steps-wrapper {
    min-height: 240px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .spicelist-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 420px;
    margin: 0 auto;
    position: relative;
  }
  .spicelist-form input {
    padding: 16px 24px;
    border: 1.5px solid rgba(255, 255, 255, 0.4);
    border-radius: 50px;
    background: rgba(255, 255, 255, 0.15);
    color: white;
    font-size: 16px;
    font-family: var(--font-body), sans-serif;
    outline: none;
    transition: border-color 0.2s;
    min-height: var(--touch-target);
  }
  .spicelist-form input::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }
  .spicelist-form input:focus {
    border-color: var(--electric-yellow);
  }
  .spicelist-form button {
    background: var(--electric-yellow);
    color: var(--charcoal);
    border: none;
    padding: 16px;
    border-radius: 50px;
    font-family: var(--font-body), sans-serif;
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    cursor: pointer;
    transition:
      background 0.2s,
      color 0.2s;
    min-height: var(--touch-target);
    white-space: nowrap;
  }
  .spicelist-form button:hover {
    background: white;
    color: var(--charcoal);
  }
  .spicelist-form button:focus-visible {
    outline: 2px solid white;
    outline-offset: 2px;
  }
  .spicelist-error {
    font-size: 13px;
    color: var(--electric-yellow);
    text-align: center;
    margin: 0;
    font-family: var(--font-body), sans-serif;
    font-style: normal;
  }
  .spicelist-trust {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 0;
    margin-top: 16px;
    font-style: normal;
    font-family: var(--font-body), sans-serif;
  }

  .nl-step2-text {
    color: rgba(255, 255, 255, 0.85);
    font-size: 16px;
    margin-bottom: 20px;
    font-family: var(--font-cormorant), serif;
    font-style: italic;
  }
  .spicelist-skip {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.5);
    font-size: 16px;
    font-family: var(--font-body), sans-serif;
    margin-top: 12px;
    transition: color 0.2s;
    padding: 12px 16px;
    min-height: var(--touch-target);
    cursor: pointer;
  }
  .spicelist-skip:hover,
  .spicelist-skip:focus-visible {
    color: white;
  }
  @keyframes stepIn {
    0% {
      opacity: 0;
      transform: translateY(6px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }
  #nl-step-2 {
    animation: stepIn 0.3s ease-out both;
  }
  @keyframes spiceSuccess {
    0% {
      opacity: 0;
      transform: scale(0.95) translateY(6px);
    }
    70% {
      transform: scale(1.03) translateY(0);
    }
    100% {
      opacity: 1;
      transform: scale(1);
    }
  }
  .nl-done-text {
    color: white;
    font-family: var(--font-cormorant), serif;
    font-size: 22px;
    font-style: italic;
    animation: spiceSuccess 0.45s ease-out both;
  }

  @media (min-width: 768px) {
    .spicelist {
      padding: 40px 32px 36px;
    }
    .spicelist p {
      font-size: 22px;
      margin-bottom: 28px;
    }
    .spicelist-form input {
      padding: 18px 28px;
    }
    .spicelist-form button {
      padding: 18px;
    }
  }
</style>
