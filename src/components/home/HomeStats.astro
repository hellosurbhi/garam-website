---
import { STATS as stats } from '@/data/copy';
---

<section class="stats" aria-label="Show statistics" data-reveal>
  <img class="stats-bg" src="/images/testimonial-reaction.webp" alt="" width="800" height="1200" loading="lazy" aria-hidden="true" />
  <div class="stats-inner">
    <h2>The Numbers Don't Lie</h2>
    <div class="stats-grid">
      {stats.map((stat) => (
        <div class="stat-item">
          <div class="stat-num">{stat.num}</div>
          <div class="stat-label">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats {
    padding: 80px 20px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .stats-bg {
    position: absolute;
    inset: -10%;
    width: 120%;
    height: 120%;
    object-fit: cover;
    object-position: center 35%;
    display: block;
    z-index: 0;
  }
  @media (min-width: 768px) {
    .stats-bg {
      inset: 0;
      width: 100%;
      height: 100%;
      object-position: center 40%;
    }
  }
  .stats-inner {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
  }
  .stats h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 900;
    color: white;
    margin-bottom: 48px;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.7), 0 0 40px rgba(0, 0, 0, 0.3);
  }
  .stats-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 32px 0;
  }
  .stat-item {
    flex: 0 1 33.33%;
    padding: 0 10px;
  }
  .stat-num {
    font-family: var(--font-playfair), serif;
    font-size: 32px;
    font-weight: 900;
    color: var(--electric-yellow);
    line-height: 1;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.6);
  }
  .stat-label {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: white;
    margin-top: 8px;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.6);
    white-space: nowrap;
  }

  @media (min-width: 768px) {
    .stats { padding: 100px 48px; }
    .stats h2 { margin-bottom: 64px; }
    .stats-grid { flex-wrap: nowrap; gap: 0; }
    .stat-item {
      flex: 1;
      padding: 0 40px;
      border-right: 1px solid rgba(255, 255, 255, 0.2);
    }
    .stat-item:last-child { border-right: none; }
    .stat-num { font-size: 72px; }
    .stat-label { font-size: 13px; }
  }
</style>
