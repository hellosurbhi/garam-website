---
import { STATS as stats } from "@/data/copy";
---

<section class="stats" aria-label="Show statistics" data-reveal>
  <img
    class="stats-bg"
    src="/images/promo/testimonial-reaction.webp"
    alt=""
    width="800"
    height="1200"
    loading="lazy"
    aria-hidden="true"
  />
  <div class="stats-inner">
    <h2>The Numbers Don't Lie</h2>
    <div class="stats-grid">
      {
        stats.map((stat) => (
          <div class="stat-item">
            <div class="stat-num" data-countup={stat.num}>
              {stat.num}
            </div>
            <div class="stat-label">{stat.label}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  // Count-up animation triggered when the stats section enters viewport.
  // Parses each .stat-num's text into a numeric target + suffix (e.g.
  // "2K+" → 2 with "K+"), then runs a rAF easeOutCubic tween over 1500ms.
  // Native static text is the SSR fallback; JS only replaces on scroll-in.
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  if (!prefersReducedMotion && "IntersectionObserver" in window) {
    const nums = document.querySelectorAll<HTMLElement>(
      ".stat-num[data-countup]",
    );
    if (nums.length === 0) {
      // nothing to animate
    } else {
      const parse = (raw: string): { target: number; suffix: string } => {
        const match = raw.match(/^(\d+)(.*)$/);
        if (!match) return { target: 0, suffix: raw };
        return { target: parseInt(match[1], 10), suffix: match[2] };
      };

      const easeOutCubic = (t: number): number => 1 - Math.pow(1 - t, 3);

      const animate = (el: HTMLElement): void => {
        const raw = el.dataset.countup ?? el.textContent ?? "0";
        const { target, suffix } = parse(raw);
        if (target === 0) {
          el.textContent = raw;
          return;
        }
        const duration = 1500;
        const start = performance.now();
        const tick = (now: number): void => {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const value = Math.round(target * easeOutCubic(progress));
          el.textContent = value + suffix;
          if (progress < 1) {
            requestAnimationFrame(tick);
          }
        };
        el.textContent = "0" + suffix;
        requestAnimationFrame(tick);
      };

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              nums.forEach(animate);
              observer.disconnect();
            }
          });
        },
        { threshold: 0.4 },
      );

      const section = document.querySelector(".stats");
      if (section) observer.observe(section);
    }
  }
</script>

<style>
  .stats {
    padding: 80px 20px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .stats-bg {
    position: absolute;
    inset: -10%;
    width: 120%;
    height: 120%;
    object-fit: cover;
    object-position: center 35%;
    display: block;
    z-index: 0;
  }
  @media (min-width: 768px) {
    .stats-bg {
      inset: 0;
      width: 100%;
      height: 100%;
      object-position: center 40%;
    }
  }
  .stats-inner {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
  }
  .stats h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 900;
    color: white;
    margin-bottom: 48px;
    text-shadow:
      0 2px 16px rgba(0, 0, 0, 0.7),
      0 0 40px rgba(0, 0, 0, 0.3);
  }
  .stats-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 32px 0;
  }
  /* Single-column on the smallest phones (<480px) */
  .stat-item {
    flex: 0 1 100%;
    padding: 0 10px;
  }
  /* 2-column on medium-sized phones (480px to 767px) */
  @media (min-width: 480px) and (max-width: 767px) {
    .stat-item {
      flex: 0 1 50%;
    }
  }
  .stat-num {
    font-family: var(--font-playfair), serif;
    font-size: 32px;
    font-weight: 900;
    color: var(--electric-yellow);
    line-height: 1;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.6);
  }
  .stat-label {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: white;
    margin-top: 8px;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.6);
  }

  @media (min-width: 768px) {
    .stats {
      padding: 100px 48px;
    }
    .stats h2 {
      margin-bottom: 64px;
    }
    .stats-grid {
      flex-wrap: nowrap;
      gap: 0;
    }
    .stat-item {
      flex: 1;
      padding: 0 40px;
      border-right: 1px solid rgba(255, 255, 255, 0.2);
    }
    .stat-item:last-child {
      border-right: none;
    }
    .stat-num {
      font-size: 72px;
    }
    .stat-label {
      font-size: 13px;
      white-space: nowrap;
    }
  }
</style>
