---
import { TESTIMONIALS as testimonials } from '@/data/copy';

const accentColors = ['var(--electric-yellow)', 'var(--brand-red)', 'var(--spice-orange)'];
---

<section class="testimonials" aria-label="Audience reviews">
  <img class="testi-bg" src="/images/after-party.webp" alt="" width="800" height="1200" loading="lazy" aria-hidden="true" />
  <div class="testimonials-inner">
    <h2 data-reveal>What They're <em>Saying</em></h2>
    <div class="testi-grid">
      {testimonials.map((t, i) => (
        <div class="testi-card" data-reveal style={`--quote-color: ${accentColors[i]}`}>
          <div class="testi-quote">{t.quote}</div>
          <div class="testi-author">{t.author} · {t.location}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials {
    padding: 80px 20px;
    position: relative;
    overflow: hidden;
  }
  .testi-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    display: block;
    z-index: 0;
  }
  .testimonials-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .testimonials-inner > h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(32px, 5vw, 60px);
    font-weight: 900;
    color: white;
    margin-bottom: 40px;
    line-height: 1;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.5);
  }
  .testimonials-inner > h2 em { color: var(--electric-yellow); font-style: italic; }
  .testi-grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .testi-card {
    padding: 32px;
    position: relative;
  }
  .testi-card::before {
    content: '\201C';
    font-family: var(--font-playfair), serif;
    font-size: 64px;
    color: var(--quote-color, var(--electric-yellow));
    line-height: 0.6;
    display: block;
    margin-bottom: 12px;
  }
  .testi-quote {
    font-family: var(--font-cormorant), serif;
    font-size: 18px;
    font-style: italic;
    line-height: 1.5;
    color: white;
    margin-bottom: 20px;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.7), 0 0 40px rgba(0, 0, 0, 0.3);
  }
  .testi-author {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: rgba(255, 255, 255, 0.8);
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.6);
  }

  @media (min-width: 768px) {
    .testimonials { padding: 120px 48px; }
    .testimonials-inner > h2 { margin-bottom: 60px; }
    .testi-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      align-items: start;
    }
    .testi-card { padding: 36px; }
    .testi-card:nth-child(2) { margin-top: 32px; }
    .testi-card::before { font-size: 80px; margin-bottom: 16px; }
    .testi-quote { font-size: 20px; margin-bottom: 24px; }
  }
</style>
