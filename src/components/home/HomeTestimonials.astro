---
import { TESTIMONIALS as testimonials } from "@/data/copy";
---

<section class="testimonials" aria-label="Audience reviews">
  <img
    class="testi-bg"
    src="/images/promo/after-party.webp"
    alt=""
    width="800"
    height="1200"
    loading="lazy"
    decoding="async"
    aria-hidden="true"
  />
  <div class="testi-overlay" aria-hidden="true"></div>

  <div class="testimonials-inner">
    <p class="testi-label" data-reveal>What they said</p>
    <h2 data-reveal>The audience<br /><em>loved it.</em></h2>
    <div class="testi-grid" data-reveal-stagger>
      {
        testimonials.map((t) => (
          <div class="testi-card" data-reveal>
            <div class="testi-mark" aria-hidden="true">"</div>
            <blockquote class="testi-quote">{t.quote}</blockquote>
            <cite class="testi-author">
              {t.author} · {t.location}
            </cite>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .testimonials {
    padding: 80px 20px;
    position: relative;
    overflow: hidden;
    background: var(--ink);
  }
  .testi-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    display: block;
    z-index: 0;
  }
  .testi-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      135deg,
      rgba(12, 12, 12, 0.88) 0%,
      rgba(12, 12, 12, 0.72) 50%,
      rgba(12, 12, 12, 0.85) 100%
    );
  }
  .testimonials-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }
  .testi-label {
    font-family: var(--font-body), sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
  }
  .testimonials-inner > h2 {
    font-family: var(--font-display), sans-serif;
    font-size: clamp(48px, 8vw, 96px);
    font-weight: 400;
    color: white;
    line-height: 0.9;
    text-transform: uppercase;
    margin-bottom: 48px;
    letter-spacing: -0.01em;
  }
  .testimonials-inner > h2 em {
    font-family: var(--font-serif), serif;
    font-style: italic;
    font-size: 0.75em;
    text-transform: none;
    color: var(--electric-yellow);
    display: block;
    line-height: 1.1;
    letter-spacing: 0;
  }
  .testi-grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .testi-card {
    padding: 32px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    position: relative;
  }
  .testi-mark {
    font-family: var(--font-serif), serif;
    font-size: 72px;
    line-height: 0.5;
    color: var(--brand-red);
    margin-bottom: 16px;
    display: block;
    opacity: 0.7;
  }
  .testi-quote {
    font-family: var(--font-serif), serif;
    font-style: italic;
    font-size: 20px;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.88);
    margin-bottom: 20px;
  }
  .testi-author {
    font-family: var(--font-body), sans-serif;
    font-size: 11px;
    font-weight: 600;
    font-style: normal;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.4);
    display: block;
  }

  @media (min-width: 768px) {
    .testimonials { padding: 120px 48px; }
    .testimonials-inner > h2 { margin-bottom: 64px; }
    .testi-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      align-items: start;
    }
    .testi-card { padding: 36px; }
    .testi-card:nth-child(2) { margin-top: 40px; }
    .testi-quote { font-size: 19px; }
  }

  @media (min-width: 768px) {
    .testi-bg { object-position: center 55%; }
  }
</style>
