---
import { YOUTUBE_VIDEO_ID, INSTAGRAM_REEL_URLS } from '@/lib/constants';
---

<section class="video" id="watch" aria-labelledby="video-heading">
  <div class="video-inner">
    <div class="video-header" data-reveal>
      <div class="video-eyebrow">Watch</div>
      <h2 id="video-heading">See What You're <em>Missing</em></h2>
    </div>

    <div class="video-main" data-reveal>
      <button
        class="video-facade"
        aria-label="Play Garam Masala Dating show highlight"
        data-youtube-id={YOUTUBE_VIDEO_ID}
      >
        <img
          src={`https://i.ytimg.com/vi/${YOUTUBE_VIDEO_ID}/hqdefault.jpg`}
          alt="Garam Masala Dating show video thumbnail"
          loading="lazy"
          width="480"
          height="360"
        />
        <span class="play-icon" aria-hidden="true">▶</span>
      </button>
    </div>
  </div>

  <div class="reels-row" data-reveal>
    {INSTAGRAM_REEL_URLS.map((url) => (
      <a
        class="reel-link"
        href={url}
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="reel-icon" aria-hidden="true">▶</span>
        <span>Watch on Instagram</span>
      </a>
    ))}
  </div>
</section>

<script>
  document.querySelector<HTMLButtonElement>('.video-facade')?.addEventListener('click', (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    const id = btn.dataset.youtubeId;
    const iframe = document.createElement('iframe');
    iframe.src = `https://www.youtube-nocookie.com/embed/${id}?rel=0&autoplay=1`;
    iframe.title = 'Garam Masala Dating show highlight';
    iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; fullscreen';
    iframe.allowFullscreen = true;
    iframe.style.width = '100%';
    iframe.style.height = '100%';
    iframe.style.border = 'none';
    iframe.style.display = 'block';
    btn.replaceWith(iframe);
  });
</script>

<style>
  .video {
    padding: 56px 16px;
    background: var(--off-white);
  }
  .video-inner {
    max-width: 900px;
    margin: 0 auto;
  }
  .video-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .video-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--brand-red);
    margin-bottom: 12px;
  }
  .video-header h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 900;
    color: var(--charcoal);
    line-height: 1.05;
  }
  .video-header h2 em {
    color: var(--brand-red);
    font-style: italic;
  }

  .video-main {
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: var(--charcoal);
    position: relative;
  }

  /* Facade button */
  .video-facade {
    width: 100%;
    height: 100%;
    border: none;
    padding: 0;
    cursor: pointer;
    background: var(--charcoal);
    position: relative;
    display: block;
  }
  .video-facade img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .play-icon {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 48px;
    color: #fff;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.6);
    transition: transform 0.2s;
  }
  .video-facade:hover .play-icon {
    transform: scale(1.15);
  }

  /* Reels row sits outside video-inner so it can be wider than 900px */
  .reels-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin-top: 32px;
    max-width: 1100px;
    margin-left: auto;
    margin-right: auto;
    padding: 0 16px;
  }

  .reel-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 16px 24px;
    min-height: var(--touch-target);
    background: var(--charcoal);
    color: #fff;
    text-decoration: none;
    border-radius: 12px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    transition: background 0.2s, transform 0.2s;
  }
  .reel-link:hover {
    background: #333;
    transform: translateY(-2px);
  }
  .reel-link:focus-visible {
    outline: 2px solid var(--brand-red);
    outline-offset: 3px;
  }
  .reel-icon {
    font-size: 13px;
    color: var(--brand-red);
  }

  @media (min-width: 768px) {
    .video { padding: 80px 48px; }
    .video-header { margin-bottom: 48px; }
    .reels-row {
      grid-template-columns: repeat(3, 1fr);
      padding: 0 48px;
    }
  }
</style>
