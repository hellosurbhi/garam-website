---
const YOUTUBE_ID = 'AXDhphHBUj4';
const THUMBNAIL = `https://img.youtube.com/vi/${YOUTUBE_ID}/maxresdefault.jpg`;

const reels = [
  'https://www.instagram.com/p/C79Pohcxu4j/embed/',
  'https://www.instagram.com/p/DWeM47lkTXS/embed/',
  'https://www.instagram.com/reel/DWuAL_REcJD/embed/',
];
---

<section class="video" id="watch" aria-labelledby="video-heading">
  <div class="video-inner">
    <div class="video-header" data-reveal>
      <div class="video-eyebrow">Watch</div>
      <h2 id="video-heading">See What You're <em>Missing</em></h2>
    </div>

    <div class="video-main" data-reveal>
      <button type="button" class="video-facade" id="yt-facade" aria-label="Play show highlight video">
        <img
          src={THUMBNAIL}
          alt="Garam Masala Dating show highlight reel"
          width="1280"
          height="720"
          loading="lazy"
        />
        <div class="video-play">
          <svg viewBox="0 0 68 48" width="68" height="48"><path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55C3.97 2.33 2.27 4.81 1.48 7.74.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="var(--brand-red)"/><path d="M45 24 27 14v20" fill="#fff"/></svg>
        </div>
      </button>
    </div>

    <div class="reels-row" data-reveal>
      {reels.map((src) => (
        <div class="reel-embed">
          <iframe
            src={src}
            loading="lazy"
            allowtransparency="true"
            title="Instagram reel"
          ></iframe>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const facade = document.getElementById('yt-facade');
  facade?.addEventListener('click', () => {
    const iframe = document.createElement('iframe');
    iframe.src = 'https://www.youtube-nocookie.com/embed/AXDhphHBUj4?autoplay=1&rel=0';
    iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
    iframe.allowFullscreen = true;
    iframe.title = 'Garam Masala Dating show highlight';
    iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:none;border-radius:20px;';
    const parent = facade.parentElement;
    if (parent) {
      parent.innerHTML = '';
      parent.style.position = 'relative';
      parent.appendChild(iframe);
    }
  });
</script>

<style>
  .video {
    padding: 56px 16px;
    background: var(--off-white);
  }
  .video-inner {
    max-width: 900px;
    margin: 0 auto;
  }
  .video-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .video-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--brand-red);
    margin-bottom: 12px;
  }
  .video-header h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 900;
    color: var(--charcoal);
    line-height: 1.05;
  }
  .video-header h2 em {
    color: var(--brand-red);
    font-style: italic;
  }

  .video-main {
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: var(--charcoal);
    position: relative;
  }
  .video-facade {
    display: block;
    width: 100%;
    height: 100%;
    border: none;
    padding: 0;
    cursor: pointer;
    position: relative;
    background: var(--charcoal);
  }
  .video-facade img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0.7;
    transition: opacity 0.3s;
  }
  .video-facade:hover img { opacity: 0.5; }
  .video-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .video-play svg {
    filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.3));
    transition: transform 0.2s;
  }
  .video-facade:hover .video-play svg { transform: scale(1.1); }

  .reels-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 32px;
  }
  .reel-embed {
    border-radius: 14px;
    overflow: hidden;
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.06);
  }
  .reel-embed iframe {
    width: 100%;
    height: 480px;
    border: none;
    display: block;
  }

  @media (max-width: 600px) {
    .reels-row {
      grid-template-columns: 1fr;
      gap: 12px;
    }
    .reel-embed iframe {
      height: 520px;
    }
  }

  @media (min-width: 768px) {
    .video { padding: 80px 48px; }
    .video-header { margin-bottom: 48px; }
  }
</style>
