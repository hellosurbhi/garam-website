---
import { YOUTUBE_VIDEO_ID, INSTAGRAM_REEL_URLS } from "@/lib/constants";
---

<section class="video" id="watch" aria-labelledby="video-heading">
  <div class="video-inner">
    <div class="video-header" data-reveal>
      <div class="video-eyebrow">Watch</div>
      <h2 id="video-heading">See What You're <em>Missing</em></h2>
    </div>

    <div class="video-main" data-reveal>
      <button
        class="video-facade"
        aria-label="Play Garam Masala Dating show highlight"
        data-youtube-id={YOUTUBE_VIDEO_ID}
      >
        <img
          src={`https://i.ytimg.com/vi/${YOUTUBE_VIDEO_ID}/hqdefault.jpg`}
          alt="Garam Masala Dating show video thumbnail"
          loading="lazy"
          width="480"
          height="360"
        />
        <span class="play-icon" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 68 48"
            width="68"
            height="48"
            aria-hidden="true"
          >
            <path
              d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z"
              fill="#f00"></path>
            <path d="M45 24 27 14v20" fill="#fff"></path>
          </svg>
        </span>
      </button>
    </div>
  </div>

  <div class="reels-row" id="reels-row" data-reveal>
    {
      INSTAGRAM_REEL_URLS.map((url, index) => (
        <div class="reel-embed">
          <button
            class="reel-facade"
            data-reel-url={url}
            aria-label={`Watch Instagram reel ${index + 1} — opens on Instagram`}
          >
            <span class="reel-facade-ig" aria-hidden="true">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                width="48"
                height="48"
                fill="white"
                aria-hidden="true"
              >
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
              </svg>
            </span>
            <span class="reel-facade-text">Watch on Instagram</span>
          </button>
        </div>
      ))
    }
  </div>
</section>

<script>
  import { trackLeadEvent } from "@/lib/analytics";

  // YouTube: swap facade for iframe on click
  document
    .querySelector<HTMLButtonElement>(".video-facade")
    ?.addEventListener("click", (e) => {
      const btn = e.currentTarget as HTMLButtonElement;
      const id = btn.dataset.youtubeId;
      if (!id) return;
      trackLeadEvent("video_played", {
        video_id: id,
        page: window.location.pathname,
      });
      const iframe = document.createElement("iframe");
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?rel=0&autoplay=1`;
      iframe.title = "Garam Masala Dating show highlight";
      iframe.allow =
        "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; fullscreen";
      iframe.allowFullscreen = true;
      iframe.style.cssText =
        "width:100%;height:100%;border:none;display:block;";
      btn.replaceWith(iframe);
    });

  // Instagram Reels: load embed.js and render the blockquote only on click.
  // Removes below-fold CLS and ~50KB embed.js from every homepage load.
  let igEmbedLoaded = false;

  function loadIgEmbed(callback: () => void): void {
    if (igEmbedLoaded) {
      callback();
      return;
    }
    const existing = document.querySelector<HTMLScriptElement>(
      'script[src*="instagram.com/embed.js"]',
    );
    if (existing) {
      existing.addEventListener("load", callback, { once: true });
      return;
    }
    const script = document.createElement("script");
    script.src = "https://www.instagram.com/embed.js";
    script.async = true;
    script.onload = () => {
      igEmbedLoaded = true;
      callback();
    };
    document.body.appendChild(script);
  }

  document
    .querySelectorAll<HTMLButtonElement>(".reel-facade")
    .forEach((btn) => {
      btn.addEventListener(
        "click",
        () => {
          const url = btn.dataset.reelUrl;
          if (!url) return;

          const bq = document.createElement("blockquote");
          bq.className = "instagram-media";
          bq.dataset.instgrmPermalink = url;
          bq.dataset.instgrmVersion = "14";
          const a = document.createElement("a");
          a.href = url;
          a.target = "_blank";
          a.rel = "noopener noreferrer";
          a.textContent = "Watch on Instagram";
          bq.appendChild(a);

          btn.replaceWith(bq);

          loadIgEmbed(() => {
            (
              window as typeof window & {
                instgrm?: { Embeds?: { process: () => void } };
              }
            ).instgrm?.Embeds?.process();
          });
        },
        { once: true },
      );
    });
</script>

<style>
  .video {
    padding: 56px 16px;
    background: white;
  }
  .video-inner {
    max-width: 900px;
    margin: 0 auto;
  }
  .video-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .video-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--brand-red);
    margin-bottom: 12px;
  }
  .video-header h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 900;
    color: var(--charcoal);
    line-height: 1.05;
  }
  .video-header h2 em {
    color: var(--brand-red);
    font-style: italic;
  }

  .video-main {
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: var(--charcoal);
    position: relative;
  }

  .video-facade {
    width: 100%;
    height: 100%;
    border: none;
    padding: 0;
    cursor: pointer;
    background: var(--charcoal);
    position: relative;
    display: block;
  }
  .video-facade img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .play-icon {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s;
  }
  .video-facade:hover .play-icon,
  .video-facade:focus-visible .play-icon {
    opacity: 0.85;
  }

  /* Reels row sits outside video-inner so it can be wider than 900px */
  .reels-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin-top: 32px;
    max-width: 1100px;
    margin-left: auto;
    margin-right: auto;
    padding: 0 16px;
  }

  .reel-embed {
    display: flex;
    justify-content: center;
  }

  /* Reel facade: Instagram-branded placeholder that reserves embed dimensions */
  .reel-facade {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    width: 100%;
    max-width: 340px;
    aspect-ratio: 4 / 5;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    background: linear-gradient(
      45deg,
      #f09433 0%,
      #e6683c 25%,
      #dc2743 50%,
      #cc2366 75%,
      #bc1888 100%
    );
    transition: opacity 0.2s;
  }
  .reel-facade:hover,
  .reel-facade:focus-visible {
    opacity: 0.9;
  }
  .reel-facade-ig {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .reel-facade-text {
    color: white;
    font-family: var(--font-body), sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.3px;
  }

  .reel-embed .instagram-media {
    margin: 0 !important;
    min-width: 0 !important;
    width: 100% !important;
    max-width: 340px !important;
  }

  @media (min-width: 768px) {
    .video {
      padding: 80px 48px;
    }
    .video-header {
      margin-bottom: 48px;
    }
    .reels-row {
      grid-template-columns: repeat(3, 1fr);
      padding: 0 48px;
    }
    .reel-facade {
      max-width: 100%;
    }
    .reel-embed .instagram-media {
      max-width: 100% !important;
    }
  }
</style>
