---
const YOUTUBE_ID = 'AXDhphHBUj4';

const reelUrls = [
  'https://www.instagram.com/p/C79Pohcxu4j/',
  'https://www.instagram.com/p/DWeM47lkTXS/',
  'https://www.instagram.com/reel/DWuAL_REcJD/',
];
---

<section class="video" id="watch" aria-labelledby="video-heading">
  <div class="video-inner">
    <div class="video-header" data-reveal>
      <div class="video-eyebrow">Watch</div>
      <h2 id="video-heading">See What You're <em>Missing</em></h2>
    </div>

    <div class="video-main" data-reveal>
      <iframe
        src={`https://www.youtube-nocookie.com/embed/${YOUTUBE_ID}?rel=0`}
        title="Garam Masala Dating show highlight"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; fullscreen"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>
  </div>

  <div class="reels-row" data-reveal>
    {reelUrls.map((url) => (
      <div class="reel-embed">
        <blockquote
          class="instagram-media"
          data-instgrm-permalink={url}
          data-instgrm-version="14"
        ></blockquote>
      </div>
    ))}
  </div>
</section>

<!-- Instagram official embed script — loads once, processes all blockquotes -->
<script async src="https://www.instagram.com/embed.js"></script>

<style>
  .video {
    padding: 56px 16px;
    background: #fff;
  }
  .video-inner {
    max-width: 900px;
    margin: 0 auto;
  }
  .video-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .video-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--brand-red);
    margin-bottom: 12px;
  }
  .video-header h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 900;
    color: var(--charcoal);
    line-height: 1.05;
  }
  .video-header h2 em {
    color: var(--brand-red);
    font-style: italic;
  }

  .video-main {
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: var(--charcoal);
    position: relative;
  }
  .video-main iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  /* Reels row sits outside video-inner so it can be wider than 900px */
  .reels-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin-top: 32px;
    max-width: 1100px;
    margin-left: auto;
    margin-right: auto;
    padding: 0 16px;
  }
  .reel-embed {
    display: flex;
    justify-content: center;
  }
  /* Let Instagram's embed control its own sizing */
  .reel-embed .instagram-media {
    margin: 0 !important;
    min-width: 0 !important;
    width: 100% !important;
    max-width: 540px !important;
  }

  @media (min-width: 768px) {
    .video { padding: 80px 48px; }
    .video-header { margin-bottom: 48px; }
    .reels-row {
      grid-template-columns: repeat(3, 1fr);
      padding: 0 48px;
    }
  }
</style>
