---
const YOUTUBE_ID = 'AXDhphHBUj4';

const reels = [
  { url: 'https://www.instagram.com/p/C79Pohcxu4j/', label: 'Show Highlight' },
  { url: 'https://www.instagram.com/p/DWeM47lkTXS/', label: 'Fan Reactions' },
  { url: 'https://www.instagram.com/reel/DWuAL_REcJD/', label: 'Behind the Scenes' },
];
---

<section class="video" id="watch" aria-labelledby="video-heading">
  <div class="video-inner">
    <div class="video-header" data-reveal>
      <div class="video-eyebrow">Watch</div>
      <h2 id="video-heading">See What You're <em>Missing</em></h2>
    </div>

    <div class="video-main" data-reveal>
      <iframe
        src={`https://www.youtube-nocookie.com/embed/${YOUTUBE_ID}?rel=0`}
        title="Garam Masala Dating show highlight"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; fullscreen"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>

    <div class="reels-row" data-reveal>
      {reels.map((reel) => (
        <a href={reel.url} target="_blank" rel="noopener noreferrer" class="reel-card" aria-label={`Watch ${reel.label} on Instagram`}>
          <div class="reel-card-inner">
            <svg class="reel-play-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true" width="40" height="40">
              <circle cx="12" cy="12" r="12" fill="rgba(255,255,255,0.2)" />
              <path d="M10 8l6 4-6 4V8z" fill="white" />
            </svg>
            <span class="reel-label">{reel.label}</span>
            <span class="reel-cta">Watch on Instagram</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .video {
    padding: 56px 16px;
    background: #fff;
  }
  .video-inner {
    max-width: 900px;
    margin: 0 auto;
  }
  .video-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .video-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--brand-red);
    margin-bottom: 12px;
  }
  .video-header h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 900;
    color: var(--charcoal);
    line-height: 1.05;
  }
  .video-header h2 em {
    color: var(--brand-red);
    font-style: italic;
  }

  .video-main {
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: var(--charcoal);
    position: relative;
  }
  .video-main iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  .reels-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 32px;
  }
  .reel-card {
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    display: block;
    aspect-ratio: 9 / 16;
    background: linear-gradient(135deg, #833ab4 0%, #fd1d1d 50%, #fcb045 100%);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .reel-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.18);
  }
  .reel-card-inner {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 24px 16px;
    text-align: center;
  }
  .reel-play-icon {
    flex-shrink: 0;
  }
  .reel-label {
    font-family: var(--font-body), sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: white;
    letter-spacing: 0.5px;
  }
  .reel-cta {
    font-family: var(--font-body), sans-serif;
    font-size: 11px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.75);
    text-transform: uppercase;
    letter-spacing: 1.5px;
  }

  @media (max-width: 600px) {
    .reels-row {
      grid-template-columns: 1fr;
      gap: 12px;
    }
    .reel-card {
      aspect-ratio: 16 / 7;
    }
    .reel-card-inner {
      flex-direction: row;
      justify-content: flex-start;
      gap: 16px;
      padding: 20px;
    }
    .reel-label { font-size: 16px; }
  }

  @media (min-width: 768px) {
    .video { padding: 80px 48px; }
    .video-header { margin-bottom: 48px; }
  }
</style>
