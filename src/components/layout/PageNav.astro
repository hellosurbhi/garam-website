---
const pathname = Astro.url.pathname;
const onHome = pathname === "/";
---

<div class="page-nav-spacer" class:list={[{ "spacer-dark": onHome }]}></div>
<nav
  class="page-nav"
  class:list={[{ "nav-dark": onHome }]}
  id="page-nav"
  aria-label="Main navigation"
>
  <a href="/" class="page-nav-logo-link" aria-label="Garam Masala Dating: Home">
    <div class="page-nav-logo" role="img" aria-hidden="true"></div>
  </a>
  <div class="page-nav-right">
    <a
      href="/apply"
      class="page-nav-link"
      aria-current={pathname.startsWith("/apply") ? "page" : undefined}
      data-ph-capture="nav_clicked"
      data-ph-destination="/apply">Apply</a
    >
    <a
      href="/tickets"
      class="page-nav-pill"
      aria-current={pathname.startsWith("/tickets") ? "page" : undefined}
      data-ph-capture="nav_clicked"
      data-ph-destination="/tickets">Get Tickets</a
    >
  </div>
</nav>

<script>
  const nav = document.getElementById("page-nav");
  if (nav) {
    const update = () => {
      const scrolled = window.scrollY > 60;
      nav.classList.toggle("scrolled", scrolled);
    };
    update();
    window.addEventListener("scroll", update, { passive: true });
  }
</script>

<style>
  /* Spacer height must match nav height so content isn't hidden behind fixed nav */
  .page-nav-spacer {
    height: 64px;
  }
  /* On the homepage the hero is dark full-height — no space needed above it */
  .spacer-dark {
    height: 0;
  }

  .page-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 500;
    padding: 16px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(253, 248, 242, 0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    transition:
      background 0.3s ease,
      border-color 0.3s ease;
  }

  /* Dark nav over hero */
  .page-nav.nav-dark {
    background: transparent;
    border-color: transparent;
  }
  .page-nav.nav-dark.scrolled {
    background: rgba(12, 12, 12, 0.96);
    border-color: rgba(255, 255, 255, 0.06);
  }

  /* ── Logo ── */
  .page-nav-logo-link {
    text-decoration: none;
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
  .page-nav-logo {
    height: 28px;
    width: 120px;
    background-color: var(--brand-red);
    -webkit-mask-image: url(/images/logo.svg);
    mask-image: url(/images/logo.svg);
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    transition: background-color 0.3s ease, opacity 0.2s;
  }
  /* Logo is white on dark nav */
  .nav-dark .page-nav-logo {
    background-color: white;
  }
  .nav-dark.scrolled .page-nav-logo {
    background-color: white;
  }
  .page-nav-logo-link:hover .page-nav-logo {
    opacity: 0.75;
  }

  /* ── Right side links ── */
  .page-nav-right {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  /* Ghost text link (Apply) */
  .page-nav-link {
    font-family: var(--font-body), sans-serif;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    text-decoration: none;
    color: var(--charcoal);
    padding: 10px 14px;
    border-radius: 3px;
    transition: color 0.2s;
    min-height: var(--touch-target);
    display: inline-flex;
    align-items: center;
  }
  .page-nav-link:hover {
    color: var(--brand-red);
  }
  .page-nav-link:focus-visible {
    outline: 2px solid var(--brand-red);
    outline-offset: 2px;
  }

  /* Light text on dark nav */
  .nav-dark .page-nav-link {
    color: rgba(255, 255, 255, 0.7);
  }
  .nav-dark .page-nav-link:hover {
    color: white;
  }

  /* Filled ticket button */
  .page-nav-pill {
    font-family: var(--font-body), sans-serif;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    text-decoration: none;
    color: white;
    background: var(--brand-red);
    padding: 10px 18px;
    border-radius: 3px;
    transition: background 0.2s;
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    min-height: var(--touch-target);
  }
  .page-nav-pill:hover {
    background: var(--brand-red-dark);
  }
  .page-nav-pill:focus-visible {
    outline: 2px solid var(--brand-red);
    outline-offset: 2px;
  }
  .page-nav-pill:active {
    transform: scale(0.97);
  }

  @media (min-width: 768px) {
    .page-nav {
      padding: 20px 48px;
    }
    .page-nav-spacer:not(.spacer-dark) {
      height: 80px;
    }
    .page-nav-logo {
      height: 36px;
      width: 160px;
    }
    .page-nav-link {
      font-size: 12px;
      padding: 12px 18px;
    }
    .page-nav-pill {
      font-size: 12px;
      padding: 12px 24px;
    }
  }
</style>
