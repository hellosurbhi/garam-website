---
const pathname = Astro.url.pathname;
---

<div class="page-nav-spacer"></div>
<nav class="page-nav" id="page-nav" aria-label="Main navigation">
  <a href="/" class="page-nav-logo-link" aria-label="Garam Masala Dating — Home">
    <div class="page-nav-logo" role="img" aria-hidden="true"></div>
  </a>
  <div class="page-nav-right">
    <a href="/apply" class="page-nav-pill" aria-current={pathname.startsWith('/apply') ? 'page' : undefined}>Apply</a>
    <a href="/tickets" class="page-nav-pill page-nav-pill--primary" aria-current={pathname.startsWith('/tickets') ? 'page' : undefined}>Get Tickets</a>
  </div>
</nav>

<script>
  const nav = document.getElementById('page-nav');
  if (nav) {
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 10);
    }, { passive: true });
  }
</script>

<style>
  .page-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 500;
    padding: 16px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(255, 248, 240, 0.95);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 2px solid transparent;
    transition: padding 0.4s;
  }
  .page-nav.scrolled {
    padding: 12px 20px;
  }

  /* Logo */
  .page-nav-logo-link {
    text-decoration: none;
    display: flex;
    align-items: center;
  }
  .page-nav-logo {
    height: 28px;
    width: 120px;
    background-color: var(--brand-red);
    -webkit-mask-image: url(/images/logo.svg);
    mask-image: url(/images/logo.svg);
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    transition: opacity 0.2s;
  }
  .page-nav-logo-link:hover .page-nav-logo {
    opacity: 0.7;
  }

  /* Pills */
  .page-nav-right {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .page-nav-pill {
    font-family: var(--font-body), sans-serif;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-decoration: none;
    color: var(--charcoal);
    padding: 8px 12px;
    border-radius: 50px;
    border: 1.5px solid transparent;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
  }
  .page-nav-pill:hover {
    border-color: rgba(26, 26, 26, 0.2);
  }
  .page-nav-pill--primary {
    background: var(--brand-red);
    color: white;
    border-color: var(--brand-red);
  }
  .page-nav-pill--primary:hover {
    background: var(--brand-red-dark);
    border-color: var(--brand-red-dark);
  }

  /* Spacer to push content below the fixed nav */
  .page-nav-spacer {
    height: 68px;
  }

  @media (min-width: 768px) {
    .page-nav { padding: 20px 48px; }
    .page-nav.scrolled { padding: 14px 48px; }
    .page-nav-logo { height: 40px; width: 180px; }
    .page-nav-pill { font-size: 13px; letter-spacing: 1.5px; padding: 12px 22px; }
    .page-nav-spacer { height: 80px; }
  }
</style>
