---
/**
 * Shared base modal component.
 * Provides dialog chrome: backdrop, close button, escape key, focus management, ARIA.
 * Content is passed via the default slot.
 *
 * Usage:
 *   <Modal id="my-modal" title="Hello">
 *     <p>Modal content here</p>
 *   </Modal>
 *
 * Open from JS:
 *   (document.getElementById('my-modal') as HTMLDialogElement).showModal();
 */
interface Props {
  id: string;
  title?: string;
  class?: string;
}

const { id, title, class: className } = Astro.props;
const titleId = `${id}-title`;
---

<dialog
  id={id}
  class:list={['base-modal', className]}
  role="dialog"
  aria-modal="true"
  aria-labelledby={title ? titleId : undefined}
>
  <div class="base-modal-inner">
    <button type="button" class="base-modal-close" aria-label="Close">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>
    {title && <h2 id={titleId} class="base-modal-title">{title}</h2>}
    <slot />
  </div>
</dialog>

<style>
  .base-modal {
    border: none;
    background: transparent;
    padding: 24px;
    max-width: 100%;
    max-height: 100vh;
    width: 100%;
    height: 100%;
    overflow: visible;
  }
  .base-modal::backdrop {
    background: var(--backdrop);
  }
  .base-modal[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .base-modal-inner {
    width: 100%;
    max-width: 400px;
    max-height: 80vh;
    overflow-y: auto;
    background: white;
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 32px 24px;
    position: relative;
    animation: baseModalIn 0.25s ease-out both;
    text-align: center;
  }
  @keyframes baseModalIn {
    from { opacity: 0; transform: scale(0.95) translateY(8px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
  .base-modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    min-width: var(--touch-target);
    min-height: var(--touch-target);
    padding: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
  }
  .base-modal-close:hover { color: var(--charcoal); }
  .base-modal-title {
    font-family: var(--font-playfair), serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--charcoal);
    margin-bottom: 8px;
  }
</style>

<script>
  // Wire up all base-modal instances: close button + backdrop click + escape
  document.querySelectorAll<HTMLDialogElement>('.base-modal').forEach((dialog) => {
    dialog.querySelector('.base-modal-close')?.addEventListener('click', () => dialog.close());
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
  });
</script>
