---
/**
 * Shared loading spinner.
 * size="sm"  → 16px, size="md" → 32px (default).
 * Border color inherits currentColor from the host element so it matches
 * whatever surface it sits on (white on dark pills, red on outline delete,
 * green on restore) without per-tone variants.
 */
import styles from "./Spinner.module.css";

interface Props {
  size?: "sm" | "md";
  label?: string;
}
const { size = "md", label = "Loading..." } = Astro.props;
---

<span
  class:list={[styles.spinner, styles[size]]}
  role="status"
  aria-label={label}></span>
