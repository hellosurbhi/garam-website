---
import "../index.css";
import PostHog from "../components/posthog.astro";
import GTM from "../components/gtm.astro";
import MetaPixel from "../components/meta-pixel.astro";
import HomeFooter from "../components/home/HomeFooter.astro";
import PageNav from "../components/layout/PageNav.astro";
import CookieConsent from "../components/CookieConsent.astro";
import { SITE } from "../data/copy";
import { pageTitle, ogTitle } from "../utils/meta";
import HomeSignup from "../components/home/HomeSignup.astro";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  noindex?: boolean;
  hideNav?: boolean;
  hideFooter?: boolean;
  hideSpiceList?: boolean;
  noCursor?: boolean;
}

const {
  title,
  description,
  ogImage = "https://garammasaladating.com/og-image.jpg",
  ogType = "website",
  canonicalUrl = Astro.site
    ? new URL(Astro.url.pathname, Astro.site).href
    : "https://garammasaladating.com/",
  noindex = false,
  hideNav = false,
  hideFooter = false,
  hideSpiceList = false,
  noCursor = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <GTM />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle(title)}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#DC2626" />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/playfair-display-latin.woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/nunito-latin-var.woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/cormorant-garamond-latin-400i.woff2"
      crossorigin
    />
    <link rel="preconnect" href="https://www.eventbrite.com" />
    <link rel="preconnect" href="https://us-assets.i.posthog.com" crossorigin />
    <link rel="preconnect" href="https://us.posthog.com" crossorigin />
    <link rel="preconnect" href="https://connect.facebook.net" crossorigin />
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="text/markdown" href="/llms.txt" />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Garam Masala Dating" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={ogTitle(title)} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={SITE.ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@garamdatingshow" />
    <meta name="twitter:creator" content="@garamdatingshow" />
    <meta name="twitter:title" content={ogTitle(title)} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <slot name="head" />
    <PostHog />
    <MetaPixel />
  </head>
  <body data-no-cursor={noCursor ? "true" : undefined}>
    <a href="#main-content" class="sr-skip-link">Skip to content</a>
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-KQCBBL2W"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <div class="grain-overlay"></div>
    <div class="cursor" id="cursor"></div>
    <div class="cursor-ring" id="cursorRing"></div>
    {!hideNav && <PageNav />}
    <slot />
    {!hideSpiceList && !hideFooter && <HomeSignup />}
    {!hideFooter && <HomeFooter />}
    <CookieConsent />
    <script>
      import {
        bootstrapLeadAttribution,
        getStoredUtms,
      } from "@/lib/leadAttribution";
      import {
        capture,
        domainFromUrl,
        isSocialUrl,
        isTicketVendorUrl,
        trackOutbound,
        vendorFromUrl,
      } from "@/lib/analytics";
      import {
        forceStoredUtmsToUrl,
        preserveUtmsOnInternalLinks,
      } from "@/utils/utmForwarding";
      const isLocalPreview = ["localhost", "127.0.0.1"].includes(
        window.location.hostname,
      );
      if (!isLocalPreview) {
        Promise.all([
          import("@vercel/analytics"),
          import("@vercel/speed-insights"),
        ]).then(([{ inject }, { injectSpeedInsights }]) => {
          inject({ mode: "production" });
          injectSpeedInsights({ debug: false });
        });
      }
      bootstrapLeadAttribution();
      preserveUtmsOnInternalLinks();
      function preserveTicketVendorUtms(anchor: HTMLAnchorElement): void {
        if (isTicketVendorUrl(anchor.href)) {
          anchor.href = forceStoredUtmsToUrl(anchor.href, getStoredUtms());
        }
      }
      document.querySelectorAll<HTMLAnchorElement>("a[href]").forEach((a) => {
        preserveTicketVendorUtms(a);
      });

      // Track elements with data-ph-capture attribute.
      // The event name is taken from data-ph-capture so callers can emit
      // named events (apply_click, ticket_click, cta_clicked, etc.) directly.
      document.addEventListener("click", (e) => {
        const el = (e.target as HTMLElement).closest<HTMLElement>(
          "[data-ph-capture]",
        );
        if (!el) return;
        const eventName = el.dataset.phCapture!;
        const props: Record<string, string | null | boolean> = {
          page: window.location.pathname,
        };
        for (const [key, value] of Object.entries(el.dataset)) {
          if (key.startsWith("ph") && key !== "phCapture" && value) {
            const prop =
              key.charAt(2).toLowerCase() +
              key.slice(3).replace(/[A-Z]/g, (m) => "_" + m.toLowerCase());
            props[prop] = value;
          }
        }
        if (el.dataset.phCta) {
          props.cta_id = el.dataset.phCta;
        }
        // Augment with non-ph data-* tracking attributes
        const extraKeys = [
          "ctaPosition",
          "ctaText",
          "destinationUrl",
          "linkUrl",
          "linkDomain",
          "eventCity",
          "eventDate",
          "eventIsoDate",
          "eventTitle",
          "eventVendor",
          "articleSlug",
          "citySlug",
        ] as const;
        for (const camel of extraKeys) {
          const val = el.dataset[camel];
          if (val) {
            const snake = camel.replace(/[A-Z]/g, (m) => "_" + m.toLowerCase());
            props[snake] = val;
          }
        }
        const linked = el.closest<HTMLAnchorElement>("a[href]");
        if (linked?.href) {
          preserveTicketVendorUtms(linked);
          props.destination_url ??= linked.href;
          props.link_url ??= linked.href;
          props.link_domain ??= domainFromUrl(linked.href);
          props.event_vendor ??= isTicketVendorUrl(linked.href)
            ? vendorFromUrl(linked.href)
            : null;
          try {
            const linkedUrl = new URL(linked.href);
            if (linkedUrl.origin !== window.location.origin) {
              props.link_type = isTicketVendorUrl(linked.href)
                ? "ticket_vendor"
                : isSocialUrl(linked.href)
                  ? "social"
                  : "outbound";
            }
          } catch {
            /* invalid URL — keep declared tracking props only */
          }
        }
        props.cta_text ??=
          el.dataset.ctaText ||
          (el.textContent ?? "").trim().replace(/\s+/g, " ").slice(0, 120);
        capture(eventName, props);

        if (linked?.href) {
          let linkUrl: URL | null = null;
          try {
            linkUrl = new URL(linked.href);
          } catch {
            linkUrl = null;
          }
          if (
            linkUrl?.origin === window.location.origin &&
            linkUrl.pathname.startsWith("/apply") &&
            eventName !== "apply_click"
          ) {
            capture("apply_click", {
              ...props,
              inferred_event: true,
              destination_url: linked.href,
              link_url: linked.href,
            });
          }
          if (
            linkUrl?.origin === window.location.origin &&
            linkUrl.pathname.startsWith("/tickets") &&
            eventName !== "ticket_click"
          ) {
            capture("ticket_click", {
              ...props,
              inferred_event: true,
              destination_url: linked.href,
              link_url: linked.href,
            });
          }
        }
      });

      // Track outbound link clicks with safe-navigation guard.
      // For same-tab clicks, prevent default and delay navigation ~100ms so the
      // PostHog XHR has time to flush before the browser navigates away.
      document.addEventListener("click", (e) => {
        const link = (e.target as HTMLElement).closest<HTMLAnchorElement>(
          "a[href]",
        );
        if (!link?.href) return;
        if (link.href.startsWith("mailto:") || link.href.startsWith("tel:"))
          return;
        let url: URL;
        try {
          url = new URL(link.href);
        } catch {
          return;
        }
        if (url.origin === window.location.origin) return;

        const me = e as MouseEvent;
        const isModified =
          me.metaKey ||
          me.ctrlKey ||
          me.shiftKey ||
          me.altKey ||
          me.button !== 0;
        const targetSelf = !link.target || link.target === "_self";

        let linkType = "outbound";
        if (isTicketVendorUrl(link.href)) {
          preserveTicketVendorUtms(link);
          linkType = "ticket_vendor";
        } else if (isSocialUrl(link.href)) linkType = "social";

        const dataCapture = link.closest<HTMLElement>("[data-ph-capture]");

        // Always fire outbound_link_clicked with full destination URL unless a
        // declarative handler on the same click already emitted that raw event.
        if (dataCapture?.dataset.phCapture !== "outbound_link_clicked") {
          trackOutbound(link, {
            link_type: linkType,
            link_domain: domainFromUrl(link.href),
          });
        }

        // Fire a named ticket_click for all ticket vendor domains
        if (linkType === "ticket_vendor") {
          if (dataCapture?.dataset.phCapture !== "ticket_click") {
            capture("ticket_click", {
              destination_url: link.href,
              link_url: link.href,
              link_domain: domainFromUrl(link.href),
              vendor: vendorFromUrl(link.href),
              event_vendor: vendorFromUrl(link.href),
              cta_text:
                link.dataset.ctaText ||
                (link.textContent ?? "")
                  .trim()
                  .replace(/\s+/g, " ")
                  .slice(0, 120),
              cta_position: link.dataset.ctaPosition ?? null,
              event_city: link.dataset.eventCity ?? link.dataset.phCity ?? null,
              event_date:
                link.dataset.eventDate ?? link.dataset.phEventDate ?? null,
              event_title:
                link.dataset.eventTitle ?? link.dataset.phEventTitle ?? null,
            });
          }
        }

        // Safe-navigation: delay same-tab unmodified clicks so beacon can flush
        if (targetSelf && !isModified) {
          e.preventDefault();
          const dest = link.href;
          window.setTimeout(() => {
            window.location.assign(dest);
          }, 100);
        }
      });

      // Custom cursor — desktop only (pointer: fine), off for prefers-reduced-motion, off if noCursor
      if (
        window.matchMedia("(pointer: fine)").matches &&
        !window.matchMedia("(prefers-reduced-motion: reduce)").matches &&
        document.body.dataset.noCursor !== "true"
      ) {
        const cursor = document.getElementById("cursor");
        const ring = document.getElementById("cursorRing");
        if (cursor && ring) {
          let mx = 0,
            my = 0,
            rx = 0,
            ry = 0;
          const darkSel = ".shows,.spicelist,.photo-break,.photos";
          document.addEventListener("mousemove", (e) => {
            mx = e.clientX;
            my = e.clientY;
            const el = document.elementFromPoint(mx, my);
            const onDark = el?.closest(darkSel);
            cursor.classList.toggle("light", !!onDark);
            ring.classList.toggle("light", !!onDark);
          });
          (function loop() {
            rx += (mx - rx) * 0.12;
            ry += (my - ry) * 0.12;
            cursor.style.left = mx + "px";
            cursor.style.top = my + "px";
            ring.style.left = rx + "px";
            ring.style.top = ry + "px";
            requestAnimationFrame(loop);
          })();
          document
            .querySelectorAll('a,button,[role="button"]')
            .forEach((el) => {
              el.addEventListener("mouseenter", () => {
                cursor.style.width = "20px";
                cursor.style.height = "20px";
                ring.style.width = "60px";
                ring.style.height = "60px";
                ring.style.opacity = "0.8";
              });
              el.addEventListener("mouseleave", () => {
                cursor.style.width = "12px";
                cursor.style.height = "12px";
                ring.style.width = "40px";
                ring.style.height = "40px";
                ring.style.opacity = "0.5";
              });
            });
          document.documentElement.classList.add("custom-cursor");

          // Keep custom cursor visible over <dialog> top-layer
          const observer = new MutationObserver(() => {
            const openDialog = document.querySelector("dialog[open]");
            if (openDialog && cursor.parentElement !== openDialog) {
              openDialog.appendChild(cursor);
              openDialog.appendChild(ring);
            } else if (!openDialog && cursor.parentElement !== document.body) {
              document.body.appendChild(cursor);
              document.body.appendChild(ring);
            }
          });
          observer.observe(document.body, {
            subtree: true,
            attributes: true,
            attributeFilter: ["open"],
          });
          document.addEventListener(
            "astro:before-swap",
            () => observer.disconnect(),
            { once: true },
          );
        }
      }
    </script>
  </body>
</html>

<style>
  .grain-overlay {
    position: fixed;
    inset: 0;
    z-index: 50;
    pointer-events: none;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 180px 180px;
    animation: grainShift 0.5s steps(4) infinite;
  }

  @keyframes grainShift {
    0% {
      transform: translate(0, 0);
    }
    25% {
      transform: translate(-2px, 2px);
    }
    50% {
      transform: translate(2px, -1px);
    }
    75% {
      transform: translate(-1px, -2px);
    }
    100% {
      transform: translate(0, 0);
    }
  }

  @media (max-width: 768px) {
    .grain-overlay {
      display: none;
      animation: none;
    }
  }

  /* Custom cursor — only visible on desktop with mouse */
  .cursor,
  .cursor-ring {
    display: none;
  }

  :global(html.custom-cursor),
  :global(html.custom-cursor *),
  :global(html.custom-cursor *::before),
  :global(html.custom-cursor *::after) {
    cursor: none !important;
  }
  :global(html.custom-cursor dialog::backdrop) {
    cursor: none !important;
  }

  :global(html.custom-cursor) .cursor {
    display: block;
    position: fixed;
    width: 12px;
    height: 12px;
    background: var(--brand-red);
    border-radius: 50%;
    pointer-events: none;
    z-index: 99999;
    transform: translate(-50%, -50%);
    transition:
      width 0.15s,
      height 0.15s;
  }
  :global(html.custom-cursor) .cursor.light {
    background: white;
  }

  :global(html.custom-cursor) .cursor-ring {
    display: block;
    position: fixed;
    width: 40px;
    height: 40px;
    border: 1.5px solid var(--brand-red);
    border-radius: 50%;
    pointer-events: none;
    z-index: 99998;
    transform: translate(-50%, -50%);
    opacity: 0.5;
    transition:
      width 0.3s,
      height 0.3s,
      opacity 0.3s;
  }
  :global(html.custom-cursor) .cursor-ring.light {
    border-color: white;
  }
</style>
