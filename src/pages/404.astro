---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageNav from '@/components/layout/PageNav.astro';
---

<BaseLayout title="Page Not Found | Garam Masala Dating" description="The page you're looking for doesn't exist.">
  <PageNav />
  <div class="not-found">
    <div class="not-found-content">
      <p class="emoji">🌶️</p>
      <h1 class="heading">Page not found</h1>
      <a href="/" class="back-link">← Back to home</a>
    </div>
  </div>
</BaseLayout>

<style>
  .not-found {
    min-height: 100vh;
    background: var(--cream);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
  }
  .not-found-content { text-align: center; }
  .emoji { font-size: 3rem; margin-bottom: 16px; }
  .heading {
    font-family: var(--font-playfair);
    font-size: 28px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 12px;
  }
  .back-link {
    color: var(--hot-pink);
    font-size: 15px;
    font-weight: 500;
  }
</style>
