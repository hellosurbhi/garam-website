---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HomeNav from '@/components/home/HomeNav.astro';
---

<BaseLayout title="404 — Page Not Found | Garam Masala Dating" description="This page doesn't exist." hideNav={true}>
  <canvas id="glCanvas" class="not-found-shader"></canvas>
  <HomeNav ticketsUrl="/tickets" />
  <div class="not-found">
    <div class="not-found-content">
      <div class="not-found-code">404</div>
      <h1>This Page Ghosted <em>You</em></h1>
      <p>Just like your last Hinge match. But unlike them, we're still here. Let's find you somewhere better.</p>
      <div class="not-found-links">
        <a href="/" class="not-found-btn not-found-btn--primary">Go Home</a>
        <a href="/tickets" class="not-found-btn not-found-btn--outline">See Shows</a>
      </div>
    </div>
  </div>
</BaseLayout>

<script src="/js/shader-app.js" defer></script>

<style is:global>
  .not-found-shader {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    opacity: 0.5;
  }
  .not-found {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
    padding: 20px 24px 20px;
  }
  .not-found-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 480px;
  }
  .not-found-code {
    font-family: var(--font-playfair), serif;
    font-size: clamp(80px, 20vw, 180px);
    font-weight: 900;
    line-height: 1;
    color: var(--hot-pink);
    opacity: 0.15;
    margin-bottom: -20px;
  }
  .not-found-content h1 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(28px, 6vw, 48px);
    font-weight: 900;
    color: #000;
    margin-bottom: 12px;
  }
  .not-found-content h1 em {
    color: var(--hot-pink);
    font-style: italic;
  }
  .not-found-content > p {
    font-size: 16px;
    color: #000;
    max-width: 380px;
    margin: 0 auto 32px;
    line-height: 1.6;
    font-family: var(--font-body), sans-serif;
  }
  .not-found-links {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .not-found-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    border-radius: 50px;
    font-family: var(--font-body), sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    text-decoration: none;
    min-height: 48px;
    transition: all 0.3s;
  }
  .not-found-btn--primary {
    background: var(--hot-pink);
    color: white;
  }
  .not-found-btn--primary:hover {
    background: var(--deep-magenta);
    transform: translateY(-2px);
  }
  .not-found-btn--outline {
    background: transparent;
    color: #000;
    border: 1.5px solid #000;
  }
  .not-found-btn--outline:hover {
    background: #000;
    color: white;
    transform: translateY(-2px);
  }

  /* Footer on 404: transparent bg, pure black text */
  footer {
    background: transparent !important;
  }
  footer .footer-logo {
    filter: none !important;
    content: url(/favicon.svg) !important;
  }
  footer .footer-brand p {
    color: #000 !important;
  }
  footer .footer-social a {
    color: #000 !important;
    border-color: #000 !important;
  }
  footer .footer-social a:hover {
    color: var(--hot-pink) !important;
    border-color: var(--hot-pink) !important;
  }
  footer .footer-col h4 {
    color: #000 !important;
  }
  footer .footer-col ul li a {
    color: #000 !important;
  }
  footer .footer-col ul li a:hover {
    color: var(--hot-pink) !important;
  }
  footer .footer-copy {
    color: #000 !important;
  }
  footer .footer-top {
    border-bottom-color: rgba(0, 0, 0, 0.15) !important;
  }
</style>
