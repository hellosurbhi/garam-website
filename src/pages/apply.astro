---
import { Picture } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buildBreadcrumbJsonLd } from "@/utils/breadcrumbs";
import ApplyPage from "@/components/ApplyPage";
import { heroImg } from "@/assets/backgrounds";
import { APPLY_PAGE } from "@/data/copy";

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: "https://garammasaladating.com/" },
  { name: "Apply" },
]);
---

<BaseLayout
  title="Apply to Be a Contestant"
  description="Think you've got what it takes to go on a blind date in front of 250 people? Apply to be a contestant on Garam Masala Dating."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
    <link
      rel="preconnect"
      href="https://firestore.googleapis.com"
      crossorigin
    />
    <link
      rel="preconnect"
      href="https://firebasestorage.googleapis.com"
      crossorigin
    />
    <link
      rel="preconnect"
      href="https://identitytoolkit.googleapis.com"
      crossorigin
    />
  </Fragment>

  <main id="main-content" class="apply-main">
    <Picture
      class="apply-bg"
      src={heroImg}
      formats={["avif", "webp"]}
      widths={[640, 1024, 1600]}
      sizes="100vw"
      alt=""
      aria-hidden="true"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />

    <!--
      One shared container for all static + skeleton content.
      Individual sections hide via :has() — no double-padding between them.
    -->
    <div class="apply-static-wrapper">
      <div class="apply-skeleton-container">
        <!-- Back + title: permanent. Hides on form submission. -->
        <div class="apply-static-header">
          <div class="apply-skeleton-header">
            <button class="apply-back-btn" onclick="history.back()"
              >← Back</button
            >
          </div>
          <div class="apply-skeleton-title-area">
            <h1 class="apply-skeleton-title">
              {APPLY_PAGE.title}
            </h1>
            <p class="apply-skeleton-subtitle">
              {APPLY_PAGE.subtitle}
            </p>
          </div>
        </div>

        <!-- Intro: permanent. Hides on form submission. -->
        <div class="apply-intro-static">
          <div class="apply-skeleton-intro">
            <p>{APPLY_PAGE.introText}</p>
            <p class="apply-skeleton-must-be">The ideal candidate:</p>
            <ul class="apply-skeleton-reqs">
              {APPLY_PAGE.requirements.map((r) => <li>{r}</li>)}
            </ul>
          </div>
        </div>

        <!-- Skeleton form: type toggle + shimmer. Hides when React mounts. -->
        <div class="apply-skeleton-form" aria-hidden="true">
          <div class="apply-skeleton-type">
            <p class="apply-skeleton-type-label">I am applying…</p>
            <div class="apply-skeleton-type-group">
              <span class="apply-skeleton-type-btn apply-skeleton-type-active"
                >For myself</span
              >
              <span class="apply-skeleton-type-btn">For a friend</span>
            </div>
          </div>

          <h2 class="apply-skeleton-section">About You</h2>

          <div class="apply-skeleton-shimmer">
            <div class="shimmer-bar"></div>
            <div class="shimmer-bar shimmer-bar--medium"></div>
            <div class="shimmer-bar"></div>
            <div class="shimmer-bar shimmer-bar--short"></div>
          </div>
        </div>
      </div>

      <!-- React form lives inside the wrapper so it occupies the same
           vertical space as the skeleton — no layout shift when skeleton hides. -->
      <ApplyPage client:only="react" />
    </div>
  </main>
</BaseLayout>

<style is:global>
  /* Hide skeleton form when React has mounted */
  .apply-main:has([data-apply-root]) .apply-skeleton-form {
    display: none;
  }
  /* Hide static header + intro when form is submitted (success panel takes over) */
  .apply-main:has([data-submitted]) .apply-static-header,
  .apply-main:has([data-submitted]) .apply-intro-static {
    display: none;
  }
</style>

<style>
  .apply-main {
    position: relative;
    overflow: hidden;
    min-height: 100vh;
  }

  .apply-bg {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    display: block;
    z-index: 0;
    opacity: 0.06;
    pointer-events: none;
  }

  /* Single wrapper: positioning only, sections own their vertical spacing */
  .apply-static-wrapper {
    position: relative;
    z-index: 1;
  }

  .apply-skeleton-container {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Header provides the top breathing room for the whole page */
  .apply-static-header {
    padding-top: 20px;
  }

  .apply-skeleton-header {
    margin-bottom: 8px;
    min-height: var(--touch-target);
    display: flex;
    align-items: center;
  }

  .apply-back-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--charcoal);
    font-family: var(--font-body);
    font-size: 16px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    min-height: var(--touch-target);
  }

  /* Title */
  .apply-skeleton-title-area {
    text-align: center;
    margin-bottom: 24px;
  }
  .apply-skeleton-title {
    font-family: var(--font-playfair);
    font-size: clamp(36px, 5vw, 48px);
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.1;
    margin: 0 0 10px;
  }
  .apply-skeleton-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  /* Casting intro */
  .apply-skeleton-intro {
    margin-bottom: 32px;
    font-family: var(--font-body);
    font-size: 15px;
    color: #3d3532;
    line-height: 1.6;
    text-align: center;
  }
  .apply-skeleton-intro p {
    margin: 0 0 12px;
  }
  .apply-skeleton-must-be {
    font-weight: 700;
    margin-bottom: 4px;
  }
  .apply-skeleton-reqs {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .apply-skeleton-reqs li::before {
    content: "• ";
    color: var(--brand-red);
    font-weight: 700;
  }

  /* Type selector — matches .typeSection in ApplyPage.module.css */
  .apply-skeleton-type {
    margin-bottom: 36px;
  }
  .apply-skeleton-type-label {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--text-secondary);
    margin: 0 0 12px;
  }
  .apply-skeleton-type-group {
    display: flex;
    gap: 10px;
  }
  .apply-skeleton-type-btn {
    flex: 1;
    padding: 12px 16px;
    min-height: var(--touch-target);
    border-radius: 100px;
    border: 1px solid rgba(0, 0, 0, 0.15);
    background: transparent;
    color: var(--charcoal);
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    text-align: center;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .apply-skeleton-type-active {
    border: none;
    background: var(--brand-red);
    color: white;
  }

  /* Section heading — matches .sectionTitle in ApplyPage.module.css */
  .apply-skeleton-section {
    font-family: var(--font-playfair);
    font-size: 28px;
    font-weight: 600;
    color: var(--charcoal);
    margin: 0 0 20px;
    padding-bottom: 12px;
  }
  .apply-skeleton-section::after {
    content: "";
    display: block;
    width: 48px;
    height: 1px;
    background: rgba(var(--brand-red-rgb), 0.3);
    margin-top: 12px;
  }

  /* Shimmer bars */
  @keyframes shimmer-sweep {
    0% {
      background-position: -400px 0;
    }
    100% {
      background-position: 400px 0;
    }
  }

  .apply-skeleton-shimmer {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .shimmer-bar {
    height: 52px;
    width: 100%;
    border-radius: 12px;
    background-color: #ebebeb;
    background-image: linear-gradient(
      90deg,
      #ebebeb 0px,
      #f5f5f5 40px,
      #ebebeb 80px
    );
    background-size: 400px 100%;
    background-repeat: no-repeat;
    animation: shimmer-sweep 1.4s ease-in-out infinite;
  }

  .shimmer-bar--medium {
    width: 75%;
  }
  .shimmer-bar--short {
    width: 55%;
  }

  @media (prefers-reduced-motion: reduce) {
    .shimmer-bar {
      animation: none;
      background-image: none;
    }
  }
</style>
