---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buildBreadcrumbJsonLd } from "@/utils/breadcrumbs";
import ApplyPage from "@/components/ApplyPage";
import { APPLY_PAGE } from "@/data/copy";

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: "https://garammasaladating.com/" },
  { name: "Apply" },
]);
---

<BaseLayout
  title="Apply to Be a Contestant"
  description="Think you've got what it takes to go on a blind date in front of 250 people? Apply to be a contestant on Garam Masala Dating."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
    <link
      rel="preconnect"
      href="https://firestore.googleapis.com"
      crossorigin
    />
    <link
      rel="preconnect"
      href="https://firebasestorage.googleapis.com"
      crossorigin
    />
    <link
      rel="preconnect"
      href="https://identitytoolkit.googleapis.com"
      crossorigin
    />
    {
      import.meta.env.PUBLIC_TURNSTILE_SITE_KEY && (
        <script
          is:inline
          src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit&onload=__gmd_turnstile_load"
          async
          defer
        />
      )
    }
  </Fragment>

  <main id="main-content" class="apply-main">
    <!--
      One shared container for all static + skeleton content.
      Individual sections hide via :has() — no double-padding between them.
    -->
    <div class="apply-static-wrapper">
      <div class="apply-skeleton-container">
        <!-- Back + title: permanent. Hides on form submission. -->
        <div class="apply-static-header">
          <div class="apply-skeleton-header">
            <button class="apply-back-btn" onclick="history.back()"
              >← Back</button
            >
          </div>
          <div class="apply-skeleton-title-area">
            <h1 class="apply-skeleton-title">
              {APPLY_PAGE.title}
            </h1>
            <p class="apply-skeleton-subtitle">
              {APPLY_PAGE.subtitle}
            </p>
          </div>
        </div>

        <!-- Intro: permanent. Hides on form submission. -->
        <div class="apply-intro-static">
          <div class="apply-skeleton-intro">
            <p>{APPLY_PAGE.introText}</p>
            <p class="apply-skeleton-must-be">The ideal candidate:</p>
            <ul class="apply-skeleton-reqs">
              {APPLY_PAGE.requirements.map((r) => <li>{r}</li>)}
            </ul>
          </div>
        </div>

        <!-- Skeleton form: type toggle + shimmer. Hides when React mounts. -->
        <div class="apply-skeleton-form" aria-hidden="true">
          <div class="apply-skeleton-type">
            <p class="apply-skeleton-type-label">I am applying…</p>
            <div class="apply-skeleton-type-group">
              <span class="apply-skeleton-type-btn apply-skeleton-type-active"
                >For myself</span
              >
              <span class="apply-skeleton-type-btn">For a friend</span>
            </div>
          </div>

          <h2 class="apply-skeleton-section">About You</h2>

          <div class="apply-skeleton-shimmer">
            <div class="shimmer-bar"></div>
            <div class="shimmer-bar shimmer-bar--medium"></div>
            <div class="shimmer-bar"></div>
            <div class="shimmer-bar shimmer-bar--short"></div>
          </div>
        </div>
      </div>

      <!-- React form lives inside the wrapper so it occupies the same
           vertical space as the skeleton — no layout shift when skeleton hides. -->
      <ApplyPage client:only="react" />
    </div>
  </main>
</BaseLayout>

<style is:global>
  /* Hide skeleton form when React has mounted */
  .apply-main:has([data-apply-root]) .apply-skeleton-form {
    display: none;
  }
  /* Hide static header + intro when form is submitted (success panel takes over) */
  .apply-main:has([data-submitted]) .apply-static-header,
  .apply-main:has([data-submitted]) .apply-intro-static {
    display: none;
  }
</style>

<style>
  .apply-main {
    position: relative;
    min-height: 100vh;
    background: var(--cream-warm);
  }

  /* Single wrapper: positioning only, sections own their vertical spacing */
  .apply-static-wrapper {
    position: relative;
    z-index: 1;
  }

  .apply-skeleton-container {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Header: top breathing room + newsprint rule below title area */
  .apply-static-header {
    padding-top: 20px;
  }

  .apply-skeleton-header {
    margin-bottom: 8px;
    min-height: var(--touch-target);
    display: flex;
    align-items: center;
  }

  /* Back button: small uppercase Anton treatment */
  .apply-back-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: rgba(17, 17, 17, 0.65);
    font-family: var(--font-cormorant);
    font-size: 10px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    min-height: var(--touch-target);
  }

  /* Title area: left-aligned, double rule below */
  .apply-skeleton-title-area {
    text-align: left;
    margin-bottom: 0;
    padding: 12px 0 10px;
    border-top: 1.5px solid var(--ink);
    border-bottom: 4px double var(--ink);
    margin-bottom: 24px;
  }

  /* Main title: Anton display treatment */
  .apply-skeleton-title {
    font-family: var(--font-cormorant);
    font-size: clamp(44px, 7vw, 84px);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--ink);
    line-height: 1;
    margin: 0 0 8px;
  }

  /* Subtitle: Instrument Serif editorial */
  .apply-skeleton-subtitle {
    font-family: var(--font-playfair);
    font-size: clamp(18px, 2.8vw, 28px);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    line-height: 1.2;
    margin: 0;
  }

  /* Casting intro: left-aligned */
  .apply-skeleton-intro {
    margin-bottom: 32px;
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--ink);
    line-height: 1.6;
    text-align: left;
  }

  .apply-skeleton-intro p {
    margin: 0 0 12px;
  }

  .apply-skeleton-must-be {
    font-family: var(--font-cormorant);
    font-size: 10px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(17, 17, 17, 0.55);
    margin-bottom: 8px;
  }

  .apply-skeleton-reqs {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .apply-skeleton-reqs li {
    border-bottom: 1px dotted rgba(17, 17, 17, 0.3);
    padding: 8px 0;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--ink);
  }

  .apply-skeleton-reqs li::before {
    content: "\00B7\00A0";
    color: var(--brand-red);
    font-weight: 700;
  }

  /* Type selector — matches .typeSection in ApplyPage.module.css */
  .apply-skeleton-type {
    margin-bottom: 36px;
  }

  .apply-skeleton-type-label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(17, 17, 17, 0.55);
    margin: 0 0 12px;
  }

  .apply-skeleton-type-group {
    display: flex;
    gap: 10px;
  }

  /* Mobile: pill skeleton buttons */
  .apply-skeleton-type-btn {
    flex: 1;
    padding: 12px 16px;
    min-height: var(--touch-target);
    border-radius: 999px;
    border: 1.5px solid var(--ink);
    background: transparent;
    color: var(--ink);
    font-family: var(--font-cormorant);
    font-size: 12px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-align: center;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .apply-skeleton-type-active {
    background: var(--brand-red);
    border-color: var(--brand-red);
    color: var(--cream);
  }

  /* Desktop: square skeleton buttons */
  @media (min-width: 768px) {
    .apply-skeleton-type-btn {
      border-radius: 0;
    }
  }

  /* Section heading — matches .sectionTitle in ApplyPage.module.css */
  .apply-skeleton-section {
    font-family: var(--font-cormorant);
    font-size: 15px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink);
    margin: 0 0 20px;
    padding-bottom: 0;
  }

  .apply-skeleton-section::after {
    display: none;
  }

  /* Shimmer bars: newsprint tones */
  @keyframes shimmer-sweep {
    0% {
      background-position: -400px 0;
    }
    100% {
      background-position: 400px 0;
    }
  }

  .apply-skeleton-shimmer {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .shimmer-bar {
    height: 44px;
    width: 100%;
    border-radius: 0;
    background-color: var(--cream-warm);
    background-image: linear-gradient(
      90deg,
      var(--cream-warm) 0px,
      var(--poster-panel, #fbf3e4) 40px,
      var(--cream-warm) 80px
    );
    background-size: 400px 100%;
    background-repeat: no-repeat;
    animation: shimmer-sweep 1.4s ease-in-out infinite;
    border-bottom: 1.5px solid rgba(17, 17, 17, 0.15);
  }

  .shimmer-bar--medium {
    width: 75%;
  }

  .shimmer-bar--short {
    width: 55%;
  }

  @media (prefers-reduced-motion: reduce) {
    .shimmer-bar {
      animation: none;
      background-image: none;
    }
  }
</style>
