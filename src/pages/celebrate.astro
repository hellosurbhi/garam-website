---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buildBreadcrumbJsonLd } from "@/utils/breadcrumbs";
import FaqAccordion from "@/components/ui/FaqAccordion.astro";
import {
  CELEBRATE_COPY,
  OCCASION_TYPES,
  CELEBRATE_INCLUSIONS,
  CELEBRATE_TESTIMONIALS,
  CELEBRATE_FAQS,
} from "@/data/celebrate";

const TITLE =
  "Private Party Entertainment NYC | Birthday, Bachelor & Reception Ideas";
const DESC =
  "Book a live comedy dating show for your birthday, bachelor party, bachelorette, rehearsal dinner or wedding reception in NYC. Private show, no recording, flat fee. Email contact@garammasaladating.com.";

const SITE_URL = "https://garammasaladating.com";

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: `${SITE_URL}/` },
  { name: "Parties & Celebrations" },
]);

const serviceJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Private Party Show",
  description: DESC,
  provider: {
    "@type": "Organization",
    name: "Garam Masala Dating",
    url: SITE_URL,
    logo: `${SITE_URL}/images/logo.svg`,
  },
  areaServed: { "@type": "City", name: "New York City" },
  serviceType: "Live Entertainment",
});

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: CELEBRATE_FAQS.map((faq) => ({
    "@type": "Question",
    name: faq.q,
    acceptedAnswer: { "@type": "Answer", text: faq.a },
  })),
});

const speakableJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  url: `${SITE_URL}/celebrate`,
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: [".cel-faq-answer"],
  },
});
---

<BaseLayout title={TITLE} description={DESC}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
    <script type="application/ld+json" set:html={serviceJsonLd} />
    <script type="application/ld+json" set:html={faqJsonLd} />
    <script type="application/ld+json" set:html={speakableJsonLd} />
  </Fragment>

  <main id="main-content" class="cel">
    <!-- Hero -->
    <section class="cel-hero" aria-labelledby="cel-heading">
      <div class="cel-container cel-hero-inner">
        <p class="cel-eyebrow">{CELEBRATE_COPY.heroEyebrow}</p>
        <h1 id="cel-heading">{CELEBRATE_COPY.heroHeadline}</h1>
        <p class="cel-hero-sub">{CELEBRATE_COPY.heroSub}</p>
        <div class="cel-email-block">
          <p class="cel-email-label">Email us to book a private show:</p>
          <a
            href={`mailto:${CELEBRATE_COPY.bookingEmail}?subject=Private%20Party%20Inquiry`}
            class="cel-email-link"
            data-ph-capture="celebrate_inquiry_click"
            data-ph-cta="email_hero"
            data-ph-section="celebrate_hero"
            data-cta-position="celebrate_hero"
            data-cta-text={CELEBRATE_COPY.bookingEmail}
            data-destination-url={`mailto:${CELEBRATE_COPY.bookingEmail}?subject=Private%20Party%20Inquiry`}
            toolname="email-celebrate-booking"
            tooldescription="Email Garam Masala Dating to book a private party or celebration show in NYC."
            >{CELEBRATE_COPY.bookingEmail}</a
          >
          <p class="cel-email-note">{CELEBRATE_COPY.heroNote}</p>
        </div>
        <div class="cel-privacy-callout" role="note">
          <p>{CELEBRATE_COPY.noCameraNote}</p>
        </div>
      </div>
    </section>

    <!-- Photo -->
    <div class="cel-photo">
      <img
        src="/images/promo/on-stage.webp"
        alt="Contestants and hosts on stage at Garam Masala Dating"
        width="1200"
        height="800"
        loading="lazy"
      />
    </div>

    <!-- What a Private Show Looks Like -->
    <section class="cel-format" aria-labelledby="cel-format-heading">
      <div class="cel-container cel-format-grid">
        <div class="cel-format-text">
          <p class="cel-eyebrow">What a Private Show Looks Like</p>
          <h2 id="cel-format-heading">
            Real singles. Real dates. Your crowd loses their minds.
          </h2>
          {CELEBRATE_COPY.showFormatBody.map((p) => <p>{p}</p>)}
        </div>
        <div class="cel-format-img">
          <img
            src="/images/promo/after-party.webp"
            alt="Audience clapping at Garam Masala Dating show"
            width="1200"
            height="800"
            loading="lazy"
          />
        </div>
      </div>
    </section>

    <!-- Occasion Types -->
    <section class="cel-occasions" aria-labelledby="cel-occasions-heading">
      <div class="cel-container">
        <p class="cel-eyebrow">Perfect for Any Occasion</p>
        <h2 id="cel-occasions-heading">
          Pick the occasion. We handle the rest.
        </h2>
        <div class="cel-occasion-grid">
          {
            OCCASION_TYPES.map((occasion) => (
              <div class="cel-occasion-card">
                <span class="cel-occasion-icon" aria-hidden="true">
                  {occasion.icon}
                </span>
                <h3>{occasion.label}</h3>
                <p>{occasion.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- What's Included -->
    <section class="cel-inc" aria-labelledby="cel-inc-heading">
      <div class="cel-container">
        <p class="cel-eyebrow">What's Included</p>
        <h2 id="cel-inc-heading">Everything handled. You just show up.</h2>
        <div class="cel-inc-grid">
          {
            CELEBRATE_INCLUSIONS.map((item) => (
              <div class="cel-inc-card">
                <h3>{item.title}</h3>
                <p>{item.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Photos -->
    <div class="cel-photo-pair">
      <img
        src="/images/promo/the-match.webp"
        alt="Matched couple laughing on stage"
        width="1200"
        height="800"
        loading="lazy"
      />
      <img
        src="/images/promo/pure-chaos.webp"
        alt="High energy moment on stage at Garam Masala Dating"
        width="1200"
        height="800"
        loading="lazy"
      />
    </div>

    <!-- Testimonials -->
    <section class="cel-test" aria-labelledby="cel-test-heading">
      <div class="cel-container">
        <p class="cel-eyebrow">What People Say</p>
        <h2 id="cel-test-heading">
          "The best party any of us have ever been to."
        </h2>
        <div class="cel-quotes">
          {
            CELEBRATE_TESTIMONIALS.map((t) => (
              <blockquote class="cel-quote">
                <p>"{t.quote}"</p>
                <footer>
                  <strong>{t.author}</strong>
                  <span>{t.role}</span>
                </footer>
              </blockquote>
            ))
          }
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="cel-faq" aria-labelledby="cel-faq-heading">
      <div class="cel-container cel-faq-inner">
        <p class="cel-eyebrow">Common Questions</p>
        <h2 id="cel-faq-heading">FAQs</h2>
        <FaqAccordion
          items={CELEBRATE_FAQS}
          groupId="celebrate-faq"
          answerClass="cel-faq-answer"
        />
      </div>
    </section>

    <!-- CTA -->
    <section class="cel-cta" aria-labelledby="cel-cta-heading">
      <div class="cel-container cel-cta-inner">
        <h2 id="cel-cta-heading">{CELEBRATE_COPY.ctaHeadline}</h2>
        <p>{CELEBRATE_COPY.ctaBody}</p>
        <a
          href={`mailto:${CELEBRATE_COPY.bookingEmail}?subject=Private%20Party%20Inquiry`}
          class="cel-email-link cel-email-link--white"
          data-ph-capture="celebrate_inquiry_click"
          data-ph-cta="email_footer"
          data-ph-section="celebrate_cta"
          data-cta-position="celebrate_cta"
          data-cta-text={CELEBRATE_COPY.bookingEmail}
          data-destination-url={`mailto:${CELEBRATE_COPY.bookingEmail}?subject=Private%20Party%20Inquiry`}
          toolname="email-celebrate-booking"
          tooldescription="Email Garam Masala Dating to book a private party or celebration show in NYC."
          >{CELEBRATE_COPY.bookingEmail}</a
        >
        <p class="cel-cta-note">{CELEBRATE_COPY.ctaNote}</p>
        <nav class="cel-cta-links" aria-label="Related pages">
          <a href="/desi-events">South Asian Events</a>
          <a href="/corporate">Corporate Events</a>
          <a href="/tickets">Upcoming Shows</a>
          <a href="/hosts">Meet the Hosts</a>
        </nav>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .cel {
    font-family: var(--font-body), sans-serif;
  }
  .cel-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .cel-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--brand-red);
    margin-bottom: 14px;
  }

  /* Email CTA */
  .cel-email-block {
    margin-top: 32px;
  }
  .cel-email-label {
    font-size: 14px;
    color: var(--text-secondary);
    margin-bottom: 6px;
    font-weight: 600;
  }
  .cel-email-link {
    display: inline-flex;
    align-items: center;
    font-size: clamp(18px, 2.5vw, 24px);
    font-weight: 800;
    color: var(--brand-red);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
    transition: color 0.2s;
    min-height: var(--touch-target);
    padding: 4px 0;
  }
  .cel-email-link:hover {
    color: var(--brand-red-dark);
  }
  .cel-email-link:focus-visible {
    outline: 2px solid var(--brand-red);
    outline-offset: 3px;
  }
  .cel-email-link--white {
    color: white;
    text-decoration-color: white;
  }
  .cel-email-link--white:hover {
    color: var(--electric-yellow);
    text-decoration-color: var(--electric-yellow);
  }
  .cel-email-note {
    font-size: 13px;
    color: var(--muted);
    margin-top: 10px;
    max-width: 480px;
  }

  /* Privacy callout */
  .cel-privacy-callout {
    margin-top: 24px;
    background: rgba(220, 38, 38, 0.06);
    border: 1px solid rgba(220, 38, 38, 0.18);
    border-radius: 10px;
    padding: 14px 18px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  .cel-privacy-callout p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--charcoal);
    margin: 0;
    text-align: center;
  }

  /* Hero */
  .cel-hero {
    background: var(--off-white);
    padding: 56px 0 48px;
    text-align: center;
  }
  .cel-hero h1 {
    font-family: var(--font-display), sans-serif;
    font-size: clamp(36px, 7vw, 72px);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--charcoal);
    line-height: 0.92;
    margin-bottom: 20px;
  }
  .cel-hero-sub {
    font-family: var(--font-cormorant), serif;
    font-size: clamp(17px, 2.2vw, 22px);
    font-style: italic;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 640px;
    margin: 0 auto;
  }
  .cel-hero .cel-email-note {
    margin-left: auto;
    margin-right: auto;
  }

  /* Standalone photos */
  .cel-photo {
    line-height: 0;
  }
  .cel-photo img {
    width: 100%;
    height: auto;
    object-fit: cover;
    max-height: 240px;
  }
  .cel-photo-pair {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    line-height: 0;
  }
  .cel-photo-pair img {
    width: 100%;
    height: auto;
    object-fit: cover;
    max-height: 240px;
  }

  /* Format section */
  .cel-format {
    background: var(--cream-warm);
    padding: 56px 0;
  }
  .cel-format-grid {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .cel-format-text h2 {
    font-family: var(--font-display), sans-serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 400;
    text-transform: uppercase;
    color: var(--charcoal);
    line-height: 0.92;
    margin-bottom: 20px;
  }
  .cel-format-text p {
    font-size: 16px;
    line-height: 1.8;
    color: var(--text-secondary);
    margin-bottom: 14px;
  }
  .cel-format-img img {
    width: 100%;
    height: auto;
    border-radius: 14px;
    aspect-ratio: 3/2;
    object-fit: cover;
  }

  /* Occasion types */
  .cel-occasions {
    background: var(--off-white);
    padding: 56px 0;
    text-align: center;
  }
  .cel-occasions h2 {
    font-family: var(--font-display), sans-serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 400;
    text-transform: uppercase;
    line-height: 0.92;
    color: var(--charcoal);
    margin-bottom: 28px;
  }
  .cel-occasion-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }
  .cel-occasion-card {
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 14px;
    padding: 24px;
    text-align: center;
  }
  .cel-occasion-icon {
    display: block;
    font-size: 40px;
    line-height: 1;
    margin-bottom: 12px;
  }
  .cel-occasion-card h3 {
    font-family: var(--font-serif), serif;
    font-size: 18px;
    font-weight: 400;
    color: var(--brand-red);
    margin-bottom: 8px;
  }
  .cel-occasion-card p {
    font-size: 14px;
    line-height: 1.65;
    color: var(--text-secondary);
    margin: 0;
    text-align: left;
  }

  /* Inclusions */
  .cel-inc {
    background: var(--cream-warm);
    padding: 56px 0;
    text-align: center;
  }
  .cel-inc h2 {
    font-family: var(--font-display), sans-serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 400;
    text-transform: uppercase;
    line-height: 0.92;
    color: var(--charcoal);
    margin-bottom: 28px;
  }
  .cel-inc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }
  .cel-inc-card {
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 14px;
    padding: 24px;
  }
  .cel-inc-card h3 {
    font-family: var(--font-serif), serif;
    font-size: 18px;
    font-weight: 400;
    color: var(--brand-red);
    margin-bottom: 8px;
  }
  .cel-inc-card p {
    font-size: 14px;
    line-height: 1.65;
    color: var(--text-secondary);
    margin: 0;
    text-align: left;
  }

  /* Testimonials */
  .cel-test {
    background: var(--off-white);
    padding: 56px 0;
    text-align: center;
  }
  .cel-test h2 {
    font-family: var(--font-display), sans-serif;
    font-size: clamp(22px, 3vw, 34px);
    font-weight: 400;
    text-transform: uppercase;
    line-height: 0.92;
    color: var(--charcoal);
    margin-bottom: 28px;
  }
  .cel-quotes {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .cel-quote {
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 14px;
    padding: 24px;
    margin: 0;
    text-align: left;
  }
  .cel-quote p {
    font-family: var(--font-cormorant), serif;
    font-size: clamp(16px, 2vw, 18px);
    font-style: italic;
    color: var(--charcoal);
    line-height: 1.7;
    margin: 0 0 12px;
  }
  .cel-quote footer {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .cel-quote strong {
    font-size: 13px;
    color: var(--brand-red);
  }
  .cel-quote span {
    font-size: 12px;
    color: var(--muted);
  }

  /* FAQ */
  .cel-faq {
    background: var(--cream-warm);
    padding: 56px 0;
  }
  .cel-faq-inner {
    max-width: 760px;
  }
  .cel-faq h2 {
    font-family: var(--font-display), sans-serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 400;
    text-transform: uppercase;
    line-height: 0.92;
    color: var(--charcoal);
    margin-bottom: 28px;
  }

  /* CTA */
  .cel-cta {
    background: var(--brand-red);
    padding: 56px 0;
    text-align: center;
  }
  .cel-cta-inner {
    max-width: 640px;
  }
  .cel-cta h2 {
    font-family: var(--font-display), sans-serif;
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 400;
    text-transform: uppercase;
    line-height: 0.92;
    color: white;
    margin-bottom: 16px;
  }
  .cel-cta p {
    font-size: 16px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 24px;
  }
  .cel-cta-note {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.5);
    margin-top: 10px;
    margin-bottom: 0;
  }
  .cel-cta-links {
    display: flex;
    gap: 24px;
    justify-content: center;
    margin-top: 28px;
    flex-wrap: wrap;
  }
  .cel-cta-links a {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s;
    min-height: var(--touch-target);
    display: inline-flex;
    align-items: center;
  }
  .cel-cta-links a:hover {
    color: white;
  }
  .cel-cta-links a:focus-visible {
    outline: 2px solid white;
    outline-offset: 3px;
  }

  @media (min-width: 480px) {
    .cel-occasion-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .cel-hero {
      padding: 80px 0 72px;
    }
    .cel-photo img {
      max-height: 500px;
    }
    .cel-photo-pair {
      grid-template-columns: 1fr 1fr;
    }
    .cel-photo-pair img {
      height: 100%;
      max-height: 400px;
    }
    .cel-format {
      padding: 80px 0;
    }
    .cel-format-grid {
      flex-direction: row;
      align-items: center;
      gap: 48px;
    }
    .cel-format-text {
      flex: 1.2;
    }
    .cel-format-img {
      flex: 0.8;
    }
    .cel-occasions {
      padding: 80px 0;
    }
    .cel-occasion-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    /* Center the 7th card (lone item in the last row of a 3-column grid) */
    .cel-occasion-card:last-child:nth-child(3n + 1) {
      grid-column: 2;
    }
    .cel-inc {
      padding: 80px 0;
    }
    .cel-inc-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .cel-test {
      padding: 80px 0;
    }
    .cel-quotes {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
    }
    .cel-faq {
      padding: 80px 0;
    }
    .cel-cta {
      padding: 80px 0;
    }
  }
</style>
