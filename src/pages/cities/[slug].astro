---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EventbriteWidgetInit from "@/components/EventbriteWidgetInit.astro";
import { cities } from "@/data/cities";
import type { CityData } from "@/data/cities";
import { getUpcomingEventsForCity } from "@/utils/cityEvents";
import { buildBreadcrumbJsonLd } from "@/utils/breadcrumbs";
import { buildEventSchemas } from "@/utils/eventSchema";
import { Picture } from "astro:assets";
import { SHOW_IMAGES_ASSETS } from "@/assets/backgrounds";
import { slugToImageIndex } from "@/data/images";
import { formatEventLocation } from "@/utils/eventCity";
import { getPostBySlug } from "@/data/journal";
import { isPublished } from "@/utils/date";
import { SOCIAL_URLS } from "@/data/socials";
import CityEventTicketEmbed from "@/components/cities/CityEventTicketEmbed.astro";
import { buildTicketUrl } from "@/utils/eventUrl";
import { domainFromUrl, vendorFromUrl } from "@/lib/analyticsCapture";
import { EVENTS, CITY_FOLLOW } from "@/data/copy";

export function getStaticPaths() {
  return Object.keys(cities).map((slug) => ({
    params: { slug },
    props: { city: cities[slug] },
  }));
}

const { city } = Astro.props;

const heroImage =
  SHOW_IMAGES_ASSETS[slugToImageIndex(city.slug, SHOW_IMAGES_ASSETS.length)];

// Nearby cities for cross-linking
const nearbyCities = (city.nearbyCities ?? [])
  .map((slug) => cities[slug])
  .filter((c): c is CityData => c !== undefined)
  .slice(0, 5);

const title = city.titleTag;
const description = city.metaDescription;

// Upcoming events for this city — derived from events data, not city.status
const cityEvents = getUpcomingEventsForCity(city.slug);

/* ── City JSON-LD ─────────────────────────────────────────── */

const cityPageUrl = `https://garammasaladating.com/cities/${city.slug}`;

function buildCityJsonLd(c: CityData): string {
  const graph: Record<string, unknown>[] = [
    {
      "@type": "LocalBusiness",
      name: "Garam Masala Dating",
      url: "https://garammasaladating.com",
      areaServed: c.areaServed,
    },
    {
      "@type": "WebPage",
      "@id": cityPageUrl,
      url: cityPageUrl,
      name: c.titleTag,
      description: c.metaDescription,
      inLanguage: "en-US",
      isPartOf: {
        "@type": "WebSite",
        "@id": "https://garammasaladating.com",
      },
    },
  ];

  if (c.faqItems && c.faqItems.length > 0) {
    graph.push({
      "@type": "FAQPage",
      mainEntity: c.faqItems.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: { "@type": "Answer", text: item.a },
      })),
    });
  }

  return JSON.stringify({ "@context": "https://schema.org", "@graph": graph });
}

const cityJsonLd = buildCityJsonLd(city);
const cityEventSchemas = buildEventSchemas(cityEvents);

const speakableJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: [".city-h1", ".city-paragraph"],
  },
  url: cityPageUrl,
});

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: "https://garammasaladating.com/" },
  { name: "Cities", url: "https://garammasaladating.com/cities" },
  { name: city.displayName },
]);

// Featured internal links appended to every city's journal section:
// - best-indian-dating-apps-ranked is the site's biggest-impression page
//   (GSC: 1,493 impressions, position 25.68); 300+ city pages linking to it
//   is the single largest internal-link boost available.
// - Active cities (real NYC-scene relevance) also feature the flagship
//   category guide.
const featuredArticleSlugs = [
  "best-indian-dating-apps-ranked",
  ...(city.status === "active" ? ["live-dating-shows-nyc-2026"] : []),
];
const relatedSlugs = [
  ...(city.relatedArticleSlugs ?? []),
  ...featuredArticleSlugs.filter(
    (s) => !(city.relatedArticleSlugs ?? []).includes(s),
  ),
];
const relatedPosts = relatedSlugs
  .map((slug) => getPostBySlug(slug))
  .filter(
    (p): p is NonNullable<typeof p> =>
      p !== undefined && isPublished(p.datePublished),
  );

const applyHref =
  city.ctas.find((c) => c.href !== "#waitlist")?.href ?? "/apply";

const waitlistCta = city.ctas.find((c) => c.href === "#waitlist") ?? {
  label: `Join the ${city.displayName} Waitlist`,
  href: "#waitlist",
};
const applyCtas = city.ctas.filter((c) => c.href !== "#waitlist");
const staticPrimaryCta = cityEvents.length === 0 ? waitlistCta : null;
const staticSecondaryCtas = applyCtas;

// State C copy: no live event, so follow CTAs are primary and the waitlist
// is the data capture beneath. {city} placeholders resolved here.
const followIntro = CITY_FOLLOW.intro.replace("{city}", city.displayName);
const followWaitlistIntro = CITY_FOLLOW.waitlistIntro.replace(
  "{city}",
  city.displayName,
);

const cityStatus = cityEvents.length
  ? {
      label: "Upcoming show",
      text:
        cityEvents.length === 1
          ? `${cityEvents[0].date} tickets are live.`
          : `${cityEvents.length} upcoming dates are live.`,
    }
  : city.status === "past"
    ? {
        label: "Past show",
        text: "Join the waitlist for the next drop.",
      }
    : city.status === "coming-soon"
      ? {
          label: `We're Coming to ${city.displayName}!`,
          text: `${city.displayName} is on the tour list. Sign up below and help us get there! Everyone on the list gets tickets first when we announce.`,
        }
      : {
          label: `${city.displayName} Waitlist`,
          text: "No date is live yet. Get on the list and be first when tickets drop.",
        };

function renderCityText(text: string, href: string): string {
  return text
    .replace(
      /get on the list|join the waitlist/gi,
      `<button class="city-inline-cta" data-waitlist-trigger data-ph-capture="waitlist_click" data-ph-cta="inline_waitlist" data-ph-section="city_body" data-cta-position="city_body_inline" data-cta-text="$&" data-event-city="${city.displayName}" data-city-slug="${city.slug}">$&</button>`,
    )
    .replace(
      /apply to be a contestant|apply now/gi,
      `<a class="city-inline-link" href="${href}" data-ph-capture="apply_click" data-ph-cta="inline_apply" data-ph-section="city_body" data-cta-position="city_body_inline" data-cta-text="$&" data-destination-url="${href}" data-event-city="${city.displayName}" data-city-slug="${city.slug}">$&</a>`,
    );
}
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={cityJsonLd} />
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
    <script type="application/ld+json" set:html={speakableJsonLd} />
    {
      cityEventSchemas.map((schema) => (
        <script type="application/ld+json" set:html={schema} />
      ))
    }
  </Fragment>

  <main id="main-content" class="city-page">
    <Picture
      class="city-bg"
      src={heroImage}
      formats={["avif", "webp"]}
      widths={[640, 1024, 1600]}
      sizes="100vw"
      alt=""
      aria-hidden="true"
      loading="lazy"
      decoding="async"
      fetchpriority="low"
    />
    <div class="city-container">
      {/* Eyebrow label */}
      <p class="city-eyebrow">{city.displayName}</p>

      {/* H1 */}
      <h1 class="city-h1">{city.h1}</h1>

      {/* Ticket hero — shown above the fold when tickets are live */}
      {
        cityEvents.length > 0 && (
          <section class="city-ticket-hero" aria-label="Buy tickets">
            <h2 class="city-ticket-hero__title">
              Grab a seat, {cityEvents[0]?.city ?? ""} shows fill fast
            </h2>
            <div class="city-ticket-hero__embeds">
              {cityEvents.map((event) => (
                <CityEventTicketEmbed event={event} citySlug={city.slug} />
              ))}
            </div>
          </section>
        )
      }

      {city.communityStats && <p class="city-stat">{city.communityStats}</p>}

      {
        cityEvents.length === 0 && (
          <a
            href="#waitlist"
            class="city-status city-status--demand"
          >
            <span class="city-status__label">{cityStatus.label}</span>
            <p class="city-status__text">{cityStatus.text}</p>
          </a>
        )
      }

      {/* Body */}
      <div class="city-body">
        {
          city.bodyParagraphs.map((para) => (
            <p
              class="city-paragraph"
              set:html={renderCityText(para, applyHref)}
            />
          ))
        }
      </div>

      {/* Deep-dive sections (h2 + paragraphs) for enriched city pages */}
      {
        (city.sections ?? []).map((section) => (
          <section class="city-section">
            <h2 class="city-section__heading">{section.heading}</h2>
            {section.paragraphs.map((para) => (
              <p
                class="city-paragraph"
                set:html={renderCityText(para, applyHref)}
              />
            ))}
          </section>
        ))
      }

      {/* CTAs */}
      <div class="city-ctas">
        {
          /* Per-event scroll anchors: scroll up to the inline embed in the hero */
        }
        {
          cityEvents.map((event) => {
            const isSoldOut = event.soldOut ?? false;
            const evLocation = formatEventLocation(event);
            const evTicketUrl = buildTicketUrl(event.url, "cities", city.slug);
            const evTitle = `Garam Masala Dating - ${evLocation} - ${event.date}`;
            const evCtaText = isSoldOut
              ? "Sold Out"
              : `${event.date}: ${EVENTS.ticketCta}`;
            const scrollHref =
              event.eventbriteId && !isSoldOut
                ? `#buy-${event.eventbriteId}`
                : evTicketUrl;
            const isExternal = !event.eventbriteId || isSoldOut;
            return (
              <a
                href={scrollHref}
                {...(isExternal
                  ? { target: "_blank", rel: "noopener noreferrer" }
                  : {})}
                class={`city-cta city-cta--primary${isSoldOut ? " city-cta--soldout" : ""}`}
                data-ph-capture="ticket_click"
                data-ph-cta="city_event_ticket"
                data-ph-section="cities"
                data-ph-price={event.price}
                data-ph-event-date={event.isoDate ?? event.date}
                data-ph-event-title={evTitle}
                data-cta-position="city_event_ticket"
                data-cta-text={evCtaText}
                data-destination-url={evTicketUrl}
                data-link-url={evTicketUrl}
                data-link-domain={domainFromUrl(evTicketUrl)}
                data-event-city={evLocation}
                data-event-date={event.isoDate ?? event.date}
                data-event-title={evTitle}
                data-event-vendor={vendorFromUrl(evTicketUrl)}
                data-city-slug={city.slug}
              >
                <span>{evCtaText}</span>
                {!isSoldOut && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="city-cta__arrow"
                    aria-hidden="true"
                  >
                    <path d="M5 12h14" />
                    <path d="m12 5 7 7-7 7" />
                  </svg>
                )}
              </a>
            );
          })
        }
        {/* Contextual waitlist prompt for cities with events */}
        {
          cityEvents.length > 0 && (
            <p class="city-waitlist-prompt">
              {cityEvents.length === 1
                ? `Can't make it ${cityEvents[0].date}?`
                : "None of these dates work?"}{" "}
              <button
                type="button"
                class="city-waitlist-prompt__btn"
                data-waitlist-trigger
                data-ph-capture="waitlist_click"
                data-ph-cta="future_show_waitlist"
                data-ph-section="city_event_ctas"
                data-cta-position="city_event_waitlist_prompt"
                data-cta-text="Add your name to the waitlist for future shows."
                data-event-city={city.displayName}
                data-city-slug={city.slug}
              >
                Add your name to the waitlist for future shows.
              </button>
            </p>
          )
        }
        {
          /* State C: no live event. Follow buttons are the primary CTA (the
            show only exists on YouTube/Instagram), waitlist is the capture. */
        }
        {
          cityEvents.length === 0 && (
            <div class="city-follow">
              <p class="city-follow__intro">{followIntro}</p>
              <a
                href={SOCIAL_URLS.youtube}
                target="_blank"
                rel="noopener noreferrer"
                class="city-cta city-follow__btn city-follow__btn--youtube"
                data-ph-capture="cta_clicked"
                data-ph-cta="city_follow_youtube"
                data-ph-section="city_follow"
                data-cta-position="city_follow_primary"
                data-cta-text={CITY_FOLLOW.youtubeLabel}
                data-destination-url={SOCIAL_URLS.youtube}
                data-event-city={city.displayName}
                data-city-slug={city.slug}
              >
                <span>{CITY_FOLLOW.youtubeLabel}</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="city-follow__icon"
                  aria-hidden="true"
                >
                  <path d="M23 12s0-3.5-.44-5.17a2.78 2.78 0 0 0-1.96-1.96C18.93 4.43 12 4.43 12 4.43s-6.93 0-8.6.44a2.78 2.78 0 0 0-1.96 1.96C1 8.5 1 12 1 12s0 3.5.44 5.17a2.78 2.78 0 0 0 1.96 1.96c1.67.44 8.6.44 8.6.44s6.93 0 8.6-.44a2.78 2.78 0 0 0 1.96-1.96C23 15.5 23 12 23 12ZM9.75 15.02V8.98L15.5 12l-5.75 3.02Z" />
                </svg>
              </a>
              <a
                href={SOCIAL_URLS.instagram}
                target="_blank"
                rel="noopener noreferrer"
                class="city-cta city-follow__btn city-follow__btn--instagram"
                data-ph-capture="cta_clicked"
                data-ph-cta="city_follow_instagram"
                data-ph-section="city_follow"
                data-cta-position="city_follow_primary"
                data-cta-text={CITY_FOLLOW.instagramLabel}
                data-destination-url={SOCIAL_URLS.instagram}
                data-event-city={city.displayName}
                data-city-slug={city.slug}
              >
                <span>{CITY_FOLLOW.instagramLabel}</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="city-follow__icon"
                  aria-hidden="true"
                >
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37Z" />
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
                </svg>
              </a>
              <p class="city-follow__support">{followWaitlistIntro}</p>
              <a
                href="/tickets"
                class="city-cta city-follow__btn city-follow__btn--nearby"
                data-ph-capture="ticket_click"
                data-ph-cta="city_follow_nearby"
                data-ph-section="city_follow"
                data-cta-position="city_follow_nearby"
                data-cta-text={CITY_FOLLOW.nearbyCtaLabel}
                data-destination-url="/tickets"
                data-event-city={city.displayName}
                data-city-slug={city.slug}
              >
                <span>{CITY_FOLLOW.nearbyCtaLabel}</span>
              </a>
            </div>
          )
        }
        {/* Primary static CTA */}
        {
          staticPrimaryCta &&
            (staticPrimaryCta.href === "#waitlist" ? (
              <button
                type="button"
                class="city-cta city-cta--primary"
                data-waitlist-trigger
                data-ph-capture="waitlist_click"
                data-ph-cta="city_waitlist"
                data-ph-section="city_ctas"
                data-cta-position="city_primary"
                data-cta-text={staticPrimaryCta.label}
                data-event-city={city.displayName}
                data-city-slug={city.slug}
              >
                <span>{staticPrimaryCta.label}</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="city-cta__arrow"
                  aria-hidden="true"
                >
                  <path d="M5 12h14" />
                  <path d="m12 5 7 7-7 7" />
                </svg>
              </button>
            ) : (
              <a
                href={staticPrimaryCta.href}
                class="city-cta city-cta--primary"
                data-ph-capture="apply_click"
                data-ph-cta="city_apply"
                data-ph-section="city_ctas"
                data-cta-position="city_primary"
                data-cta-text={staticPrimaryCta.label}
                data-destination-url={staticPrimaryCta.href}
                data-event-city={city.displayName}
                data-city-slug={city.slug}
              >
                <span>{staticPrimaryCta.label}</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="city-cta__arrow"
                  aria-hidden="true"
                >
                  <path d="M5 12h14" />
                  <path d="m12 5 7 7-7 7" />
                </svg>
              </a>
            ))
        }
        {/* Secondary CTAs as text links */}
        {
          staticSecondaryCtas.map((cta) =>
            cta.href === "#waitlist" ? (
              <button
                type="button"
                class="city-cta--tertiary"
                data-waitlist-trigger
                data-ph-capture="waitlist_click"
                data-ph-cta="city_waitlist"
                data-ph-section="city_ctas"
                data-cta-position="city_secondary"
                data-cta-text={cta.label}
                data-event-city={city.displayName}
                data-city-slug={city.slug}
              >
                {cta.label} &rarr;
              </button>
            ) : (
              <a
                href={cta.href}
                class="city-cta--tertiary"
                data-ph-capture="apply_click"
                data-ph-cta="city_apply"
                data-ph-section="city_ctas"
                data-cta-position="city_secondary"
                data-cta-text={cta.label}
                data-destination-url={cta.href}
                data-event-city={city.displayName}
                data-city-slug={city.slug}
              >
                {cta.label} &rarr;
              </a>
            ),
          )
        }
      </div>

      {/* Waitlist modal */}
      <dialog id="waitlist-modal" class="modal-dialog">
        <div class="modal-inner">
          <button type="button" class="modal-close" aria-label="Close">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg
            >
          </button>
          <div id="waitlist-form-view">
            <h2 class="modal-title">Join the {city.displayName} Waitlist</h2>
            <p class="modal-subtitle">
              We'll email you the moment tickets drop for {city.displayName}.
            </p>
            <form
              id="waitlist-form"
              class="modal-form"
              toolname="join-city-show-waitlist"
              tooldescription="Join the waitlist for Garam Masala Dating shows in this city. You will be notified when tickets go on sale."
            >
              <input
                type="email"
                id="waitlist-email"
                class="ph-mask"
                placeholder="Your email"
                required
                aria-label="Email address"
                aria-describedby="waitlist-error"
                toolparamdescription="Email address to be notified when show tickets go on sale in this city"
              />
              <input
                type="tel"
                id="waitlist-phone"
                class="ph-mask"
                placeholder="Phone for text drops (optional)"
                aria-label="Phone number (optional)"
                aria-describedby="waitlist-error"
                autocomplete="tel"
                inputmode="tel"
                toolparamdescription="Mobile phone number for SMS ticket drops in this city (optional)"
              />
              <p id="waitlist-error" class="modal-error" hidden role="alert">
              </p>
              <button type="submit" class="modal-submit"
                >Join the Waitlist</button
              >
            </form>
          </div>
          <div id="waitlist-success" class="modal-success" hidden>
            <p>You're on the list! We'll let you know.</p>
          </div>
        </div>
      </dialog>

      {
        /* Email + phone signup. Renders in every state: for event cities it
          captures repeat interest, for no-event cities it is the data
          capture for future tickets that pairs with the follow buttons. */
      }
      {
        (
          <div id="waitlist" class="city-notify">
            <div class="city-notify__steps">
              <div id="city-notify-step1">
                <h3 class="city-notify__title">Stay in the Loop</h3>
                <p class="city-notify__desc">
                  Get notified about future {city.displayName} shows, discount
                  codes, and free ticket drops.
                </p>
                <form
                  id="city-notify-email-form"
                  class="city-notify__form"
                  toolname="subscribe-to-city-show-alerts"
                  tooldescription="Subscribe to email notifications for upcoming Garam Masala Dating shows in this city, including discount codes and ticket drops."
                >
                  <input
                    type="email"
                    id="city-notify-email"
                    class="ph-mask"
                    placeholder="Your email"
                    required
                    aria-label="Email address"
                    aria-describedby="city-notify-email-error"
                    toolparamdescription="Email address for show announcements, discount codes, and ticket drops in this city"
                  />
                  <p
                    id="city-notify-email-error"
                    class="city-notify__error"
                    hidden
                    role="alert"
                  />
                  <button type="submit">Get Notified</button>
                </form>
              </div>
              <div id="city-notify-step2" hidden>
                <p class="city-notify__desc">
                  Add your number for text-only discounts and free ticket drops.
                </p>
                <form
                  id="city-notify-phone-form"
                  class="city-notify__form"
                  toolname="add-phone-to-city-show-alerts"
                  tooldescription="Add a phone number for SMS notifications about upcoming Garam Masala Dating shows in this city (optional step after email signup)."
                >
                  <input
                    type="tel"
                    id="city-notify-phone"
                    class="ph-mask"
                    placeholder="(555) 123-4567"
                    aria-label="Phone number"
                    aria-describedby="city-notify-phone-error"
                    toolparamdescription="Mobile phone number for SMS-only ticket drops and show alerts in this city (optional)"
                  />
                  <p
                    id="city-notify-phone-error"
                    class="city-notify__error"
                    hidden
                    role="alert"
                  />
                  <button type="submit">Send Me Deals</button>
                </form>
                <button
                  type="button"
                  id="city-notify-skip"
                  class="city-notify__skip"
                >
                  Maybe later
                </button>
              </div>
              <div id="city-notify-success" hidden>
                <p class="city-notify__done">You're on the list!</p>
              </div>
            </div>
          </div>
        )
      }

      {/* FAQ section */}
      {
        city.faqItems && city.faqItems.length > 0 && (
          <div class="city-faq">
            <h3 class="city-faq__title">
              Questions About {city.displayName} Shows
            </h3>
            <div class="city-faq__list">
              {city.faqItems.map((item) => (
                <details class="city-faq__item">
                  <summary class="city-faq__question">{item.q}</summary>
                  <p
                    class="city-faq__answer"
                    set:html={renderCityText(item.a, applyHref)}
                  />
                </details>
              ))}
            </div>
          </div>
        )
      }

      {/* Related journal articles */}
      {
        relatedPosts.length > 0 && (
          <div class="city-articles">
            <h3 class="city-articles__title">From the Journal</h3>
            <div class="city-articles__list">
              {relatedPosts.map((post) => (
                <a
                  href={`/journal/${post.slug}`}
                  class="city-articles__card"
                  data-ph-capture="cta_clicked"
                  data-ph-cta="city_related_journal"
                  data-ph-section="city_articles"
                  data-cta-position="city_related_journal"
                  data-cta-text={post.title}
                  data-destination-url={`/journal/${post.slug}`}
                  data-event-city={city.displayName}
                  data-city-slug={city.slug}
                >
                  <span class="city-articles__card-title">{post.title}</span>
                  <span class="city-articles__card-arrow">&rarr;</span>
                </a>
              ))}
            </div>
          </div>
        )
      }

      {/* Nearby cities */}
      {
        nearbyCities.length > 0 && (
          <p class="city-nearby">
            <span class="city-nearby__label">Also coming to: </span>
            {nearbyCities.map((nc, i) => (
              <>
                <a
                  href={`/cities/${nc.slug}`}
                  class="city-nearby__link"
                  data-ph-capture="cta_clicked"
                  data-ph-cta="nearby_city"
                  data-ph-section="city_nearby"
                  data-cta-position="city_nearby"
                  data-cta-text={nc.displayName}
                  data-destination-url={`/cities/${nc.slug}`}
                  data-event-city={city.displayName}
                  data-city-slug={city.slug}
                >
                  {nc.displayName}
                </a>
                {i < nearbyCities.length - 1 && (
                  <span class="city-nearby__sep">, </span>
                )}
              </>
            ))}
          </p>
        )
      }

      {/* Footer */}
      <div class="city-footer">
        <a href="/cities" class="city-footer__link"> &larr; All cities </a>
      </div>
    </div>
  </main>
  <EventbriteWidgetInit />
</BaseLayout>

<script>
  import { cleanPhone } from "@/lib/phone";
  import { identifyLead, trackLeadEvent } from "@/lib/analytics";
  import { buildLeadAttribution } from "@/lib/leadAttribution";
  import {
    captureLead,
    updateLeadPhone,
    type LeadCaptureResult,
  } from "@/lib/leadSubmission";

  const dialog = document.getElementById("waitlist-modal") as HTMLDialogElement;
  const citySlug =
    window.location.pathname.split("/").filter(Boolean).at(-1) ?? "";
  if (dialog) {
    document.querySelectorAll("[data-waitlist-trigger]").forEach((btn) => {
      btn.addEventListener("click", () => {
        trackLeadEvent("waitlist_modal_opened", {
          source: "city-waitlist",
          sourcePage: window.location.pathname,
          sourceCitySlug: citySlug,
          city:
            document.querySelector(".city-eyebrow")?.textContent?.trim() ??
            undefined,
          event_city:
            document.querySelector(".city-eyebrow")?.textContent?.trim() ??
            undefined,
        });
        dialog.showModal();
      });
    });
    dialog
      .querySelector(".modal-close")
      ?.addEventListener("click", () => dialog.close());
    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) dialog.close();
    });

    document
      .getElementById("waitlist-form")
      ?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const email = (
          document.getElementById("waitlist-email") as HTMLInputElement
        ).value;
        const phoneRaw = (
          document.getElementById("waitlist-phone") as HTMLInputElement | null
        )?.value.trim();
        const phone = phoneRaw ? cleanPhone(phoneRaw) : "";
        const city = document.querySelector(".city-eyebrow")?.textContent ?? "";
        const submitBtn = (
          e.target as HTMLFormElement
        ).querySelector<HTMLButtonElement>('[type="submit"]');
        const errorEl = document.getElementById("waitlist-error");
        if (phoneRaw && !phone) {
          if (errorEl) {
            errorEl.textContent =
              "Please enter a valid phone number or leave it blank.";
            errorEl.removeAttribute("hidden");
          }
          return;
        }
        if (submitBtn) submitBtn.disabled = true;
        try {
          const attribution = await buildLeadAttribution({
            source: "city-waitlist",
            sourceCitySlug: citySlug,
          });
          await captureLead({
            email,
            city,
            ...(phone ? { phone } : {}),
            ...attribution,
          });
          identifyLead(email, { ...attribution, city });
          trackLeadEvent("lead_email_submitted", { ...attribution, city });
          trackLeadEvent("email_signup", { ...attribution, city });
          trackLeadEvent("waitlist_submit", { ...attribution, city });
          document
            .getElementById("waitlist-form-view")
            ?.setAttribute("hidden", "");
          document
            .getElementById("waitlist-success")
            ?.removeAttribute("hidden");
        } catch {
          if (errorEl) {
            errorEl.textContent = "Something went wrong. Please try again.";
            errorEl.removeAttribute("hidden");
          }
        } finally {
          if (submitBtn) submitBtn.disabled = false;
        }
      });
  }

  // City page email + phone signup
  let cityNotifyEmail = "";
  let cityNotifyDocId: LeadCaptureResult | null = null;
  const cityName = document.querySelector(".city-eyebrow")?.textContent ?? "";

  document
    .getElementById("city-notify-email-form")
    ?.addEventListener("submit", async (e) => {
      e.preventDefault();
      cityNotifyEmail = (
        document.getElementById("city-notify-email") as HTMLInputElement
      ).value;
      const errorEl = document.getElementById("city-notify-email-error");
      const submitBtn = (
        e.target as HTMLFormElement
      ).querySelector<HTMLButtonElement>('[type="submit"]');
      if (submitBtn) submitBtn.disabled = true;
      try {
        const attribution = await buildLeadAttribution({
          source: "city-page",
          sourceCitySlug: citySlug,
        });
        const captured = await captureLead({
          email: cityNotifyEmail,
          city: cityName,
          ...attribution,
        });
        cityNotifyDocId = captured.id ? captured : null;
        identifyLead(cityNotifyEmail, { ...attribution, city: cityName });
        trackLeadEvent("lead_email_submitted", {
          ...attribution,
          city: cityName,
        });
        trackLeadEvent("email_signup", {
          ...attribution,
          city: cityName,
        });
        if (errorEl) {
          errorEl.textContent = "";
          errorEl.setAttribute("hidden", "");
        }
        document
          .getElementById("city-notify-step1")
          ?.setAttribute("hidden", "");
        document.getElementById("city-notify-step2")?.removeAttribute("hidden");
      } catch (err) {
        if (errorEl) {
          errorEl.textContent = "Something went wrong. Please try again.";
          errorEl.removeAttribute("hidden");
        }
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });

  document
    .getElementById("city-notify-phone-form")
    ?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const raw = (
        document.getElementById("city-notify-phone") as HTMLInputElement
      ).value;
      const cleaned = cleanPhone(raw);
      const phoneErrorEl = document.getElementById("city-notify-phone-error");

      if (!raw.trim()) {
        document
          .getElementById("city-notify-step2")
          ?.setAttribute("hidden", "");
        document
          .getElementById("city-notify-success")
          ?.removeAttribute("hidden");
        return;
      }

      if (!cleaned) {
        if (phoneErrorEl) {
          phoneErrorEl.textContent = "Please enter a valid phone number.";
          phoneErrorEl.removeAttribute("hidden");
        }
        return;
      }

      const submitBtn = (
        e.target as HTMLFormElement
      ).querySelector<HTMLButtonElement>('[type="submit"]');
      if (submitBtn) submitBtn.disabled = true;
      try {
        if (cityNotifyDocId) {
          await updateLeadPhone(cityNotifyDocId, cleaned);
        } else {
          const attribution = await buildLeadAttribution({
            source: "city-page",
            sourceCitySlug: citySlug,
          });
          await captureLead({
            email: cityNotifyEmail,
            phone: cleaned,
            city: cityName,
            ...attribution,
          });
        }
        trackLeadEvent("lead_phone_submitted", {
          source: "city-page",
          sourcePage: window.location.pathname,
          sourceCitySlug: citySlug,
        });
        document
          .getElementById("city-notify-step2")
          ?.setAttribute("hidden", "");
        document
          .getElementById("city-notify-success")
          ?.removeAttribute("hidden");
      } catch (err) {
        if (phoneErrorEl) {
          phoneErrorEl.textContent =
            "Something went wrong. Please try again or skip.";
          phoneErrorEl.removeAttribute("hidden");
        }
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });

  document.getElementById("city-notify-skip")?.addEventListener("click", () => {
    document.getElementById("city-notify-step2")?.setAttribute("hidden", "");
    document.getElementById("city-notify-success")?.removeAttribute("hidden");
  });
</script>

<style>
