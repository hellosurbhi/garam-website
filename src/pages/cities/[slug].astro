---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EventbriteWidgetInit from "@/components/EventbriteWidgetInit.astro";
import { cities } from "@/data/cities";
import type { CityData } from "@/data/cities";
import { events } from "@/data/events";
import { isEventPast } from "@/utils/eventDate";
import { buildBreadcrumbJsonLd } from "@/utils/breadcrumbs";
import { SHOW_IMAGES, slugToImageIndex } from "@/data/images";
import { buildTicketUrl } from "@/utils/eventUrl";
import { EVENTS } from "@/data/copy";
import { getPostBySlug } from "@/data/journal";

export function getStaticPaths() {
  return Object.keys(cities).map((slug) => ({
    params: { slug },
    props: { city: cities[slug] },
  }));
}

const { city } = Astro.props;

const heroImage = SHOW_IMAGES[slugToImageIndex(city.slug, SHOW_IMAGES.length)];

// Nearby cities for cross-linking
const nearbyCities = (city.nearbyCities ?? [])
  .map((slug) => cities[slug])
  .filter((c): c is CityData => c !== undefined)
  .slice(0, 5);

const title = city.titleTag;
const description = city.metaDescription;

// Upcoming events matching this city (for active cities with real shows)
const cityEvents =
  city.status === "active"
    ? events.filter(
        (e) =>
          !e.hidden &&
          !isEventPast(e.date) &&
          e.url !== "#" &&
          e.url !== "" &&
          (e.citySlug
            ? e.citySlug === city.slug
            : e.city.includes(city.displayName)),
      )
    : [];

/* ── City JSON-LD ─────────────────────────────────────────── */

function buildCityJsonLd(c: CityData): string {
  const graph: Record<string, unknown>[] = [
    {
      "@type": "LocalBusiness",
      name: "Garam Masala Dating",
      url: "https://garammasaladating.com",
      areaServed: c.areaServed,
    },
  ];

  if (c.includeEventSchema) {
    const event: Record<string, unknown> = {
      "@type": "Event",
      name: `Garam Masala Dating \u2013 ${c.displayName}`,
      eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
      eventStatus: "https://schema.org/EventScheduled",
      organizer: {
        "@type": "Organization",
        name: "Garam Masala Dating",
        url: "https://garammasaladating.com",
      },
      performer: [
        {
          "@type": "Person",
          name: "Surbhi",
          url: "https://www.instagram.com/lordmakemetaller/",
        },
        {
          "@type": "Person",
          name: "Wyatt Feegrado",
          url: "https://www.instagram.com/wyattfeegrado/",
        },
      ],
      location: {
        "@type": "Place",
        name: c.venueName ?? c.displayName,
        address: {
          "@type": "PostalAddress",
          addressLocality: c.addressLocality,
          addressRegion: c.addressRegion,
          addressCountry: "US",
        },
      },
    };

    if (c.eventScheduleFrequency) {
      event.eventSchedule = {
        "@type": "Schedule",
        repeatFrequency: c.eventScheduleFrequency,
      };
    }
    graph.push(event);
  }

  if (c.faqItems && c.faqItems.length > 0) {
    graph.push({
      "@type": "FAQPage",
      mainEntity: c.faqItems.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: { "@type": "Answer", text: item.a },
      })),
    });
  }

  return JSON.stringify({ "@context": "https://schema.org", "@graph": graph });
}

const cityJsonLd = buildCityJsonLd(city);

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: "https://garammasaladating.com/" },
  { name: "Cities", url: "https://garammasaladating.com/cities" },
  { name: city.displayName },
]);

const relatedPosts = (city.relatedArticleSlugs ?? [])
  .map((slug) => getPostBySlug(slug))
  .filter((p) => p !== undefined);

const applyHref =
  city.ctas.find((c) => c.href !== "#waitlist")?.href ?? "/apply";

const staticPrimaryCta =
  cityEvents.length === 0 ? (city.ctas[0] ?? null) : null;
const staticSecondaryCtas =
  cityEvents.length === 0 ? city.ctas.slice(1) : city.ctas;

function renderBodyParagraph(para: string, href: string): string {
  return para
    .replace(
      /get on the list/gi,
      `<button class="city-inline-cta" data-waitlist-trigger>get on the list</button>`,
    )
    .replace(
      /apply to be a contestant/gi,
      `<a class="city-inline-link" href="${href}">apply to be a contestant</a>`,
    );
}
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={cityJsonLd} />
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
  </Fragment>

  <main id="main-content" class="city-page">
    <img
      class="city-bg"
      src={heroImage}
      alt=""
      width="1200"
      height="675"
      loading="lazy"
      aria-hidden="true"
    />
    <div class="city-container">
      {/* Eyebrow label */}
      <p class="city-eyebrow">{city.displayName}</p>

      {/* H1 */}
      <h1 class="city-h1">{city.h1}</h1>

      {/* Body */}
      <div class="city-body">
        {
          city.bodyParagraphs.map((para) => (
            <p
              class="city-paragraph"
              set:html={renderBodyParagraph(para, applyHref)}
            />
          ))
        }
      </div>

      {/* Related journal articles */}
      {
        relatedPosts.length > 0 && (
          <div class="city-articles">
            <h3 class="city-articles__title">From the Journal</h3>
            <div class="city-articles__list">
              {relatedPosts.map((post) => (
                <a href={`/journal/${post.slug}`} class="city-articles__card">
                  <p class="city-articles__card-title">{post.title}</p>
                  <p class="city-articles__card-excerpt">{post.excerpt}</p>
                </a>
              ))}
            </div>
          </div>
        )
      }

      {/* CTAs */}
      <div class="city-ctas">
        {/* Per-event ticket buttons for active cities */}
        {
          cityEvents.map((event) => {
            const isSoldOut = event.soldOut ?? false;
            const arrowSvg = (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="city-cta__arrow"
                aria-hidden="true"
              >
                <>
                  <path d="M5 12h14" />
                  <path d="m12 5 7 7-7 7" />
                </>
              </svg>
            );
            return event.eventbriteId && !isSoldOut ? (
              <button
                type="button"
                id={`eventbrite-widget-modal-trigger-${event.eventbriteId}`}
                class="city-cta city-cta--primary"
                data-eb-url={buildTicketUrl(event.url, "cities", city.slug)}
                data-city={event.city}
                data-ph-section="cities"
                data-ph-price={event.price}
                data-ph-event-date={event.date}
              >
                <span>
                  {event.date}: {EVENTS.ticketCta}
                </span>
                {arrowSvg}
              </button>
            ) : (
              <a
                href={buildTicketUrl(event.url, "cities", city.slug)}
                target="_blank"
                rel="noopener noreferrer"
                class="city-cta city-cta--primary"
              >
                <span>
                  {event.date}: {EVENTS.ticketCta}
                </span>
                {arrowSvg}
              </a>
            );
          })
        }
        {/* Primary static CTA */}
        {
          staticPrimaryCta &&
            (staticPrimaryCta.href === "#waitlist" ? (
              <button
                type="button"
                class="city-cta city-cta--primary"
                data-waitlist-trigger
              >
                <span>{staticPrimaryCta.label}</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="city-cta__arrow"
                  aria-hidden="true"
                >
                  <path d="M5 12h14" />
                  <path d="m12 5 7 7-7 7" />
                </svg>
              </button>
            ) : (
              <a
                href={staticPrimaryCta.href}
                class="city-cta city-cta--primary"
              >
                <span>{staticPrimaryCta.label}</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="city-cta__arrow"
                  aria-hidden="true"
                >
                  <path d="M5 12h14" />
                  <path d="m12 5 7 7-7 7" />
                </svg>
              </a>
            ))
        }
        {/* Secondary CTAs as text links */}
        {
          staticSecondaryCtas.map((cta) =>
            cta.href === "#waitlist" ? (
              <button
                type="button"
                class="city-cta--tertiary"
                data-waitlist-trigger
              >
                {cta.label} &rarr;
              </button>
            ) : (
              <a href={cta.href} class="city-cta--tertiary">
                {cta.label} &rarr;
              </a>
            ),
          )
        }
      </div>

      {/* Waitlist modal */}
      <dialog id="waitlist-modal" class="modal-dialog">
        <div class="modal-inner">
          <button type="button" class="modal-close" aria-label="Close">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg
            >
          </button>
          <div id="waitlist-form-view">
            <h2 class="modal-title">Join the {city.displayName} Waitlist</h2>
            <p class="modal-subtitle">
              We'll email you the moment tickets drop for {city.displayName}.
            </p>
            <form
              id="waitlist-form"
              class="modal-form"
              toolname="join-city-show-waitlist"
              tooldescription="Join the waitlist for Garam Masala Dating shows in this city. You will be notified when tickets go on sale."
            >
              <input
                type="email"
                id="waitlist-email"
                class="ph-mask"
                placeholder="Your email"
                required
                aria-label="Email address"
                aria-describedby="waitlist-error"
                toolparamdescription="Email address to be notified when show tickets go on sale in this city"
              />
              <p id="waitlist-error" class="modal-error" hidden role="alert">
              </p>
              <button type="submit" class="modal-submit"
                >Join the Waitlist</button
              >
            </form>
          </div>
          <div id="waitlist-success" class="modal-success" hidden>
            <p>You're on the list! We'll let you know.</p>
          </div>
        </div>
      </dialog>

      {/* Email + phone signup for cities with events */}
      {
        cityEvents.length > 0 && (
          <div class="city-notify">
            <div class="city-notify__steps">
              <div id="city-notify-step1">
                <h3 class="city-notify__title">Stay in the Loop</h3>
                <p class="city-notify__desc">
                  Get notified about future {city.displayName} shows, discount
                  codes, and free ticket drops.
                </p>
                <form
                  id="city-notify-email-form"
                  class="city-notify__form"
                  toolname="subscribe-to-city-show-alerts"
                  tooldescription="Subscribe to email notifications for upcoming Garam Masala Dating shows in this city, including discount codes and ticket drops."
                >
                  <input
                    type="email"
                    id="city-notify-email"
                    class="ph-mask"
                    placeholder="Your email"
                    required
                    aria-label="Email address"
                    aria-describedby="city-notify-email-error"
                    toolparamdescription="Email address for show announcements, discount codes, and ticket drops in this city"
                  />
                  <p
                    id="city-notify-email-error"
                    class="city-notify__error"
                    hidden
                    role="alert"
                  />
                  <button type="submit">Get Notified</button>
                </form>
              </div>
              <div id="city-notify-step2" hidden>
                <p class="city-notify__desc">
                  Add your number for text-only discounts and free ticket drops.
                </p>
                <form
                  id="city-notify-phone-form"
                  class="city-notify__form"
                  toolname="add-phone-to-city-show-alerts"
                  tooldescription="Add a phone number for SMS notifications about upcoming Garam Masala Dating shows in this city (optional step after email signup)."
                >
                  <input
                    type="tel"
                    id="city-notify-phone"
                    class="ph-mask"
                    placeholder="(555) 123-4567"
                    aria-label="Phone number"
                    aria-describedby="city-notify-phone-error"
                    toolparamdescription="Mobile phone number for SMS-only ticket drops and show alerts in this city (optional)"
                  />
                  <p
                    id="city-notify-phone-error"
                    class="city-notify__error"
                    hidden
                    role="alert"
                  />
                  <button type="submit">Send Me Deals</button>
                </form>
                <button
                  type="button"
                  id="city-notify-skip"
                  class="city-notify__skip"
                >
                  Maybe later
                </button>
              </div>
              <div id="city-notify-success" hidden>
                <p class="city-notify__done">You're on the list!</p>
              </div>
            </div>
          </div>
        )
      }

      {/* FAQ section */}
      {
        city.faqItems && city.faqItems.length > 0 && (
          <div class="city-faq">
            <h3 class="city-faq__title">
              Questions About {city.displayName} Shows
            </h3>
            <div class="city-faq__list">
              {city.faqItems.map((item) => (
                <details class="city-faq__item">
                  <summary class="city-faq__question">{item.q}</summary>
                  <p class="city-faq__answer">{item.a}</p>
                </details>
              ))}
            </div>
          </div>
        )
      }

      {/* Nearby cities */}
      {
        nearbyCities.length > 0 && (
          <div class="city-nearby">
            <h3 class="city-nearby__title">Also coming to</h3>
            <div class="city-nearby__list">
              {nearbyCities.map((nc) => (
                <a href={`/cities/${nc.slug}`} class="city-nearby__link">
                  {nc.displayName}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M5 12h14" />
                    <path d="m12 5 7 7-7 7" />
                  </svg>
                </a>
              ))}
            </div>
          </div>
        )
      }

      {/* Footer */}
      <div class="city-footer">
        <a href="/cities" class="city-footer__link"> &larr; All cities </a>
      </div>
    </div>
  </main>
  <EventbriteWidgetInit />
</BaseLayout>

<script>
  import { getFirebaseDb } from "@/lib/firebase";
  import {
    collection,
    addDoc,
    updateDoc,
    type DocumentReference,
  } from "firebase/firestore";
  import { cleanPhone } from "@/lib/phone";
  import { identifyLead, trackLeadEvent } from "@/lib/analytics";
  import { buildLeadAttribution } from "@/lib/leadAttribution";

  const dialog = document.getElementById("waitlist-modal") as HTMLDialogElement;
  const citySlug =
    window.location.pathname.split("/").filter(Boolean).at(-1) ?? "";
  if (dialog) {
    document.querySelectorAll("[data-waitlist-trigger]").forEach((btn) => {
      btn.addEventListener("click", () => {
        trackLeadEvent("waitlist_modal_opened", {
          source: "city-waitlist",
          sourcePage: window.location.pathname,
          sourceCitySlug: citySlug,
        });
        dialog.showModal();
      });
    });
    dialog
      .querySelector(".modal-close")
      ?.addEventListener("click", () => dialog.close());
    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) dialog.close();
    });

    document
      .getElementById("waitlist-form")
      ?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const email = (
          document.getElementById("waitlist-email") as HTMLInputElement
        ).value;
        const city = document.querySelector(".city-eyebrow")?.textContent ?? "";
        const submitBtn = (
          e.target as HTMLFormElement
        ).querySelector<HTMLButtonElement>('[type="submit"]');
        const errorEl = document.getElementById("waitlist-error");
        if (submitBtn) submitBtn.disabled = true;
        try {
          const db = getFirebaseDb();
          const attribution = buildLeadAttribution({
            source: "city-waitlist",
            sourceCitySlug: citySlug,
          });
          await addDoc(collection(db, "leads"), {
            email,
            city,
            ...attribution,
            createdAt: new Date().toISOString(),
          });
          identifyLead(email, { ...attribution, city });
          trackLeadEvent("lead_email_submitted", { ...attribution, city });
          document
            .getElementById("waitlist-form-view")
            ?.setAttribute("hidden", "");
          document
            .getElementById("waitlist-success")
            ?.removeAttribute("hidden");
        } catch {
          if (errorEl) {
            errorEl.textContent = "Something went wrong. Please try again.";
            errorEl.removeAttribute("hidden");
          }
        } finally {
          if (submitBtn) submitBtn.disabled = false;
        }
      });
  }

  // City page email + phone signup
  let cityNotifyEmail = "";
  let cityNotifyDocRef: DocumentReference | null = null;
  const cityName = document.querySelector(".city-eyebrow")?.textContent ?? "";

  document
    .getElementById("city-notify-email-form")
    ?.addEventListener("submit", async (e) => {
      e.preventDefault();
      cityNotifyEmail = (
        document.getElementById("city-notify-email") as HTMLInputElement
      ).value;
      const errorEl = document.getElementById("city-notify-email-error");
      const submitBtn = (
        e.target as HTMLFormElement
      ).querySelector<HTMLButtonElement>('[type="submit"]');
      if (submitBtn) submitBtn.disabled = true;
      try {
        const db = getFirebaseDb();
        const attribution = buildLeadAttribution({
          source: "city-page",
          sourceCitySlug: citySlug,
        });
        cityNotifyDocRef = await addDoc(collection(db, "leads"), {
          email: cityNotifyEmail,
          city: cityName,
          ...attribution,
          createdAt: new Date().toISOString(),
        });
        identifyLead(cityNotifyEmail, { ...attribution, city: cityName });
        trackLeadEvent("lead_email_submitted", {
          ...attribution,
          city: cityName,
        });
        if (errorEl) {
          errorEl.textContent = "";
          errorEl.setAttribute("hidden", "");
        }
        document
          .getElementById("city-notify-step1")
          ?.setAttribute("hidden", "");
        document.getElementById("city-notify-step2")?.removeAttribute("hidden");
      } catch (err) {
        if (errorEl) {
          errorEl.textContent = "Something went wrong. Please try again.";
          errorEl.removeAttribute("hidden");
        }
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });

  document
    .getElementById("city-notify-phone-form")
    ?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const raw = (
        document.getElementById("city-notify-phone") as HTMLInputElement
      ).value;
      const cleaned = cleanPhone(raw);
      const phoneErrorEl = document.getElementById("city-notify-phone-error");

      if (!raw.trim()) {
        document
          .getElementById("city-notify-step2")
          ?.setAttribute("hidden", "");
        document
          .getElementById("city-notify-success")
          ?.removeAttribute("hidden");
        return;
      }

      if (!cleaned) {
        if (phoneErrorEl) {
          phoneErrorEl.textContent = "Please enter a valid phone number.";
          phoneErrorEl.removeAttribute("hidden");
        }
        return;
      }

      const submitBtn = (
        e.target as HTMLFormElement
      ).querySelector<HTMLButtonElement>('[type="submit"]');
      if (submitBtn) submitBtn.disabled = true;
      try {
        const db = getFirebaseDb();
        if (cityNotifyDocRef) {
          await updateDoc(cityNotifyDocRef, { phone: cleaned });
        } else {
          const attribution = buildLeadAttribution({
            source: "city-page",
            sourceCitySlug: citySlug,
          });
          await addDoc(collection(db, "leads"), {
            email: cityNotifyEmail,
            phone: cleaned,
            city: cityName,
            ...attribution,
            createdAt: new Date().toISOString(),
          });
        }
        trackLeadEvent("lead_phone_submitted", {
          source: "city-page",
          sourcePage: window.location.pathname,
          sourceCitySlug: citySlug,
        });
        document
          .getElementById("city-notify-step2")
          ?.setAttribute("hidden", "");
        document
          .getElementById("city-notify-success")
          ?.removeAttribute("hidden");
      } catch (err) {
        if (phoneErrorEl) {
          phoneErrorEl.textContent =
            "Something went wrong. Please try again or skip.";
          phoneErrorEl.removeAttribute("hidden");
        }
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });

  document.getElementById("city-notify-skip")?.addEventListener("click", () => {
    document.getElementById("city-notify-step2")?.setAttribute("hidden", "");
    document.getElementById("city-notify-success")?.removeAttribute("hidden");
  });
</script>

<style>
  @keyframes cityFadeIn {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .city-page {
    overflow: hidden;
    min-height: 100vh;
    position: relative;
    z-index: 1;
    animation: cityFadeIn 0.5s ease-out both;
  }
  .city-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    z-index: 0;
    opacity: 0.06;
  }

  .city-container {
    position: relative;
    z-index: 1;
    max-width: 680px;
    margin: 0 auto;
    padding: 24px;
  }

  .city-eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--brand-red);
    margin-bottom: 16px;
  }

  .city-h1 {
    font-family: var(--font-playfair);
    font-size: clamp(28px, 5vw, 40px);
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.12;
    margin-bottom: 32px;
  }

  .city-body {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .city-paragraph {
    font-family: var(--font-cormorant);
    font-style: italic;
    font-size: 17px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0;
  }

  .city-inline-cta {
    background: none;
    border: none;
    font-family: inherit;
    font-style: inherit;
    font-size: inherit;
    color: var(--brand-red);
    text-decoration: underline;
    cursor: pointer;
    padding: 0;
  }

  .city-inline-link {
    color: var(--brand-red);
    text-decoration: underline;
  }

  .city-ctas {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 44px;
  }

  .city-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 22px;
    border-radius: 14px;
    border: 1px solid;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    text-decoration: none;
    appearance: none;
    cursor: pointer;
    transition:
      background 0.15s,
      border-color 0.15s,
      transform 0.15s;
  }

  .city-cta:active {
    transform: scale(0.97);
