    margin-top: 4px;
  }

  @media (hover: hover) and (pointer: fine) {
    .city-follow__btn--nearby:hover {
      background: rgba(0, 0, 0, 0.04);
    }
  }

  .city-ctas {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 32px;
  }

  .city-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 22px;
    border-radius: 14px;
    border: 1px solid;
    font-family: var(--font-body);
