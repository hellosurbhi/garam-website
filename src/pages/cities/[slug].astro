---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { cities } from '@/data/cities';
import type { CityData } from '@/data/cities';
import { events } from '@/data/events';
import { isEventPast } from '@/utils/eventDate';
import { buildBreadcrumbJsonLd } from '@/utils/breadcrumbs';
import { SHOW_IMAGES, slugToImageIndex } from '@/data/images';

export function getStaticPaths() {
  return Object.keys(cities).map((slug) => ({
    params: { slug },
    props: { city: cities[slug] },
  }));
}

interface Props { city: CityData; }
const { city } = Astro.props;

const heroImage = SHOW_IMAGES[slugToImageIndex(city.slug, SHOW_IMAGES.length)];

// Nearby cities for cross-linking
const nearbyCities = (city.nearbyCities ?? [])
  .map((slug) => cities[slug])
  .filter((c): c is CityData => c !== undefined)
  .slice(0, 5);

const title = city.titleTag;
const description = city.metaDescription;

// Upcoming events matching this city (for active cities with real shows)
const cityEvents = city.status === "active"
  ? events.filter((e) =>
      !e.hidden &&
      !isEventPast(e.date) &&
      e.url !== "#" &&
      e.city.includes(city.displayName)
    )
  : [];

/* ── City JSON-LD ─────────────────────────────────────────── */

function buildCityJsonLd(c: CityData): string {
  const localBusiness = {
    "@type": "LocalBusiness" as const,
    name: "Garam Masala Dating",
    url: "https://garammasaladating.com",
    areaServed: c.areaServed,
  };

  if (!c.includeEventSchema) {
    return JSON.stringify({
      "@context": "https://schema.org",
      ...localBusiness,
    });
  }

  const event: Record<string, unknown> = {
    "@type": "Event",
    name: `Garam Masala Dating \u2013 ${c.displayName}`,
    eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
    eventStatus: "https://schema.org/EventScheduled",
    organizer: {
      "@type": "Organization",
      name: "Garam Masala Dating",
      url: "https://garammasaladating.com",
    },
    performer: [
      { "@type": "Person", name: "Surbhi", url: "https://www.instagram.com/lordmakemetaller/" },
      { "@type": "Person", name: "Wyatt Feegrado", url: "https://www.instagram.com/wyattfeegrado/" },
    ],
    location: {
      "@type": "Place",
      name: c.venueName ?? c.displayName,
      address: {
        "@type": "PostalAddress",
        addressLocality: c.addressLocality,
        addressRegion: c.addressRegion,
        addressCountry: "US",
      },
    },
  };

  if (c.eventScheduleFrequency) {
    event.eventSchedule = {
      "@type": "Schedule",
      repeatFrequency: c.eventScheduleFrequency,
    };
  }

  return JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [localBusiness, event],
  });
}

const cityJsonLd = buildCityJsonLd(city);

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: "https://garammasaladating.com/" },
  { name: "Cities", url: "https://garammasaladating.com/cities" },
  { name: city.displayName },
]);
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={cityJsonLd} />
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
  </Fragment>

  <div class="city-hero" aria-hidden="true">
    <img src={heroImage} alt="" width="1200" height="675" loading="eager" class="city-hero-img" />
  </div>

  <main id="main-content" class="city-page">
    <div class="city-container">
      {/* Eyebrow label */}
      <p class="city-eyebrow">{city.displayName}</p>

      {/* H1 */}
      <h1 class="city-h1">{city.h1}</h1>

      {/* Divider */}
      <div class="city-divider" />

      {/* Body */}
      <div class="city-body">
        {city.bodyParagraphs.map((para) => (
          <p class="city-paragraph">{para}</p>
        ))}
      </div>

      {/* CTAs */}
      <div class="city-ctas">
        {/* Per-event ticket buttons for active cities */}
        {cityEvents.map((event) => (
          <a
            href={event.url}
            target="_blank"
            rel="noopener noreferrer"
            class="city-cta city-cta--primary"
          >
            <span>{event.date} — Get Tickets</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="city-cta__arrow"><path d="M5 12h14" /><path d="m12 5 7 7-7 7" /></svg>
          </a>
        ))}
        {/* Static CTAs (apply, waitlist, etc.) */}
        {city.ctas.map((cta, i) => {
          const isWaitlist = cta.href === '#waitlist';
          const isPrimary = cityEvents.length === 0 && i === 0;
          return isWaitlist ? (
            <button
              type="button"
              class:list={["city-cta", isPrimary ? "city-cta--primary" : "city-cta--secondary"]}
              data-waitlist-trigger
            >
              <span>{cta.label}</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="city-cta__arrow"><path d="M5 12h14" /><path d="m12 5 7 7-7 7" /></svg>
            </button>
          ) : (
            <a
              href={cta.href}
              class:list={["city-cta", isPrimary ? "city-cta--primary" : "city-cta--secondary"]}
            >
              <span>{cta.label}</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="city-cta__arrow"><path d="M5 12h14" /><path d="m12 5 7 7-7 7" /></svg>
            </a>
          );
        })}
      </div>

      {/* Waitlist modal */}
      <dialog id="waitlist-modal" class="modal-dialog">
        <div class="modal-inner">
          <button type="button" class="modal-close" aria-label="Close">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          </button>
          <div id="waitlist-form-view">
            <h2 class="modal-title">Join the {city.displayName} Waitlist</h2>
            <p class="modal-subtitle">We'll email you the moment tickets drop for {city.displayName}.</p>
            <form id="waitlist-form" class="modal-form">
              <input type="email" id="waitlist-email" placeholder="Your email" required aria-label="Email address" />
              <button type="submit" class="modal-submit">Join the Waitlist</button>
            </form>
          </div>
          <div id="waitlist-success" class="modal-success" hidden>
            <p>You're on the list! We'll let you know.</p>
          </div>
        </div>
      </dialog>

      {/* Email + phone signup for cities with events */}
      {cityEvents.length > 0 && (
        <div class="city-notify">
          <div id="city-notify-step1">
            <h3 class="city-notify__title">Stay in the Loop</h3>
            <p class="city-notify__desc">Get notified about future {city.displayName} shows, discount codes, and free ticket drops.</p>
            <form id="city-notify-email-form" class="city-notify__form">
              <input type="email" id="city-notify-email" placeholder="Your email" required aria-label="Email address" />
              <button type="submit">Get Notified</button>
            </form>
          </div>
          <div id="city-notify-step2" hidden>
            <p class="city-notify__desc">Add your number for text-only discounts and free ticket drops.</p>
            <form id="city-notify-phone-form" class="city-notify__form">
              <input type="tel" id="city-notify-phone" placeholder="Your phone number" aria-label="Phone number" />
              <button type="submit">Send Me Deals</button>
            </form>
            <button type="button" id="city-notify-skip" class="city-notify__skip">Maybe later</button>
          </div>
          <div id="city-notify-success" hidden>
            <p class="city-notify__done">You're on the list!</p>
          </div>
        </div>
      )}

      {/* Nearby cities */}
      {nearbyCities.length > 0 && (
        <div class="city-nearby">
          <h3 class="city-nearby__title">Also coming to</h3>
          <div class="city-nearby__list">
            {nearbyCities.map((nc) => (
              <a href={`/cities/${nc.slug}`} class="city-nearby__link">
                {nc.displayName}
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            ))}
          </div>
        </div>
      )}

      {/* Footer */}
      <div class="city-footer">
        <a href="/cities" class="city-footer__link">
          &larr; All cities
        </a>
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  import { getFirebaseDb } from '@/lib/firebase';
  import { collection, addDoc } from 'firebase/firestore';

  const dialog = document.getElementById('waitlist-modal') as HTMLDialogElement;
  if (dialog) {
    document.querySelectorAll('[data-waitlist-trigger]').forEach((btn) => {
      btn.addEventListener('click', () => dialog.showModal());
    });
    dialog.querySelector('.modal-close')?.addEventListener('click', () => dialog.close());
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });

    document.getElementById('waitlist-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (document.getElementById('waitlist-email') as HTMLInputElement).value;
      const city = document.querySelector('.city-eyebrow')?.textContent ?? '';
      try {
        const db = getFirebaseDb();
        await addDoc(collection(db, 'notifications'), {
          email,
          city,
          source: 'city-waitlist',
          createdAt: new Date().toISOString(),
        });
      } catch { /* fail silently */ }
      document.getElementById('waitlist-form-view')?.setAttribute('hidden', '');
      document.getElementById('waitlist-success')?.removeAttribute('hidden');
    });
  }

  // City page email + phone signup
  let cityNotifyEmail = '';
  const cityName = document.querySelector('.city-eyebrow')?.textContent ?? '';

  document.getElementById('city-notify-email-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    cityNotifyEmail = (document.getElementById('city-notify-email') as HTMLInputElement).value;
    try {
      const db = getFirebaseDb();
      await addDoc(collection(db, 'subscribers'), {
        email: cityNotifyEmail,
        city: cityName,
        source: 'city-page',
        createdAt: new Date().toISOString(),
      });
    } catch { /* fail silently */ }
    document.getElementById('city-notify-step1')?.setAttribute('hidden', '');
    document.getElementById('city-notify-step2')?.removeAttribute('hidden');
  });

  document.getElementById('city-notify-phone-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const phone = (document.getElementById('city-notify-phone') as HTMLInputElement).value;
    if (phone) {
      try {
        const db = getFirebaseDb();
        await addDoc(collection(db, 'subscribers'), {
          email: cityNotifyEmail,
          phone,
          city: cityName,
          source: 'city-page-phone',
          createdAt: new Date().toISOString(),
        });
      } catch { /* fail silently */ }
    }
    document.getElementById('city-notify-step2')?.setAttribute('hidden', '');
    document.getElementById('city-notify-success')?.removeAttribute('hidden');
  });

  document.getElementById('city-notify-skip')?.addEventListener('click', () => {
    document.getElementById('city-notify-step2')?.setAttribute('hidden', '');
    document.getElementById('city-notify-success')?.removeAttribute('hidden');
  });
</script>

<style>
  @keyframes cityFadeIn {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .city-hero {
    width: 100%;
    aspect-ratio: 16 / 9;
    max-height: 400px;
    overflow: hidden;
  }
  .city-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
    display: block;
  }

  .city-page {
    min-height: 100vh;
    position: relative;
    z-index: 1;
    animation: cityFadeIn 0.5s ease-out both;
  }

  .city-container {
    max-width: 680px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  .city-eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--brand-red);
    margin-bottom: 16px;
  }

  .city-h1 {
    font-family: var(--font-playfair);
    font-size: clamp(28px, 5vw, 40px);
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.12;
    margin-bottom: 32px;
  }

  .city-divider {
    width: 48px;
    height: 1px;
    background: rgba(var(--brand-red-rgb), 0.3);
    margin-bottom: 36px;
  }

  .city-body {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .city-paragraph {
    font-family: var(--font-cormorant);
    font-style: italic;
    font-size: 17px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0;
  }

  .city-ctas {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 44px;
  }

  .city-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 22px;
    border-radius: 14px;
    border: 1px solid;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }

  .city-cta--primary {
    border-color: rgba(var(--brand-red-rgb), 0.5);
    background: rgba(var(--brand-red-rgb), 0.1);
    color: var(--brand-red);
  }

  .city-cta--secondary {
    border-color: rgba(0, 0, 0, 0.1);
    background: white;
    color: var(--text-secondary);
  }

  .city-cta__arrow {
    flex-shrink: 0;
  }

  /* ─── Nearby Cities ───────────────────────────────── */

  .city-nearby {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }

  .city-nearby__title {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--muted);
    margin-bottom: 16px;
  }

  .city-nearby__list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .city-nearby__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 16px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 50px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }

  .city-nearby__link:hover {
    border-color: rgba(var(--brand-red-rgb), 0.3);
    color: var(--brand-red);
  }

  .city-footer {
    margin-top: 64px;
    padding-top: 24px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }

  .city-footer__link {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--muted);
    text-decoration: none;
  }

  /* ─── City Notify Signup ──────────────────────────── */

  .city-notify {
    margin-top: 48px;
    padding: 32px 24px;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 16px;
    background: rgba(var(--brand-red-rgb), 0.02);
    text-align: center;
  }

  .city-notify__title {
    font-family: var(--font-playfair), serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--charcoal);
    margin-bottom: 8px;
  }

  .city-notify__desc {
    font-family: var(--font-cormorant), serif;
    font-style: italic;
    font-size: 16px;
    color: var(--text-light);
    line-height: 1.5;
    margin-bottom: 20px;
  }

  .city-notify__form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 380px;
    margin: 0 auto;
  }

  .city-notify__form input {
    padding: 14px 20px;
    border: 1.5px solid rgba(0, 0, 0, 0.1);
    border-radius: 50px;
    font-size: 16px;
    font-family: var(--font-body), sans-serif;
    outline: none;
    transition: border-color 0.2s;
    min-height: 48px;
  }

  .city-notify__form input:focus {
    border-color: var(--brand-red);
  }

  .city-notify__form button {
    background: var(--brand-red);
    color: white;
    border: none;
    padding: 14px;
    border-radius: 50px;
    font-family: var(--font-body), sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: background 0.2s;
    min-height: 48px;
    white-space: nowrap;
    cursor: pointer;
  }

  .city-notify__form button:hover {
    background: var(--brand-red-dark);
  }

  .city-notify__skip {
    background: none;
    border: none;
    color: var(--muted);
    font-size: 14px;
    font-family: var(--font-body), sans-serif;
    margin-top: 12px;
    transition: color 0.2s;
    padding: 4px;
    cursor: pointer;
  }

  .city-notify__skip:hover {
    color: var(--charcoal);
  }

  .city-notify__done {
    font-family: var(--font-cormorant), serif;
    font-size: 20px;
    font-style: italic;
    color: var(--charcoal);
    padding: 12px 0;
  }

  /* Waitlist modal */
  .modal-dialog {
    border: none;
    background: transparent;
    padding: 24px;
    max-width: 100%;
    max-height: 100vh;
    width: 100%;
    height: 100%;
    overflow: visible;
  }
  .modal-dialog::backdrop { background: rgba(0, 0, 0, 0.5); }
  .modal-dialog[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .modal-inner {
    width: 100%;
    max-width: 400px;
    max-height: 80vh;
    overflow-y: auto;
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 20px;
    padding: 32px 24px;
    position: relative;
    animation: modalIn 0.25s ease-out both;
    text-align: center;
  }
  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.95) translateY(8px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
  .modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    color: var(--muted);
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
  }
  .modal-close:hover { color: var(--charcoal); }
  .modal-title {
    font-family: var(--font-playfair), serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--charcoal);
    margin-bottom: 8px;
  }
  .modal-subtitle {
    font-size: 15px;
    color: var(--text-light);
    margin-bottom: 24px;
    line-height: 1.5;
  }
  .modal-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .modal-form input {
    padding: 14px 20px;
    border: 1.5px solid rgba(0, 0, 0, 0.1);
    border-radius: 50px;
    font-size: 16px;
    font-family: var(--font-body), sans-serif;
    outline: none;
    transition: border-color 0.2s;
    min-height: 48px;
  }
  .modal-form input:focus { border-color: var(--brand-red); }
  .modal-submit {
    background: var(--brand-red);
    color: white;
    border: none;
    padding: 14px;
    border-radius: 50px;
    font-family: var(--font-body), sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: background 0.2s;
    min-height: 48px;
    white-space: nowrap;
    width: 100%;
  }
  .modal-submit:hover { background: var(--brand-red-dark); }
  .modal-success {
    text-align: center;
    padding: 24px 0;
  }
  .modal-success p {
    font-family: var(--font-cormorant), serif;
    font-size: 18px;
    font-style: italic;
    color: var(--charcoal);
  }
</style>
