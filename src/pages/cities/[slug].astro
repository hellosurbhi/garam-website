  }

  .city-cta--tertiary:hover {
    color: var(--brand-red);
  }

  .city-cta__arrow {
    flex-shrink: 0;
  }

  /* ─── Nearby Cities ───────────────────────────────── */

  .city-nearby {
    padding-top: 20px;
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
