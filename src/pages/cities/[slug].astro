---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageNav from '@/components/layout/PageNav.astro';
import { cities } from '@/data/cities';
import type { CityData } from '@/data/cities';
import { buildBreadcrumbJsonLd } from '@/utils/breadcrumbs';

export function getStaticPaths() {
  return Object.keys(cities).map((slug) => ({
    params: { slug },
    props: { city: cities[slug] },
  }));
}

interface Props { city: CityData; }
const { city } = Astro.props;

const title = city.titleTag;
const description = city.metaDescription;

/* ── City JSON-LD ─────────────────────────────────────────── */

function buildCityJsonLd(c: CityData): string {
  const localBusiness = {
    "@type": "LocalBusiness" as const,
    name: "Garam Masala Dating",
    url: "https://garammasaladating.com",
    areaServed: c.areaServed,
  };

  if (!c.includeEventSchema) {
    return JSON.stringify({
      "@context": "https://schema.org",
      ...localBusiness,
    });
  }

  const event: Record<string, unknown> = {
    "@type": "Event",
    name: `Garam Masala Dating \u2013 ${c.displayName}`,
    eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
    eventStatus: "https://schema.org/EventScheduled",
    organizer: {
      "@type": "Organization",
      name: "Garam Masala Dating",
      url: "https://garammasaladating.com",
    },
    performer: [
      { "@type": "Person", name: "Surbhi", url: "https://www.instagram.com/lordmakemetaller/" },
      { "@type": "Person", name: "Wyatt Feegrado", url: "https://www.instagram.com/wyattfeegrado/" },
    ],
    location: {
      "@type": "Place",
      name: c.venueName ?? c.displayName,
      address: {
        "@type": "PostalAddress",
        addressLocality: c.addressLocality,
        addressRegion: c.addressRegion,
        addressCountry: "US",
      },
    },
  };

  if (c.eventScheduleFrequency) {
    event.eventSchedule = {
      "@type": "Schedule",
      repeatFrequency: c.eventScheduleFrequency,
    };
  }

  return JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [localBusiness, event],
  });
}

const cityJsonLd = buildCityJsonLd(city);

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: "https://garammasaladating.com/" },
  { name: "Cities", url: "https://garammasaladating.com/cities" },
  { name: city.displayName },
]);
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={cityJsonLd} />
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
  </Fragment>

  <PageNav />
  <div class="city-page">
    <div class="city-container">
      {/* Eyebrow label */}
      <p class="city-eyebrow">{city.displayName}</p>

      {/* H1 */}
      <h1 class="city-h1">{city.h1}</h1>

      {/* Divider */}
      <div class="city-divider" />

      {/* Body */}
      <div class="city-body">
        {city.bodyParagraphs.map((para) => (
          <p class="city-paragraph">{para}</p>
        ))}
      </div>

      {/* CTAs */}
      <div class="city-ctas">
        {city.ctas.map((cta, i) => {
          const isWaitlist = cta.href === '#waitlist';
          return isWaitlist ? (
            <button
              type="button"
              class:list={["city-cta", i === 0 ? "city-cta--primary" : "city-cta--secondary"]}
              data-waitlist-trigger
            >
              <span>{cta.label}</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="city-cta__arrow"><path d="M5 12h14" /><path d="m12 5 7 7-7 7" /></svg>
            </button>
          ) : (
            <a
              href={cta.href}
              class:list={["city-cta", i === 0 ? "city-cta--primary" : "city-cta--secondary"]}
            >
              <span>{cta.label}</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="city-cta__arrow"><path d="M5 12h14" /><path d="m12 5 7 7-7 7" /></svg>
            </a>
          );
        })}
      </div>

      {/* Waitlist modal */}
      <dialog id="waitlist-modal" class="modal-dialog">
        <div class="modal-inner">
          <button type="button" class="modal-close" aria-label="Close">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          </button>
          <div id="waitlist-form-view">
            <h2 class="modal-title">Join the {city.displayName} Waitlist</h2>
            <p class="modal-subtitle">We'll email you the moment tickets drop for {city.displayName}.</p>
            <form id="waitlist-form" class="modal-form">
              <input type="email" id="waitlist-email" placeholder="Your email" required aria-label="Email address" />
              <button type="submit" class="modal-submit">Join the Waitlist</button>
            </form>
          </div>
          <div id="waitlist-success" class="modal-success" hidden>
            <p>You're on the list! We'll let you know.</p>
          </div>
        </div>
      </dialog>

      {/* Footer */}
      <div class="city-footer">
        <a href="/cities" class="city-footer__link">
          &larr; All cities
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { getFirebaseDb } from '@/lib/firebase';
  import { collection, addDoc } from 'firebase/firestore';

  const dialog = document.getElementById('waitlist-modal') as HTMLDialogElement;
  if (dialog) {
    document.querySelectorAll('[data-waitlist-trigger]').forEach((btn) => {
      btn.addEventListener('click', () => dialog.showModal());
    });
    dialog.querySelector('.modal-close')?.addEventListener('click', () => dialog.close());
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });

    document.getElementById('waitlist-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (document.getElementById('waitlist-email') as HTMLInputElement).value;
      const city = document.querySelector('.city-eyebrow')?.textContent ?? '';
      try {
        const db = getFirebaseDb();
        await addDoc(collection(db, 'notifications'), {
          email,
          city,
          source: 'city-waitlist',
          createdAt: new Date().toISOString(),
        });
      } catch { /* fail silently */ }
      document.getElementById('waitlist-form-view')?.setAttribute('hidden', '');
      document.getElementById('waitlist-success')?.removeAttribute('hidden');
    });
  }
</script>

<style>
  @keyframes cityFadeIn {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .city-page {
    min-height: 100vh;
    position: relative;
    z-index: 1;
    animation: cityFadeIn 0.5s ease-out both;
  }

  .city-container {
    max-width: 680px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  .city-eyebrow {
    font-family: var(--font-jetbrains);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--hot-pink);
    margin-bottom: 16px;
  }

  .city-h1 {
    font-family: var(--font-playfair);
    font-size: clamp(28px, 5vw, 40px);
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.12;
    margin-bottom: 32px;
  }

  .city-divider {
    width: 48px;
    height: 1px;
    background: rgba(233, 30, 118, 0.3);
    margin-bottom: 36px;
  }

  .city-body {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .city-paragraph {
    font-family: var(--font-cormorant);
    font-style: italic;
    font-size: 17px;
    color: #555;
    line-height: 1.7;
    margin: 0;
  }

  .city-ctas {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 44px;
  }

  .city-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 22px;
    border-radius: 14px;
    border: 1px solid;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }

  .city-cta--primary {
    border-color: rgba(233, 30, 118, 0.5);
    background: rgba(233, 30, 118, 0.1);
    color: var(--hot-pink);
  }

  .city-cta--secondary {
    border-color: rgba(0, 0, 0, 0.1);
    background: white;
    color: #555;
  }

  .city-cta__arrow {
    flex-shrink: 0;
  }

  .city-footer {
    margin-top: 64px;
    padding-top: 24px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }

  .city-footer__link {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--muted);
    text-decoration: none;
  }

  /* Waitlist modal */
  .modal-dialog {
    border: none;
    background: transparent;
    padding: 24px;
    max-width: 100vw;
    max-height: 100vh;
    width: 100%;
    height: 100%;
    overflow: visible;
  }
  .modal-dialog::backdrop { background: rgba(0, 0, 0, 0.5); }
  .modal-dialog[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .modal-inner {
    width: 100%;
    max-width: 400px;
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 20px;
    padding: 32px 24px;
    position: relative;
    animation: modalIn 0.25s ease-out both;
  }
  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.95) translateY(8px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
  .modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    color: #888;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
  }
  .modal-close:hover { color: var(--charcoal); }
  .modal-title {
    font-family: var(--font-playfair), serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--charcoal);
    margin-bottom: 8px;
  }
  .modal-subtitle {
    font-size: 15px;
    color: #666;
    margin-bottom: 24px;
    line-height: 1.5;
  }
  .modal-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .modal-form input {
    padding: 14px 20px;
    border: 1.5px solid rgba(0, 0, 0, 0.1);
    border-radius: 50px;
    font-size: 16px;
    font-family: var(--font-body), sans-serif;
    outline: none;
    transition: border-color 0.2s;
    min-height: 48px;
  }
  .modal-form input:focus { border-color: var(--hot-pink); }
  .modal-submit {
    background: var(--hot-pink);
    color: white;
    border: none;
    padding: 14px;
    border-radius: 50px;
    font-family: var(--font-body), sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: background 0.2s;
    min-height: 48px;
  }
  .modal-submit:hover { background: var(--deep-magenta); }
  .modal-success {
    text-align: center;
    padding: 24px 0;
  }
  .modal-success p {
    font-family: var(--font-cormorant), serif;
    font-size: 18px;
    font-style: italic;
    color: var(--charcoal);
  }
</style>
