---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { cities } from '@/data/cities';
import type { CityData } from '@/data/cities';
import { buildBreadcrumbJsonLd } from '@/utils/breadcrumbs';

export function getStaticPaths() {
  return Object.keys(cities).map((slug) => ({
    params: { slug },
    props: { city: cities[slug] },
  }));
}

interface Props { city: CityData; }
const { city } = Astro.props;

const title = city.titleTag;
const description = city.metaDescription;

/* ── City JSON-LD ─────────────────────────────────────────── */

function buildCityJsonLd(c: CityData): string {
  const localBusiness = {
    "@type": "LocalBusiness" as const,
    name: "Garam Masala Dating",
    url: "https://garammasaladating.com",
    areaServed: c.areaServed,
  };

  if (!c.includeEventSchema) {
    return JSON.stringify({
      "@context": "https://schema.org",
      ...localBusiness,
    });
  }

  const event: Record<string, unknown> = {
    "@type": "Event",
    name: `Garam Masala Dating \u2013 ${c.displayName}`,
    eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
    eventStatus: "https://schema.org/EventScheduled",
    organizer: {
      "@type": "Organization",
      name: "Garam Masala Dating",
      url: "https://garammasaladating.com",
    },
    performer: [
      { "@type": "Person", name: "Surbhi", url: "https://www.instagram.com/lordmakemetaller/" },
      { "@type": "Person", name: "Wyatt Feegrado", url: "https://www.instagram.com/wyattfeegrado/" },
    ],
    location: {
      "@type": "Place",
      name: c.venueName ?? c.displayName,
      address: {
        "@type": "PostalAddress",
        addressLocality: c.addressLocality,
        addressRegion: c.addressRegion,
        addressCountry: "US",
      },
    },
  };

  if (c.eventScheduleFrequency) {
    event.eventSchedule = {
      "@type": "Schedule",
      repeatFrequency: c.eventScheduleFrequency,
    };
  }

  return JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [localBusiness, event],
  });
}

const cityJsonLd = buildCityJsonLd(city);

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: "https://garammasaladating.com/" },
  { name: "Cities", url: "https://garammasaladating.com/cities" },
  { name: city.displayName },
]);
---

<BaseLayout title={title} description={description} overlayBg="rgba(13, 10, 8, 0.88)">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={cityJsonLd} />
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
  </Fragment>

  <div class="city-page">
    <div class="city-container">
      {/* Eyebrow label */}
      <p class="city-eyebrow">{city.displayName}</p>

      {/* H1 */}
      <h1 class="city-h1">{city.h1}</h1>

      {/* Divider */}
      <div class="city-divider" />

      {/* Body */}
      <div class="city-body">
        {city.bodyParagraphs.map((para) => (
          <p class="city-paragraph">{para}</p>
        ))}
      </div>

      {/* CTAs */}
      <div class="city-ctas">
        {city.ctas.map((cta, i) => (
          <a
            href={cta.href}
            class:list={["city-cta", i === 0 ? "city-cta--primary" : "city-cta--secondary"]}
          >
            <span>{cta.label}</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="city-cta__arrow"
            >
              <path d="M5 12h14" />
              <path d="m12 5 7 7-7 7" />
            </svg>
          </a>
        ))}
      </div>

      {/* Footer */}
      <div class="city-footer">
        <a href="/cities" class="city-footer__link">
          &larr; All cities
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  @keyframes cityFadeIn {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .city-page {
    min-height: 100vh;
    position: relative;
    z-index: 1;
    animation: cityFadeIn 0.5s ease-out both;
  }

  .city-container {
    max-width: 680px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  .city-eyebrow {
    font-family: var(--font-jetbrains);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #C9A84C;
    margin-bottom: 16px;
  }

  .city-h1 {
    font-family: var(--font-playfair);
    font-size: clamp(28px, 5vw, 40px);
    font-weight: 700;
    color: var(--text-ivory);
    line-height: 1.12;
    margin-bottom: 32px;
  }

  .city-divider {
    width: 48px;
    height: 1px;
    background: rgba(201, 168, 76, 0.3);
    margin-bottom: 36px;
  }

  .city-body {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .city-paragraph {
    font-family: var(--font-cormorant);
    font-size: 18px;
    color: rgba(245, 237, 228, 0.78);
    line-height: 1.7;
    margin: 0;
  }

  .city-ctas {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 44px;
  }

  .city-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 22px;
    border-radius: 14px;
    border: 1px solid;
    font-family: var(--font-dm-sans);
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }

  .city-cta--primary {
    border-color: rgba(201, 168, 76, 0.5);
    background: rgba(201, 168, 76, 0.1);
    color: #E2C97E;
  }

  .city-cta--secondary {
    border-color: rgba(245, 237, 228, 0.12);
    background: rgba(255, 255, 255, 0.03);
    color: rgba(245, 237, 228, 0.7);
  }

  .city-cta__arrow {
    flex-shrink: 0;
  }

  .city-footer {
    margin-top: 64px;
    padding-top: 24px;
    border-top: 1px solid rgba(245, 237, 228, 0.06);
  }

  .city-footer__link {
    font-family: var(--font-dm-sans);
    font-size: 14px;
    color: rgba(245, 237, 228, 0.35);
    text-decoration: none;
  }
</style>
