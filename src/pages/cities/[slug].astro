  }

  .city-footer__link {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--muted);
    text-decoration: none;
  }

  /* ─── City Notify Signup ──────────────────────────── */

  .city-notify {
    margin-top: 48px;
    padding: 32px 24px;
    border: 1px solid rgba(0, 0, 0, 0.06);
