---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContestantPortalApp from "@/components/ContestantPortal";
---

<BaseLayout
  title="Contestant Packet"
  description="Private contestant packet and show prep guide."
  noindex={true}
>
  <Fragment slot="head">
    <script is:inline>
      // WHY: ?invite= values are single-use bearer tokens. This runs
      // synchronously during HTML parse, before the DEFERRED analytics
      // scripts (GTM, PostHog, Meta pixel) can execute and capture the URL.
      // It stashes the link context plus a one-load "explicit" flag under the
      // same keys src/lib/portalBootstrap.ts reads (keep the two in sync),
      // then scrubs the URL unconditionally. When sessionStorage is
      // unavailable the context survives in window.__portalCtx instead, so
      // the token still never reaches an analytics pageview.
      (function () {
        try {
          var params = new URLSearchParams(location.search);
          var invite = params.get("invite");
          var show = params.get("show");
          if (!invite && !show) return;
          var ctx = invite
            ? { kind: "invite", id: invite }
            : { kind: "show", id: show };
          try {
            sessionStorage.setItem("gmd_portal_ctx", JSON.stringify(ctx));
            sessionStorage.setItem("gmd_portal_ctx_explicit", "1");
          } catch (storageErr) {
            window.__portalCtx = ctx;
          }
          try {
            history.replaceState(null, "", "/contestant-portal");
          } catch (replaceErr) {
            // Fail closed: a hard navigation drops the query string before
            // the deferred analytics scripts can run with the token in the
            // URL. The stored context (when storage worked) survives it.
            location.replace("/contestant-portal");
          }
        } catch (err) {}
      })();
    </script>
  </Fragment>
  <main id="main-content">
    <ContestantPortalApp client:load />
  </main>
</BaseLayout>

<script>
  // WHY: starts the /api/portal-state request the moment this module executes,
  // before the React island downloads and hydrates. Without this, the server
  // round trip (serverless cold start + rate limit + Firestore) runs AFTER
  // hydration instead of overlapping it. The island calls the same idempotent
  // function and receives this in-flight promise.
  import { startPortalStateLoad } from "@/lib/portalBootstrap";
  startPortalStateLoad();
</script>
