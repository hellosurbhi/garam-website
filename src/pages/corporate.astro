---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buildBreadcrumbJsonLd } from "@/utils/breadcrumbs";
import FaqAccordion from "@/components/ui/FaqAccordion.astro";
import {
  CORPORATE_COPY,
  AUDIENCE_TIERS,
  INCLUSIONS,
  CORPORATE_TESTIMONIALS,
  CORPORATE_FAQS,
} from "@/data/corporate";

const TITLE = "Private & Corporate Events NYC";
const DESC =
  "Book Garam Masala Dating for your next corporate team event, Diwali party, or private show in NYC. 50 to 250 guests. Professional hosts, full production, venue coordination. Email our manager Caleb at caleb@garammasaladating.com to book.";

const SITE_URL = "https://garammasaladating.com";

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: `${SITE_URL}/` },
  { name: "Corporate Events" },
]);

const serviceJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Private & Corporate Show",
  description: DESC,
  provider: {
    "@type": "Organization",
    name: "Garam Masala Dating",
    url: SITE_URL,
    logo: `${SITE_URL}/images/logo.svg`,
  },
  areaServed: { "@type": "City", name: "New York City" },
  serviceType: "Live Entertainment",
});

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: CORPORATE_FAQS.map((faq) => ({
    "@type": "Question",
    name: faq.q,
    acceptedAnswer: { "@type": "Answer", text: faq.a },
  })),
});

const reviewJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Private & Corporate Show — Garam Masala Dating",
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: 5,
    bestRating: 5,
    worstRating: 1,
    ratingCount: CORPORATE_TESTIMONIALS.length,
  },
  review: CORPORATE_TESTIMONIALS.map((t) => ({
    "@type": "Review",
    author: { "@type": "Person", name: t.author },
    reviewBody: t.quote,
    reviewRating: {
      "@type": "Rating",
      ratingValue: 5,
      bestRating: 5,
      worstRating: 1,
    },
  })),
});

const speakableJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  url: `${SITE_URL}/corporate`,
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: [".corp-faq-answer"],
  },
});
---

<BaseLayout title={TITLE} description={DESC}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
    <script type="application/ld+json" set:html={serviceJsonLd} />
    <script type="application/ld+json" set:html={faqJsonLd} />
    <script type="application/ld+json" set:html={speakableJsonLd} />
    <script type="application/ld+json" set:html={reviewJsonLd} />
  </Fragment>

  <main id="main-content" class="corp">
    <!-- Hero -->
    <section class="corp-hero" aria-labelledby="corp-heading">
      <div class="corp-container corp-hero-inner">
        <p class="corp-eyebrow">Private & Corporate Events</p>
        <h1 id="corp-heading">{CORPORATE_COPY.heroHeadline}</h1>
        <p class="corp-hero-sub">{CORPORATE_COPY.heroSub}</p>
        <div class="corp-email-block">
          <p class="corp-email-label">
            Email our {CORPORATE_COPY.agentTitle}, {CORPORATE_COPY.agentName}:
          </p>
          <a
            href={`mailto:${CORPORATE_COPY.agentEmail}?subject=Private%20Show%20Inquiry`}
            class="corp-email-link"
            data-ph-capture="cta_clicked"
            data-ph-cta="email_hero"
            data-ph-section="corporate_hero"
            toolname="email-corporate-booking"
            tooldescription="Email Caleb, the manager at Garam Masala Dating, to book a private or corporate show in NYC."
            >{CORPORATE_COPY.agentEmail}</a
          >
          <p class="corp-email-note">{CORPORATE_COPY.heroNote}</p>
        </div>
      </div>
    </section>

    <!-- Photo -->
    <div class="corp-photo">
      <img
        src="/images/promo/on-stage.webp"
        alt="Contestants and hosts on stage at Garam Masala Dating"
        width="1200"
        height="800"
        loading="lazy"
      />
    </div>

    <!-- What a Private Show Looks Like -->
    <section class="corp-format" aria-labelledby="corp-format-heading">
      <div class="corp-container corp-format-grid">
        <div class="corp-format-text">
          <p class="corp-eyebrow">What a Private Show Looks Like</p>
          <h2 id="corp-format-heading">
            Real singles. Real dates. Your crowd loses their minds.
          </h2>
          {CORPORATE_COPY.showFormatBody.map((p) => <p>{p}</p>)}
        </div>
        <div class="corp-format-img">
          <img
            src="/images/promo/after-party.webp"
            alt="Audience clapping at Garam Masala Dating show"
            width="1200"
            height="800"
            loading="lazy"
          />
        </div>
      </div>
    </section>

    <!-- Audience Size Options -->
    <section class="corp-sizes" aria-labelledby="corp-sizes-heading">
      <div class="corp-container">
        <p class="corp-eyebrow">Choose Your Format</p>
        <h2 id="corp-sizes-heading">We scale the show to your group.</h2>
        <div class="corp-tiers">
          {
            AUDIENCE_TIERS.map((tier) => (
              <div class="corp-tier">
                <div class="corp-tier-range">{tier.range}</div>
                <div class="corp-tier-label">{tier.label}</div>
                <p class="corp-tier-desc">{tier.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- What's Included -->
    <section class="corp-inc" aria-labelledby="corp-inc-heading">
      <div class="corp-container">
        <p class="corp-eyebrow">What's Included</p>
        <h2 id="corp-inc-heading">Everything handled. You just show up.</h2>
        <div class="corp-inc-grid">
          {
            INCLUSIONS.map((item) => (
              <div class="corp-inc-card">
                <h3>{item.title}</h3>
                <p>{item.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Photos -->
    <div class="corp-photo-pair">
      <img
        src="/images/promo/the-match.webp"
        alt="Matched couple laughing on stage"
        width="1200"
        height="800"
        loading="lazy"
      />
      <img
        src="/images/promo/testimonial-reaction.webp"
        alt="Audience reacting at the show"
        width="800"
        height="1200"
        loading="lazy"
      />
    </div>

    <!-- Testimonials -->
    <section class="corp-test" aria-labelledby="corp-test-heading">
      <div class="corp-container">
        <p class="corp-eyebrow">What People Say</p>
        <h2 id="corp-test-heading">
          "The only company event anyone talks about."
        </h2>
        <div class="corp-quotes">
          {
            CORPORATE_TESTIMONIALS.map((t) => (
              <blockquote class="corp-quote">
                <p>"{t.quote}"</p>
                <footer>
                  <strong>{t.author}</strong>
                  <span>{t.role}</span>
                </footer>
              </blockquote>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Photo -->
    <div class="corp-photo">
      <img
        src="/images/promo/pure-chaos.webp"
        alt="High energy moment on stage"
        width="1200"
        height="800"
        loading="lazy"
      />
    </div>

    <!-- FAQ -->
    <section class="corp-faq" aria-labelledby="corp-faq-heading">
      <div class="corp-container corp-faq-inner">
        <p class="corp-eyebrow">Common Questions</p>
        <h2 id="corp-faq-heading">FAQs</h2>
        <FaqAccordion
          items={CORPORATE_FAQS}
          groupId="corporate-faq"
          answerClass="corp-faq-answer"
        />
      </div>
    </section>

    <!-- CTA -->
    <section class="corp-cta" aria-labelledby="corp-cta-heading">
      <div class="corp-container corp-cta-inner">
        <h2 id="corp-cta-heading">{CORPORATE_COPY.ctaHeadline}</h2>
        <p>{CORPORATE_COPY.ctaBody}</p>
        <a
          href={`mailto:${CORPORATE_COPY.agentEmail}?subject=Private%20Show%20Inquiry`}
          class="corp-email-link corp-email-link--white"
          data-ph-capture="cta_clicked"
          data-ph-cta="email_footer"
          data-ph-section="corporate_cta"
          toolname="email-corporate-booking"
          tooldescription="Email Caleb, the manager at Garam Masala Dating, to book a private or corporate show in NYC."
          >{CORPORATE_COPY.agentEmail}</a
        >
        <p class="corp-cta-note">{CORPORATE_COPY.ctaNote}</p>
        <nav class="corp-cta-links" aria-label="Related pages">
          <a href="/hosts">Meet the Hosts</a>
          <a href="/tickets">Upcoming Shows</a>
          <a href="/faq">More Questions</a>
        </nav>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .corp {
    font-family: var(--font-body), sans-serif;
  }
  .corp-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .corp-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--brand-red);
    margin-bottom: 14px;
  }

  /* Email CTA */
  .corp-email-block {
    margin-top: 32px;
  }
  .corp-email-label {
    font-size: 14px;
    color: var(--text-secondary);
    margin-bottom: 6px;
    font-weight: 600;
  }
  .corp-email-link {
    display: inline-flex;
    align-items: center;
    font-size: clamp(18px, 2.5vw, 24px);
    font-weight: 800;
    color: var(--brand-red);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
    transition: color 0.2s;
    min-height: var(--touch-target);
    padding: 4px 0;
  }
  .corp-email-link:hover {
    color: var(--brand-red-dark);
  }
  .corp-email-link:focus-visible {
    outline: 2px solid var(--brand-red);
    outline-offset: 3px;
  }
  .corp-email-link--white {
    color: white;
    text-decoration-color: white;
  }
  .corp-email-link--white:hover {
    color: var(--electric-yellow);
    text-decoration-color: var(--electric-yellow);
  }
  .corp-email-note {
    font-size: 13px;
    color: var(--muted);
    margin-top: 10px;
    max-width: 480px;
  }

  /* Hero */
  .corp-hero {
    background: var(--off-white);
    padding: 56px 0 48px;
    text-align: center;
  }
  .corp-hero h1 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(28px, 5vw, 54px);
    font-weight: 900;
    color: var(--charcoal);
    line-height: 1.08;
    margin-bottom: 20px;
  }
  .corp-hero-sub {
    font-family: var(--font-cormorant), serif;
    font-size: clamp(17px, 2.2vw, 22px);
    font-style: italic;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 640px;
    margin: 0 auto;
  }
  .corp-hero .corp-email-note {
    margin-left: auto;
    margin-right: auto;
  }

  /* Standalone photos */
  .corp-photo {
    line-height: 0;
  }
  .corp-photo img {
    width: 100%;
    height: auto;
    object-fit: cover;
    max-height: 240px;
  }
  .corp-photo-pair {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    line-height: 0;
  }
  .corp-photo-pair img {
    width: 100%;
    height: auto;
    object-fit: cover;
    max-height: 240px;
  }

  /* Format section */
  .corp-format {
    background: var(--cream-warm);
    padding: 56px 0;
  }
  .corp-format-grid {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .corp-format-text h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 800;
    color: var(--charcoal);
    line-height: 1.15;
    margin-bottom: 20px;
  }
  .corp-format-text p {
    font-size: 16px;
    line-height: 1.8;
    color: var(--text-secondary);
    margin-bottom: 14px;
  }
  .corp-format-img img {
    width: 100%;
    height: auto;
    border-radius: 14px;
    aspect-ratio: 3/2;
    object-fit: cover;
  }

  /* Audience tiers */
  .corp-sizes {
    background: var(--off-white);
    padding: 56px 0;
    text-align: center;
  }
  .corp-sizes h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 800;
    color: var(--charcoal);
    margin-bottom: 28px;
    text-align: center;
  }
  .corp-tiers {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .corp-tier {
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 14px;
    padding: 24px;
  }
  .corp-tier-range {
    font-family: var(--font-playfair), serif;
    font-size: 28px;
    font-weight: 900;
    color: var(--brand-red);
    line-height: 1;
    margin-bottom: 4px;
  }
  .corp-tier-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 10px;
  }
  .corp-tier-desc {
    font-size: 15px;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
    text-align: left;
  }

  /* Inclusions */
  .corp-inc {
    background: var(--cream-warm);
    padding: 56px 0;
    text-align: center;
  }
  .corp-inc h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 800;
    color: var(--charcoal);
    margin-bottom: 28px;
  }
  .corp-inc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }
  .corp-inc-card {
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 14px;
    padding: 24px;
  }
  .corp-inc-card h3 {
    font-family: var(--font-playfair), serif;
    font-size: 18px;
    font-weight: 800;
    color: var(--brand-red);
    margin-bottom: 8px;
  }
  .corp-inc-card p {
    font-size: 14px;
    line-height: 1.65;
    color: var(--text-secondary);
    margin: 0;
    text-align: left;
  }

  /* Testimonials */
  .corp-test {
    background: var(--off-white);
    padding: 56px 0;
    text-align: center;
  }
  .corp-test h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(22px, 3vw, 34px);
    font-weight: 800;
    color: var(--charcoal);
    margin-bottom: 28px;
  }
  .corp-quotes {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .corp-quote {
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 14px;
    padding: 24px;
    margin: 0;
    text-align: left;
  }
  .corp-quote p {
    font-family: var(--font-cormorant), serif;
    font-size: clamp(16px, 2vw, 18px);
    font-style: italic;
    color: var(--charcoal);
    line-height: 1.7;
    margin: 0 0 12px;
  }
  .corp-quote footer {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .corp-quote strong {
    font-size: 13px;
    color: var(--brand-red);
  }
  .corp-quote span {
    font-size: 12px;
    color: var(--muted);
  }

  /* FAQ */
  .corp-faq {
    background: var(--cream-warm);
    padding: 56px 0;
  }
  .corp-faq-inner {
    max-width: 760px;
  }
  .corp-faq h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 800;
    color: var(--charcoal);
    margin-bottom: 28px;
  }

  /* CTA */
  .corp-cta {
    background: var(--brand-red);
    padding: 56px 0;
    text-align: center;
  }
  .corp-cta-inner {
    max-width: 640px;
  }
  .corp-cta h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 900;
    color: white;
    margin-bottom: 16px;
  }
  .corp-cta p {
    font-size: 16px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 24px;
  }
  .corp-cta-note {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.5);
    margin-top: 10px;
    margin-bottom: 0;
  }
  .corp-cta-links {
    display: flex;
    gap: 24px;
    justify-content: center;
    margin-top: 28px;
  }
  .corp-cta-links a {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }
  .corp-cta-links a:hover {
    color: white;
  }

  @media (min-width: 768px) {
    .corp-hero {
      padding: 80px 0 72px;
    }
    .corp-photo img {
      max-height: 500px;
    }
    .corp-photo-pair {
      grid-template-columns: 1fr 1fr;
    }
    .corp-photo-pair img {
      height: 100%;
      max-height: 400px;
    }
    .corp-format {
      padding: 80px 0;
    }
    .corp-format-grid {
      flex-direction: row;
      align-items: center;
      gap: 48px;
    }
    .corp-format-text {
      flex: 1.2;
    }
    .corp-format-img {
      flex: 0.8;
    }
    .corp-sizes {
      padding: 80px 0;
    }
    .corp-tiers {
      flex-direction: row;
    }
    .corp-tiers .corp-tier {
      flex: 1;
    }
    .corp-inc {
      padding: 80px 0;
    }
    .corp-inc-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .corp-test {
      padding: 80px 0;
    }
    .corp-quotes {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
    }
    .corp-faq {
      padding: 80px 0;
    }
    .corp-cta {
      padding: 80px 0;
    }
  }
</style>
