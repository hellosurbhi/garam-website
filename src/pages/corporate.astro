---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buildBreadcrumbJsonLd } from "@/utils/breadcrumbs";
import {
  CORPORATE_COPY,
  AUDIENCE_TIERS,
  INCLUSIONS,
  CORPORATE_TESTIMONIALS,
  CORPORATE_FAQS,
} from "@/data/corporate";

const TITLE = "Private & Corporate Events NYC | Garam Masala Dating";
const DESC =
  "Book Garam Masala Dating for your next corporate team event, Diwali party, or private show in NYC. 50–250 guests. Professional hosts, full production, venue coordination. Email our events agent Caleb at caleb@garammasaladating.com to book.";

const SITE_URL = "https://garammasaladating.com";

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: `${SITE_URL}/` },
  { name: "Corporate Events" },
]);

const serviceJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Private & Corporate Show — Garam Masala Dating",
  description:
    "A fully produced live South Asian comedy dating show for corporate teams, private parties, and client entertainment events in NYC. 50–250 guests. Includes professional hosts, production, venue coordination, and post-show mixer.",
  provider: {
    "@type": "Organization",
    name: "Garam Masala Dating",
    url: SITE_URL,
    logo: `${SITE_URL}/images/logo.svg`,
  },
  areaServed: {
    "@type": "City",
    name: "New York City",
  },
  serviceType: "Live Entertainment",
  audience: {
    "@type": "Audience",
    audienceType: "Corporate teams, private event organizers",
  },
  offers: {
    "@type": "Offer",
    eligibleCustomerType: "Business",
  },
});

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: CORPORATE_FAQS.map((faq) => ({
    "@type": "Question",
    name: faq.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.a,
    },
  })),
});

const speakableJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  url: `${SITE_URL}/corporate`,
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: [".corp-faq-answer"],
  },
});
---

<BaseLayout title={TITLE} description={DESC}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
    <script type="application/ld+json" set:html={serviceJsonLd} />
    <script type="application/ld+json" set:html={faqJsonLd} />
    <script type="application/ld+json" set:html={speakableJsonLd} />
  </Fragment>

  <main id="main-content" class="corp-page">
    <!-- ── Hero ─────────────────────────────────────────────────── -->
    <section class="corp-hero" aria-labelledby="corp-hero-heading">
      <div class="corp-container corp-hero-inner">
        <p class="corp-eyebrow">Private &amp; Corporate Events</p>
        <h1 id="corp-hero-heading">{CORPORATE_COPY.heroHeadline}</h1>
        <p class="corp-hero-sub">{CORPORATE_COPY.heroSub}</p>
        <div class="corp-email-cta">
          <p class="corp-email-label">Email our {CORPORATE_COPY.agentTitle}:</p>
          <a
            href={`mailto:${CORPORATE_COPY.agentEmail}?subject=Private%20Show%20Inquiry`}
            class="corp-email-link"
            data-ph-capture="cta_clicked"
            data-ph-cta="email_hero"
            data-ph-section="corporate_hero"
          >
            {CORPORATE_COPY.agentEmail}
          </a>
          <p class="corp-email-note">{CORPORATE_COPY.heroNote}</p>
        </div>
      </div>
    </section>

    <!-- ── What a Private Show Looks Like ───────────────────────── -->
    <section class="corp-format" aria-labelledby="corp-format-heading">
      <div class="corp-container">
        <p class="corp-eyebrow corp-eyebrow--light">
          What a Private Show Looks Like
        </p>
        <h2 id="corp-format-heading">{CORPORATE_COPY.showFormatHeadline}</h2>
        {
          CORPORATE_COPY.showFormatBody.map((p) => (
            <p class="corp-format-p">{p}</p>
          ))
        }
      </div>
    </section>

    <!-- ── Audience Size Options ────────────────────────────────── -->
    <section class="corp-sizes" aria-labelledby="corp-sizes-heading">
      <div class="corp-container">
        <p class="corp-eyebrow">Choose Your Format</p>
        <h2 id="corp-sizes-heading">We scale the show to your group.</h2>
        <div class="corp-tiers">
          {
            AUDIENCE_TIERS.map((tier) => (
              <div class="corp-tier">
                <div class="corp-tier-range">{tier.range}</div>
                <div class="corp-tier-label">{tier.label}</div>
                <p class="corp-tier-desc">{tier.description}</p>
                <p class="corp-tier-ideal">
                  <strong>Ideal for:</strong> {tier.ideal}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ── What's Included ──────────────────────────────────────── -->
    <section class="corp-inclusions" aria-labelledby="corp-inc-heading">
      <div class="corp-container">
        <p class="corp-eyebrow corp-eyebrow--light">What's Included</p>
        <h2 id="corp-inc-heading">Everything handled. You just show up.</h2>
        <div class="corp-inc-list">
          {
            INCLUSIONS.map((item) => (
              <div class="corp-inc-item">
                <h3>{item.title}</h3>
                <p>{item.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ── Testimonials ─────────────────────────────────────────── -->
    <section
      class="corp-testimonials"
      aria-labelledby="corp-testimonials-heading"
    >
      <div class="corp-container">
        <p class="corp-eyebrow">What People Say</p>
        <h2 id="corp-testimonials-heading" class="corp-testimonials-heading">
          "Still talking about it three months later."
        </h2>
        <div class="corp-quotes">
          {
            CORPORATE_TESTIMONIALS.map((t) => (
              <blockquote class="corp-quote">
                <p class="corp-quote-text">"{t.quote}"</p>
                <footer class="corp-quote-attr">
                  <strong>{t.author}</strong>
                  <span>{t.role}</span>
                </footer>
              </blockquote>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ── FAQ ──────────────────────────────────────────────────── -->
    <section class="corp-faq" aria-labelledby="corp-faq-heading">
      <div class="corp-container corp-faq-inner">
        <p class="corp-eyebrow">Common Questions</p>
        <h2 id="corp-faq-heading">FAQs</h2>
        <div class="corp-faq-list">
          {
            CORPORATE_FAQS.map((faq) => (
              <details class="corp-faq-item">
                <summary class="corp-faq-q">
                  {faq.q}
                  <span class="corp-faq-toggle" aria-hidden="true">
                    +
                  </span>
                </summary>
                <p class="corp-faq-answer">{faq.a}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ── Final CTA ─────────────────────────────────────────────── -->
    <section class="corp-cta" aria-labelledby="corp-cta-heading">
      <div class="corp-container corp-cta-inner">
        <h2 id="corp-cta-heading">{CORPORATE_COPY.ctaHeadline}</h2>
        <p class="corp-cta-body">{CORPORATE_COPY.ctaBody}</p>
        <div class="corp-email-cta corp-email-cta--dark">
          <a
            href={`mailto:${CORPORATE_COPY.agentEmail}?subject=Private%20Show%20Inquiry`}
            class="corp-email-link corp-email-link--yellow"
            data-ph-capture="cta_clicked"
            data-ph-cta="email_footer"
            data-ph-section="corporate_cta"
          >
            {CORPORATE_COPY.agentEmail}
          </a>
          <p class="corp-email-note corp-email-note--dark">
            {CORPORATE_COPY.ctaNote}
          </p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ── Shared ─────────────────────────────────────────────────── */
  .corp-page {
    font-family: var(--font-body), sans-serif;
  }

  .corp-container {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .corp-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--brand-red);
    margin-bottom: 14px;
  }
  .corp-eyebrow--light {
    color: rgba(255, 255, 255, 0.55);
  }

  /* ── Email CTA (replaces fake buttons) ──────────────────── */
  .corp-email-cta {
    margin-top: 32px;
  }
  .corp-email-label {
    font-size: 14px;
    color: var(--text-secondary);
    margin-bottom: 6px;
    font-weight: 600;
  }
  .corp-email-link {
    display: inline-block;
    font-family: var(--font-body), sans-serif;
    font-size: clamp(18px, 2.5vw, 24px);
    font-weight: 800;
    color: var(--brand-red);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
    transition: color 0.2s;
    padding: 4px 0;
    min-height: var(--touch-target);
    display: inline-flex;
    align-items: center;
  }
  .corp-email-link:hover {
    color: var(--brand-red-dark);
  }
  .corp-email-link:focus-visible {
    outline: 2px solid var(--brand-red);
    outline-offset: 3px;
  }
  .corp-email-link--yellow {
    color: var(--electric-yellow);
    text-decoration-color: var(--electric-yellow);
  }
  .corp-email-link--yellow:hover {
    color: white;
    text-decoration-color: white;
  }
  .corp-email-note {
    font-size: 14px;
    color: var(--muted);
    margin-top: 10px;
    line-height: 1.6;
    max-width: 560px;
  }
  .corp-email-note--dark {
    color: rgba(255, 255, 255, 0.45);
  }

  /* ── Hero ─────────────────────────────────────────────────── */
  .corp-hero {
    background: var(--off-white);
    padding: 56px 0 48px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }
  .corp-hero-inner {
    text-align: center;
  }
  .corp-hero h1 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(28px, 5vw, 52px);
    font-weight: 900;
    color: var(--charcoal);
    line-height: 1.08;
    margin-bottom: 20px;
  }
  .corp-hero-sub {
    font-family: var(--font-cormorant), serif;
    font-size: clamp(17px, 2.2vw, 21px);
    font-style: italic;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 680px;
    margin: 0 auto;
  }
  .corp-hero .corp-email-cta {
    margin-top: 36px;
  }
  .corp-hero .corp-email-note {
    margin-left: auto;
    margin-right: auto;
  }

  /* ── Format / Show Description ───────────────────────────── */
  .corp-format {
    background: var(--charcoal);
    padding: 56px 0;
    color: white;
  }
  .corp-format h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 800;
    color: white;
    line-height: 1.15;
    margin-bottom: 24px;
  }
  .corp-format-p {
    font-size: 16px;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.82);
    margin-bottom: 16px;
  }

  /* ── Audience Sizes ──────────────────────────────────────── */
  .corp-sizes {
    background: var(--off-white);
    padding: 56px 0;
  }
  .corp-sizes h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 800;
    color: var(--charcoal);
    line-height: 1.15;
    margin-bottom: 32px;
  }
  .corp-tiers {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .corp-tier {
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 14px;
    padding: 28px;
  }
  .corp-tier-range {
    font-family: var(--font-playfair), serif;
    font-size: 32px;
    font-weight: 900;
    color: var(--brand-red);
    line-height: 1;
    margin-bottom: 4px;
  }
  .corp-tier-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 12px;
  }
  .corp-tier-desc {
    font-size: 15px;
    line-height: 1.75;
    color: var(--text-secondary);
    margin: 0 0 10px;
  }
  .corp-tier-ideal {
    font-size: 13px;
    color: var(--muted);
    margin: 0;
  }

  /* ── Inclusions ──────────────────────────────────────────── */
  .corp-inclusions {
    background: var(--charcoal);
    padding: 56px 0;
    color: white;
  }
  .corp-inclusions h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 800;
    color: white;
    line-height: 1.15;
    margin-bottom: 36px;
  }
  .corp-inc-list {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }
  .corp-inc-item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding-bottom: 28px;
  }
  .corp-inc-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .corp-inc-item h3 {
    font-family: var(--font-playfair), serif;
    font-size: 20px;
    font-weight: 800;
    color: var(--electric-yellow);
    margin-bottom: 10px;
  }
  .corp-inc-item p {
    font-size: 15px;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.78);
    margin: 0;
  }

  /* ── Testimonials ────────────────────────────────────────── */
  .corp-testimonials {
    background: var(--cream-warm);
    padding: 56px 0;
  }
  .corp-testimonials-heading {
    font-family: var(--font-playfair), serif;
    font-size: clamp(22px, 3vw, 34px);
    font-weight: 800;
    color: var(--charcoal);
    margin-bottom: 36px;
    line-height: 1.2;
  }
  .corp-quotes {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .corp-quote {
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 14px;
    padding: 28px;
    margin: 0;
  }
  .corp-quote-text {
    font-family: var(--font-cormorant), serif;
    font-size: clamp(16px, 2vw, 18px);
    font-style: italic;
    color: var(--charcoal);
    line-height: 1.7;
    margin: 0 0 16px;
  }
  .corp-quote-attr {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .corp-quote-attr strong {
    font-size: 14px;
    font-weight: 700;
    color: var(--brand-red);
  }
  .corp-quote-attr span {
    font-size: 13px;
    color: var(--muted);
  }

  /* ── FAQ ─────────────────────────────────────────────────── */
  .corp-faq {
    background: var(--off-white);
    padding: 56px 0;
  }
  .corp-faq-inner {
    max-width: 760px;
  }
  .corp-faq h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 800;
    color: var(--charcoal);
    margin-bottom: 28px;
  }
  .corp-faq-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .corp-faq-item {
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }
  .corp-faq-item:first-child {
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }
  .corp-faq-q {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 18px 0;
    font-size: 16px;
    font-weight: 700;
    color: var(--charcoal);
    cursor: pointer;
    list-style: none;
    line-height: 1.4;
  }
  .corp-faq-q::-webkit-details-marker {
    display: none;
  }
  .corp-faq-toggle {
    flex-shrink: 0;
    font-size: 22px;
    font-weight: 400;
    color: var(--brand-red);
    transition: transform 0.2s;
    line-height: 1;
  }
  .corp-faq-item[open] .corp-faq-toggle {
    transform: rotate(45deg);
  }
  .corp-faq-answer {
    font-size: 15px;
    line-height: 1.75;
    color: var(--text-secondary);
    padding: 0 0 18px;
    margin: 0;
  }

  /* ── Final CTA ───────────────────────────────────────────── */
  .corp-cta {
    background: var(--charcoal);
    padding: 56px 0;
    text-align: center;
  }
  .corp-cta-inner {
    max-width: 680px;
  }
  .corp-cta h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 900;
    color: white;
    margin-bottom: 20px;
  }
  .corp-cta-body {
    font-size: 16px;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.78);
    margin-bottom: 0;
  }
  .corp-cta .corp-email-cta {
    margin-top: 28px;
  }

  /* ── Desktop ─────────────────────────────────────────────── */
  @media (min-width: 768px) {
    .corp-hero {
      padding: 80px 0 72px;
    }
    .corp-format {
      padding: 80px 0;
    }
    .corp-sizes {
      padding: 80px 0;
    }
    .corp-tiers {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
    }
    .corp-inclusions {
      padding: 80px 0;
    }
    .corp-testimonials {
      padding: 80px 0;
    }
    .corp-faq {
      padding: 80px 0;
    }
    .corp-cta {
      padding: 80px 0;
    }
  }
</style>
