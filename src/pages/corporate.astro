---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buildBreadcrumbJsonLd } from "@/utils/breadcrumbs";
import FaqAccordion from "@/components/ui/FaqAccordion.astro";
import {
  CORPORATE_COPY,
  AUDIENCE_TIERS,
  INCLUSIONS,
  CORPORATE_TESTIMONIALS,
  CORPORATE_FAQS,
} from "@/data/corporate";

const TITLE = "Private & Corporate Events NYC | Garam Masala Dating";
const DESC =
  "Book Garam Masala Dating for your next corporate team event, Diwali party, or private show in NYC. 50 to 250 guests. Professional hosts, full production, venue coordination. Email our manager Caleb at caleb@garammasaladating.com to book.";

const SITE_URL = "https://garammasaladating.com";

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: `${SITE_URL}/` },
  { name: "Corporate Events" },
]);

const serviceJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Private & Corporate Show",
  description: DESC,
  provider: {
    "@type": "Organization",
    name: "Garam Masala Dating",
    url: SITE_URL,
    logo: `${SITE_URL}/images/logo.svg`,
  },
  areaServed: { "@type": "City", name: "New York City" },
  serviceType: "Live Entertainment",
});

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: CORPORATE_FAQS.map((faq) => ({
    "@type": "Question",
    name: faq.q,
    acceptedAnswer: { "@type": "Answer", text: faq.a },
  })),
});

const speakableJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  url: `${SITE_URL}/corporate`,
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: [".corp-faq-answer"],
  },
});
---

<BaseLayout title={TITLE} description={DESC}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
    <script type="application/ld+json" set:html={serviceJsonLd} />
    <script type="application/ld+json" set:html={faqJsonLd} />
    <script type="application/ld+json" set:html={speakableJsonLd} />
  </Fragment>

  <main id="main-content" class="corp">
    <!-- Hero with background image -->
    <section class="corp-hero" aria-labelledby="corp-heading">
      <img
        class="corp-hero-bg"
        src="/images/on-stage.webp"
        alt=""
        width="1200"
        height="800"
        aria-hidden="true"
      />
      <div class="corp-hero-overlay"></div>
      <div class="corp-container corp-hero-inner">
        <p class="corp-eyebrow corp-eyebrow--white">
          Private & Corporate Events
        </p>
        <h1 id="corp-heading">{CORPORATE_COPY.heroHeadline}</h1>
        <p class="corp-hero-sub">{CORPORATE_COPY.heroSub}</p>
        <div class="corp-email-block">
          <p class="corp-email-label">
            Email our {CORPORATE_COPY.agentTitle}, {CORPORATE_COPY.agentName}:
          </p>
          <a
            href={`mailto:${CORPORATE_COPY.agentEmail}?subject=Private%20Show%20Inquiry`}
            class="corp-email-link"
            data-ph-capture="cta_clicked"
            data-ph-cta="email_hero"
            data-ph-section="corporate_hero">{CORPORATE_COPY.agentEmail}</a
          >
          <p class="corp-email-note">{CORPORATE_COPY.heroNote}</p>
        </div>
      </div>
    </section>

    <!-- What a Private Show Looks Like -->
    <section class="corp-format" aria-labelledby="corp-format-heading">
      <div class="corp-container corp-format-grid">
        <div class="corp-format-text">
          <p class="corp-eyebrow">What a Private Show Looks Like</p>
          <h2 id="corp-format-heading">
            Real singles. Real dates. Your crowd loses their minds.
          </h2>
          {CORPORATE_COPY.showFormatBody.map((p) => <p>{p}</p>)}
        </div>
        <div class="corp-format-img">
          <img
            src="/images/after-party.webp"
            alt="Audience clapping at Garam Masala Dating show"
            width="1200"
            height="800"
            loading="lazy"
          />
        </div>
      </div>
    </section>

    <!-- Audience Size Options -->
    <section class="corp-sizes" aria-labelledby="corp-sizes-heading">
      <div class="corp-container">
        <p class="corp-eyebrow">Choose Your Format</p>
        <h2 id="corp-sizes-heading">We scale the show to your group.</h2>
        <div class="corp-tiers">
          {
            AUDIENCE_TIERS.map((tier) => (
              <div class="corp-tier">
                <div class="corp-tier-range">{tier.range}</div>
                <div class="corp-tier-label">{tier.label}</div>
                <p class="corp-tier-desc">{tier.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- What's Included -->
    <section class="corp-inc" aria-labelledby="corp-inc-heading">
      <div class="corp-container">
        <p class="corp-eyebrow">What's Included</p>
        <h2 id="corp-inc-heading">Everything handled. You just show up.</h2>
        <div class="corp-inc-grid">
          {
            INCLUSIONS.map((item) => (
              <div class="corp-inc-card">
                <h3>{item.title}</h3>
                <p>{item.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Photo break -->
    <section class="corp-photos" aria-hidden="true">
      <img
        src="/images/the-match.webp"
        alt="Matched couple laughing on stage"
        width="1200"
        height="800"
        loading="lazy"
      />
      <img
        src="/images/the-crowd.webp"
        alt="Audience reacting"
        width="800"
        height="1200"
        loading="lazy"
      />
    </section>

    <!-- Testimonials -->
    <section class="corp-test" aria-labelledby="corp-test-heading">
      <img
        class="corp-test-bg"
        src="/images/pure-chaos.webp"
        alt=""
        width="1200"
        height="800"
        loading="lazy"
        aria-hidden="true"
      />
      <div class="corp-test-overlay"></div>
      <div class="corp-container corp-test-inner">
        <p class="corp-eyebrow corp-eyebrow--white">What People Say</p>
        <h2 id="corp-test-heading">
          "The only company event anyone talks about."
        </h2>
        <div class="corp-quotes">
          {
            CORPORATE_TESTIMONIALS.map((t) => (
              <blockquote class="corp-quote">
                <p>"{t.quote}"</p>
                <footer>
                  <strong>{t.author}</strong>
                  <span>{t.role}</span>
                </footer>
              </blockquote>
            ))
          }
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="corp-faq" aria-labelledby="corp-faq-heading">
      <div class="corp-container corp-faq-inner">
        <p class="corp-eyebrow">Common Questions</p>
        <h2 id="corp-faq-heading">FAQs</h2>
        <FaqAccordion
          items={CORPORATE_FAQS}
          groupId="corporate-faq"
          answerClass="corp-faq-answer"
        />
      </div>
    </section>

    <!-- CTA -->
    <section class="corp-cta" aria-labelledby="corp-cta-heading">
      <div class="corp-container corp-cta-inner">
        <h2 id="corp-cta-heading">{CORPORATE_COPY.ctaHeadline}</h2>
        <p>{CORPORATE_COPY.ctaBody}</p>
        <a
          href={`mailto:${CORPORATE_COPY.agentEmail}?subject=Private%20Show%20Inquiry`}
          class="corp-email-link corp-email-link--white"
          data-ph-capture="cta_clicked"
          data-ph-cta="email_footer"
          data-ph-section="corporate_cta">{CORPORATE_COPY.agentEmail}</a
        >
        <p class="corp-cta-note">{CORPORATE_COPY.ctaNote}</p>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .corp {
    font-family: var(--font-body), sans-serif;
  }
  .corp-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .corp-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--brand-red);
    margin-bottom: 14px;
  }
  .corp-eyebrow--white {
    color: rgba(255, 255, 255, 0.7);
  }

  /* Email CTA */
  .corp-email-block {
    margin-top: 32px;
  }
  .corp-email-label {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 6px;
    font-weight: 600;
  }
  .corp-email-link {
    display: inline-flex;
    align-items: center;
    font-size: clamp(18px, 2.5vw, 24px);
    font-weight: 800;
    color: var(--electric-yellow);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
    transition: color 0.2s;
    min-height: var(--touch-target);
    padding: 4px 0;
  }
  .corp-email-link:hover {
    color: white;
    text-decoration-color: white;
  }
  .corp-email-link:focus-visible {
    outline: 2px solid var(--electric-yellow);
    outline-offset: 3px;
  }
  .corp-email-link--white {
    color: white;
    text-decoration-color: white;
  }
  .corp-email-link--white:hover {
    color: var(--electric-yellow);
    text-decoration-color: var(--electric-yellow);
  }
  .corp-email-note {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.5);
    margin-top: 10px;
    max-width: 480px;
  }

  /* Hero */
  .corp-hero {
    position: relative;
    overflow: hidden;
    padding: 80px 0 72px;
    text-align: center;
  }
  .corp-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    z-index: 0;
  }
  .corp-hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.7) 0%,
      rgba(0, 0, 0, 0.55) 100%
    );
  }
  .corp-hero-inner {
    position: relative;
    z-index: 2;
  }
  .corp-hero h1 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(28px, 5vw, 54px);
    font-weight: 900;
    color: white;
    line-height: 1.08;
    margin-bottom: 20px;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.5);
  }
  .corp-hero-sub {
    font-family: var(--font-cormorant), serif;
    font-size: clamp(17px, 2.2vw, 22px);
    font-style: italic;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.7;
    max-width: 640px;
    margin: 0 auto;
  }
  .corp-hero .corp-email-note {
    margin-left: auto;
    margin-right: auto;
  }

  /* Format section */
  .corp-format {
    background: var(--cream-warm);
    padding: 56px 0;
  }
  .corp-format-grid {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .corp-format-text h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 800;
    color: var(--charcoal);
    line-height: 1.15;
    margin-bottom: 20px;
  }
  .corp-format-text p {
    font-size: 16px;
    line-height: 1.8;
    color: var(--text-secondary);
    margin-bottom: 14px;
  }
  .corp-format-img img {
    width: 100%;
    height: auto;
    border-radius: 14px;
    aspect-ratio: 3/2;
    object-fit: cover;
  }

  /* Audience tiers */
  .corp-sizes {
    background: var(--off-white);
    padding: 56px 0;
  }
  .corp-sizes h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 800;
    color: var(--charcoal);
    margin-bottom: 28px;
  }
  .corp-tiers {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .corp-tier {
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 14px;
    padding: 24px;
  }
  .corp-tier-range {
    font-family: var(--font-playfair), serif;
    font-size: 28px;
    font-weight: 900;
    color: var(--brand-red);
    line-height: 1;
    margin-bottom: 4px;
  }
  .corp-tier-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 10px;
  }
  .corp-tier-desc {
    font-size: 15px;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
  }

  /* Inclusions */
  .corp-inc {
    background: var(--cream-warm);
    padding: 56px 0;
  }
  .corp-inc h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 800;
    color: var(--charcoal);
    margin-bottom: 28px;
  }
  .corp-inc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }
  .corp-inc-card {
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 14px;
    padding: 24px;
  }
  .corp-inc-card h3 {
    font-family: var(--font-playfair), serif;
    font-size: 18px;
    font-weight: 800;
    color: var(--brand-red);
    margin-bottom: 8px;
  }
  .corp-inc-card p {
    font-size: 14px;
    line-height: 1.65;
    color: var(--text-secondary);
    margin: 0;
  }

  /* Photo break */
  .corp-photos {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
    padding: 0;
  }
  .corp-photos img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 3/2;
  }

  /* Testimonials with image bg */
  .corp-test {
    position: relative;
    overflow: hidden;
    padding: 56px 0;
    text-align: center;
  }
  .corp-test-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    z-index: 0;
  }
  .corp-test-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: rgba(0, 0, 0, 0.65);
  }
  .corp-test-inner {
    position: relative;
    z-index: 2;
  }
  .corp-test h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(22px, 3vw, 34px);
    font-weight: 800;
    color: white;
    margin-bottom: 32px;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.5);
  }
  .corp-quotes {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .corp-quote {
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 14px;
    padding: 24px;
    margin: 0;
    text-align: left;
  }
  .corp-quote p {
    font-family: var(--font-cormorant), serif;
    font-size: clamp(16px, 2vw, 18px);
    font-style: italic;
    color: white;
    line-height: 1.7;
    margin: 0 0 12px;
  }
  .corp-quote footer {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .corp-quote strong {
    font-size: 13px;
    color: var(--electric-yellow);
  }
  .corp-quote span {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.5);
  }

  /* FAQ */
  .corp-faq {
    background: var(--off-white);
    padding: 56px 0;
  }
  .corp-faq-inner {
    max-width: 760px;
  }
  .corp-faq h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 800;
    color: var(--charcoal);
    margin-bottom: 28px;
  }

  /* CTA */
  .corp-cta {
    background: var(--brand-red);
    padding: 56px 0;
    text-align: center;
  }
  .corp-cta-inner {
    max-width: 640px;
  }
  .corp-cta h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 900;
    color: white;
    margin-bottom: 16px;
  }
  .corp-cta p {
    font-size: 16px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 24px;
  }
  .corp-cta-note {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.5);
    margin-top: 10px;
    margin-bottom: 0;
  }

  @media (min-width: 768px) {
    .corp-hero {
      padding: 120px 0 100px;
    }
    .corp-format {
      padding: 80px 0;
    }
    .corp-format-grid {
      flex-direction: row;
      align-items: center;
      gap: 48px;
    }
    .corp-format-text {
      flex: 1.2;
    }
    .corp-format-img {
      flex: 0.8;
    }
    .corp-sizes {
      padding: 80px 0;
    }
    .corp-tiers {
      flex-direction: row;
    }
    .corp-tiers .corp-tier {
      flex: 1;
    }
    .corp-inc {
      padding: 80px 0;
    }
    .corp-inc-grid {
      grid-template-columns: 1fr 1fr;
    }
    .corp-photos {
      gap: 10px;
    }
    .corp-test {
      padding: 100px 0;
    }
    .corp-quotes {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
    }
    .corp-faq {
      padding: 80px 0;
    }
    .corp-cta {
      padding: 80px 0;
    }
  }
</style>
