---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buildBreadcrumbJsonLd } from "@/utils/breadcrumbs";
import FaqAccordion from "@/components/ui/FaqAccordion.astro";
import {
  DESI_EVENTS_COPY,
  DESI_OCCASION_TYPES,
  DESI_INCLUSIONS,
  DESI_TESTIMONIALS,
  DESI_FAQS,
} from "@/data/desi-events";

const TITLE =
  "South Asian Event Entertainment NYC | Sangeet, Roka & Indian Wedding";
const DESC =
  "Book a live comedy dating show for your sangeet, roka, Indian wedding reception or desi celebration in NYC. Private show, no recording, flat fee. Set up your single cousins, kids and grandkids. Email contact@garammasaladating.com.";

const SITE_URL = "https://garammasaladating.com";

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: `${SITE_URL}/` },
  { name: "South Asian Events" },
]);

const serviceJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  name: "South Asian Private Event Show",
  description: DESC,
  provider: {
    "@type": "Organization",
    name: "Garam Masala Dating",
    url: SITE_URL,
    logo: `${SITE_URL}/images/logo.svg`,
  },
  areaServed: { "@type": "City", name: "New York City" },
  serviceType: "Live Entertainment",
});

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: DESI_FAQS.map((faq) => ({
    "@type": "Question",
    name: faq.q,
    acceptedAnswer: { "@type": "Answer", text: faq.a },
  })),
});

const speakableJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  url: `${SITE_URL}/desi-events`,
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: [".desi-faq-answer"],
  },
});
---

<BaseLayout title={TITLE} description={DESC}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
    <script type="application/ld+json" set:html={serviceJsonLd} />
    <script type="application/ld+json" set:html={faqJsonLd} />
    <script type="application/ld+json" set:html={speakableJsonLd} />
  </Fragment>

  <main id="main-content" class="desi">
    <!-- Hero -->
    <section class="desi-hero" aria-labelledby="desi-heading">
      <div class="desi-container desi-hero-inner">
        <p class="desi-eyebrow">{DESI_EVENTS_COPY.heroEyebrow}</p>
        <h1 id="desi-heading">{DESI_EVENTS_COPY.heroHeadline}</h1>
        <p class="desi-hero-sub">{DESI_EVENTS_COPY.heroSub}</p>
        <div class="desi-privacy-callout" role="note">
          <p>{DESI_EVENTS_COPY.noCameraNote}</p>
        </div>
        <div class="desi-email-block">
          <p class="desi-email-label">Email us to book a private show:</p>
          <a
            href={`mailto:${DESI_EVENTS_COPY.bookingEmail}?subject=South%20Asian%20Event%20Inquiry`}
            class="desi-email-link"
            data-ph-capture="desi_events_inquiry_click"
            data-ph-cta="email_hero"
            data-ph-section="desi_hero"
            data-cta-position="desi_hero"
            data-cta-text={DESI_EVENTS_COPY.bookingEmail}
            data-destination-url={`mailto:${DESI_EVENTS_COPY.bookingEmail}?subject=South%20Asian%20Event%20Inquiry`}
            toolname="email-desi-events-booking"
            tooldescription="Email Garam Masala Dating to book a private South Asian event show in NYC."
            >{DESI_EVENTS_COPY.bookingEmail}</a
          >
          <p class="desi-email-note">{DESI_EVENTS_COPY.heroNote}</p>
        </div>
      </div>
    </section>

    <!-- Photo -->
    <div class="desi-photo">
      <img
        src="/images/promo/on-stage.webp"
        alt="Contestants and hosts on stage at Garam Masala Dating"
        width="1200"
        height="800"
        loading="lazy"
      />
    </div>

    <!-- What a Private Show Looks Like -->
    <section class="desi-format" aria-labelledby="desi-format-heading">
      <div class="desi-container desi-format-grid">
        <div class="desi-format-text">
          <p class="desi-eyebrow">What a Private Show Looks Like</p>
          <h2 id="desi-format-heading">
            Real singles. Real dates. Your crowd loses their minds.
          </h2>
          {DESI_EVENTS_COPY.showFormatBody.map((p) => <p>{p}</p>)}
        </div>
        <div class="desi-format-img">
          <img
            src="/images/promo/after-party.webp"
            alt="Audience clapping at Garam Masala Dating show"
            width="1200"
            height="800"
            loading="lazy"
          />
        </div>
      </div>
    </section>

    <!-- Occasion Types -->
    <section class="desi-occasions" aria-labelledby="desi-occasions-heading">
      <div class="desi-container">
        <p class="desi-eyebrow">Perfect for Every South Asian Occasion</p>
        <h2 id="desi-occasions-heading">
          Pick the occasion. We handle the rest.
        </h2>
        <div class="desi-occasions-grid">
          {
            DESI_OCCASION_TYPES.map((occasion) => (
              <div class="desi-occasion-card">
                <span class="desi-occasion-icon" aria-hidden="true">
                  {occasion.icon}
                </span>
                <h3>{occasion.label}</h3>
                <p>{occasion.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- What's Included -->
    <section class="desi-inc" aria-labelledby="desi-inc-heading">
      <div class="desi-container">
        <p class="desi-eyebrow">What's Included</p>
        <h2 id="desi-inc-heading">Everything handled. You just show up.</h2>
        <div class="desi-inc-grid">
          {
            DESI_INCLUSIONS.map((item) => (
              <div class="desi-inc-card">
                <h3>{item.title}</h3>
                <p>{item.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Photos -->
    <div class="desi-photo-pair">
      <img
        src="/images/promo/the-match.webp"
        alt="Matched couple laughing on stage"
        width="1200"
        height="800"
        loading="lazy"
      />
      <img
        src="/images/promo/pure-chaos.webp"
        alt="High energy moment on stage"
        width="1200"
        height="800"
        loading="lazy"
      />
    </div>

    <!-- Testimonials -->
    <section class="desi-test" aria-labelledby="desi-test-heading">
      <div class="desi-container">
        <p class="desi-eyebrow">What People Say</p>
        <h2 id="desi-test-heading">
          "The best night of the whole wedding weekend."
        </h2>
        <div class="desi-quotes">
          {
            DESI_TESTIMONIALS.map((t) => (
              <blockquote class="desi-quote">
                <p>"{t.quote}"</p>
                <footer>
                  <strong>{t.author}</strong>
                  <span>{t.role}</span>
                </footer>
              </blockquote>
            ))
          }
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="desi-faq" aria-labelledby="desi-faq-heading">
      <div class="desi-container desi-faq-inner">
        <p class="desi-eyebrow">Common Questions</p>
        <h2 id="desi-faq-heading">FAQs</h2>
        <FaqAccordion
          items={DESI_FAQS}
          groupId="desi-faq"
          answerClass="desi-faq-answer"
        />
      </div>
    </section>

    <!-- CTA -->
    <section class="desi-cta" aria-labelledby="desi-cta-heading">
      <div class="desi-container desi-cta-inner">
        <h2 id="desi-cta-heading">{DESI_EVENTS_COPY.ctaHeadline}</h2>
        <p>{DESI_EVENTS_COPY.ctaBody}</p>
        <a
          href={`mailto:${DESI_EVENTS_COPY.bookingEmail}?subject=South%20Asian%20Event%20Inquiry`}
          class="desi-email-link desi-email-link--white"
          data-ph-capture="desi_events_inquiry_click"
          data-ph-cta="email_footer"
          data-ph-section="desi_cta"
          data-cta-position="desi_cta"
          data-cta-text={DESI_EVENTS_COPY.bookingEmail}
          data-destination-url={`mailto:${DESI_EVENTS_COPY.bookingEmail}?subject=South%20Asian%20Event%20Inquiry`}
          toolname="email-desi-events-booking"
          tooldescription="Email Garam Masala Dating to book a private South Asian event show in NYC."
          >{DESI_EVENTS_COPY.bookingEmail}</a
        >
        <p class="desi-cta-note">{DESI_EVENTS_COPY.ctaNote}</p>
        <nav class="desi-cta-links" aria-label="Related pages">
          <a href="/celebrate">Parties & Celebrations</a>
          <a href="/corporate">Corporate Events</a>
          <a href="/tickets">Upcoming Shows</a>
          <a href="/hosts">Meet the Hosts</a>
        </nav>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .desi {
    font-family: var(--font-body), sans-serif;
  }
  .desi-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .desi-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--brand-red);
    margin-bottom: 14px;
  }

  /* Email CTA */
  .desi-email-block {
    margin-top: 32px;
  }
  .desi-email-label {
    font-size: 14px;
    color: var(--text-secondary);
    margin-bottom: 6px;
    font-weight: 600;
  }
  .desi-email-link {
    display: inline-flex;
    align-items: center;
    font-size: clamp(18px, 2.5vw, 24px);
    font-weight: 800;
    color: var(--brand-red);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
    transition: color 0.2s;
    min-height: var(--touch-target);
    padding: 4px 0;
  }
  .desi-email-link:hover {
    color: var(--brand-red-dark);
  }
  .desi-email-link:focus-visible {
    outline: 2px solid var(--brand-red);
    outline-offset: 3px;
  }
  .desi-email-link--white {
    color: white;
    text-decoration-color: white;
  }
  .desi-email-link--white:hover {
    color: var(--electric-yellow);
    text-decoration-color: var(--electric-yellow);
  }
  .desi-email-note {
    font-size: 13px;
    color: var(--muted);
    margin-top: 10px;
    max-width: 480px;
  }

  /* Hero */
  .desi-hero {
    background: var(--off-white);
    padding: 56px 0 48px;
    text-align: center;
  }
  .desi-hero h1 {
    font-family: var(--font-display), sans-serif;
    font-size: clamp(36px, 7vw, 72px);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--charcoal);
    line-height: 0.92;
    margin-bottom: 20px;
  }
  .desi-hero-sub {
    font-family: var(--font-cormorant), serif;
    font-size: clamp(17px, 2.2vw, 22px);
    font-style: italic;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 640px;
    margin: 0 auto;
  }
  .desi-hero .desi-email-note {
    margin-left: auto;
    margin-right: auto;
  }

  /* Privacy callout */
  .desi-privacy-callout {
    background: rgba(220, 38, 38, 0.06);
    border: 1px solid rgba(220, 38, 38, 0.18);
    border-radius: 10px;
    padding: 14px 20px;
    margin: 24px auto 0;
    max-width: 580px;
  }
  .desi-privacy-callout p {
    font-size: 14px;
    font-weight: 600;
    color: var(--brand-red);
    line-height: 1.6;
    margin: 0;
    text-align: left;
  }

  /* Standalone photos */
  .desi-photo {
    line-height: 0;
  }
  .desi-photo img {
    width: 100%;
    height: auto;
    object-fit: cover;
    max-height: 240px;
  }
  .desi-photo-pair {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    line-height: 0;
  }
  .desi-photo-pair img {
    width: 100%;
    height: auto;
    object-fit: cover;
    max-height: 240px;
  }

  /* Format section */
  .desi-format {
    background: var(--cream-warm);
    padding: 56px 0;
  }
  .desi-format-grid {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .desi-format-text h2 {
    font-family: var(--font-display), sans-serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 400;
    text-transform: uppercase;
    color: var(--charcoal);
    line-height: 0.92;
    margin-bottom: 20px;
  }
  .desi-format-text p {
    font-size: 16px;
    line-height: 1.8;
    color: var(--text-secondary);
    margin-bottom: 14px;
  }
  .desi-format-img img {
    width: 100%;
    height: auto;
    border-radius: 14px;
    aspect-ratio: 3/2;
    object-fit: cover;
  }

  /* Occasion Types */
  .desi-occasions {
    background: var(--off-white);
    padding: 56px 0;
    text-align: center;
  }
  .desi-occasions h2 {
    font-family: var(--font-display), sans-serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 400;
    text-transform: uppercase;
    line-height: 0.92;
    color: var(--charcoal);
    margin-bottom: 28px;
    text-align: center;
  }
  .desi-occasions-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }
  .desi-occasion-card {
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 14px;
    padding: 24px;
    text-align: center;
  }
  .desi-occasion-icon {
    display: block;
    font-size: 36px;
    line-height: 1;
    margin-bottom: 12px;
  }
  .desi-occasion-card h3 {
    font-family: var(--font-serif), serif;
    font-size: 18px;
    font-weight: 400;
    color: var(--brand-red);
    margin-bottom: 8px;
  }
  .desi-occasion-card p {
    font-size: 14px;
    line-height: 1.65;
    color: var(--text-secondary);
    margin: 0;
    text-align: left;
  }

  /* Inclusions */
  .desi-inc {
    background: var(--cream-warm);
    padding: 56px 0;
    text-align: center;
  }
  .desi-inc h2 {
    font-family: var(--font-display), sans-serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 400;
    text-transform: uppercase;
    line-height: 0.92;
    color: var(--charcoal);
    margin-bottom: 28px;
  }
  .desi-inc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }
  .desi-inc-card {
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 14px;
    padding: 24px;
  }
  .desi-inc-card h3 {
    font-family: var(--font-serif), serif;
    font-size: 18px;
    font-weight: 400;
    color: var(--brand-red);
    margin-bottom: 8px;
  }
  .desi-inc-card p {
    font-size: 14px;
    line-height: 1.65;
    color: var(--text-secondary);
    margin: 0;
    text-align: left;
  }

  /* Testimonials */
  .desi-test {
    background: var(--off-white);
    padding: 56px 0;
    text-align: center;
  }
  .desi-test h2 {
    font-family: var(--font-display), sans-serif;
    font-size: clamp(22px, 3vw, 34px);
    font-weight: 400;
    text-transform: uppercase;
    line-height: 0.92;
    color: var(--charcoal);
    margin-bottom: 28px;
  }
  .desi-quotes {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .desi-quote {
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 14px;
    padding: 24px;
    margin: 0;
    text-align: left;
  }
  .desi-quote p {
    font-family: var(--font-cormorant), serif;
    font-size: clamp(16px, 2vw, 18px);
    font-style: italic;
    color: var(--charcoal);
    line-height: 1.7;
    margin: 0 0 12px;
  }
  .desi-quote footer {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .desi-quote strong {
    font-size: 13px;
    color: var(--brand-red);
  }
  .desi-quote span {
    font-size: 12px;
    color: var(--muted);
  }

  /* FAQ */
  .desi-faq {
    background: var(--cream-warm);
    padding: 56px 0;
  }
  .desi-faq-inner {
    max-width: 760px;
  }
  .desi-faq h2 {
    font-family: var(--font-display), sans-serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 400;
    text-transform: uppercase;
    line-height: 0.92;
    color: var(--charcoal);
    margin-bottom: 28px;
  }

  /* CTA */
  .desi-cta {
    background: var(--brand-red);
    padding: 56px 0;
    text-align: center;
  }
  .desi-cta-inner {
    max-width: 640px;
  }
  .desi-cta h2 {
    font-family: var(--font-display), sans-serif;
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 400;
    text-transform: uppercase;
    line-height: 0.92;
    color: white;
    margin-bottom: 16px;
  }
  .desi-cta p {
    font-size: 16px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 24px;
  }
  .desi-cta-note {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.5);
    margin-top: 10px;
    margin-bottom: 0;
  }
  .desi-cta-links {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    justify-content: center;
    margin-top: 28px;
  }
  .desi-cta-links a {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }
  .desi-cta-links a:hover {
    color: white;
  }

  @media (min-width: 480px) {
    .desi-occasions-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .desi-hero {
      padding: 80px 0 72px;
    }
    .desi-photo img {
      max-height: 500px;
    }
    .desi-photo-pair {
      grid-template-columns: 1fr 1fr;
    }
    .desi-photo-pair img {
      height: 100%;
      max-height: 400px;
    }
    .desi-format {
      padding: 80px 0;
    }
    .desi-format-grid {
      flex-direction: row;
      align-items: center;
      gap: 48px;
    }
    .desi-format-text {
      flex: 1.2;
    }
    .desi-format-img {
      flex: 0.8;
    }
    .desi-occasions {
      padding: 80px 0;
    }
    .desi-occasions-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .desi-inc {
      padding: 80px 0;
    }
    .desi-inc-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .desi-test {
      padding: 80px 0;
    }
    .desi-quotes {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
    }
    .desi-faq {
      padding: 80px 0;
    }
    .desi-cta {
      padding: 80px 0;
    }
  }
</style>
