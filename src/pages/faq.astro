---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { buildBreadcrumbJsonLd } from '@/utils/breadcrumbs';

const FAQ_TITLE = "FAQ \u2013 Garam Masala Dating | Live South Asian Dating Show NYC";
const FAQ_DESC =
  "Everything you need to know about Garam Masala Dating \u2014 tickets, how the show works, who can apply, what to expect, and how to get on stage.";

function stripHtml(str: string): string {
  return str.replace(/<[^>]*>/g, '');
}

const FAQS = [
  {
    q: "What is Garam Masala Dating?",
    a: "Garam Masala Dating is a live South Asian dating show and singles mixer in NYC. Every week, real singles go on blind dates on stage in front of a 250-person audience. It\u2019s part comedy show, part actual matchmaking \u2014 and it\u2019s more fun than any app you\u2019ve ever been on.",
  },
  {
    q: "Do I have to be South Asian to come?",
    a: "No. The show is open to everyone. Our audience and contestants are a mix of South Asian, desi diaspora, and anyone who loves a good night out. If you like comedy, dating culture, and meeting new people, you\u2019ll fit right in.",
  },
  {
    q: "How do I get tickets?",
    a: 'Tickets are available on Eventbrite. Search \u2018Garam Masala Dating\u2019 or visit <a href="/tickets">garammasaladating.com/tickets</a>. General admission includes entry to the show and the singles mixer before and after.',
  },
  {
    q: "How do I apply to be a contestant?",
    a: 'Fill out the <a href="/apply">application on our website</a>. We cast contestants based on personality, chemistry potential, and your answers \u2014 not looks. Being genuinely funny, honest, or a little chaotic helps.',
  },
  {
    q: "What actually happens at the show?",
    a: "Contestants are introduced to the audience, then paired for a live blind date on stage. The hosts ask questions, the audience reacts, and the dates decide how it ends. After the show, everyone mixes at the venue. It\u2019s a real night out, not a cringe exercise.",
  },
  {
    q: "Is it scripted or staged?",
    a: "Nothing is scripted. The dates are real, the reactions are real, and the awkwardness is definitely real. We only coach contestants on timing and mic basics.",
  },
  {
    q: "What should I wear?",
    a: "Dress like you\u2019re going on a real date. Bold colors, fun fits, something you feel good in. This is not a night for business casual.",
  },
  {
    q: "Can I come solo?",
    a: "Yes \u2014 most people do. The mixer format means you\u2019ll meet people before the show even starts.",
  },
  {
    q: "How often does the show run?",
    a: 'Garam Masala Dating runs weekly in Manhattan and monthly in Jersey City, New Jersey. Visit <a href="/tickets">garammasaladating.com</a> for upcoming dates.',
  },
  {
    q: "Is Garam Masala Dating like Indian Matchmaking?",
    a: "Garam Masala Dating is a live comedy show, not a TV production. Unlike Indian Matchmaking, it happens in real time in front of a live audience of 250 people in NYC. There are no producers, no editing, and no second takes \u2014 just two real singles on a real date on stage.",
  },
  {
    q: "What cities is Garam Masala Dating in?",
    a: 'Garam Masala Dating currently runs weekly in Manhattan, New York City and monthly in Jersey City, New Jersey. Check <a href="/tickets">garammasaladating.com</a> for upcoming show dates and locations.',
  },
  {
    q: "Is Garam Masala Dating free?",
    a: 'No. Tickets are purchased on Eventbrite. Prices vary by show \u2014 check <a href="/tickets">garammasaladating.com</a> for current pricing and upcoming dates.',
  },
  {
    q: "I want to collaborate, sponsor, or book the show for a private event. Who do I contact?",
    a: 'Email <a href="mailto:press@garammasaladating.com">press@garammasaladating.com</a>. We do private events, brand partnerships, and media features.',
  },
];

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: FAQS.map(({ q, a }) => ({
    "@type": "Question",
    name: q,
    acceptedAnswer: { "@type": "Answer", text: stripHtml(a) },
  })),
});

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: "https://garammasaladating.com" },
  { name: "FAQ" },
]);
---

<BaseLayout
  title={FAQ_TITLE}
  description={FAQ_DESC}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={faqJsonLd} />
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
  </Fragment>

  <main id="main-content" class="faq-page">
    <img class="faq-bg" src="/images/higgs-field.webp" alt="" width="1200" height="800" aria-hidden="true" />
    <div class="faq-container">
      <!-- Header -->
      <div class="faq-header">
        <p class="faq-label">FAQ</p>
        <h1 class="faq-title">
          Garam Mas<em>ala</em> Dating
        </h1>
        <p class="faq-intro">
          Everything you need to know before you show up.
        </p>
      </div>

      <!-- FAQ items -->
      <div class="faq-list">
        {FAQS.map((item, i) => (
          <div class="faq-item">
            <h2 class="faq-question">{item.q}</h2>
            <p class="faq-answer-text" set:html={item.a} />
          </div>
        ))}
      </div>

      <!-- Footer -->
      <div class="faq-footer">
        <p class="faq-footer-text">
          Still have questions? Reach out at{' '}
          <a href="mailto:contact@garammasaladating.com" class="faq-footer-link">
            contact@garammasaladating.com
          </a>
        </p>
      </div>
    </div>
  </main>
</BaseLayout>


<style>
  @keyframes faqFadeIn {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .faq-page {
    min-height: 100vh;
    position: relative;
    z-index: 1;
    animation: faqFadeIn 0.5s ease-out both;
    overflow: hidden;
  }
  .faq-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
    z-index: 0;
    opacity: 0.06;
  }

  .faq-container {
    position: relative;
    z-index: 1;
    max-width: 680px;
    margin: 0 auto;
    padding: 36px 24px;
  }

  /* Header */
  .faq-header {
    margin-bottom: 20px;
  }

  .faq-label {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--brand-red);
    margin-bottom: 12px;
  }

  .faq-title {
    font-family: var(--font-playfair);
    font-size: 32px;
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.15;
    margin-bottom: 14px;
  }

  .faq-title em {
    font-style: italic;
    color: var(--brand-red);
  }

  .faq-intro {
    font-family: var(--font-cormorant);
    font-style: italic;
    font-size: 17px;
    color: var(--text-light);
    line-height: 1.55;
  }

  /* FAQ list */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .faq-item {
    border-radius: 12px;
    border: 1px solid rgba(0, 0, 0, 0.06);
    background: white;
    padding: 22px;
    transition: border-color 0.15s, background 0.15s;
  }

  .faq-item:hover {
    border-color: rgba(var(--brand-red-rgb), 0.2);
    background: white;
  }

  .faq-question {
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 600;
    color: var(--charcoal);
    line-height: 1.4;
    margin: 0 0 10px;
  }

  .faq-answer-text {
    font-family: var(--font-body);
    font-size: 17px;
    color: var(--text-secondary);
    line-height: 1.65;
    margin: 0;
  }

  /* Footer */
  .faq-footer {
    text-align: center;
    padding-top: 24px;
  }

  .faq-footer-text {
    font-family: var(--font-body);
    font-size: 15px;
    font-style: italic;
    color: var(--muted);
  }

  .faq-answer-text a {
    color: var(--brand-red);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .faq-footer-link {
    color: var(--brand-red);
    text-decoration: none;
  }
</style>
