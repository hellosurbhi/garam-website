---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EventbriteWidgetInit from "@/components/EventbriteWidgetInit.astro";
import HomeNav from "@/components/home/HomeNav.astro";
import HomeHero from "@/components/home/HomeHero.astro";
import HomeMarquee from "@/components/home/HomeMarquee.astro";
import HomeExperience from "@/components/home/HomeExperience.astro";
import HomeShows from "@/components/home/HomeShows.astro";
import HomeStats from "@/components/home/HomeStats.astro";
import HomePress from "@/components/home/HomePress.astro";
import HomeTestimonials from "@/components/home/HomeTestimonials.astro";
import HomeCreators from "@/components/home/HomeCreators.astro";
import HomeVideo from "@/components/home/HomeVideo.astro";
import HomeFAQ from "@/components/home/HomeFAQ.astro";
import HomeJournal from "@/components/home/HomeJournal.astro";
import StickyCTA from "@/components/StickyCTA.astro";
import { CREATOR_URLS } from "@/data/socials";
import { PAGES } from "@/data/copy";
import { buildOrganizationJsonLd } from "@/utils/organizationSchema";
import { YOUTUBE_VIDEO_ID, VIDEO_METADATA } from "@/lib/constants";
import { events, allEvents } from "@/data/events";
import { isUpcomingByIso } from "@/utils/eventDate";
import { buildEventSchemas } from "@/utils/eventSchema";

const HIDDEN_FROM_HOME = ["Salt Lake City", "Denver"];
const today = new Date().toISOString().slice(0, 10);
const upcomingEvents = allEvents.filter(
  (e) => isUpcomingByIso(e, today) && !HIDDEN_FROM_HOME.includes(e.city),
);
const firstTicketUrl = "/tickets";
const heroEvents = events
  .filter((e) => !e.hidden && e.isoDate && e.isoDate >= today && e.url)
  .slice(0, 5);

// Organization JSON-LD
const orgJsonLd = buildOrganizationJsonLd();

// WebSite JSON-LD
const websiteJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Garam Masala Dating",
  url: "https://garammasaladating.com",
});

// Individual Event JSON-LD blocks (one per upcoming show with a real date+url)
const eventSchemas = buildEventSchemas(
  events.filter((e) => !e.hidden && e.isoDate && e.isoDate >= today),
);

// VideoObject JSON-LD
const videoJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "VideoObject",
  name: VIDEO_METADATA.title,
  description: VIDEO_METADATA.description,
  thumbnailUrl: `https://i.ytimg.com/vi/${YOUTUBE_VIDEO_ID}/maxresdefault.jpg`,
  contentUrl: `https://www.youtube.com/watch?v=${YOUTUBE_VIDEO_ID}`,
  embedUrl: `https://www.youtube.com/embed/${YOUTUBE_VIDEO_ID}`,
  uploadDate: VIDEO_METADATA.uploadDate,
  duration: VIDEO_METADATA.duration,
  publisher: {
    "@type": "Organization",
    name: "Garam Masala Dating",
    url: "https://garammasaladating.com",
    logo: {
      "@type": "ImageObject",
      url: "https://garammasaladating.com/images/logo.svg",
    },
  },
});

// EventSeries JSON-LD
const eventSeriesJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "EventSeries",
  "@id": "https://garammasaladating.com/#event-series",
  name: "Garam Masala Dating",
  description:
    "America's #1 recurring live desi comedy dating show. Two real South Asian singles go on a blind date in front of a 250-person audience. Bi-weekly in Manhattan at Top Secret Comedy Club.",
  url: "https://garammasaladating.com",
  startDate: "2022",
  organizer: {
    "@type": "Organization",
    name: "Garam Masala Dating",
    url: "https://garammasaladating.com",
  },
  location: {
    "@type": "Place",
    name: "Top Secret Comedy Club",
    address: {
      "@type": "PostalAddress",
      streetAddress: "44 Avenue A",
      addressLocality: "New York",
      addressRegion: "NY",
      postalCode: "10009",
      addressCountry: "US",
    },
  },
  eventSchedule: {
    "@type": "Schedule",
    repeatFrequency: "P2W",
  },
  performer: [
    { "@type": "Person", name: "Surbhi", url: CREATOR_URLS.surbhi },
    { "@type": "Person", name: "Wyatt Feegrado", url: CREATOR_URLS.wyatt },
  ],
});

// Speakable — targets hero description + HomeFAQ answer text
const speakableJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  url: "https://garammasaladating.com",
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: [".hero-sub", ".faq-answer-summary", ".faq-answer-detail"],
  },
});
---

<BaseLayout
  title="America's #1 Live Desi Comedy Dating Show"
  description={PAGES.home.description}
  hideNav={true}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={orgJsonLd} />
    <script type="application/ld+json" set:html={websiteJsonLd} />
    <script type="application/ld+json" set:html={speakableJsonLd} />
    <script type="application/ld+json" set:html={videoJsonLd} />
    <script type="application/ld+json" set:html={eventSeriesJsonLd} />
    {
      eventSchemas.map((schema) => (
        <script type="application/ld+json" set:html={schema} />
      ))
    }
  </Fragment>

  <HomeNav ticketsUrl={firstTicketUrl} />
  <main id="main-content">
    <HomeHero ticketsUrl={firstTicketUrl} heroEvents={heroEvents} />
    <HomeMarquee />
    <HomeExperience />
    <HomeShows events={upcomingEvents} />
    <HomeStats />
    <HomePress />
    <HomeTestimonials />
    <HomeCreators />
    <HomeVideo />
    <HomeFAQ />
    <HomeJournal />
  </main>
  <EventbriteWidgetInit />

  <!-- 30-second email popup -->
  <dialog id="email-popup" class="popup-dialog">
    <div class="popup-inner">
      <button type="button" class="popup-close" aria-label="Close">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          ><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg
        >
      </button>

      <!-- min-height prevents CLS when switching between steps -->
      <div class="popup-steps-wrapper">
        <div id="popup-step-1">
          <h2 class="popup-title">Want Cheaper Tickets?</h2>
          <p class="popup-subtitle">
            Join our list for exclusive discount codes and early access.
          </p>
          <form
            id="popup-email-form"
            class="popup-form"
            toolname="subscribe-via-homepage-popup"
            tooldescription="Subscribe to Garam Masala Dating discount codes and ticket drops via the homepage signup popup. Provide an email address."
          >
            <input
              type="email"
              id="popup-email"
              class="ph-mask"
              placeholder="Your email"
              required
              aria-label="Email address"
              toolparamdescription="Email address to receive discount codes and show announcements"
            />
            <input
              type="text"
              id="popup-city"
              class="ph-mask"
              placeholder="Your city (optional)"
              aria-label="City (optional)"
              autocomplete="address-level2"
              toolparamdescription="City the subscriber lives in, used to alert them when a show comes near them (optional)"
            />
            <p id="popup-email-error" class="popup-error" hidden role="alert">
            </p>
            <button type="submit" class="popup-submit"
              >Get My Discount Code!</button
            >
          </form>
          <button type="button" class="popup-dismiss">No thanks</button>
        </div>

        <div id="popup-step-2" hidden>
          <h2 class="popup-title">One more thing...</h2>
          <p class="popup-subtitle">
            Add your number for text-only discounts and free ticket drops.
          </p>
          <form
            id="popup-phone-form"
            class="popup-form"
            toolname="add-phone-via-homepage-popup"
            tooldescription="Add a phone number for SMS-only ticket drops and deals (optional second step after email signup via homepage popup)."
          >
            <input
              type="tel"
              id="popup-phone"
              class="ph-mask"
              placeholder="(555) 123-4567"
              aria-label="Phone number"
              toolparamdescription="Mobile phone number for SMS-only deals (optional)"
            />
            <p id="popup-phone-error" class="popup-error" hidden role="alert">
            </p>
            <button type="submit" class="popup-submit">Send Me Deals!</button>
          </form>
          <button type="button" class="popup-skip">Maybe later</button>
        </div>
      </div>
    </div>
  </dialog>
  <StickyCTA triggerSelector=".hero" />
</BaseLayout>

<script>
  import { initHomepagePopup, initScrollReveal } from "@/lib/homepageInit";
  initHomepagePopup();
  initScrollReveal();
</script>

<style is:global>
  .js-reveal [data-reveal] {
    opacity: 0;
    transform: translateY(32px);
    transition:
      opacity 0.7s ease,
      transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .js-reveal [data-reveal].revealed {
    opacity: 1;
    transform: none;
  }

  /* Email popup */
  .popup-dialog {
    border: none;
    background: transparent;
    padding: 24px;
    max-width: 100%;
    max-height: 100vh;
    width: 100%;
    height: 100%;
    overflow: visible;
  }
  .popup-dialog::backdrop {
    background: rgba(0, 0, 0, 0.5);
  }
  .popup-dialog[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .popup-inner {
    width: 100%;
    max-width: 400px;
    max-height: 80vh;
    overflow-y: auto;
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 20px;
    padding: 32px 24px;
    position: relative;
    animation: popupIn 0.25s ease-out both;
    text-align: center;
  }
  /* Prevent CLS when switching between steps */
  .popup-steps-wrapper {
    min-height: 240px;
  }
  @keyframes popupIn {
    from {
      opacity: 0;
      transform: scale(0.95) translateY(8px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }
  .popup-dialog.closing .popup-inner {
    animation: dialog-out 0.2s ease-in forwards;
  }
  .popup-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    color: #888;
    cursor: pointer;
    padding: 12px;
    min-width: var(--touch-target);
    min-height: var(--touch-target);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
  }
  .popup-close:hover {
    color: var(--charcoal);
  }
  .popup-title {
    font-family: var(--font-playfair), serif;
    font-size: 24px;
    font-weight: 700;
    color: var(--charcoal);
    margin-bottom: 8px;
  }
  .popup-subtitle {
    font-size: 15px;
    color: #666;
    margin-bottom: 24px;
    line-height: 1.5;
  }
  .popup-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .popup-form input {
    padding: 14px 20px;
    border: 1.5px solid rgba(0, 0, 0, 0.1);
    border-radius: 50px;
    font-size: 16px;
    font-family: var(--font-body), sans-serif;
    outline: none;
    transition: border-color 0.2s;
    min-height: var(--touch-target);
  }
  .popup-form input:focus {
    border-color: var(--brand-red);
  }
  .popup-submit {
    background: var(--brand-red);
    color: white;
    border: none;
    padding: 14px;
    border-radius: 50px;
    font-family: var(--font-body), sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: background 0.2s;
    min-height: var(--touch-target);
    white-space: nowrap;
    width: 100%;
  }
  .popup-submit:hover {
    background: var(--brand-red-dark);
  }
  .popup-error {
    font-size: 13px;
    color: var(--brand-red);
    text-align: center;
    margin: 0;
    font-family: var(--font-body), sans-serif;
  }
  .popup-dismiss,
  .popup-skip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 16px;
    background: none;
    border: none;
    color: #999;
    font-size: 14px;
    cursor: pointer;
    font-family: var(--font-body), sans-serif;
    transition: color 0.2s;
    padding: 12px 16px;
    min-height: var(--touch-target);
  }
  .popup-dismiss:hover,
  .popup-skip:hover {
    color: #666;
  }
</style>
