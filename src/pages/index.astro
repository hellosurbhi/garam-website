---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HomeNav from '@/components/home/HomeNav.astro';
import HomeHero from '@/components/home/HomeHero.astro';
import HomeMarquee from '@/components/home/HomeMarquee.astro';
import HomeExperience from '@/components/home/HomeExperience.astro';
import HomeShows from '@/components/home/HomeShows.astro';
import HomeStats from '@/components/home/HomeStats.astro';
import HomePhotos from '@/components/home/HomePhotos.astro';
import HomePress from '@/components/home/HomePress.astro';
import HomeTestimonials from '@/components/home/HomeTestimonials.astro';
import HomeCreators from '@/components/home/HomeCreators.astro';
import HomeFAQ from '@/components/home/HomeFAQ.astro';
import HomeNewsletter from '@/components/home/HomeNewsletter.astro';
import HomeFooter from '@/components/home/HomeFooter.astro';
import { SOCIAL_URLS } from '@/data/socials';
import { events } from '@/data/events';
import { isEventPast } from '@/utils/eventDate';
import { buildEventSchemas } from '@/utils/eventSchema';

const upcomingEvents = events.filter((e) => !isEventPast(e.date) && !e.hidden);
const firstTicketUrl = upcomingEvents.find((e) => e.url && e.url !== '#')?.url ?? '/tickets';

// Organization JSON-LD
const orgJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Garam Masala Dating",
  url: "https://garammasaladating.com",
  logo: "https://garammasaladating.com/logo.png",
  description: "Garam Masala Dating is a live comedy dating show and singles mixer in New York City. Real singles go on blind dates on stage in front of a 250-person live audience. Weekly in Manhattan, monthly in Jersey City.",
  foundingDate: "2023",
  sameAs: [SOCIAL_URLS.instagram, SOCIAL_URLS.tiktok, SOCIAL_URLS.youtube],
  contactPoint: {
    "@type": "ContactPoint",
    email: "contact@garammasaladating.com",
    contactType: "customer support",
  },
});

// WebSite JSON-LD
const websiteJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Garam Masala Dating",
  url: "https://garammasaladating.com",
});

// FAQ data and JSON-LD
const HOME_FAQS = [
  {
    q: "What is Garam Masala Dating?",
    a: "Garam Masala Dating is a live comedy dating show in New York City where real singles go on blind dates on stage in front of a 250-person audience. Hosted by comedians Surbhi and Wyatt, the show runs weekly in Manhattan and monthly in Jersey City, followed by a singles mixer open to all attendees.",
  },
  {
    q: "Do you have to be South Asian to come?",
    a: "No. The show is open to everyone. The audience is a mix of South Asian, desi diaspora, and anyone who loves comedy and meeting new people.",
  },
  {
    q: "Is Garam Masala Dating like Indian Matchmaking?",
    a: "No. Garam Masala Dating is a live comedy show that happens in real time in front of 250 people in NYC. There are no producers, no editing, no second takes — just two real singles on a real first date on stage.",
  },
  {
    q: "How do I get tickets?",
    a: "Tickets are available on Eventbrite. Search \u2018Garam Masala Dating\u2019 or visit garammasaladating.com/tickets.",
  },
  {
    q: "How do I apply to be on the show?",
    a: "Fill out the contestant application at garammasaladating.com/apply. We cast based on personality and your answers, not looks.",
  },
];

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: HOME_FAQS.map(({ q, a }) => ({
    "@type": "Question",
    name: q,
    acceptedAnswer: { "@type": "Answer", text: a },
  })),
});

// Individual Event JSON-LD blocks (one per upcoming show)
const today = new Date().toISOString().slice(0, 10);
const upcomingForSchema = events.filter((e) => !e.hidden && e.isoDate && e.isoDate >= today);
const eventSchemas = buildEventSchemas(upcomingForSchema);
---

<BaseLayout
  title="Garam Masala Dating — NYC's Live South Asian Comedy Dating Show"
  description="Garam Masala Dating is New York City's hottest live comedy dating show. Watch real South Asian singles find love on stage. Hosted by comedians Surbhi & Wyatt. Tickets available now."
  bodyClass="home-v3"
>
  <Fragment slot="head">
    <meta name="keywords" content="live dating show NYC, south asian comedy show, indian dating show new york, comedy dating show, desi dating show, live comedy show NYC, indian matchmaking live" />
    <script type="application/ld+json" set:html={orgJsonLd} />
    <script type="application/ld+json" set:html={websiteJsonLd} />
    {eventSchemas.map((schema) => (
      <script type="application/ld+json" set:html={schema} />
    ))}
    <script type="application/ld+json" set:html={faqJsonLd} />
  </Fragment>

  <HomeNav ticketsUrl={firstTicketUrl} />
  <main>
    <HomeHero ticketsUrl={firstTicketUrl} />
    <HomeMarquee />
    <HomeExperience />
    <HomeShows events={upcomingEvents} />
    <HomeStats />
    <HomePhotos />
    <HomePress />
    <HomeTestimonials />
    <HomeCreators />
    <HomeFAQ />
    <HomeNewsletter />
  </main>
  <HomeFooter />
</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12 }
  );
  document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));
</script>

<style is:global>
  [data-reveal] {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }
  [data-reveal].revealed {
    opacity: 1;
    transform: none;
  }
</style>
