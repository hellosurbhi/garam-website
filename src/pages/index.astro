---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EventbriteWidgetInit from "@/components/EventbriteWidgetInit.astro";
import HomeNav from "@/components/home/HomeNav.astro";
import HomeHero from "@/components/home/HomeHero.astro";
import HomeMarquee from "@/components/home/HomeMarquee.astro";
import HomeExperience from "@/components/home/HomeExperience.astro";
import HomeShows from "@/components/home/HomeShows.astro";
import HomeStats from "@/components/home/HomeStats.astro";
import HomePress from "@/components/home/HomePress.astro";
import HomeTestimonials from "@/components/home/HomeTestimonials.astro";
import HomeCreators from "@/components/home/HomeCreators.astro";
import HomeVideo from "@/components/home/HomeVideo.astro";
import HomeFAQ from "@/components/home/HomeFAQ.astro";
import HomeJournal from "@/components/home/HomeJournal.astro";
import StickyCTA from "@/components/StickyCTA.astro";
import { CREATOR_URLS } from "@/data/socials";
import { PAGES } from "@/data/copy";
import { buildOrganizationJsonLd } from "@/utils/organizationSchema";
import { YOUTUBE_VIDEO_ID, VIDEO_METADATA } from "@/lib/constants";
import { events, allEvents } from "@/data/events";
import { isUpcomingByIso } from "@/utils/eventDate";
import { buildEventSchemas } from "@/utils/eventSchema";

const HIDDEN_FROM_HOME = ["Salt Lake City", "Denver"];
const today = new Date().toISOString().slice(0, 10);
const upcomingEvents = allEvents.filter(
  (e) => isUpcomingByIso(e, today) && !HIDDEN_FROM_HOME.includes(e.city),
);
const firstTicketUrl = "/tickets";
const heroEvents = events
  .filter((e) => !e.hidden && e.isoDate && e.isoDate >= today && e.url)
  .slice(0, 5);

// Organization JSON-LD
const orgJsonLd = buildOrganizationJsonLd();

// WebSite JSON-LD
const websiteJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Garam Masala Dating",
  url: "https://garammasaladating.com",
});

// Individual Event JSON-LD blocks (one per upcoming show with a real date+url)
const eventSchemas = buildEventSchemas(
  events.filter((e) => !e.hidden && e.isoDate && e.isoDate >= today),
);

// VideoObject JSON-LD
const videoJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "VideoObject",
  name: VIDEO_METADATA.title,
  description: VIDEO_METADATA.description,
  thumbnailUrl: `https://i.ytimg.com/vi/${YOUTUBE_VIDEO_ID}/maxresdefault.jpg`,
  contentUrl: `https://www.youtube.com/watch?v=${YOUTUBE_VIDEO_ID}`,
  embedUrl: `https://www.youtube.com/embed/${YOUTUBE_VIDEO_ID}`,
  uploadDate: VIDEO_METADATA.uploadDate,
  duration: VIDEO_METADATA.duration,
  publisher: {
    "@type": "Organization",
    name: "Garam Masala Dating",
    url: "https://garammasaladating.com",
    logo: {
      "@type": "ImageObject",
      url: "https://garammasaladating.com/images/logo.svg",
    },
  },
});

// EventSeries JSON-LD
const eventSeriesJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "EventSeries",
  "@id": "https://garammasaladating.com/#event-series",
  name: "Garam Masala Dating",
  description:
    "America's #1 recurring live desi comedy dating show. Two real South Asian singles go on a blind date in front of a 250-person audience. Bi-weekly in Manhattan at Top Secret Comedy Club.",
  url: "https://garammasaladating.com",
  startDate: "2022",
  organizer: {
    "@type": "Organization",
    name: "Garam Masala Dating",
    url: "https://garammasaladating.com",
  },
  location: {
    "@type": "Place",
    name: "Top Secret Comedy Club",
    address: {
      "@type": "PostalAddress",
      streetAddress: "44 Avenue A",
      addressLocality: "New York",
      addressRegion: "NY",
      postalCode: "10009",
      addressCountry: "US",
    },
  },
  eventSchedule: {
    "@type": "Schedule",
    repeatFrequency: "P2W",
  },
  performer: [
    { "@type": "Person", name: "Surbhi", url: CREATOR_URLS.surbhi },
    { "@type": "Person", name: "Wyatt Feegrado", url: CREATOR_URLS.wyatt },
  ],
});

// Speakable — targets hero description + HomeFAQ answer text
const speakableJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  url: "https://garammasaladating.com",
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: [".hero-sub", ".faq-answer-summary", ".faq-answer-detail"],
  },
});
---

<BaseLayout
  title="America's #1 Live Desi Comedy Dating Show"
  description={PAGES.home.description}
  hideNav={true}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={orgJsonLd} />
    <script type="application/ld+json" set:html={websiteJsonLd} />
    <script type="application/ld+json" set:html={speakableJsonLd} />
    <script type="application/ld+json" set:html={videoJsonLd} />
    <script type="application/ld+json" set:html={eventSeriesJsonLd} />
    {
      eventSchemas.map((schema) => (
        <script type="application/ld+json" set:html={schema} />
      ))
    }
  </Fragment>

  <HomeNav ticketsUrl={firstTicketUrl} />
  <main id="main-content">
    <HomeHero ticketsUrl={firstTicketUrl} heroEvents={heroEvents} />
    <HomeMarquee />
    <HomeExperience />
    <HomeShows events={upcomingEvents} />
    <HomeStats />
    <HomePress />
    <HomeTestimonials />
    <HomeCreators />
    <HomeVideo />
    <HomeFAQ />
    <HomeJournal />
  </main>
  <EventbriteWidgetInit />

  <StickyCTA triggerSelector=".hero" />
</BaseLayout>

<script>
  // Scroll reveal observer — progressive enhancement
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  if ("IntersectionObserver" in window && !prefersReducedMotion) {
    document.documentElement.classList.add("js-reveal");

    // Stagger pre-pass: any parent with [data-reveal-stagger] cascades its
    // [data-reveal] children 60ms apart so the group reveals like a wave
    // instead of snapping in together.
    const STAGGER_STEP_MS = 60;
    document
      .querySelectorAll("[data-reveal-stagger]")
      .forEach((parent) => {
        const children = parent.querySelectorAll("[data-reveal]");
        children.forEach((child, i) => {
          child.style.transitionDelay = `${i * STAGGER_STEP_MS}ms`;
        });
      });

    const revealNodes = document.querySelectorAll("[data-reveal]");
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("revealed");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12 },
    );
    revealNodes.forEach((el) => observer.observe(el));
  }
</script>

<style is:global>
  .js-reveal [data-reveal] {
    opacity: 0;
    transform: translateY(32px);
    transition:
      opacity 0.7s ease,
      transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .js-reveal [data-reveal].revealed {
    opacity: 1;
    transform: none;
  }

</style>
