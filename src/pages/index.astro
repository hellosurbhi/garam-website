---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HomeNav from '@/components/home/HomeNav.astro';
import HomeHero from '@/components/home/HomeHero.astro';
import HomeMarquee from '@/components/home/HomeMarquee.astro';
import HomeExperience from '@/components/home/HomeExperience.astro';
import HomeShows from '@/components/home/HomeShows.astro';
import HomeStats from '@/components/home/HomeStats.astro';
import HomePhotos from '@/components/home/HomePhotos.astro';
import HomePress from '@/components/home/HomePress.astro';
import HomeTestimonials from '@/components/home/HomeTestimonials.astro';
import HomeCreators from '@/components/home/HomeCreators.astro';
import HomeFAQ from '@/components/home/HomeFAQ.astro';
import HomeSignup from '@/components/home/HomeSignup.astro';
import { SOCIAL_URLS } from '@/data/socials';
import { events, allEvents } from '@/data/events';
import { isEventPast } from '@/utils/eventDate';
import { buildEventSchemas } from '@/utils/eventSchema';

const upcomingEvents = allEvents.filter((e) => !isEventPast(e.date) && !e.hidden);
const firstTicketUrl = '/tickets';

// Organization JSON-LD
const orgJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Garam Masala Dating",
  url: "https://garammasaladating.com",
  logo: "https://garammasaladating.com/logo.png",
  description: "Garam Masala Dating is a live South Asian dating show and singles mixer in New York City. Real singles go on blind dates on stage in front of a 250-person live audience. Weekly in Manhattan, monthly in Jersey City.",
  foundingDate: "2022",
  sameAs: [SOCIAL_URLS.instagram, SOCIAL_URLS.tiktok, SOCIAL_URLS.youtube, SOCIAL_URLS.threads, SOCIAL_URLS.x, SOCIAL_URLS.facebook],
  contactPoint: {
    "@type": "ContactPoint",
    email: "contact@garammasaladating.com",
    contactType: "customer support",
  },
});

// WebSite JSON-LD
const websiteJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Garam Masala Dating",
  url: "https://garammasaladating.com",
});

// FAQ data and JSON-LD
const HOME_FAQS = [
  {
    q: "What is Garam Masala Dating?",
    a: "Garam Masala Dating is a live South Asian dating show in New York City where real singles go on blind dates on stage in front of a 250-person audience. Hosted by comedians Surbhi and Wyatt, the show runs weekly in Manhattan and monthly in Jersey City, followed by a singles mixer open to all attendees.",
  },
  {
    q: "Do you have to be South Asian to come?",
    a: "No. The show is open to everyone. The audience is a mix of South Asian, desi diaspora, and anyone who loves comedy and meeting new people.",
  },
  {
    q: "Is Garam Masala Dating like Indian Matchmaking?",
    a: "No. Garam Masala Dating is a live comedy show that happens in real time in front of 250 people in NYC. There are no producers, no editing, no second takes. Just two real singles on a real first date on stage.",
  },
  {
    q: "How do I get tickets?",
    a: "Tickets are available on Eventbrite. Search \u2018Garam Masala Dating\u2019 or visit garammasaladating.com/tickets.",
  },
  {
    q: "How do I apply to be on the show?",
    a: "Fill out the contestant application at garammasaladating.com/apply. We cast based on personality and your answers, not looks.",
  },
];

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: HOME_FAQS.map(({ q, a }) => ({
    "@type": "Question",
    name: q,
    acceptedAnswer: { "@type": "Answer", text: a },
  })),
});

// Individual Event JSON-LD blocks (one per upcoming show)
const today = new Date().toISOString().slice(0, 10);
const upcomingForSchema = events.filter((e) => !e.hidden && e.isoDate && e.isoDate >= today);
const eventSchemas = buildEventSchemas(upcomingForSchema);
---

<BaseLayout
  title="Garam Masala Dating | NYC's Live South Asian Dating Show"
  description="Garam Masala Dating is New York City's hottest live South Asian dating show. Watch real South Asian singles find love on stage. Hosted by comedians Surbhi & Wyatt. Tickets available now."
  hideNav={true}
>
  <Fragment slot="head">
    <meta name="keywords" content="live dating show NYC, south asian comedy show, indian dating show new york, comedy dating show, desi dating show, live comedy show NYC, indian matchmaking live" />
    <script type="application/ld+json" set:html={orgJsonLd} />
    <script type="application/ld+json" set:html={websiteJsonLd} />
    {eventSchemas.map((schema) => (
      <script type="application/ld+json" set:html={schema} />
    ))}
    <script type="application/ld+json" set:html={faqJsonLd} />
  </Fragment>

  <HomeNav ticketsUrl={firstTicketUrl} />
  <main id="main-content">
    <HomeHero ticketsUrl={firstTicketUrl} />
    <HomeMarquee />
    <HomeExperience />
    <HomeShows events={upcomingEvents} />
    <HomeStats />
    <HomePhotos />
    <HomePress />
    <HomeTestimonials />
    <HomeCreators />
    <HomeFAQ />
    <HomeSignup />
  </main>

  <!-- 30-second email popup -->
  <dialog id="email-popup" class="popup-dialog">
    <div class="popup-inner">
      <button type="button" class="popup-close" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>

      <div id="popup-step-1">
        <h2 class="popup-title">Want Cheaper Tickets?</h2>
        <p class="popup-subtitle">Join our list for exclusive discount codes and early access.</p>
        <form id="popup-email-form" class="popup-form">
          <input type="email" id="popup-email" placeholder="Your email" required aria-label="Email address" />
          <button type="submit" class="popup-submit">Get My Discount Code</button>
        </form>
        <button type="button" class="popup-dismiss">No thanks</button>
      </div>

      <div id="popup-step-2" hidden>
        <h2 class="popup-title">One more thing...</h2>
        <p class="popup-subtitle">Add your number for text-only discounts and free ticket drops.</p>
        <form id="popup-phone-form" class="popup-form">
          <input type="tel" id="popup-phone" placeholder="Your phone number" aria-label="Phone number" />
          <button type="submit" class="popup-submit">Send Me Deals</button>
        </form>
        <button type="button" class="popup-skip">Maybe later</button>
      </div>
    </div>
  </dialog>
</BaseLayout>

<script>
  import { getFirebaseDb } from '@/lib/firebase';
  import { collection, addDoc } from 'firebase/firestore';

  // Email popup logic — only suppressed permanently after email submit
  const POPUP_KEY = 'gmd-popup-subscribed';
  const popup = document.getElementById('email-popup') as HTMLDialogElement;

  if (popup && !localStorage.getItem(POPUP_KEY)) {
    const timer = setTimeout(() => {
      if (!document.querySelector('dialog[open]')) {
        popup.showModal();
      }
    }, 30000);

    const close = () => {
      popup.close();
      clearTimeout(timer);
    };

    popup.querySelector('.popup-close')?.addEventListener('click', close);
    popup.querySelector('.popup-dismiss')?.addEventListener('click', close);
    popup.querySelector('.popup-skip')?.addEventListener('click', close);
    popup.addEventListener('click', (e) => {
      if (e.target === popup) close();
    });

    let savedEmail = '';

    document.getElementById('popup-email-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      savedEmail = (document.getElementById('popup-email') as HTMLInputElement).value;
      localStorage.setItem(POPUP_KEY, 'true');
      try {
        const db = getFirebaseDb();
        await addDoc(collection(db, 'subscribers'), {
          email: savedEmail,
          source: 'popup',
          createdAt: new Date().toISOString(),
        });
      } catch { /* fail silently */ }
      document.getElementById('popup-step-1')?.setAttribute('hidden', '');
      document.getElementById('popup-step-2')?.removeAttribute('hidden');
    });

    document.getElementById('popup-phone-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const phone = (document.getElementById('popup-phone') as HTMLInputElement).value;
      if (phone) {
        try {
          const db = getFirebaseDb();
          await addDoc(collection(db, 'subscribers'), {
            email: savedEmail,
            phone,
            source: 'popup-phone',
            createdAt: new Date().toISOString(),
          });
        } catch { /* fail silently */ }
      }
      close();
    });
  }

  // Scroll reveal observer
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12 }
  );
  document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));
</script>

<style is:global>
  [data-reveal] {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }
  [data-reveal].revealed {
    opacity: 1;
    transform: none;
  }

  /* Email popup */
  .popup-dialog {
    border: none;
    background: transparent;
    padding: 24px;
    max-width: 100%;
    max-height: 100vh;
    width: 100%;
    height: 100%;
    overflow: visible;
  }
  .popup-dialog::backdrop {
    background: rgba(0, 0, 0, 0.5);
  }
  .popup-dialog[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .popup-inner {
    width: 100%;
    max-width: 400px;
    max-height: 80vh;
    overflow-y: auto;
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 20px;
    padding: 32px 24px;
    position: relative;
    animation: popupIn 0.25s ease-out both;
    text-align: center;
  }
  @keyframes popupIn {
    from { opacity: 0; transform: scale(0.95) translateY(8px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
  .popup-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    color: #888;
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
  }
  .popup-close:hover { color: var(--charcoal); }
  .popup-title {
    font-family: var(--font-playfair), serif;
    font-size: 24px;
    font-weight: 700;
    color: var(--charcoal);
    margin-bottom: 8px;
  }
  .popup-subtitle {
    font-size: 15px;
    color: #666;
    margin-bottom: 24px;
    line-height: 1.5;
  }
  .popup-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .popup-form input {
    padding: 14px 20px;
    border: 1.5px solid rgba(0, 0, 0, 0.1);
    border-radius: 50px;
    font-size: 16px;
    font-family: var(--font-body), sans-serif;
    outline: none;
    transition: border-color 0.2s;
    min-height: 48px;
  }
  .popup-form input:focus {
    border-color: var(--hot-pink);
  }
  .popup-submit {
    background: var(--hot-pink);
    color: white;
    border: none;
    padding: 14px;
    border-radius: 50px;
    font-family: var(--font-body), sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: background 0.2s;
    min-height: 48px;
    white-space: nowrap;
    width: 100%;
  }
  .popup-submit:hover { background: var(--deep-magenta); }
  .popup-dismiss,
  .popup-skip {
    display: inline-block;
    margin-top: 16px;
    background: none;
    border: none;
    color: #999;
    font-size: 14px;
    cursor: pointer;
    font-family: var(--font-body), sans-serif;
    transition: color 0.2s;
    padding: 4px;
  }
  .popup-dismiss:hover,
  .popup-skip:hover { color: #666; }
</style>
