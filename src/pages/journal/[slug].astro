---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AuthorBio from "@/components/AuthorBio.astro";
import JournalCtaSocial from "@/components/journal/JournalCtaSocial.astro";
import JournalCtaWaitlist from "@/components/journal/JournalCtaWaitlist.astro";
import JournalCtaTickets from "@/components/journal/JournalCtaTickets.astro";
import JournalCityLinks from "@/components/journal/JournalCityLinks.astro";
import LeadCaptureModal from "@/components/LeadCaptureModal.astro";
import {
  journalPostsPublished,
  getPostBySlug,
  type JournalPost,
  type JournalFaq,
} from "@/data/journal";
import { buildBreadcrumbJsonLd } from "@/utils/breadcrumbs";
import { deriveSeoTitle } from "@/utils/meta";
import { Picture } from "astro:assets";
import { HF_IMAGES_ASSETS } from "@/assets/backgrounds";
import { slugToImageIndex } from "@/data/images";
import { gitDates } from "virtual:git-dates";
import { VERDICT_BOX } from "@/data/copy";

export function getStaticPaths() {
  return journalPostsPublished.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: JournalPost;
}

const { post } = Astro.props;
const publishedSlugs = new Set(journalPostsPublished.map((p) => p.slug));
const related = post.relatedSlugs
  .map((s) => getPostBySlug(s))
  .filter(
    (p): p is JournalPost => p !== undefined && publishedSlugs.has(p.slug),
  );

const heroImage =
  HF_IMAGES_ASSETS[slugToImageIndex(post.slug, HF_IMAGES_ASSETS.length)];

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
    timeZone: "UTC",
  });
}

const postUrl = `https://garammasaladating.com/journal/${post.slug}`;
const gitDate = gitDates[post.slug];
const dateModified =
  gitDate && gitDate > post.dateModified ? gitDate : post.dateModified;
const articleJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.title,
  datePublished: post.datePublished,
  dateModified,
  author: {
    "@type": "Person",
    name: "Surbhi",
    url: "https://garammasaladating.com",
  },
  publisher: {
    "@type": "Organization",
    name: "Garam Masala Dating",
    url: "https://garammasaladating.com",
    logo: {
      "@type": "ImageObject",
      url: "https://garammasaladating.com/images/logo.svg",
    },
  },
  description: post.metaDescription,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": postUrl,
  },
});

const faqJsonLd = post.faqs?.length
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: post.faqs.map(({ q, a }: JournalFaq) => ({
        "@type": "Question",
        name: q,
        acceptedAnswer: { "@type": "Answer", text: a },
      })),
    })
  : null;

// Ranked list articles emit ItemList (semantic structure, no carousel expected)
const itemListJsonLd = post.rankedItems?.length
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ItemList",
      itemListElement: post.rankedItems.map((item) => ({
        "@type": "ListItem",
        position: item.position,
        name: item.name,
        ...(item.url ? { url: item.url } : {}),
      })),
    })
  : null;

// Third party app reviews emit Review JSON-LD; the rating is also rendered
// visibly in the verdict box below, as Google's review snippet policy requires
const reviewJsonLd = post.appReview
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Review",
      itemReviewed: {
        "@type": "SoftwareApplication",
        name: post.appReview.appName,
        operatingSystem: post.appReview.operatingSystem,
        applicationCategory: post.appReview.applicationCategory,
      },
      reviewRating: {
        "@type": "Rating",
        ratingValue: post.appReview.ratingValue,
        bestRating: 5,
        worstRating: 1,
      },
      author: {
        "@type": "Person",
        name: post.author,
        url: "https://garammasaladating.com",
      },
      publisher: {
        "@type": "Organization",
        name: "Garam Masala Dating",
        url: "https://garammasaladating.com",
      },
      datePublished: post.datePublished,
    })
  : null;

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: "https://garammasaladating.com" },
  { name: "Journal", url: "https://garammasaladating.com/journal" },
  { name: post.title },
]);

// Speakable (AEO): marks the title + keyTakeaway recap as the passages AI
// voice/answer engines should extract. Only when a keyTakeaway exists. The
// recap renders at the END of the article (see WHY comment at the render
// site); CSS selectors are position-independent so extraction still works.
const speakableJsonLd = post.keyTakeaway
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      url: postUrl,
      speakable: {
        "@type": "SpeakableSpecification",
        cssSelector: [".post-title", ".post-answer__text"],
      },
    })
  : null;

const seoTitle = post.seoTitle ?? deriveSeoTitle(post.title);

const hasModalCta = true;

const cta1Idx = 2;
const cta2Idx = Math.max(Math.floor(post.body.length / 2), 4);
const cta3Idx = Math.max(post.body.length - 2, cta2Idx + 2);
---

<BaseLayout
  title={seoTitle}
  description={post.metaDescription}
  ogType="article"
>
  <Fragment slot="head">
    <meta property="article:published_time" content={post.datePublished} />
    {
      dateModified && (
        <meta property="article:modified_time" content={dateModified} />
      )
    }
    <meta property="article:author" content="Surbhi" />
    <script type="application/ld+json" set:html={articleJsonLd} />
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
    {faqJsonLd && <script type="application/ld+json" set:html={faqJsonLd} />}
    {
      speakableJsonLd && (
        <script type="application/ld+json" set:html={speakableJsonLd} />
      )
    }
    {
      itemListJsonLd && (
        <script type="application/ld+json" set:html={itemListJsonLd} />
      )
    }
    {
      reviewJsonLd && (
        <script type="application/ld+json" set:html={reviewJsonLd} />
      )
    }
  </Fragment>

  <main id="main-content" class="post-page">
    <Picture
      class="post-bg"
      src={heroImage}
      formats={["avif", "webp"]}
      widths={[640, 1024, 1600]}
      sizes="100vw"
      alt=""
      aria-hidden="true"
      loading="lazy"
      decoding="async"
      fetchpriority="low"
    />
    <div class="post-container">
      <!-- Back link -->
      <a href="/journal" class="post-back">&larr; Journal</a>

      <!-- Article header -->
      <header class="post-header">
        <p class="post-meta">
          {formatDate(post.datePublished)} &mdash; {post.author}
        </p>
        <h1 class="post-title">{post.title}</h1>
      </header>

      <!-- Divider -->
      <div class="post-divider"></div>

      {
        post.appReview && (
          <aside
            class="verdict-box"
            aria-label={`${VERDICT_BOX.eyebrow}: ${post.appReview.appName}`}
          >
            <p class="verdict-box__eyebrow">{VERDICT_BOX.eyebrow}</p>
            <div class="verdict-box__header">
              <span class="verdict-box__app">{post.appReview.appName}</span>
              <span
                class="verdict-box__rating"
                role="img"
                aria-label={`Rated ${post.appReview.ratingValue} ${VERDICT_BOX.outOfLabel}`}
              >
                <span class="verdict-box__score" aria-hidden="true">
                  {post.appReview.ratingValue}
                </span>
                <span class="verdict-box__outof" aria-hidden="true">
                  {VERDICT_BOX.outOfLabel}
                </span>
              </span>
            </div>
            <div class="verdict-box__cols">
              <div class="verdict-box__col">
                <p class="verdict-box__label verdict-box__label--pros">
                  {VERDICT_BOX.prosLabel}
                </p>
                <ul class="verdict-box__list">
                  {post.appReview.pros.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
              <div class="verdict-box__col">
                <p class="verdict-box__label verdict-box__label--cons">
                  {VERDICT_BOX.consLabel}
                </p>
                <ul class="verdict-box__list">
                  {post.appReview.cons.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            </div>
          </aside>
        )
      }

      <!-- Article body -->
      <article class="post-body">
        {
          post.body.map((block, i) => {
            const injectCta1 = i === cta1Idx;
            const injectCta2 = i === cta2Idx;
            const injectCta3 = i === cta3Idx;

            if (block.type === "h2") {
              return (
                <>
                  {injectCta1 && <JournalCtaSocial articleSlug={post.slug} />}
                  {injectCta2 && <JournalCtaWaitlist articleSlug={post.slug} />}
                  {injectCta3 && <JournalCtaTickets articleSlug={post.slug} />}
                  <h2
                    class="post-h2"
                    style={i === 0 ? "margin-top: 0;" : "margin-top: 16px;"}
                  >
                    {block.text}
                  </h2>
                </>
              );
            }
            if (block.type === "h3") {
              return (
                <>
                  {injectCta1 && <JournalCtaSocial articleSlug={post.slug} />}
                  {injectCta2 && <JournalCtaWaitlist articleSlug={post.slug} />}
                  {injectCta3 && <JournalCtaTickets articleSlug={post.slug} />}
                  <h3
                    class="post-h3"
                    style={i === 0 ? "margin-top: 0;" : "margin-top: 12px;"}
                  >
                    {block.text}
                  </h3>
                </>
              );
            }
            return (
              <>
                {injectCta1 && <JournalCtaSocial articleSlug={post.slug} />}
                {injectCta2 && <JournalCtaWaitlist articleSlug={post.slug} />}
                {injectCta3 && <JournalCtaTickets articleSlug={post.slug} />}
                <p class="post-p" set:html={block.text} />
              </>
            );
          })
        }
      </article>

      {
        /* WHY: this recap renders at the END of the article on purpose. It
          started life as a top-of-page "Quick answer" callout (commit 6c1a8dd)
          and killed retention: readers got the full answer above the fold and
          bounced before the mid-article CTAs, and on ranked articles it spoiled
          the entire countdown. The Speakable JSON-LD above targets the
          .post-answer__text selector, which is position-independent, so AI
          answer engines still extract it from down here. Moving this block
          back above the body re-introduces the bounce and the spoiler. */
      }
      {
        post.keyTakeaway && (
          <aside class="post-answer" aria-label="The short version">
            <p class="post-answer__label">The short version</p>
            <p class="post-answer__text">{post.keyTakeaway}</p>
          </aside>
        )
      }

      <JournalCityLinks
        articleSlug={post.slug}
        curatedSlugs={post.ctaConfig?.cityLinks ?? []}
      />

      <!-- Author bio -->
      <AuthorBio />

      <!-- Related articles -->
      {
        related.length > 0 && (
          <section class="related-section">
            <h2 class="related-heading">You might also like</h2>
            <div class="related-grid">
              {related.map((r) => (
                <a
                  href={`/journal/${r.slug}`}
                  class="related-card"
                  data-ph-capture="cta_clicked"
                  data-ph-cta="related_journal"
                  data-ph-section="journal_related"
                  data-cta-position="journal_related"
                  data-cta-text={r.title}
                  data-article-slug={post.slug}
                  data-destination-url={`/journal/${r.slug}`}
                >
                  <span class="related-card-title">{r.title}</span>
                  <span class="related-card-arrow">&rarr;</span>
                </a>
              ))}
            </div>
          </section>
        )
      }

      <!-- Footer -->
      <div class="post-footer">
        <a href="/journal" class="post-footer-back">&larr; All posts</a>
        <a
          href="/tickets"
          class="post-footer-cta"
          data-ph-capture="ticket_click"
          data-ph-cta="journal_footer_tickets"
          data-ph-section="journal_footer"
          data-cta-position="journal_footer"
          data-cta-text="Get Tickets"
          data-article-slug={post.slug}
          data-destination-url="/tickets">Get Tickets &rarr;</a
        >
      </div>
    </div>
  </main>

  {
    hasModalCta && (
      <LeadCaptureModal
        id="links-spice-modal"
        source="journal-article"
        heading="Get on the List"
        subheading="Cheap and free tickets, exclusive drops."
        collectCity={true}
      />
    )
  }
</BaseLayout>

<style>
  @keyframes postFadeIn {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .post-page {
    min-height: 100vh;
    position: relative;
    z-index: 1;
    animation: postFadeIn 0.5s ease-out both;
    overflow: hidden;
  }
  .post-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    z-index: 0;
    opacity: 0.06;
  }

  .post-container {
    position: relative;
    z-index: 1;
    max-width: 620px;
    margin: 0 auto;
    padding: 36px;
  }

  .post-back {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 13px;
    color: #888;
    text-decoration: none;
    margin-bottom: 24px;
  }

  .post-header {
    margin-bottom: 30px;
  }

  .post-meta {
    font-family: var(--font-body);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brand-red);
    margin-bottom: 16px;
  }

  .post-title {
    font-family: var(--font-playfair);
    font-size: clamp(26px, 5vw, 36px);
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.15;
  }

  .post-divider {
    width: 48px;
    height: 1px;
    background: rgba(var(--brand-red-rgb), 0.3);
    margin-bottom: 30px;
  }

  /* End-of-article recap (AEO): quiet by design, machine-extractable.
     Muted label and hairline rules so it reads as a finishing note, not a
     skip-to summary. */
  .post-answer {
    border-top: 1px solid rgba(var(--black-rgb), 0.08);
    border-bottom: 1px solid rgba(var(--black-rgb), 0.08);
    padding: 20px 0;
    margin-top: 36px;
  }
  .post-answer__label {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--gray-mid);
    margin: 0 0 8px;
  }
  .post-answer__text {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.6;
    color: var(--charcoal);
    margin: 0;
  }

  .post-body {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .post-h2 {
    font-family: var(--font-playfair);
    font-size: 24px;
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.25;
  }

  .post-h3 {
    font-family: var(--font-playfair);
    font-size: 20px;
    font-weight: 600;
    color: var(--charcoal);
    line-height: 1.3;
  }

  .post-p {
    font-family: var(--font-body);
    font-size: 18px;
    color: #555;
    line-height: 1.75;
    margin: 0;
  }

  /* Inline links in body text */
  .post-p :global(a) {
    color: var(--brand-red);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.15s ease;
  }
  .post-p :global(a:hover) {
    color: var(--brand-red-dark);
  }

  /* Related articles */
  .related-section {
    margin-top: 28px;
    padding-top: 20px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }

  .related-heading {
    font-family: var(--font-playfair);
    font-size: 20px;
    font-weight: 700;
    color: var(--charcoal);
    margin-bottom: 16px;
  }

  .related-grid {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .related-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px 18px;
    background: rgba(var(--brand-red-rgb), 0.04);
    border: 1px solid rgba(var(--brand-red-rgb), 0.1);
    border-radius: 8px;
    text-decoration: none;
    transition:
      background 0.15s ease,
      border-color 0.15s ease;
  }

  .related-card:hover {
    background: rgba(var(--brand-red-rgb), 0.08);
    border-color: rgba(var(--brand-red-rgb), 0.2);
  }

  .related-card-title {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--charcoal);
    line-height: 1.35;
  }

  .related-card-arrow {
    color: var(--brand-red);
    font-size: 16px;
    flex-shrink: 0;
  }

  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .post-footer-back {
    font-family: var(--font-body);
    font-size: 14px;
    color: #888;
    text-decoration: none;
  }

  .post-footer-cta {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--brand-red);
    text-decoration: none;
  }

  .verdict-box {
    background: var(--white);
    border: 1px solid rgba(var(--brand-red-rgb), 0.15);
    border-radius: 10px;
    padding: 20px;
    margin-bottom: 30px;
  }
  .verdict-box__eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brand-red);
    margin: 0 0 10px;
  }
  .verdict-box__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    border-bottom: 1px solid rgba(var(--brand-red-rgb), 0.12);
    padding-bottom: 14px;
    margin-bottom: 14px;
  }
  .verdict-box__app {
    font-family: var(--font-playfair);
    font-size: 22px;
    font-weight: 700;
    color: var(--charcoal);
  }
  .verdict-box__rating {
    display: flex;
    align-items: baseline;
    gap: 6px;
    white-space: nowrap;
  }
  .verdict-box__score {
    font-family: var(--font-playfair);
    font-size: 30px;
    font-weight: 700;
    color: var(--brand-red);
    line-height: 1;
  }
  .verdict-box__outof {
    font-family: var(--font-body);
    font-size: 13px;
    color: #888;
  }
  .verdict-box__cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 480px) {
    .verdict-box__cols {
      grid-template-columns: 1fr 1fr;
    }
  }
  .verdict-box__label {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 8px;
  }
  .verdict-box__label--pros {
    color: var(--success);
  }
  .verdict-box__label--cons {
    color: var(--brand-red);
  }
  .verdict-box__list {
    margin: 0;
    padding-left: 18px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .verdict-box__list li {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.55;
    color: var(--charcoal);
  }

  .article-cta {
    background: rgba(var(--brand-red-rgb), 0.05);
    border-left: 3px solid var(--brand-red);
    border-radius: 0 8px 8px 0;
    padding: 16px 20px;
    margin: 24px 0;
  }
  .article-cta__text {
    font-family: var(--font-body), sans-serif;
    font-size: 15px;
    line-height: 1.6;
    color: var(--charcoal);
    margin: 0;
  }
  .article-cta__text a {
    color: var(--brand-red);
    font-weight: 600;
    text-decoration: none;
  }
  .article-cta__text a:hover {
    text-decoration: underline;
  }
</style>
