---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AuthorBio from '@/components/AuthorBio.astro';
import { journalPostsPublished, getPostBySlug, type JournalPost, type JournalFaq } from '@/data/journal';
import { buildBreadcrumbJsonLd } from '@/utils/breadcrumbs';

export function getStaticPaths() {
  return journalPostsPublished.map((post, idx) => {
    const prev = idx < journalPostsPublished.length - 1 ? journalPostsPublished[idx + 1] : null;
    const next = idx > 0 ? journalPostsPublished[idx - 1] : null;
    return {
      params: { slug: post.slug },
      props: { post, prev, next },
    };
  });
}

interface Props {
  post: JournalPost;
  prev: JournalPost | null;
  next: JournalPost | null;
}

const { post, prev, next } = Astro.props;
const related = post.relatedSlugs
  .map((s) => getPostBySlug(s))
  .filter((p): p is JournalPost => p !== undefined);

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
    timeZone: "UTC",
  });
}

const postUrl = `https://garammasaladating.com/journal/${post.slug}`;
const articleJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.title,
  datePublished: post.datePublished,
  dateModified: post.dateModified,
  author: {
    "@type": "Person",
    name: "Surbhi",
    url: "https://garammasaladating.com",
  },
  publisher: {
    "@type": "Organization",
    name: "Garam Masala Dating",
    url: "https://garammasaladating.com",
    logo: {
      "@type": "ImageObject",
      url: "https://garammasaladating.com/images/logo.svg",
    },
  },
  description: post.metaDescription,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": postUrl,
  },
});

const faqJsonLd = post.faqs?.length
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: post.faqs.map(({ q, a }: JournalFaq) => ({
        "@type": "Question",
        name: q,
        acceptedAnswer: { "@type": "Answer", text: a },
      })),
    })
  : null;

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: "https://garammasaladating.com" },
  { name: "Journal", url: "https://garammasaladating.com/journal" },
  { name: post.title },
]);

const pageTitle = `${post.title} | Garam Masala Dating`;
---

<BaseLayout
  title={pageTitle}
  description={post.metaDescription}
  ogType="article"
>
  <Fragment slot="head">
    <meta property="article:published_time" content={post.datePublished} />
    {post.dateModified && <meta property="article:modified_time" content={post.dateModified} />}
    <meta property="article:author" content="Surbhi" />
    <script type="application/ld+json" set:html={articleJsonLd} />
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
    {faqJsonLd && <script type="application/ld+json" set:html={faqJsonLd} />}
  </Fragment>

  <main id="main-content" class="post-page">
    <div class="post-container">
      <!-- Back link -->
      <a href="/journal" class="post-back">&larr; Journal</a>

      <!-- Article header -->
      <header class="post-header">
        <p class="post-meta">
          {formatDate(post.datePublished)} &mdash; {post.author}
        </p>
        <h1 class="post-title">{post.title}</h1>
      </header>

      <!-- Divider -->
      <div class="post-divider"></div>

      <!-- Article body -->
      <article class="post-body">
        {post.body.map((block, i) => {
          if (block.type === "h2") {
            return (
              <h2
                class="post-h2"
                style={i === 0 ? "margin-top: 0;" : "margin-top: 16px;"}
              >
                {block.text}
              </h2>
            );
          }
          if (block.type === "h3") {
            return (
              <h3
                class="post-h3"
                style={i === 0 ? "margin-top: 0;" : "margin-top: 12px;"}
              >
                {block.text}
              </h3>
            );
          }
          return <p class="post-p" set:html={block.text} />;
        })}
      </article>

      <!-- Author bio -->
      <AuthorBio />

      <!-- Related articles -->
      {related.length > 0 && (
        <section class="related-section">
          <h2 class="related-heading">You might also like</h2>
          <div class="related-grid">
            {related.map((r) => (
              <a href={`/journal/${r.slug}`} class="related-card">
                <span class="related-card-title">{r.title}</span>
                <span class="related-card-arrow">&rarr;</span>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Prev / Next navigation -->
      <nav class="post-nav" aria-label="Article navigation">
        {prev ? (
          <a href={`/journal/${prev.slug}`} class="post-nav-link post-nav-prev">
            <span class="post-nav-label">&larr; Previous</span>
            <span class="post-nav-title">{prev.title}</span>
          </a>
        ) : <span />}
        {next ? (
          <a href={`/journal/${next.slug}`} class="post-nav-link post-nav-next">
            <span class="post-nav-label">Next &rarr;</span>
            <span class="post-nav-title">{next.title}</span>
          </a>
        ) : <span />}
      </nav>

      <!-- Footer -->
      <div class="post-footer">
        <a href="/journal" class="post-footer-back">&larr; All posts</a>
        <a href="/apply" class="post-footer-cta">Apply to be on the show &rarr;</a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  @keyframes postFadeIn {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .post-page {
    min-height: 100vh;
    position: relative;
    z-index: 1;
    animation: postFadeIn 0.5s ease-out both;
  }

  .post-container {
    max-width: 620px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  .post-back {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 13px;
    color: #888;
    text-decoration: none;
    margin-bottom: 36px;
  }

  .post-header {
    margin-bottom: 40px;
  }

  .post-meta {
    font-family: var(--font-body);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brand-red);
    margin-bottom: 16px;
  }

  .post-title {
    font-family: var(--font-playfair);
    font-size: clamp(26px, 5vw, 36px);
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.15;
  }

  .post-divider {
    width: 48px;
    height: 1px;
    background: rgba(var(--brand-red-rgb), 0.3);
    margin-bottom: 40px;
  }

  .post-body {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .post-h2 {
    font-family: var(--font-playfair);
    font-size: 24px;
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.25;
  }

  .post-h3 {
    font-family: var(--font-playfair);
    font-size: 20px;
    font-weight: 600;
    color: var(--charcoal);
    line-height: 1.3;
  }

  .post-p {
    font-family: var(--font-body);
    font-size: 18px;
    color: #555;
    line-height: 1.75;
    margin: 0;
  }

  /* Inline links in body text */
  .post-p :global(a) {
    color: var(--brand-red);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.15s ease;
  }
  .post-p :global(a:hover) {
    color: var(--brand-red-dark);
  }

  /* Related articles */
  .related-section {
    margin-top: 56px;
    padding-top: 24px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }

  .related-heading {
    font-family: var(--font-playfair);
    font-size: 20px;
    font-weight: 700;
    color: var(--charcoal);
    margin-bottom: 16px;
  }

  .related-grid {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .related-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px 18px;
    background: rgba(var(--brand-red-rgb), 0.04);
    border: 1px solid rgba(var(--brand-red-rgb), 0.1);
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .related-card:hover {
    background: rgba(var(--brand-red-rgb), 0.08);
    border-color: rgba(var(--brand-red-rgb), 0.2);
  }

  .related-card-title {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--charcoal);
    line-height: 1.35;
  }

  .related-card-arrow {
    color: var(--brand-red);
    font-size: 16px;
    flex-shrink: 0;
  }

  /* Prev / Next navigation */
  .post-nav {
    margin-top: 40px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 14px 16px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.15s ease;
  }

  .post-nav-link:hover {
    border-color: var(--brand-red);
  }

  .post-nav-prev {
    text-align: left;
  }

  .post-nav-next {
    text-align: right;
    grid-column: 2;
  }

  .post-nav-label {
    font-family: var(--font-body);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #888;
  }

  .post-nav-title {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--charcoal);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 480px) {
    .post-nav {
      grid-template-columns: 1fr;
    }
    .post-nav-next {
      text-align: left;
      grid-column: 1;
    }
  }

  .post-footer {
    margin-top: 64px;
    padding-top: 24px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  .post-footer-back {
    font-family: var(--font-body);
    font-size: 14px;
    color: #888;
    text-decoration: none;
  }

  .post-footer-cta {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--brand-red);
    text-decoration: none;
  }
</style>
