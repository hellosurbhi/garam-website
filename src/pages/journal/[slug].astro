---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AuthorBio from "@/components/AuthorBio.astro";
import ArticleCta from "@/components/journal/ArticleCta.astro";
import LeadCaptureModal from "@/components/LeadCaptureModal.astro";
import { getCityBySlug } from "@/data/cities";
import {
  journalPostsPublished,
  getPostBySlug,
  type JournalPost,
  type JournalFaq,
} from "@/data/journal";
import { buildBreadcrumbJsonLd } from "@/utils/breadcrumbs";
import { deriveSeoTitle } from "@/utils/meta";
import { Picture } from "astro:assets";
import { HF_IMAGES_ASSETS } from "@/assets/backgrounds";
import { slugToImageIndex } from "@/data/images";
import { gitDates } from "virtual:git-dates";
import { VERDICT_BOX, JOURNAL_FOLLOW } from "@/data/copy";
import { SOCIAL_URLS } from "@/data/socials";

export function getStaticPaths() {
  return journalPostsPublished.map((post, idx) => {
    const prev =
      idx < journalPostsPublished.length - 1
        ? journalPostsPublished[idx + 1]
        : null;
    const next = idx > 0 ? journalPostsPublished[idx - 1] : null;
    return {
      params: { slug: post.slug },
      props: { post, prev, next },
    };
  });
}

interface Props {
  post: JournalPost;
  prev: JournalPost | null;
  next: JournalPost | null;
}

const { post, prev, next } = Astro.props;
const publishedSlugs = new Set(journalPostsPublished.map((p) => p.slug));
const related = post.relatedSlugs
  .map((s) => getPostBySlug(s))
  .filter(
    (p): p is JournalPost => p !== undefined && publishedSlugs.has(p.slug),
  );

const heroImage =
  HF_IMAGES_ASSETS[slugToImageIndex(post.slug, HF_IMAGES_ASSETS.length)];

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
    timeZone: "UTC",
  });
}

const postUrl = `https://garammasaladating.com/journal/${post.slug}`;
const gitDate = gitDates[post.slug];
const dateModified =
  gitDate && gitDate > post.dateModified ? gitDate : post.dateModified;
const articleJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.title,
  datePublished: post.datePublished,
  dateModified,
  author: {
    "@type": "Person",
    name: "Surbhi",
    url: "https://garammasaladating.com",
  },
  publisher: {
    "@type": "Organization",
    name: "Garam Masala Dating",
    url: "https://garammasaladating.com",
    logo: {
      "@type": "ImageObject",
      url: "https://garammasaladating.com/images/logo.svg",
    },
  },
  description: post.metaDescription,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": postUrl,
  },
});

const faqJsonLd = post.faqs?.length
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: post.faqs.map(({ q, a }: JournalFaq) => ({
        "@type": "Question",
        name: q,
        acceptedAnswer: { "@type": "Answer", text: a },
      })),
    })
  : null;

// Ranked list articles emit ItemList (semantic structure, no carousel expected)
const itemListJsonLd = post.rankedItems?.length
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ItemList",
      itemListElement: post.rankedItems.map((item) => ({
        "@type": "ListItem",
        position: item.position,
        name: item.name,
        ...(item.url ? { url: item.url } : {}),
      })),
    })
  : null;

// Third party app reviews emit Review JSON-LD; the rating is also rendered
// visibly in the verdict box below, as Google's review snippet policy requires
const reviewJsonLd = post.appReview
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Review",
      itemReviewed: {
        "@type": "SoftwareApplication",
        name: post.appReview.appName,
        operatingSystem: post.appReview.operatingSystem,
        applicationCategory: post.appReview.applicationCategory,
      },
      reviewRating: {
        "@type": "Rating",
        ratingValue: post.appReview.ratingValue,
        bestRating: 5,
        worstRating: 1,
      },
      author: {
        "@type": "Person",
        name: post.author,
        url: "https://garammasaladating.com",
      },
      publisher: {
        "@type": "Organization",
        name: "Garam Masala Dating",
        url: "https://garammasaladating.com",
      },
      datePublished: post.datePublished,
    })
  : null;

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: "https://garammasaladating.com" },
  { name: "Journal", url: "https://garammasaladating.com/journal" },
  { name: post.title },
]);

// Speakable (AEO): marks the title + answer-first lead as the passages AI
// voice/answer engines should extract. Only when a keyTakeaway exists.
const speakableJsonLd = post.keyTakeaway
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      url: postUrl,
      speakable: {
        "@type": "SpeakableSpecification",
        cssSelector: [".post-title", ".post-answer__text"],
      },
    })
  : null;

const seoTitle = post.seoTitle ?? deriveSeoTitle(post.title);

const cfg = post.ctaConfig;
const hasModalCta =
  cfg?.topCta?.modal || cfg?.midCta?.modal || cfg?.bottomCta?.modal;
const cityLinks =
  cfg?.cityLinks
    ?.map((slug) => getCityBySlug(slug))
    .filter((city): city is NonNullable<typeof city> => city !== undefined) ??
  [];
---

<BaseLayout
  title={seoTitle}
  description={post.metaDescription}
  ogType="article"
>
  <Fragment slot="head">
    <meta property="article:published_time" content={post.datePublished} />
    {
      dateModified && (
        <meta property="article:modified_time" content={dateModified} />
      )
    }
    <meta property="article:author" content="Surbhi" />
    <script type="application/ld+json" set:html={articleJsonLd} />
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
    {faqJsonLd && <script type="application/ld+json" set:html={faqJsonLd} />}
    {
      speakableJsonLd && (
        <script type="application/ld+json" set:html={speakableJsonLd} />
      )
    }
    {
      itemListJsonLd && (
        <script type="application/ld+json" set:html={itemListJsonLd} />
      )
    }
    {
      reviewJsonLd && (
        <script type="application/ld+json" set:html={reviewJsonLd} />
      )
    }
  </Fragment>

  <main id="main-content" class="post-page">
    <Picture
      class="post-bg"
      src={heroImage}
      formats={["avif", "webp"]}
      widths={[640, 1024, 1600]}
      sizes="100vw"
      alt=""
      aria-hidden="true"
      loading="lazy"
      decoding="async"
      fetchpriority="low"
    />
    <div class="post-container">
      <!-- Back link -->
      <a href="/journal" class="post-back">&larr; Journal</a>

      <!-- Article header -->
      <header class="post-header">
        <p class="post-meta">
          {formatDate(post.datePublished)} &mdash; {post.author}
        </p>
        <h1 class="post-title">{post.title}</h1>
      </header>

      <!-- Divider -->
      <div class="post-divider"></div>

      {/* Answer-first lead (AEO): definition-led direct answer, Speakable. */}
      {
        post.keyTakeaway && (
          <aside class="post-answer" aria-label="Quick answer">
            <p class="post-answer__label">Quick answer</p>
            <p class="post-answer__text">{post.keyTakeaway}</p>
          </aside>
        )
      }

      {
        post.appReview && (
          <aside
            class="verdict-box"
            aria-label={`${VERDICT_BOX.eyebrow}: ${post.appReview.appName}`}
          >
            <p class="verdict-box__eyebrow">{VERDICT_BOX.eyebrow}</p>
            <div class="verdict-box__header">
              <span class="verdict-box__app">{post.appReview.appName}</span>
              <span
                class="verdict-box__rating"
                role="img"
                aria-label={`Rated ${post.appReview.ratingValue} ${VERDICT_BOX.outOfLabel}`}
              >
                <span class="verdict-box__score" aria-hidden="true">
                  {post.appReview.ratingValue}
                </span>
                <span class="verdict-box__outof" aria-hidden="true">
                  {VERDICT_BOX.outOfLabel}
                </span>
              </span>
            </div>
            <div class="verdict-box__cols">
              <div class="verdict-box__col">
                <p class="verdict-box__label verdict-box__label--pros">
                  {VERDICT_BOX.prosLabel}
                </p>
                <ul class="verdict-box__list">
                  {post.appReview.pros.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
              <div class="verdict-box__col">
                <p class="verdict-box__label verdict-box__label--cons">
                  {VERDICT_BOX.consLabel}
                </p>
                <ul class="verdict-box__list">
                  {post.appReview.cons.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            </div>
          </aside>
        )
      }

      <!-- Article body -->
      {
        post.ctaConfig?.topCta && (
          <ArticleCta
            cta={post.ctaConfig.topCta}
            placement="top"
            articleSlug={post.slug}
          />
        )
      }
      <article class="post-body">
        {
          post.body.map((block, i) => {
            const cfg = post.ctaConfig;
            const midCta =
              i === 3 ? (
                cfg?.midCta ? (
                  <ArticleCta
                    cta={cfg.midCta}
                    placement="mid"
                    articleSlug={post.slug}
                  />
                ) : (
                  <aside class="article-cta" aria-label="Show promotion">
                    <p class="article-cta__text">
                      We host the #1 desi comedy dating show, weekly in NYC,
                      traveling to new cities.
                      <a
                        href="/tickets"
                        data-ph-capture="ticket_click"
                        data-ph-cta="journal_mid_tickets"
                        data-ph-section="journal"
                        data-cta-position="journal_mid"
                        data-cta-text="Get tickets"
                        data-article-slug={post.slug}
                        data-destination-url="/tickets"
                      >
                        Get tickets
                      </a>{" "}
                      or{" "}
                      <a
                        href="/apply"
                        data-ph-capture="apply_click"
                        data-ph-cta="journal_mid_apply"
                        data-ph-section="journal"
                        data-cta-position="journal_mid"
                        data-cta-text="apply to be on stage"
                        data-article-slug={post.slug}
                        data-destination-url="/apply"
                      >
                        apply to be on stage
                      </a>
                      .
                    </p>
                  </aside>
                )
              ) : null;

            if (block.type === "h2") {
              return (
                <>
                  {midCta}
                  <h2
                    class="post-h2"
                    style={i === 0 ? "margin-top: 0;" : "margin-top: 16px;"}
                  >
                    {block.text}
                  </h2>
                </>
              );
            }
            if (block.type === "h3") {
              return (
                <>
                  {midCta}
                  <h3
                    class="post-h3"
                    style={i === 0 ? "margin-top: 0;" : "margin-top: 12px;"}
                  >
                    {block.text}
                  </h3>
                </>
              );
            }
            return (
              <>
                {midCta}
                <p class="post-p" set:html={block.text} />
              </>
            );
          })
        }
      </article>
      {
        post.ctaConfig?.bottomCta && (
          <ArticleCta
            cta={post.ctaConfig.bottomCta}
            placement="bottom"
            articleSlug={post.slug}
          />
        )
      }

      <aside class="journal-follow" aria-label={JOURNAL_FOLLOW.ariaLabel}>
        <p class="journal-follow__intro">{JOURNAL_FOLLOW.intro}</p>
        <div class="journal-follow__btns">
          <a
            href={SOCIAL_URLS.youtube}
            target="_blank"
            rel="noopener noreferrer"
            class="journal-follow__btn journal-follow__btn--youtube"
            data-ph-capture="cta_clicked"
            data-ph-cta="journal_follow_youtube"
            data-ph-section="journal_follow"
            data-cta-position="journal_follow"
            data-cta-text={JOURNAL_FOLLOW.youtubeLabel}
            data-article-slug={post.slug}
            data-destination-url={SOCIAL_URLS.youtube}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M23 12s0-3.5-.44-5.17a2.78 2.78 0 0 0-1.96-1.96C18.93 4.43 12 4.43 12 4.43s-6.93 0-8.6.44a2.78 2.78 0 0 0-1.96 1.96C1 8.5 1 12 1 12s0 3.5.44 5.17a2.78 2.78 0 0 0 1.96 1.96c1.67.44 8.6.44 8.6.44s6.93 0 8.6-.44a2.78 2.78 0 0 0 1.96-1.96C23 15.5 23 12 23 12ZM9.75 15.02V8.98L15.5 12l-5.75 3.02Z"
              ></path>
            </svg>
            <span>{JOURNAL_FOLLOW.youtubeLabel}</span>
          </a>
          <a
            href={SOCIAL_URLS.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="journal-follow__btn journal-follow__btn--instagram"
            data-ph-capture="cta_clicked"
            data-ph-cta="journal_follow_instagram"
            data-ph-section="journal_follow"
            data-cta-position="journal_follow"
            data-cta-text={JOURNAL_FOLLOW.instagramLabel}
            data-article-slug={post.slug}
            data-destination-url={SOCIAL_URLS.instagram}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37Z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
            <span>{JOURNAL_FOLLOW.instagramLabel}</span>
          </a>
        </div>
      </aside>

      {
        cityLinks.length > 0 && (
          <section class="article-city-links" aria-label="City show pages">
            <h2 class="article-city-links__title">Find a show near you</h2>
            <div class="article-city-links__grid">
              {cityLinks.map((city) => (
                <a
                  href={`/cities/${city.slug}`}
                  class="article-city-links__item"
                  data-ph-capture="cta_clicked"
                  data-ph-cta="journal_city_link"
                  data-ph-section="journal_city_links"
                  data-cta-position="journal_city_links"
                  data-cta-text={city.displayName}
                  data-article-slug={post.slug}
                  data-destination-url={`/cities/${city.slug}`}
                  data-event-city={city.displayName}
                  data-city-slug={city.slug}
                >
                  <span>{city.displayName}</span>
                  <small>
                    {city.status === "active"
                      ? "Tickets and dates"
                      : "Waitlist"}
                  </small>
                </a>
              ))}
            </div>
          </section>
        )
      }

      <!-- Author bio -->
      <AuthorBio />

      <!-- Related articles -->
      {
        related.length > 0 && (
          <section class="related-section">
            <h2 class="related-heading">You might also like</h2>
            <div class="related-grid">
              {related.map((r) => (
                <a
                  href={`/journal/${r.slug}`}
                  class="related-card"
                  data-ph-capture="cta_clicked"
                  data-ph-cta="related_journal"
                  data-ph-section="journal_related"
                  data-cta-position="journal_related"
                  data-cta-text={r.title}
                  data-article-slug={post.slug}
                  data-destination-url={`/journal/${r.slug}`}
                >
                  <span class="related-card-title">{r.title}</span>
                  <span class="related-card-arrow">&rarr;</span>
                </a>
              ))}
            </div>
          </section>
        )
      }

      <!-- Prev / Next navigation -->
      <nav class="post-nav" aria-label="Article navigation">
        {
          prev ? (
            <a
              href={`/journal/${prev.slug}`}
              class="post-nav-link post-nav-prev"
            >
              <span class="post-nav-label">&larr; Previous</span>
              <span class="post-nav-title">{prev.title}</span>
            </a>
          ) : (
            <span />
          )
        }
        {
          next ? (
            <a
              href={`/journal/${next.slug}`}
              class="post-nav-link post-nav-next"
            >
              <span class="post-nav-label">Next &rarr;</span>
              <span class="post-nav-title">{next.title}</span>
            </a>
          ) : (
            <span />
          )
        }
      </nav>

      <!-- Footer -->
      <div class="post-footer">
        <a href="/journal" class="post-footer-back">&larr; All posts</a>
        <a
          href="/apply"
          class="post-footer-cta"
          data-ph-capture="apply_click"
          data-ph-cta="journal_footer_apply"
          data-ph-section="journal_footer"
          data-cta-position="journal_footer"
          data-cta-text="Apply to be on the show"
          data-article-slug={post.slug}
          data-destination-url="/apply">Apply to be on the show &rarr;</a
        >
      </div>
    </div>
  </main>

  {
    hasModalCta && (
      <LeadCaptureModal
        id="links-spice-modal"
        source="journal-article"
        heading="Get on the List"
        subheading="Cheap and free tickets, exclusive drops."
        collectCity={true}
      />
    )
  }
</BaseLayout>

<style>
  @keyframes postFadeIn {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .post-page {
    min-height: 100vh;
    position: relative;
    z-index: 1;
    animation: postFadeIn 0.5s ease-out both;
    overflow: hidden;
  }
  .post-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    z-index: 0;
    opacity: 0.06;
  }

  .post-container {
    position: relative;
    z-index: 1;
    max-width: 620px;
    margin: 0 auto;
    padding: 36px;
  }

  .post-back {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 13px;
    color: #888;
    text-decoration: none;
    margin-bottom: 24px;
  }

  .post-header {
    margin-bottom: 30px;
  }

  .post-meta {
    font-family: var(--font-body);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brand-red);
    margin-bottom: 16px;
  }

  .post-title {
    font-family: var(--font-playfair);
    font-size: clamp(26px, 5vw, 36px);
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.15;
  }

  .post-divider {
    width: 48px;
    height: 1px;
    background: rgba(var(--brand-red-rgb), 0.3);
    margin-bottom: 30px;
  }

  /* Answer-first lead (AEO): visually prominent, machine-extractable. */
  .post-answer {
    background: rgba(var(--brand-red-rgb), 0.05);
    border: 1px solid rgba(var(--brand-red-rgb), 0.15);
    border-radius: 12px;
    padding: 18px 22px;
    margin-bottom: 30px;
  }
  .post-answer__label {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brand-red);
    margin: 0 0 8px;
  }
  .post-answer__text {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.6;
    color: var(--charcoal);
    margin: 0;
  }

  .post-body {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .post-h2 {
    font-family: var(--font-playfair);
    font-size: 24px;
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.25;
  }

  .post-h3 {
    font-family: var(--font-playfair);
    font-size: 20px;
    font-weight: 600;
    color: var(--charcoal);
    line-height: 1.3;
  }

  .post-p {
    font-family: var(--font-body);
    font-size: 18px;
    color: #555;
    line-height: 1.75;
    margin: 0;
  }

  /* Inline links in body text */
  .post-p :global(a) {
    color: var(--brand-red);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.15s ease;
  }
  .post-p :global(a:hover) {
    color: var(--brand-red-dark);
  }

  /* Related articles */
  .related-section {
    margin-top: 28px;
    padding-top: 20px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }

  .related-heading {
    font-family: var(--font-playfair);
    font-size: 20px;
    font-weight: 700;
    color: var(--charcoal);
    margin-bottom: 16px;
  }

  .related-grid {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .related-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px 18px;
    background: rgba(var(--brand-red-rgb), 0.04);
    border: 1px solid rgba(var(--brand-red-rgb), 0.1);
    border-radius: 8px;
    text-decoration: none;
    transition:
      background 0.15s ease,
      border-color 0.15s ease;
  }

  .related-card:hover {
    background: rgba(var(--brand-red-rgb), 0.08);
    border-color: rgba(var(--brand-red-rgb), 0.2);
  }

  .related-card-title {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--charcoal);
    line-height: 1.35;
  }

  .related-card-arrow {
    color: var(--brand-red);
    font-size: 16px;
    flex-shrink: 0;
  }

  .article-city-links {
    margin: 36px 0 32px;
    padding: 24px 0 4px;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .article-city-links__title {
    margin: 0 0 14px;
    font-family: var(--font-body), sans-serif;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--brand-red);
  }

  .article-city-links__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .article-city-links__item {
    display: flex;
    min-height: 48px;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
