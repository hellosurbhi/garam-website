---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AuthorBio from '@/components/AuthorBio.astro';
import { journalPostsPublished, type JournalPost, type JournalFaq } from '@/data/journal';
import { buildBreadcrumbJsonLd } from '@/utils/breadcrumbs';

export function getStaticPaths() {
  return journalPostsPublished.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: JournalPost;
}

const { post } = Astro.props;

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
    timeZone: "UTC",
  });
}

const postUrl = `https://garammasaladating.com/journal/${post.slug}`;
const articleJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.title,
  datePublished: post.datePublished,
  dateModified: post.dateModified,
  author: {
    "@type": "Person",
    name: "Surbhi",
    url: "https://garammasaladating.com",
  },
  publisher: {
    "@type": "Organization",
    name: "Garam Masala Dating",
    url: "https://garammasaladating.com",
    logo: {
      "@type": "ImageObject",
      url: "https://garammasaladating.com/logo.png",
    },
  },
  description: post.metaDescription,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": postUrl,
  },
});

const faqJsonLd = post.faqs?.length
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: post.faqs.map(({ q, a }: JournalFaq) => ({
        "@type": "Question",
        name: q,
        acceptedAnswer: { "@type": "Answer", text: a },
      })),
    })
  : null;

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: "https://garammasaladating.com" },
  { name: "Journal", url: "https://garammasaladating.com/journal" },
  { name: post.title },
]);

const pageTitle = `${post.title} | Garam Masala Dating`;
---

<BaseLayout
  title={pageTitle}
  description={post.metaDescription}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={articleJsonLd} />
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
    {faqJsonLd && <script type="application/ld+json" set:html={faqJsonLd} />}
  </Fragment>

  <main id="main-content" class="post-page">
    <div class="post-container">
      <!-- Back link -->
      <a href="/journal" class="post-back">&larr; Journal</a>

      <!-- Article header -->
      <header class="post-header">
        <p class="post-meta">
          {formatDate(post.datePublished)} &mdash; {post.author}
        </p>
        <h1 class="post-title">{post.title}</h1>
      </header>

      <!-- Divider -->
      <div class="post-divider"></div>

      <!-- Article body -->
      <article class="post-body">
        {post.body.map((block, i) => {
          if (block.type === "h2") {
            return (
              <h2
                class="post-h2"
                style={i === 0 ? "margin-top: 0;" : "margin-top: 16px;"}
              >
                {block.text}
              </h2>
            );
          }
          if (block.type === "h3") {
            return (
              <h3
                class="post-h3"
                style={i === 0 ? "margin-top: 0;" : "margin-top: 12px;"}
              >
                {block.text}
              </h3>
            );
          }
          return <p class="post-p">{block.text}</p>;
        })}
      </article>

      <!-- Author bio -->
      <AuthorBio />

      <!-- Footer -->
      <div class="post-footer">
        <a href="/journal" class="post-footer-back">&larr; All posts</a>
        <a href="/apply" class="post-footer-cta">Apply to be on the show &rarr;</a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  @keyframes postFadeIn {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .post-page {
    min-height: 100vh;
    position: relative;
    z-index: 1;
    animation: postFadeIn 0.5s ease-out both;
  }

  .post-container {
    max-width: 620px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  .post-back {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 13px;
    color: #888;
    text-decoration: none;
    margin-bottom: 36px;
  }

  .post-header {
    margin-bottom: 40px;
  }

  .post-meta {
    font-family: var(--font-jetbrains);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brand-red);
    margin-bottom: 16px;
  }

  .post-title {
    font-family: var(--font-playfair);
    font-size: clamp(26px, 5vw, 36px);
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.15;
  }

  .post-divider {
    width: 48px;
    height: 1px;
    background: rgba(var(--brand-red-rgb), 0.3);
    margin-bottom: 40px;
  }

  .post-body {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .post-h2 {
    font-family: var(--font-playfair);
    font-size: 24px;
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.25;
  }

  .post-h3 {
    font-family: var(--font-playfair);
    font-size: 20px;
    font-weight: 600;
    color: var(--charcoal);
    line-height: 1.3;
  }

  .post-p {
    font-family: var(--font-body);
    font-size: 18px;
    color: #555;
    line-height: 1.75;
    margin: 0;
  }

  .post-footer {
    margin-top: 64px;
    padding-top: 24px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  .post-footer-back {
    font-family: var(--font-body);
    font-size: 14px;
    color: #888;
    text-decoration: none;
  }

  .post-footer-cta {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--brand-red);
    text-decoration: none;
  }
</style>
