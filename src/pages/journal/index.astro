---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { journalPostsPublished } from '@/data/journal';
import { buildBreadcrumbJsonLd } from '@/utils/breadcrumbs';

const TITLE = "South Asian Dating & Relationships Journal | Garam Masala Dating";
const DESC =
  "Essays on South Asian dating, the live show, and what we\u2019ve learned from watching hundreds of blind dates unfold on stage.";

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
    timeZone: "UTC",
  });
}

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: "https://garammasaladating.com" },
  { name: "Journal" },
]);
---

<BaseLayout
  title={TITLE}
  description={DESC}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
  </Fragment>

  <main id="main-content" class="journal-page">
    <img class="journal-bg" src="/images/higgs-field.webp" alt="" width="1200" height="800" aria-hidden="true" />
    <div class="journal-container">
      <!-- Header -->
      <div class="journal-header">
        <p class="journal-eyebrow">Journal</p>
        <h1 class="journal-title">
          Garam Mas<em>ala</em> Dating
        </h1>
        <p class="journal-desc">
          Essays on desi dating, the live show, and what we've learned
          from watching it all unfold on stage.
        </p>
      </div>

      <!-- Divider -->
      <div class="journal-divider"></div>

      <!-- Post list -->
      <div class="journal-list">
        {journalPostsPublished.length === 0 ? (
          <p class="journal-empty" set:html={'New essays coming soon — follow us on <a href="https://www.instagram.com/garammasaladating/" target="_blank" rel="noopener noreferrer">Instagram</a> for the latest.'} />
        ) : journalPostsPublished.map((post, i) => (
          <a
            href={`/journal/${post.slug}`}
            class="journal-card"
            style={`animation-delay: ${0.1 + i * 0.08}s;`}
          >
            <p class="journal-card-date">
              {formatDate(post.datePublished)}
            </p>
            <h2 class="journal-card-title">
              {post.title}
            </h2>
            <p class="journal-card-excerpt">
              {post.excerpt}
            </p>
            <div class="journal-card-read">
              Read
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  @keyframes journalFadeIn {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .journal-page {
    min-height: 100vh;
    position: relative;
    z-index: 1;
    animation: journalFadeIn 0.5s ease-out both;
    overflow: hidden;
  }
  .journal-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    z-index: 0;
    opacity: 0.06;
  }

  .journal-container {
    position: relative;
    z-index: 1;
    max-width: 680px;
    margin: 0 auto;
    padding: 36px 20px 24px;
  }

  .journal-header {
    margin-bottom: 32px;
  }

  .journal-eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--brand-red);
    margin-bottom: 12px;
  }

  .journal-title {
    font-family: var(--font-playfair);
    font-size: 32px;
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.15;
    margin-bottom: 14px;
  }

  .journal-title em {
    font-style: italic;
    color: var(--brand-red);
  }

  .journal-desc {
    font-family: var(--font-cormorant);
    font-style: italic;
    font-size: 17px;
    color: #666;
    line-height: 1.55;
  }

  .journal-divider {
    width: 48px;
    height: 1px;
    background: rgba(var(--brand-red-rgb), 0.3);
    margin-bottom: 36px;
  }

  .journal-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .journal-card {
    display: block;
    padding: 24px 20px;
    border-radius: 12px;
    border: 1px solid rgba(0, 0, 0, 0.06);
    background: white;
    text-decoration: none;
    animation: journalFadeIn 0.5s ease-out both;
  }

  .journal-card-date {
    font-family: var(--font-body);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brand-red);
    margin-bottom: 10px;
  }

  .journal-card-title {
    font-family: var(--font-playfair);
    font-size: 20px;
    font-weight: 600;
    color: var(--charcoal);
    line-height: 1.25;
    margin-bottom: 10px;
  }

  .journal-card-excerpt {
    font-family: var(--font-cormorant);
    font-style: italic;
    font-size: 17px;
    color: #666;
    line-height: 1.6;
    margin: 0;
  }

  .journal-card-read {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 14px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--brand-red);
  }

  .journal-empty {
    font-family: var(--font-cormorant);
    font-style: italic;
    font-size: 18px;
    color: #888;
    padding: 24px 0;
  }

  .journal-empty a {
    color: var(--brand-red);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
