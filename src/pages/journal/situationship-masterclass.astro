<script>
  // Progress bar
  const progressEl = document.getElementById("mc-progress");
  if (progressEl) {
    const bar = progressEl;
    function updateProgress() {
      const scrolled = window.scrollY;
      const total = document.documentElement.scrollHeight - window.innerHeight;
      const pct = total > 0 ? (scrolled / total) * 100 : 0;
      bar.style.width = pct + "%";
    }
    window.addEventListener("scroll", updateProgress, { passive: true });
    updateProgress();
  }

  // Keyboard arrow navigation between sections
  (function () {
    const navSections = Array.from(
      document.querySelectorAll<HTMLElement>(".mc-section, .mc-faqs"),
    );
    const reducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    function getCurrentIndex(): number {
      const center = window.scrollY + window.innerHeight / 2;
      let bestIdx = 0;
      let bestDist = Infinity;
      navSections.forEach((section, i) => {
        const mid = section.offsetTop + section.offsetHeight / 2;
        const dist = Math.abs(center - mid);
        if (dist < bestDist) {
          bestDist = dist;
          bestIdx = i;
        }
      });
      return bestIdx;
    }

    document.addEventListener("keydown", (e) => {
      if (e.altKey || e.ctrlKey || e.metaKey || e.shiftKey) return;
      const el = document.activeElement as HTMLElement | null;
      const tag = (el?.tagName ?? "").toLowerCase();
      const role = el?.getAttribute("role") ?? "";
      if (
        tag === "input" ||
        tag === "textarea" ||
        tag === "select" ||
        tag === "button" ||
        tag === "a" ||
        role === "button" ||
        role === "link" ||
        (el?.hasAttribute("tabindex") &&
          el.getAttribute("tabindex") !== "-1") ||
        el?.isContentEditable
      )
        return;

      if (e.key === "ArrowDown" || e.key === "ArrowRight") {
        e.preventDefault();
        const next = Math.min(getCurrentIndex() + 1, navSections.length - 1);
        navSections[next].scrollIntoView({
          behavior: reducedMotion ? "instant" : "smooth",
          block: "start",
        });
      } else if (e.key === "ArrowUp" || e.key === "ArrowLeft") {
        e.preventDefault();
        const prev = Math.max(getCurrentIndex() - 1, 0);
        navSections[prev].scrollIntoView({
          behavior: reducedMotion ? "instant" : "smooth",
          block: "start",
        });
      }
    });
  })();

  // Scroll-triggered section reveals
  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const section = entry.target;
            section.querySelectorAll<HTMLElement>(".reveal").forEach((el) => {
              const delay = parseInt(el.dataset.delay ?? "0", 10);
              setTimeout(() => el.classList.add("is-visible"), delay);
            });
            observer.unobserve(section);
          }
        });
      },
      { threshold: 0.05 },
    );

    document
      .querySelectorAll(".mc-section:not(.mc-cover)")
      .forEach((section) => observer.observe(section));
  }
</script>
