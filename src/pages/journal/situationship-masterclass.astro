---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AuthorBio from "@/components/AuthorBio.astro";
import { masterclassPosts } from "@/data/masterclasses";
import { buildBreadcrumbJsonLd } from "@/utils/breadcrumbs";
import { BRAND_LOGO_URL } from "@/data/brand";

const post = masterclassPosts.find(
  (p) => p.slug === "situationship-masterclass",
);
if (!post) return Astro.redirect("/404");

const postUrl = `https://garammasaladating.com/journal/${post.slug}`;

const titleSlide = post.slides.find((s) => s.type === "title");
const disclaimerSlide = post.slides.find((s) => s.type === "disclaimer");
const stepSlides = post.slides.filter((s) => s.type === "step");
const scienceSlide = post.slides.find((s) => s.type === "science");
const twistSlide = post.slides.find((s) => s.type === "twist");
const bonusSlide = post.slides.find((s) => s.type === "bonus");
const ctaSlide = post.slides.find((s) => s.type === "cta");

if (
  !titleSlide ||
  !disclaimerSlide ||
  !scienceSlide ||
  !twistSlide ||
  !bonusSlide ||
  !ctaSlide
) {
  throw new Error(
    "situationship-masterclass: missing required slide type(s). Check src/data/masterclasses.ts.",
  );
}

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
    timeZone: "UTC",
  });
}

const articleJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.title,
  datePublished: post.datePublished,
  dateModified: post.dateModified,
  author: {
    "@type": "Person",
    name: "Surbhi",
    url: "https://garammasaladating.com",
  },
  publisher: {
    "@type": "Organization",
    name: "Garam Masala Dating",
    url: "https://garammasaladating.com",
    logo: {
      "@type": "ImageObject",
      url: BRAND_LOGO_URL,
    },
  },
  description: post.metaDescription,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": postUrl,
  },
});

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: post.faqs.map(({ q, a }) => ({
    "@type": "Question",
    name: q,
    acceptedAnswer: { "@type": "Answer", text: a },
  })),
});

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: "https://garammasaladating.com" },
  { name: "Journal", url: "https://garammasaladating.com/journal" },
  { name: post.title },
]);
---

<BaseLayout
  title={post.title}
  description={post.metaDescription}
  ogType="article"
>
  <Fragment slot="head">
    <meta property="article:published_time" content={post.datePublished} />
    <meta property="article:modified_time" content={post.dateModified} />
    <meta property="article:author" content="Surbhi" />
    <script type="application/ld+json" set:html={articleJsonLd} />
    <script type="application/ld+json" set:html={faqJsonLd} />
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
  </Fragment>

  <main id="main-content" class="mc-page">
    <!-- Reading progress bar -->
    <div class="mc-progress" id="mc-progress" aria-hidden="true"></div>

    <!-- COVER -->
    <section class="mc-section mc-cover bg-light" aria-label="Introduction">
      <a href="/journal" class="mc-back">&larr; Journal</a>
      <div class="mc-content mc-cover-content">
        <div class="mc-cover-emoji" aria-hidden="true">🫠🔥💀</div>
        <p class="mc-eyebrow">
          Masterclass &middot; {formatDate(post.datePublished)}
        </p>
        <h1 class="mc-cover-title">{titleSlide.title}</h1>
        <p class="mc-cover-sub">{titleSlide.body}</p>
      </div>
      <div class="mc-scroll-hint" aria-hidden="true">
        <span>scroll or ↓</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M12 5v14"></path>
          <path d="m19 12-7 7-7-7"></path>
        </svg>
      </div>
    </section>

    <section class="mc-bridge bg-light" aria-label="Live show bridge">
      <div class="mc-bridge-inner">
        <p>Come watch situationships get handled live.</p>
        <div class="mc-bridge-actions">
          <a
            href="/tickets"
            data-ph-capture="ticket_click"
            data-ph-cta="situationship_top_tickets"
            data-ph-section="journal"
            data-cta-position="journal_top"
            data-cta-text="Get tickets"
            data-article-slug={post.slug}
            data-destination-url="/tickets"
          >
            Get tickets
          </a>
          <a
            href="/apply"
            data-ph-capture="apply_click"
            data-ph-cta="situationship_top_apply"
            data-ph-section="journal"
            data-cta-position="journal_top"
            data-cta-text="Apply to be on stage"
            data-article-slug={post.slug}
            data-destination-url="/apply"
          >
            Apply
          </a>
        </div>
      </div>
    </section>

    <!-- DISCLAIMER -->
    <section class="mc-section mc-disclaimer bg-warm" aria-label="Disclaimer">
      <div class="mc-content">
        <div class="disclaimer-box">
          <span class="warning-label">Surgeon General's Warning</span>
          <h2 class="mc-step-title reveal" data-delay="0">
            {disclaimerSlide.title}
          </h2>
          <div
            class="mc-step-body reveal"
            data-delay="150"
            set:html={disclaimerSlide.body}
          />
        </div>
      </div>
    </section>

    <!-- STEPS -->
    {
      stepSlides.map((slide, stepIdx) => {
        const bgClass = stepIdx % 2 === 0 ? "bg-light" : "bg-warm";
        return (
          <section
            class={`mc-section mc-step ${slide.stepNumber ? "" : "mc-step--cont"} ${slide.stepNumber === "04" ? "mc-step--has-cta" : ""} ${bgClass}`}
            aria-label={slide.stepLabel ?? slide.title}
          >
            <div class="mc-content">
              {slide.stepNumber && (
                <span class="step-ghost" aria-hidden="true">
                  {slide.stepNumber}
                </span>
              )}
              {slide.stepLabel && (
                <p class="mc-step-label reveal" data-delay="0">
                  {slide.stepLabel}
                </p>
              )}
              <h2 class="mc-step-title reveal" data-delay="100">
                {slide.title}
              </h2>
              <div
                class="mc-step-body reveal"
                data-delay="200"
                set:html={slide.body}
              />
              {slide.hotTake && (
                <p class="hot-take reveal" data-delay="320">
                  {slide.hotTake}
                </p>
              )}
            </div>
            {slide.stepNumber === "04" && post.promoText && (
              <aside class="mc-mid-cta" aria-label="Show promotion">
                <p class="mc-mid-cta-text">
                  {post.promoText}{" "}
                  <a
                    href="/tickets"
                    data-ph-capture="ticket_click"
                    data-ph-cta="situationship_mid_tickets"
                    data-ph-section="journal"
                    data-cta-position="journal_mid"
                    data-cta-text="Get tickets"
                    data-article-slug={post.slug}
                    data-destination-url="/tickets"
                  >
                    Get tickets
                  </a>{" "}
                  or{" "}
                  <a
                    href="/apply"
                    data-ph-capture="apply_click"
                    data-ph-cta="situationship_mid_apply"
                    data-ph-section="journal"
                    data-cta-position="journal_mid"
                    data-cta-text="apply to be on stage"
                    data-article-slug={post.slug}
                    data-destination-url="/apply"
                  >
                    apply to be on stage
                  </a>
                  .
                </p>
              </aside>
            )}
          </section>
        );
      })
    }

    <!-- SCIENCE -->
    <section
      class="mc-section mc-science bg-warm"
      aria-label={scienceSlide.stepLabel}
    >
      <div class="mc-content">
        <span class="step-ghost step-ghost-emoji" aria-hidden="true">🧠</span>
        <p class="mc-step-label reveal" data-delay="0">
          {scienceSlide.stepLabel}
        </p>
        <h2 class="mc-step-title reveal" data-delay="100">
          {scienceSlide.title}
        </h2>
        <div
          class="mc-step-body reveal"
          data-delay="200"
          set:html={scienceSlide.body}
        />
        {
          scienceSlide.hotTake && (
            <p class="hot-take reveal" data-delay="320">
              {scienceSlide.hotTake}
            </p>
          )
        }
      </div>
    </section>

    <!-- PLOT TWIST -->
    <section class="mc-section mc-twist bg-light" aria-label="Plot twist">
      <div class="mc-content mc-twist-content">
        <span class="quote-mark reveal" data-delay="0" aria-hidden="true"
          >&ldquo;</span
        >
        <h2 class="mc-step-title reveal" data-delay="100">
          {twistSlide.title}
        </h2>
        <div
          class="mc-step-body reveal"
          data-delay="200"
          set:html={twistSlide.body}
        />
      </div>
    </section>

    <!-- BONUS -->
    <section
      class="mc-section mc-bonus bg-warm"
      aria-label={bonusSlide.stepLabel}
    >
      <div class="mc-content">
        <span class="step-ghost step-ghost-emoji" aria-hidden="true">🌶️</span>
        <p class="mc-step-label reveal" data-delay="0">
          {bonusSlide.stepLabel}
        </p>
        <h2 class="mc-step-title reveal" data-delay="100">
          {bonusSlide.title}
        </h2>
        <div
          class="mc-step-body mc-step-body--bonus reveal"
          data-delay="200"
          set:html={bonusSlide.body}
        />
        {
          bonusSlide.hotTake && (
            <p class="hot-take reveal" data-delay="320">
              {bonusSlide.hotTake}
            </p>
          )
        }
      </div>
    </section>

    <!-- FAQs + AUTHOR BIO -->
    <section class="mc-faqs bg-light" aria-labelledby="faq-heading">
      <div class="mc-content mc-content--narrow">
        <h2 class="mc-faqs-heading" id="faq-heading">{post.faqHeading}</h2>
        <dl class="faq-list">
          {
            post.faqs.map(({ q, a }) => (
              <div class="faq-item">
                <dt class="faq-q">{q}</dt>
                <dd class="faq-a">{a}</dd>
              </div>
            ))
          }
        </dl>
        <AuthorBio />
        <section class="mc-city-links" aria-label="City show pages">
          <h2>Find a show near you</h2>
          <div class="mc-city-links-grid">
            {
              [
                ["Manhattan", "/cities/manhattan"],
                ["Jersey City", "/cities/jersey-city"],
                ["San Francisco", "/cities/san-francisco"],
                ["Seattle", "/cities/seattle"],
                ["Los Angeles", "/cities/los-angeles"],
              ].map(([label, href]) => (
                <a
                  href={href}
                  data-ph-capture="cta_clicked"
                  data-ph-cta="situationship_city_link"
                  data-ph-section="journal_city_links"
                  data-cta-position="journal_city_links"
                  data-cta-text={label}
                  data-article-slug={post.slug}
                  data-destination-url={href}
                  data-event-city={label}
                  data-city-slug={href.replace("/cities/", "")}
                >
                  <span>{label}</span>
                  <small>
                    {label === "Manhattan" || label === "Jersey City"
                      ? "Tickets and dates"
                      : "Waitlist"}
                  </small>
                </a>
              ))
            }
          </div>
        </section>
      </div>
    </section>

    <!-- CLOSING CTA -->
    <section
      class="mc-section mc-cta-final bg-red"
      aria-label="Come to the show"
    >
      <div class="mc-content mc-cta-content">
        <p class="mc-cta-eyebrow reveal" data-delay="0">
          Tired of situationships?
        </p>
        <h2 class="mc-cta-title reveal" data-delay="100">{ctaSlide.title}</h2>
        <div
          class="mc-cta-body reveal"
          data-delay="200"
          set:html={ctaSlide.body}
        />
        <a
          href="/tickets"
          class="mc-cta-btn reveal"
          data-delay="320"
          data-ph-capture="ticket_click"
          data-ph-cta="situationship_bottom_tickets"
          data-ph-section="journal"
          data-cta-position="journal_bottom"
          data-cta-text="Get Tickets"
          data-article-slug={post.slug}
          data-destination-url="/tickets"
        >
          Get Tickets
        </a>
        <p class="mc-cta-ig reveal" data-delay="420">@garammasaladating</p>
      </div>
    </section>

    <!-- PAGE FOOTER -->
    <div class="mc-footer bg-light">
      <a href="/journal" class="mc-footer-back">&larr; All journal posts</a>
      <a
        href="/apply"
        class="mc-footer-apply"
        data-ph-capture="apply_click"
        data-ph-cta="situationship_footer_apply"
        data-ph-section="journal_footer"
        data-cta-position="journal_footer"
        data-cta-text="Apply to be on the show"
        data-article-slug={post.slug}
        data-destination-url="/apply">Apply to be on the show &rarr;</a
      >
    </div>
  </main>
</BaseLayout>

<style>
  /* ── Layout ──────────────────────────────────────────────── */

  .mc-page {
    position: relative;
  }

  .mc-section {
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: 80px 0;
  }

  .mc-content {
    position: relative;
    max-width: 640px;
    width: 100%;
    padding: 0 24px;
  }

  .mc-content--narrow {
    max-width: 640px;
    margin: 0 auto;
  }

  /* ── Backgrounds ─────────────────────────────────────────── */

  .bg-light {
    background-color: var(--off-white);
  }

  .bg-warm {
    background-color: var(--cream-warm);
  }

  .bg-red {
    background-color: var(--brand-red);
  }

  /* ── Progress bar ────────────────────────────────────────── */

  .mc-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    width: 0%;
    background-color: var(--brand-red);
    z-index: 1000;
    transition: width 0.1s linear;
  }

  /* ── Back link ───────────────────────────────────────────── */

  .mc-back {
    position: absolute;
    top: 24px;
    left: 24px;
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--gray-light);
    text-decoration: none;
    z-index: 10;
    transition: color 0.15s ease;
    display: flex;
    align-items: center;
    min-height: 48px;
  }

  .mc-back:hover {
    color: var(--brand-red);
  }

  /* ── Cover ───────────────────────────────────────────────── */

  .mc-cover {
    background-image: radial-gradient(
      circle,
      rgba(var(--brand-red-rgb), 0.04) 1px,
      transparent 1px
    );
    background-size: 24px 24px;
    text-align: center;
    flex-direction: column;
  }

  .mc-cover-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .mc-cover-emoji {
    font-size: clamp(2rem, 6vw, 3.5rem);
    margin-bottom: 24px;
    line-height: 1;
    animation: mcPulse 3s ease-in-out infinite;
  }

  @keyframes mcPulse {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.06);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mc-cover-emoji {
      animation: none;
    }
  }

  .mc-eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--brand-red);
    margin-bottom: 20px;
  }

  .mc-cover-title {
    font-family: var(--font-playfair);
    font-size: clamp(2.25rem, 7vw, 5rem);
    font-weight: 900;
    line-height: 1.05;
    color: var(--charcoal);
    margin-bottom: 20px;
    max-width: 560px;
  }

  .mc-cover-sub {
    font-family: var(--font-cormorant);
    font-style: italic;
    font-size: clamp(1.1rem, 3vw, 1.5rem);
    color: var(--gray-mid);
    letter-spacing: 0.02em;
  }

  .mc-scroll-hint {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--gray-lighter);
    animation: mcBounce 2s ease-in-out infinite;
  }

  @keyframes mcBounce {
    0%,
    100% {
      transform: translateX(-50%) translateY(0);
    }
    50% {
      transform: translateX(-50%) translateY(5px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mc-scroll-hint {
      animation: none;
    }
  }

  .mc-bridge {
    padding: 18px 24px 24px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .mc-bridge-inner {
    display: flex;
    max-width: 640px;
    margin: 0 auto;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .mc-bridge p {
    margin: 0;
    font-family: var(--font-body), sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: var(--charcoal);
  }

  .mc-bridge-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .mc-bridge-actions a {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0 16px;
    border: 1px solid rgba(var(--brand-red-rgb), 0.22);
    color: var(--brand-red);
    font-family: var(--font-body), sans-serif;
    font-size: 13px;
    font-weight: 800;
    text-decoration: none;
  }

  .mc-bridge-actions a:first-child {
    background: var(--brand-red);
    border-color: var(--brand-red);
    color: var(--white);
  }

  @media (max-width: 560px) {
    .mc-bridge-inner {
      display: grid;
      justify-items: stretch;
    }

    .mc-bridge-actions {
      justify-content: stretch;
    }

    .mc-bridge-actions a {
      flex: 1 1 120px;
    }
  }

  /* ── Disclaimer ──────────────────────────────────────────── */

  .mc-disclaimer {
    text-align: center;
  }

  .disclaimer-box {
    border: 2px dashed rgba(var(--brand-red-rgb), 0.25);
    border-radius: 16px;
    padding: 40px 32px;
    position: relative;
    max-width: 560px;
    margin: 0 auto;
  }

  .warning-label {
    position: absolute;
    top: -13px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--brand-red);
    color: var(--white);
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    padding: 3px 16px;
    border-radius: 20px;
    white-space: nowrap;
  }

  /* ── Step sections ───────────────────────────────────────── */

  .mc-step .mc-content {
    padding-top: 48px;
    padding-bottom: 48px;
  }

  .step-ghost {
    position: absolute;
    top: 0;
    left: -4px;
    font-family: var(--font-playfair);
    font-size: clamp(5rem, 14vw, 10rem);
    font-weight: 900;
    color: var(--charcoal);
    opacity: 0.06;
    line-height: 1;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .step-ghost-emoji {
    font-size: clamp(4rem, 11vw, 8rem);
    opacity: 0.1;
  }

  .mc-step-label {
    position: relative;
    z-index: 1;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--brand-red);
    margin-bottom: 12px;
    margin-top: 80px;
  }

  .mc-step-title {
    position: relative;
    z-index: 1;
    font-family: var(--font-playfair);
    font-size: clamp(1.75rem, 5vw, 3rem);
    font-weight: 900;
    color: var(--charcoal);
    line-height: 1.12;
    margin-bottom: 20px;
  }

  .mc-step-body {
    position: relative;
    z-index: 1;
    font-family: var(--font-body);
    font-size: clamp(1rem, 2.5vw, 1.125rem);
    color: var(--text-secondary);
    line-height: 1.75;
    max-width: 55ch;
  }

  .mc-step-body :global(em) {
    color: var(--brand-red);
    font-style: italic;
    font-weight: 600;
  }

  .mc-step-body :global(strong) {
    color: var(--charcoal);
    font-weight: 700;
  }

  .mc-step-body--bonus :global(strong) {
    color: var(--charcoal);
    font-weight: 700;
    display: block;
    margin-top: 16px;
  }

  .mc-step-body--bonus :global(strong:first-child) {
    margin-top: 0;
  }

  .hot-take {
    position: relative;
    z-index: 1;
    display: inline-block;
    background: var(--brand-red);
    color: var(--white);
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    padding: 6px 14px;
    border-radius: 50px;
    margin-top: 20px;
  }

  /* ── Disclaimer text override ────────────────────────────── */

  .mc-disclaimer .mc-step-title {
    margin-top: 8px;
    font-size: clamp(1.5rem, 4vw, 2.25rem);
  }

  .mc-disclaimer .mc-step-body {
    margin-top: 16px;
    text-align: left;
  }

  /* ── Continuation slides (no step label/number) ─────────── */

  .mc-step--cont .mc-step-title {
    margin-top: 80px;
  }

  /* ── Science section ─────────────────────────────────────── */

  .mc-science .mc-step-label {
    margin-top: 72px;
  }

  /* ── Twist section ───────────────────────────────────────── */

  .mc-twist-content {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .quote-mark {
    font-family: var(--font-playfair);
