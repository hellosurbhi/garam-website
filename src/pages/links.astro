---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { events } from '@/data/events';
import { isEventPast } from '@/utils/eventDate';
import { pressItems } from '@/data/press';
import { SOCIAL_URLS } from '@/data/socials';
import { buildBreadcrumbJsonLd } from '@/utils/breadcrumbs';

const TITLE = "Tickets, Shows & More | Garam Masala Dating";
const DESC =
  "Get tickets to upcoming Garam Masala Dating shows, follow us on Instagram and TikTok, apply as a contestant, or reach out for booking and press.";

const upcomingEvents = events.filter((e) => !isEventPast(e.date) && !e.hidden);

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: "https://garammasaladating.com/" },
  { name: "Links" },
]);

/* ── SVG icon markup ──────────────────────────────────────── */

import { ICON_SVGS, SOCIAL_ICON_SVGS, type IconName } from '@/data/icons';

function iconSvg(name: IconName, isPrimary?: boolean): string {
  const cls = isPrimary ? "icon-primary" : "icon-glass";
  return `<span class="${cls}">${ICON_SVGS[name]}</span>`;
}

/* ── Link definitions ─────────────────────────────────────── */

interface LinkDef {
  label: string;
  href?: string;
  isPrimary?: boolean;
  external?: boolean;
  dialogTrigger?: string;
  icon: IconName;
}

const links: LinkDef[] = [
  { label: "Apply to Be on the Show", href: "/apply", isPrimary: true, icon: "heart" },
  { label: "Short form content — Instagram", href: SOCIAL_URLS.instagram, external: true, icon: "instagram" },
  { label: "Full episodes — YouTube", href: SOCIAL_URLS.youtube, external: true, icon: "youtube" },
  { label: "Upcoming Shows & Tickets", dialogTrigger: "events-trigger", icon: "ticket" },
  { label: "As Seen In", dialogTrigger: "press-trigger", icon: "mic" },
  { label: "Booking & Press Inquiries", href: "mailto:press@garammasaladating.com", icon: "mail" },
];

const socials = [
  { href: SOCIAL_URLS.instagram, label: "Instagram", icon: "instagram" },
  { href: SOCIAL_URLS.tiktok, label: "TikTok", icon: "tiktok" },
  { href: SOCIAL_URLS.youtube, label: "YouTube", icon: "youtube" },
  { href: SOCIAL_URLS.threads, label: "Threads", icon: "threads" },
  { href: SOCIAL_URLS.x, label: "X", icon: "x" },
  { href: SOCIAL_URLS.facebook, label: "Facebook", icon: "facebook" },
  { href: "mailto:hello@garammasaladating.com", label: "Email", icon: "mail" },
];

const reversedPress = [...pressItems].reverse();
---

<BaseLayout title={TITLE} description={DESC}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
  </Fragment>

  <div class="page">
    <div class="container">
      {/* Header */}
      <div class="header-wrap">
        <h1 class="subtitle">NYC&apos;s hottest live South Asian dating show&nbsp;🌶️</h1>
        <div class="divider" />
      </div>

      {/* Link list */}
      <div class="link-list">
        {links.map((link, i) => {
          const delay = 0.1 + i * 0.1;

          if (link.dialogTrigger) {
            return (
              <button
                type="button"
                id={link.dialogTrigger}
                class="glass-link"
                style={`animation: fadeUp 0.5s ease-out ${delay}s both`}
              >
                <Fragment set:html={iconSvg(link.icon, false)} />
                <span class="link-label">{link.label}</span>
              </button>
            );
          }

          return (
            <a
              href={link.href}
              class:list={[link.isPrimary ? "primary-link" : "glass-link"]}
              style={link.isPrimary
                ? `animation: fadeUp 0.5s ease-out ${delay}s both, pulseGlow 2.5s ease-in-out 1s infinite`
                : `animation: fadeUp 0.5s ease-out ${delay}s both`}
              target={link.external ? "_blank" : undefined}
              rel={link.external ? "noopener noreferrer" : undefined}
            >
              <Fragment set:html={iconSvg(link.icon, link.isPrimary)} />
              <span class="link-label">{link.label}</span>
            </a>
          );
        })}
      </div>

      {/* Social icons */}
      <div class="social-row">
        {socials.map((s) => (
          <a
            href={s.href}
            aria-label={s.label}
            target="_blank"
            rel="noopener noreferrer"
            class="social-icon"
          >
            <Fragment set:html={SOCIAL_ICON_SVGS[s.icon]} />
          </a>
        ))}
      </div>

      <p class="footer-text">
        Made with love and a lot of spice
      </p>
    </div>
  </div>

  {/* ── Events modal ─────────────────────────────────────── */}
  <dialog id="events-modal" class="modal-dialog">
    <div class="modal-inner">
      <button type="button" class="modal-close" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>

      <h2 class="modal-title">Upcoming Shows</h2>
      <div class="modal-divider" />

      {upcomingEvents.length === 0 ? (
        <p class="no-events">No upcoming shows. Stay tuned!</p>
      ) : (
        <div class="event-list">
          {upcomingEvents.map((event) => {
            const hasLink = event.url && event.url !== "#";
            return hasLink ? (
              <a
                href={event.url}
                target="_blank"
                rel="noopener noreferrer"
                class="event-link"
              >
                <span class="event-city">{event.city}</span>
                <div class="event-date-group">
                  <span class="event-date">{event.date}</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ticket-icon"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M13 5v2"/><path d="M13 17v2"/><path d="M13 11v2"/></svg>
                </div>
              </a>
            ) : (
              <div class="event-tba">
                <span class="event-city">{event.city}</span>
                <span class="event-date-muted">{event.date}</span>
              </div>
            );
          })}
        </div>
      )}
    </div>
  </dialog>

  {/* ── Press modal ──────────────────────────────────────── */}
  <dialog id="press-modal" class="modal-dialog modal-dialog--scrollable">
    <div class="modal-inner">
      <button type="button" class="modal-close" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>

      <h2 class="modal-title">As Seen In</h2>
      <div class="modal-divider" />

      <div class="event-list">
        {reversedPress.map((item) => (
          <a
            href={item.url}
            target="_blank"
            rel="noopener noreferrer"
            class="press-item"
          >
            <div class="press-content">
              <div class="press-badge-row">
                <span class="press-badge">
                  {item.type === "podcast" ? (
                    <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>
                  ) : (
                    <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/></svg>
                  )}
                  {item.type}
                </span>
              </div>
              <p class="press-source">{item.source}</p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="press-external-icon"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
          </a>
        ))}
      </div>
    </div>
  </dialog>
</BaseLayout>

<script>
  function setupDialog(triggerId: string, dialogId: string) {
    const trigger = document.getElementById(triggerId);
    const dialog = document.getElementById(dialogId) as HTMLDialogElement;
    if (!trigger || !dialog) return;

    trigger.addEventListener('click', () => dialog.showModal());
    dialog.querySelector('.modal-close')?.addEventListener('click', () => dialog.close());
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
  }
  setupDialog('events-trigger', 'events-modal');
  setupDialog('press-trigger', 'press-modal');
</script>

<style>
  /* ─── Animations ──────────────────────────────────────────── */

  @keyframes pageIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes headerFadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes pulseGlow {
    0%, 100% { box-shadow: 0 2px 12px rgba(var(--hot-pink-rgb), 0.25), 0 0 0 0 rgba(var(--hot-pink-rgb), 0); }
    50%       { box-shadow: 0 2px 12px rgba(var(--hot-pink-rgb), 0.25), 0 0 0 8px rgba(var(--hot-pink-rgb), 0.12); }
  }

  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.95) translateY(8px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }

  /* ─── Page layout ─────────────────────────────────────────── */

  .page {
    min-height: 100vh;
    background: transparent;
    position: relative;
    animation: pageIn 0.3s ease-out both;
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 420px;
    margin: 0 auto;
    padding: 48px 24px 56px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ─── Header ──────────────────────────────────────────────── */

  .header-wrap {
    text-align: center;
    animation: headerFadeUp 0.6s ease-out 0s both;
    margin-bottom: 32px;
  }

  .home-link {
    text-decoration: none;
    cursor: pointer;
  }

  .links-logo {
    height: 64px;
    width: auto;
    margin-bottom: 10px;
  }

  .subtitle {
    font-family: var(--font-playfair);
    font-size: 24px;
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.3;
    margin: 0;
  }

  .divider {
    width: 48px;
    height: 1px;
    background: rgba(var(--hot-pink-rgb), 0.3);
    margin: 18px auto 0;
  }

  /* ─── Link list ───────────────────────────────────────────── */

  .link-list {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* ─── LinkButton — primary ────────────────────────────────── */

  .primary-link {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    padding: 20px 24px;
    border-radius: 14px;
    border: none;
    background: var(--hot-pink);
    color: white;
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    transform: scale(1);
    box-shadow: 0 2px 12px rgba(var(--hot-pink-rgb), 0.25);
    white-space: nowrap;
  }

  .primary-link:hover {
    transform: scale(1.02);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  /* ─── LinkButton — glass ──────────────────────────────────── */

  .glass-link {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    padding: 17px 22px;
    border-radius: 12px;
    border: 1px solid rgba(0, 0, 0, 0.06);
    background: white;
    color: var(--charcoal);
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.25s ease;
    transform: scale(1);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    text-align: left;
    white-space: nowrap;
  }

  .glass-link:hover {
    border-color: rgba(var(--hot-pink-rgb), 0.35);
    background: white;
    transform: scale(1.015);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  /* icon-primary / icon-glass are injected via set:html, so need :global */
  :global(.icon-primary) {
    flex-shrink: 0;
    color: white;
    display: inline-flex;
  }

  :global(.icon-glass) {
    flex-shrink: 0;
    color: #888;
    display: inline-flex;
  }

  .link-label {
    flex: 1;
    text-align: center;
  }

  /* ─── Social icons ────────────────────────────────────────── */

  .social-row {
    display: flex;
    gap: 12px;
    margin-top: 36px;
    animation: headerFadeUp 0.5s ease-out 0.9s both;
  }

  .social-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.06);
    color: #888;
    transition: background 0.2s, color 0.2s;
    text-decoration: none;
  }

  .social-icon:hover {
    background: rgba(var(--hot-pink-rgb), 0.15);
    color: var(--hot-pink);
  }

  /* ─── Footer ──────────────────────────────────────────────── */

  .footer-text {
    margin-top: 32px;
    font-size: 14px;
    font-family: var(--font-body);
    font-style: italic;
    color: var(--muted);
    text-align: center;
    animation: headerFadeUp 0.5s ease-out 1s both;
  }

  /* ─── Dialog / Modal ──────────────────────────────────────── */

  .modal-dialog {
    border: none;
    background: transparent;
    padding: 24px;
    max-width: 100%;
    max-height: 100vh;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .modal-dialog::backdrop {
    background: rgba(0, 0, 0, 0.5);
  }

  .modal-dialog[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .modal-inner {
    width: 100%;
    max-width: 400px;
    max-height: 80vh;
    overflow-y: auto;
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 20px;
    padding: 32px 24px;
    animation: modalIn 0.25s ease-out both;
    position: relative;
    text-align: center;
  }

  .modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    color: #888;
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
  }

  .modal-close:hover {
    color: var(--charcoal);
  }

  .modal-title {
    font-family: var(--font-playfair);
    font-size: 22px;
    font-weight: 600;
    color: var(--charcoal);
    margin-bottom: 8px;
  }

  .modal-divider {
    width: 32px;
    height: 1px;
    background: rgba(var(--hot-pink-rgb), 0.3);
    margin-bottom: 24px;
  }

  /* ─── Events list ─────────────────────────────────────────── */

  .event-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .event-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    border-radius: 12px;
    border: 1px solid rgba(0, 0, 0, 0.06);
    background: white;
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .event-link:hover {
    background: rgba(var(--hot-pink-rgb), 0.06);
    border-color: rgba(var(--hot-pink-rgb), 0.35);
  }

  .event-tba {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    border-radius: 12px;
    border: 1px solid rgba(0, 0, 0, 0.06);
    background: white;
    opacity: 0.5;
  }

  .event-city {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    color: var(--charcoal);
  }

  .event-date {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    color: #666;
  }

  .event-date-muted {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    color: #888;
  }

  .event-date-group {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .ticket-icon {
    color: var(--hot-pink);
  }

  .no-events {
    font-family: var(--font-body);
    font-size: 16px;
    color: #666;
    text-align: center;
    padding: 16px 0;
  }

  /* ─── Press items ─────────────────────────────────────────── */

  .press-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    border-radius: 12px;
    border: 1px solid rgba(0, 0, 0, 0.06);
    background: white;
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
    gap: 12px;
  }

  .press-item:hover {
    background: rgba(var(--hot-pink-rgb), 0.06);
    border-color: rgba(var(--hot-pink-rgb), 0.35);
  }

  .press-content {
    flex: 1;
    min-width: 0;
  }

  .press-badge-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 4px;
  }

  .press-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 8px;
    border-radius: 6px;
    background: rgba(var(--hot-pink-rgb), 0.12);
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    color: var(--hot-pink);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .press-source {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    color: var(--charcoal);
    margin: 0;
    line-height: 1.3;
  }

  .press-external-icon {
    flex-shrink: 0;
    color: var(--hot-pink);
  }
</style>
