---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { events } from '@/data/events';
import { isEventPast } from '@/utils/eventDate';
import { pressItems } from '@/data/press';
import { SOCIAL_URLS } from '@/data/socials';
import { buildBreadcrumbJsonLd } from '@/utils/breadcrumbs';

const TITLE = "Tickets, Shows & More | Garam Masala Dating";
const DESC =
  "Get tickets to upcoming Garam Masala Dating shows, follow us on Instagram and TikTok, apply as a contestant, or reach out for booking and press.";

const upcomingEvents = events.filter((e) => !isEventPast(e.date) && !e.hidden);

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: "https://garammasaladating.com/" },
  { name: "Links" },
]);

/* ── SVG icon markup ──────────────────────────────────────── */

type IconName = "heart" | "instagram" | "tiktok" | "youtube" | "mic" | "ticket" | "mail";

const ICON_SVGS: Record<IconName, string> = {
  heart: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>`,
  instagram: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>`,
  tiktok: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M16.6 5.82A4.278 4.278 0 0 1 15.54 3h-3.09v12.4a2.592 2.592 0 0 1-2.59 2.5c-1.42 0-2.6-1.16-2.6-2.6 0-1.72 1.66-3.01 3.37-2.48V9.66c-3.45-.46-6.47 2.22-6.47 5.64 0 3.33 2.76 5.7 5.69 5.7 3.14 0 5.69-2.55 5.69-5.7V9.01a7.35 7.35 0 0 0 4.3 1.38V7.3s-1.88.09-3.24-1.48Z"/></svg>`,
  youtube: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/><path d="m10 15 5-3-5-3z"/></svg>`,
  mic: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>`,
  ticket: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M13 5v2"/><path d="M13 17v2"/><path d="M13 11v2"/></svg>`,
  mail: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
};

function iconSvg(name: IconName, isPrimary?: boolean): string {
  const cls = isPrimary ? "icon-primary" : "icon-glass";
  return `<span class="${cls}">${ICON_SVGS[name]}</span>`;
}

/* Social icons reuse the same SVGs at 18px */
const SOCIAL_ICON_SVGS: Record<string, string> = {
  instagram: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>`,
  tiktok: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16.6 5.82A4.278 4.278 0 0 1 15.54 3h-3.09v12.4a2.592 2.592 0 0 1-2.59 2.5c-1.42 0-2.6-1.16-2.6-2.6 0-1.72 1.66-3.01 3.37-2.48V9.66c-3.45-.46-6.47 2.22-6.47 5.64 0 3.33 2.76 5.7 5.69 5.7 3.14 0 5.69-2.55 5.69-5.7V9.01a7.35 7.35 0 0 0 4.3 1.38V7.3s-1.88.09-3.24-1.48Z"/></svg>`,
  youtube: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/><path d="m10 15 5-3-5-3z"/></svg>`,
  mail: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
};

/* ── Link definitions ─────────────────────────────────────── */

interface LinkDef {
  label: string;
  href?: string;
  isPrimary?: boolean;
  external?: boolean;
  dialogTrigger?: string;
  icon: IconName;
}

const links: LinkDef[] = [
  { label: "Apply to Be on the Show", href: "/apply", isPrimary: true, icon: "heart" },
  { label: "Instagram", href: SOCIAL_URLS.instagram, external: true, icon: "instagram" },
  { label: "TikTok", href: SOCIAL_URLS.tiktok, external: true, icon: "tiktok" },
  { label: "YouTube", href: SOCIAL_URLS.youtube, external: true, icon: "youtube" },
  { label: "As Seen In", dialogTrigger: "press-trigger", icon: "mic" },
  { label: "Upcoming Shows & Tickets", dialogTrigger: "events-trigger", icon: "ticket" },
  { label: "Booking & Press Inquiries", href: SOCIAL_URLS.email, icon: "mail" },
];

const socials = [
  { href: SOCIAL_URLS.instagram, label: "Instagram", icon: "instagram" },
  { href: SOCIAL_URLS.tiktok, label: "TikTok", icon: "tiktok" },
  { href: SOCIAL_URLS.youtube, label: "YouTube", icon: "youtube" },
  { href: SOCIAL_URLS.email, label: "Email", icon: "mail" },
];

const reversedPress = [...pressItems].reverse();
---

<BaseLayout title={TITLE} description={DESC} overlayBg="rgba(13, 10, 8, 0.88)">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
  </Fragment>

  <div class="page">
    <div class="container">
      {/* Header */}
      <div class="header-wrap">
        <a href="/" class="home-link">
          <h1 class="title">
            Garam Mas<em class="title-accent">ala</em> Dating
          </h1>
        </a>
        <p class="subtitle">NYC&apos;s hottest live comedy dating show&nbsp;🌶️</p>
        <div class="divider" />
      </div>

      {/* Link list */}
      <div class="link-list">
        {links.map((link, i) => {
          const delay = 0.1 + i * 0.1;

          if (link.dialogTrigger) {
            return (
              <button
                type="button"
                id={link.dialogTrigger}
                class="glass-link"
                style={`animation: fadeUp 0.5s ease-out ${delay}s both`}
              >
                <Fragment set:html={iconSvg(link.icon, false)} />
                <span class="link-label">{link.label}</span>
              </button>
            );
          }

          return (
            <a
              href={link.href}
              class:list={[link.isPrimary ? "primary-link" : "glass-link"]}
              style={link.isPrimary
                ? `animation: fadeUp 0.5s ease-out ${delay}s both, pulseGlow 2.5s ease-in-out 1s infinite`
                : `animation: fadeUp 0.5s ease-out ${delay}s both`}
              target={link.external ? "_blank" : undefined}
              rel={link.external ? "noopener noreferrer" : undefined}
            >
              <Fragment set:html={iconSvg(link.icon, link.isPrimary)} />
              <span class="link-label">{link.label}</span>
            </a>
          );
        })}
      </div>

      {/* Social icons */}
      <div class="social-row">
        {socials.map((s) => (
          <a
            href={s.href}
            aria-label={s.label}
            target="_blank"
            rel="noopener noreferrer"
            class="social-icon"
          >
            <Fragment set:html={SOCIAL_ICON_SVGS[s.icon]} />
          </a>
        ))}
      </div>

      <p class="footer-text">
        Made with love and a lot of spice&nbsp;🌶️
      </p>
    </div>
  </div>

  {/* ── Events modal ─────────────────────────────────────── */}
  <dialog id="events-modal" class="modal-dialog">
    <div class="modal-inner">
      <button type="button" class="modal-close" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>

      <h2 class="modal-title">Upcoming Shows</h2>
      <div class="modal-divider" />

      {upcomingEvents.length === 0 ? (
        <p class="no-events">No upcoming shows — stay tuned!</p>
      ) : (
        <div class="event-list">
          {upcomingEvents.map((event) => {
            const hasLink = event.url && event.url !== "#";
            return hasLink ? (
              <a
                href={event.url}
                target="_blank"
                rel="noopener noreferrer"
                class="event-link"
              >
                <span class="event-city">{event.city}</span>
                <div class="event-date-group">
                  <span class="event-date">{event.date}</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ticket-icon"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M13 5v2"/><path d="M13 17v2"/><path d="M13 11v2"/></svg>
                </div>
              </a>
            ) : (
              <div class="event-tba">
                <span class="event-city">{event.city}</span>
                <span class="event-date-muted">{event.date}</span>
              </div>
            );
          })}
        </div>
      )}
    </div>
  </dialog>

  {/* ── Press modal ──────────────────────────────────────── */}
  <dialog id="press-modal" class="modal-dialog modal-dialog--scrollable">
    <div class="modal-inner">
      <button type="button" class="modal-close" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>

      <h2 class="modal-title">As Seen In</h2>
      <div class="modal-divider" />

      <div class="event-list">
        {reversedPress.map((item) => (
          <a
            href={item.url}
            target="_blank"
            rel="noopener noreferrer"
            class="press-item"
          >
            <div class="press-content">
              <div class="press-badge-row">
                <span class="press-badge">
                  {item.type === "podcast" ? (
                    <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>
                  ) : (
                    <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/></svg>
                  )}
                  {item.type}
                </span>
              </div>
              <p class="press-source">{item.source}</p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="press-external-icon"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
          </a>
        ))}
      </div>
    </div>
  </dialog>
</BaseLayout>

<script>
  function setupDialog(triggerId: string, dialogId: string) {
    const trigger = document.getElementById(triggerId);
    const dialog = document.getElementById(dialogId) as HTMLDialogElement;
    if (!trigger || !dialog) return;

    trigger.addEventListener('click', () => dialog.showModal());
    dialog.querySelector('.modal-close')?.addEventListener('click', () => dialog.close());
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
  }
  setupDialog('events-trigger', 'events-modal');
  setupDialog('press-trigger', 'press-modal');
</script>

<style>
  /* ─── Animations ──────────────────────────────────────────── */

  @keyframes pageIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes headerFadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes pulseGlow {
    0%, 100% { box-shadow: 0 2px 12px rgba(201, 168, 76, 0.25), 0 0 0 0 rgba(201, 168, 76, 0); }
    50%       { box-shadow: 0 2px 12px rgba(201, 168, 76, 0.25), 0 0 0 8px rgba(201, 168, 76, 0.12); }
  }

  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.95) translateY(8px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }

  /* ─── Page layout ─────────────────────────────────────────── */

  .page {
    min-height: 100vh;
    background: transparent;
    position: relative;
    animation: pageIn 0.3s ease-out both;
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 420px;
    margin: 0 auto;
    padding: 48px 24px 56px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ─── Header ──────────────────────────────────────────────── */

  .header-wrap {
    text-align: center;
    animation: headerFadeUp 0.6s ease-out 0s both;
    margin-bottom: 32px;
  }

  .home-link {
    text-decoration: none;
    cursor: pointer;
  }

  .title {
    font-family: var(--font-playfair);
    font-size: 36px;
    font-weight: 700;
    color: #F5EDE4;
    line-height: 1.15;
    margin-bottom: 10px;
  }

  .title-accent {
    font-style: italic;
    color: #E2C97E;
  }

  .subtitle {
    font-family: var(--font-cormorant);
    font-size: 17px;
    color: rgba(245, 237, 228, 0.55);
    line-height: 1.5;
  }

  .divider {
    width: 48px;
    height: 1px;
    background: rgba(201, 168, 76, 0.3);
    margin: 18px auto 0;
  }

  /* ─── Link list ───────────────────────────────────────────── */

  .link-list {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* ─── LinkButton — primary ────────────────────────────────── */

  .primary-link {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    padding: 20px 24px;
    border-radius: 14px;
    border: none;
    background: #C9A84C;
    color: #0D0A08;
    font-family: var(--font-cormorant);
    font-size: 17px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    transform: scale(1);
    box-shadow: 0 2px 12px rgba(201, 168, 76, 0.25);
  }

  .primary-link:hover {
    transform: scale(1.02);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  /* ─── LinkButton — glass ──────────────────────────────────── */

  .glass-link {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    padding: 17px 22px;
    border-radius: 14px;
    border: 1px solid rgba(245, 237, 228, 0.1);
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: #F5EDE4;
    font-family: var(--font-cormorant);
    font-size: 16px;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.25s ease;
    transform: scale(1);
    box-shadow: none;
    text-align: left;
  }

  .glass-link:hover {
    border-color: rgba(201, 168, 76, 0.35);
    background: rgba(255, 255, 255, 0.08);
    transform: scale(1.015);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  /* icon-primary / icon-glass are injected via set:html, so need :global */
  :global(.icon-primary) {
    flex-shrink: 0;
    color: #0D0A08;
    display: inline-flex;
  }

  :global(.icon-glass) {
    flex-shrink: 0;
    color: rgba(245, 237, 228, 0.5);
    display: inline-flex;
  }

  .link-label {
    flex: 1;
    text-align: center;
  }

  /* ─── Social icons ────────────────────────────────────────── */

  .social-row {
    display: flex;
    gap: 12px;
    margin-top: 36px;
    animation: headerFadeUp 0.5s ease-out 0.9s both;
  }

  .social-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(245, 237, 228, 0.08);
    color: rgba(245, 237, 228, 0.25);
    transition: background 0.2s, color 0.2s;
    text-decoration: none;
  }

  .social-icon:hover {
    background: rgba(201, 168, 76, 0.15);
    color: #C9A84C;
  }

  /* ─── Footer ──────────────────────────────────────────────── */

  .footer-text {
    margin-top: 32px;
    font-size: 14px;
    font-family: var(--font-cormorant);
    font-style: italic;
    color: rgba(245, 237, 228, 0.2);
    text-align: center;
    animation: headerFadeUp 0.5s ease-out 1s both;
  }

  /* ─── Dialog / Modal ──────────────────────────────────────── */

  .modal-dialog {
    border: none;
    background: transparent;
    padding: 24px;
    max-width: 100vw;
    max-height: 100vh;
    width: 100%;
    height: 100%;
    overflow: visible;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .modal-dialog::backdrop {
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .modal-dialog[open] {
    display: flex;
  }

  .modal-inner {
    width: 100%;
    max-width: 400px;
    background: rgba(20, 16, 13, 0.95);
    border: 1px solid rgba(201, 168, 76, 0.2);
    border-radius: 20px;
    padding: 32px 24px;
    animation: modalIn 0.25s ease-out both;
    position: relative;
  }

  .modal-dialog--scrollable .modal-inner {
    max-height: 80vh;
    overflow-y: auto;
  }

  .modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    color: rgba(245, 237, 228, 0.4);
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
  }

  .modal-close:hover {
    color: #F5EDE4;
  }

  .modal-title {
    font-family: var(--font-playfair);
    font-size: 22px;
    font-weight: 600;
    color: #F5EDE4;
    margin-bottom: 8px;
  }

  .modal-divider {
    width: 32px;
    height: 1px;
    background: rgba(201, 168, 76, 0.3);
    margin-bottom: 24px;
  }

  /* ─── Events list ─────────────────────────────────────────── */

  .event-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .event-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    border-radius: 12px;
    border: 1px solid rgba(201, 168, 76, 0.15);
    background: rgba(255, 255, 255, 0.04);
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .event-link:hover {
    background: rgba(201, 168, 76, 0.1);
