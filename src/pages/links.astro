---
import BaseLayout from "@/layouts/BaseLayout.astro";
import LeadCaptureModal from "@/components/LeadCaptureModal.astro";
import { events } from "@/data/events";
import { ICON_SVGS, SOCIAL_ICON_SVGS, type IconName } from "@/data/icons";
import { pressItems } from "@/data/press";
import { SOCIAL_URLS } from "@/data/socials";
import { buildBreadcrumbJsonLd } from "@/utils/breadcrumbs";
import { formatEventLocation } from "@/utils/eventCity";
import { isDatedUpcoming } from "@/utils/eventFilters";
import { buildTicketUrl } from "@/utils/eventUrl";
import { domainFromUrl, vendorFromUrl } from "@/lib/analyticsCapture";

const TITLE = "Tickets, Shows & More";
const DESC =
  "Get tickets to upcoming Garam Masala Dating shows, apply as a contestant, join a city waitlist, or watch full episodes.";

const today = new Date().toISOString().slice(0, 10);
const upcomingEvents = events
  .filter((event) => isDatedUpcoming(event, today))
  .sort((a, b) => a.isoDate!.localeCompare(b.isoDate!));

const liveTicketEvents = upcomingEvents.filter(
  (event) => event.url && event.url !== "#" && !event.soldOut,
);
const featuredEvents = liveTicketEvents.slice(0, 4);

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: "https://garammasaladating.com/" },
  { name: "Links" },
]);

function iconSvg(name: IconName): string {
  return `<span class="link-icon" aria-hidden="true">${ICON_SVGS[name]}</span>`;
}

const primaryActions = [
  {
    label: "Grab My Spot",
    href: "/tickets",
    icon: "ticket",
    eventName: "cta_clicked",
    ctaId: "buy_tickets",
    description:
      liveTicketEvents.length > 0
        ? `${liveTicketEvents.length} upcoming shows`
        : "See the next drop",
  },
  {
    label: "Apply to Be on Stage",
    href: "/apply",
    icon: "heart",
    eventName: "apply_click",
    ctaId: "apply",
    description: "Get cast on stage",
  },
  {
    label: "Join the Waitlist!",
    dialog: "links-spice-modal",
    icon: "mail",
    eventName: "waitlist_click",
    ctaId: "city_waitlist",
    description: "Presales and city drops",
  },
] satisfies Array<{
  label: string;
  href?: string;
  dialog?: string;
  icon: IconName;
  eventName: string;
  ctaId: string;
  description: string;
}>;

const episodeLinks = [
  {
    label: "Full Episodes",
    href: SOCIAL_URLS.youtube,
    icon: "youtube",
    ctaId: "youtube_full_episodes",
  },
  {
    label: "Instagram",
    href: SOCIAL_URLS.instagram,
    icon: "instagram",
    ctaId: "instagram",
  },
  {
    label: "TikTok",
    href: SOCIAL_URLS.tiktok,
    icon: "tiktok",
    ctaId: "tiktok",
  },
] as const;

type PressLink = (typeof pressItems)[number] & { url: string };
const pressLinks = pressItems
  .filter((item): item is PressLink => Boolean(item.url))
  .slice(-4)
  .reverse();
---

<BaseLayout title={TITLE} description={DESC}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
  </Fragment>

  <main id="main-content" class="links-page">
    <div class="links-shell">
      <header class="links-header">
        <p class="links-kicker">Garam Masala Dating</p>
        <h1>Shows, casting, episodes.</h1>
      </header>

      <section class="primary-actions" aria-label="Primary actions">
        {
          primaryActions.map((action, index) =>
            action.href ? (
              <a
                href={action.href}
                class:list={[
                  "action-link",
                  index === 0 ? "action-link--primary" : "",
                ]}
                data-ph-capture={action.eventName}
                data-ph-cta={action.ctaId}
                data-ph-section="links_primary"
                data-cta-position={`links_primary_${index + 1}`}
                data-cta-text={action.label}
                data-destination-url={action.href}
              >
                <Fragment set:html={iconSvg(action.icon)} />
                <span class="action-copy">
                  <strong>{action.label}</strong>
                  <span>{action.description}</span>
                </span>
              </a>
            ) : (
              <button
                type="button"
                class:list={[
                  "action-link",
                  index === 0 ? "action-link--primary" : "",
                ]}
                data-open-modal={action.dialog}
                data-ph-capture={action.eventName}
                data-ph-cta={action.ctaId}
                data-ph-section="links_primary"
                data-cta-position={`links_primary_${index + 1}`}
                data-cta-text={action.label}
              >
                <Fragment set:html={iconSvg(action.icon)} />
                <span class="action-copy">
                  <strong>{action.label}</strong>
                  <span>{action.description}</span>
                </span>
              </button>
            ),
          )
        }
      </section>

      {
        featuredEvents.length > 0 && (
          <section class="event-strip" aria-labelledby="event-strip-heading">
            <div class="section-heading">
              <h2 id="event-strip-heading">Next tickets</h2>
              <a
                href="/tickets"
                data-ph-capture="cta_clicked"
                data-ph-cta="all_tickets"
                data-ph-section="links_events"
                data-cta-position="links_events_header"
                data-cta-text="All shows"
                data-destination-url="/tickets"
              >
                All shows
              </a>
            </div>
            <div class="event-list">
              {featuredEvents.map((event, index) => {
                const city = formatEventLocation(event);
                const ticketUrl = buildTicketUrl(
                  event.url,
                  "links",
                  `event_${index + 1}`,
                );
                const title = `Garam Masala Dating - ${city} - ${event.date}`;
                return (
                  <a
                    href={ticketUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="event-link"
                    data-ph-capture="ticket_click"
                    data-ph-cta="ticket_vendor"
                    data-ph-section="links_events"
                    data-cta-position={`links_event_${index + 1}`}
                    data-cta-text={`Tickets: ${city}`}
                    data-destination-url={ticketUrl}
                    data-link-url={ticketUrl}
                    data-link-domain={domainFromUrl(ticketUrl)}
                    data-event-city={city}
                    data-event-date={event.isoDate ?? event.date}
                    data-event-title={title}
                    data-event-vendor={vendorFromUrl(ticketUrl)}
                  >
                    <span>
                      <strong>{city}</strong>
                      <small>{event.date}</small>
                    </span>
                    <span class="event-link__cta">Get Tickets</span>
                  </a>
                );
              })}
            </div>
          </section>
        )
      }

      <section class="watch-section" aria-labelledby="watch-heading">
        <div class="section-heading">
          <h2 id="watch-heading">Watch episodes</h2>
        </div>
        <div class="watch-links">
          {
            episodeLinks.map((link, index) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="watch-link"
                data-ph-capture="outbound_link_clicked"
                data-ph-cta={link.ctaId}
                data-ph-section="links_watch"
                data-cta-position={`links_watch_${index + 1}`}
                data-cta-text={link.label}
                data-destination-url={link.href}
                data-link-url={link.href}
                data-link-domain={domainFromUrl(link.href)}
              >
                <span
                  class="watch-icon"
                  set:html={SOCIAL_ICON_SVGS[link.icon]}
                />
                <span>{link.label}</span>
              </a>
            ))
          }
        </div>
      </section>

      <section class="secondary-section" aria-labelledby="secondary-heading">
        <h2 id="secondary-heading">Press and booking</h2>
        <a
          href="mailto:press@garammasaladating.com"
          class="secondary-link"
          data-ph-capture="cta_clicked"
          data-ph-cta="booking_inquiry"
          data-ph-section="links_secondary"
          data-cta-position="links_secondary_booking"
          data-cta-text="Booking and press inquiries"
          data-destination-url="mailto:press@garammasaladating.com"
        >
          Booking and press inquiries
        </a>
        {
          pressLinks.length > 0 && (
            <div class="press-list">
              {pressLinks.map((item, index) => (
                <a
                  href={item.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-ph-capture="outbound_link_clicked"
                  data-ph-cta="press_link"
                  data-ph-section="links_press"
                  data-cta-position={`links_press_${index + 1}`}
                  data-cta-text={item.source}
                  data-destination-url={item.url}
                  data-link-url={item.url}
                  data-link-domain={domainFromUrl(item.url)}
                >
                  {item.source}
                </a>
              ))}
            </div>
          )
        }
      </section>
    </div>
  </main>

  <LeadCaptureModal
    id="links-spice-modal"
    source="links-page"
    heading="Get on the List"
    subheading="Cheap and free tickets, exclusive discount codes, city drops."
    submitLabel="Count Me In"
    successMessage="You're on the list. Deals incoming!"
    collectCity={true}
  />
</BaseLayout>

<style>
  .links-page {
    min-height: 100svh;
    background:
      radial-gradient(
        circle at top right,
        rgba(var(--brand-red-rgb), 0.12),
        transparent 22rem
      ),
      linear-gradient(180deg, var(--off-white) 0%, var(--cream-warm) 100%);
  }

  .links-shell {
    width: min(100%, 540px);
    margin: 0 auto;
    padding: 24px 18px 56px;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .links-header {
    padding-top: 8px;
  }

  .links-kicker {
    font-family: var(--font-body), sans-serif;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--brand-red);
    margin-bottom: 10px;
  }

  .links-header h1 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(2.4rem, 12vw, 4.75rem);
    line-height: 0.95;
    color: var(--charcoal);
    max-width: 8ch;
  }

  .primary-actions,
  .event-list,
  .watch-links,
  .secondary-section,
  .press-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .action-link,
  .event-link,
  .watch-link,
  .secondary-link {
    min-height: 56px;
    border: 1px solid rgba(26, 26, 26, 0.12);
    border-radius: 8px;
    background: rgba(var(--white-rgb), 0.74);
    color: var(--charcoal);
    text-decoration: none;
    font-family: var(--font-body), sans-serif;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding: 14px 16px;
    width: 100%;
  }

  button.action-link {
    appearance: none;
    cursor: pointer;
    text-align: left;
  }

  .action-link--primary {
    min-height: 68px;
    background: var(--brand-red);
    border-color: var(--brand-red);
    color: var(--white);
  }

  .link-icon,
  .watch-icon {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
  }

  .action-copy {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .action-copy strong,
  .event-link strong {
    font-size: 16px;
    line-height: 1.1;
  }

  .action-copy span,
  .event-link small {
    color: currentColor;
    opacity: 0.72;
    font-size: 13px;
    line-height: 1.2;
  }

  .section-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 10px;
  }

  .section-heading h2,
  .secondary-section h2 {
    font-family: var(--font-body), sans-serif;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .section-heading a {
    color: var(--brand-red);
    font-family: var(--font-body), sans-serif;
    font-size: 13px;
    font-weight: 800;
    text-decoration: none;
  }

  .event-link > span:first-child {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .event-link__cta {
    flex: 0 0 auto;
    color: var(--brand-red);
    font-size: 13px;
    font-weight: 800;
  }

  .watch-links {
    display: grid;
    grid-template-columns: 1fr;
  }

  .watch-link {
    justify-content: flex-start;
    font-weight: 800;
  }

  .secondary-section {
    padding-bottom: 8px;
  }

  .secondary-link {
    justify-content: flex-start;
    font-weight: 800;
  }

  .press-list a {
    color: var(--text-secondary);
    font-family: var(--font-body), sans-serif;
    font-size: 14px;
    line-height: 1.4;
    text-decoration: none;
    padding: 8px 0;
  }

  .action-link:hover,
  .event-link:hover,
  .watch-link:hover,
  .secondary-link:hover,
  .press-list a:hover,
  .section-heading a:hover {
    color: var(--brand-red);
  }

  .action-link--primary:hover {
    color: var(--white);
    background: var(--brand-red-dark);
  }

  @media (min-width: 520px) {
    .links-shell {
      padding-top: 40px;
    }

    .watch-links {
      grid-template-columns: repeat(3, 1fr);
    }

    .watch-link {
      justify-content: center;
    }
  }
</style>
