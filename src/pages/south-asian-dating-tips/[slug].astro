---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AuthorBio from '@/components/AuthorBio.astro';
import { tipPosts, type TipPost } from '@/data/tips';
import { buildBreadcrumbJsonLd } from '@/utils/breadcrumbs';

export function getStaticPaths() {
  return tipPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: TipPost;
}

const { post } = Astro.props;

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
    timeZone: "UTC",
  });
}

const postUrl = `https://garammasaladating.com/south-asian-dating-tips/${post.slug}`;
const articleJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.title,
  datePublished: post.datePublished,
  dateModified: post.dateModified,
  author: {
    "@type": "Person",
    name: "Surbhi",
    url: "https://garammasaladating.com",
  },
  publisher: {
    "@type": "Organization",
    name: "Garam Masala Dating",
    url: "https://garammasaladating.com",
    logo: {
      "@type": "ImageObject",
      url: "https://garammasaladating.com/logo.png",
    },
  },
  description: post.metaDescription,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": postUrl,
  },
});

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: "https://garammasaladating.com" },
  { name: "Dating Tips", url: "https://garammasaladating.com/south-asian-dating-tips" },
  { name: post.title },
]);

const pageTitle = `${post.title} | Garam Masala Dating`;
const firstBlock = post.body[0];
const remainingBlocks = post.body.slice(1);
---

<BaseLayout
  title={pageTitle}
  description={post.metaDescription}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={articleJsonLd} />
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
  </Fragment>

  <main id="main-content" class="tip-post-page">
    <div class="tip-post-container">
      <!-- Back link -->
      <a href="/south-asian-dating-tips" class="tip-post-back">&larr; Dating Tips</a>

      <!-- Article header -->
      <header class="tip-post-header">
        <p class="tip-post-meta">
          {formatDate(post.datePublished)} &mdash; {post.author}
        </p>
        <h1 class="tip-post-title">{post.title}</h1>
      </header>

      <!-- Divider -->
      <div class="tip-post-divider"></div>

      <!-- Article body — Answer-First format -->
      <article class="tip-post-body">
        <!-- Lead paragraph: bolded summary for AEO scraping -->
        <p class="tip-post-lead">{firstBlock.text}</p>

        {remainingBlocks.map((block, i) => {
          if (block.type === "h3") {
            return (
              <h3
                class="tip-post-h3"
                style={i === 0 ? "margin-top: 0;" : "margin-top: 12px;"}
              >
                {block.text}
              </h3>
            );
          }
          return <p class="tip-post-p">{block.text}</p>;
        })}
      </article>

      <!-- Author bio -->
      <AuthorBio />

      <!-- Footer -->
      <div class="tip-post-footer">
        <a href="/south-asian-dating-tips" class="tip-post-footer-back">&larr; All tips</a>
        <a href="/apply" class="tip-post-footer-cta">Apply to be on the show &rarr;</a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  @keyframes tipPostFadeIn {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .tip-post-page {
    min-height: 100vh;
    position: relative;
    z-index: 1;
    animation: tipPostFadeIn 0.5s ease-out both;
  }

  .tip-post-container {
    max-width: 620px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  .tip-post-back {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 13px;
    color: #888;
    text-decoration: none;
    margin-bottom: 36px;
  }

  .tip-post-header {
    margin-bottom: 40px;
  }

  .tip-post-meta {
    font-family: var(--font-jetbrains);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brand-red);
    margin-bottom: 16px;
  }

  .tip-post-title {
    font-family: var(--font-playfair);
    font-size: clamp(26px, 5vw, 36px);
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.15;
  }

  .tip-post-divider {
    width: 48px;
    height: 1px;
    background: rgba(var(--brand-red-rgb), 0.3);
    margin-bottom: 40px;
  }

  .tip-post-body {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .tip-post-lead {
    font-family: var(--font-body);
    font-size: 19px;
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.7;
    margin: 0;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(var(--brand-red-rgb), 0.15);
  }

  .tip-post-h3 {
    font-family: var(--font-playfair);
    font-size: 20px;
    font-weight: 600;
    color: var(--charcoal);
    line-height: 1.3;
  }

  .tip-post-p {
    font-family: var(--font-body);
    font-size: 18px;
    color: #555;
    line-height: 1.75;
    margin: 0;
  }

  .tip-post-footer {
    margin-top: 64px;
    padding-top: 24px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  .tip-post-footer-back {
    font-family: var(--font-body);
    font-size: 14px;
    color: #888;
    text-decoration: none;
  }

  .tip-post-footer-cta {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--brand-red);
    text-decoration: none;
  }
</style>
