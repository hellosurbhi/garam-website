---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { tipPostsSorted } from '@/data/tips';
import { buildBreadcrumbJsonLd } from '@/utils/breadcrumbs';

const TITLE = "South Asian Dating Tips | Garam Masala Dating";
const DESC =
  "Real, unfiltered advice for desi singles navigating modern dating, family pressure, and finding actual love.";

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
    timeZone: "UTC",
  });
}

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: "https://garammasaladating.com" },
  { name: "Dating Tips" },
]);
---

<BaseLayout
  title={TITLE}
  description={DESC}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
  </Fragment>

  <main id="main-content" class="tips-page">
    <div class="tips-container">
      <!-- Header -->
      <div class="tips-header">
        <p class="tips-eyebrow">Dating Tips</p>
        <h1 class="tips-title">
          South Asian Dating <em>Tips</em>
        </h1>
        <p class="tips-desc">
          Real, unfiltered advice for desi singles navigating modern dating,
          family pressure, and finding actual love.
        </p>
      </div>

      <!-- Divider -->
      <div class="tips-divider"></div>

      <!-- Post list -->
      <div class="tips-list">
        {tipPostsSorted.map((post, i) => (
          <a
            href={`/south-asian-dating-tips/${post.slug}`}
            class="tips-card"
            style={`animation-delay: ${0.1 + i * 0.08}s;`}
          >
            <p class="tips-card-date">
              {formatDate(post.datePublished)}
            </p>
            <h2 class="tips-card-title">
              {post.title}
            </h2>
            <p class="tips-card-excerpt">
              {post.excerpt}
            </p>
            <div class="tips-card-read">
              Read
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  @keyframes tipsFadeIn {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .tips-page {
    min-height: 100vh;
    position: relative;
    z-index: 1;
    animation: tipsFadeIn 0.5s ease-out both;
  }

  .tips-container {
    max-width: 560px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  .tips-header {
    margin-bottom: 40px;
  }

  .tips-eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--brand-red);
    margin-bottom: 12px;
  }

  .tips-title {
    font-family: var(--font-playfair);
    font-size: 32px;
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.15;
    margin-bottom: 14px;
  }

  .tips-title em {
    font-style: italic;
    color: var(--brand-red);
  }

  .tips-desc {
    font-family: var(--font-cormorant);
    font-style: italic;
    font-size: 17px;
    color: #666;
    line-height: 1.55;
  }

  .tips-divider {
    width: 48px;
    height: 1px;
    background: rgba(var(--brand-red-rgb), 0.3);
    margin-bottom: 36px;
  }

  .tips-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .tips-card {
    display: block;
    padding: 24px 20px;
    border-radius: 12px;
    border: 1px solid rgba(0, 0, 0, 0.06);
    background: white;
    text-decoration: none;
    animation: tipsFadeIn 0.5s ease-out both;
  }

  .tips-card-date {
    font-family: var(--font-body);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brand-red);
    margin-bottom: 10px;
  }

  .tips-card-title {
    font-family: var(--font-playfair);
    font-size: 20px;
    font-weight: 600;
    color: var(--charcoal);
    line-height: 1.25;
    margin-bottom: 10px;
  }

  .tips-card-excerpt {
    font-family: var(--font-cormorant);
    font-style: italic;
    font-size: 17px;
    color: #666;
    line-height: 1.6;
    margin: 0;
  }

  .tips-card-read {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 14px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--brand-red);
  }
</style>
