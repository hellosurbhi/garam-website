---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buildBreadcrumbJsonLd } from "@/utils/breadcrumbs";
import {
  SPONSORSHIP_COPY,
  SPONSOR_TIERS,
  MEDIA_KIT_STATS,
  TARGET_CATEGORIES,
  SPONSORSHIP_FAQS,
} from "@/data/sponsorship";

const TITLE =
  "Sponsor Garam Masala Dating | South Asian Live Show NYC — Media Kit";
const DESC =
  "Reach NYC's most engaged South Asian audience. Presenting ($3K–$5K), Gold ($1.5K–$2.5K), Silver ($500–$1K), and In-Kind sponsorship packages. 40+ shows, 10M+ views. Email partnerships@garammasaladating.com.";

const SITE_URL = "https://garammasaladating.com";

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: `${SITE_URL}/` },
  { name: "Sponsorship" },
]);

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: SPONSORSHIP_FAQS.map((faq) => ({
    "@type": "Question",
    name: faq.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.a,
    },
  })),
});

const speakableJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  url: `${SITE_URL}/sponsorship`,
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: [".sponsor-faq-answer"],
  },
});
---

<BaseLayout title={TITLE} description={DESC}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
    <script type="application/ld+json" set:html={faqJsonLd} />
    <script type="application/ld+json" set:html={speakableJsonLd} />
  </Fragment>

  <main id="main-content" class="sponsor-page">
    <!-- ── Hero ─────────────────────────────────────────────── -->
    <section class="sponsor-hero" aria-labelledby="sponsor-hero-heading">
      <div class="sponsor-container sponsor-hero-inner">
        <p class="sponsor-eyebrow">Brand Partnerships</p>
        <h1 id="sponsor-hero-heading">
          Reach NYC's Most Engaged South Asian Audience
        </h1>
        <p class="sponsor-hero-sub">
          40+ shows. 250 people per night. 10M+ social views.<br />
          A room full of people who actually pay attention.
        </p>
        <a
          href={`mailto:${SPONSORSHIP_COPY.partnerEmail}?subject=Sponsorship%20Inquiry`}
          class="sponsor-btn"
          data-ph-capture="cta_clicked"
          data-ph-cta="get_media_kit_hero"
          data-ph-section="sponsorship_hero"
        >
          Get the Media Kit
        </a>
      </div>
    </section>

    <!-- ── Media Kit Stats ───────────────────────────────────── -->
    <section class="sponsor-stats" aria-labelledby="sponsor-stats-heading">
      <div class="sponsor-container">
        <p class="sponsor-eyebrow sponsor-eyebrow--light">By the Numbers</p>
        <h2 id="sponsor-stats-heading" class="sponsor-stats-heading">
          Why brands choose Garam Masala Dating
        </h2>
        <div class="sponsor-stats-grid" role="list">
          {
            MEDIA_KIT_STATS.map((stat) => (
              <div class="sponsor-stat" role="listitem">
                <div class="sponsor-stat-num">{stat.num}</div>
                <div class="sponsor-stat-label">{stat.label}</div>
                <div class="sponsor-stat-sub">{stat.sub}</div>
              </div>
            ))
          }
        </div>
        <p class="sponsor-demo-blurb">
          Our audience is South Asian, desi diaspora, and culturally engaged
          non-South Asian guests — primarily in NYC, 22–40, high disposable
          income, active on social media. They're not passive attendees. They're
          the ones who share the clips, quote the hosts, and come back the next
          month.
        </p>
      </div>
    </section>

    <!-- ── Sponsorship Tiers ─────────────────────────────────── -->
    <section class="sponsor-tiers" aria-labelledby="sponsor-tiers-heading">
      <div class="sponsor-container">
        <p class="sponsor-eyebrow">Sponsorship Packages</p>
        <h2 id="sponsor-tiers-heading">Pick your level of involvement.</h2>
        <p class="sponsor-tiers-sub">
          All packages are per-show. Multi-show season discounts available —
          email us.
        </p>
        <div class="sponsor-tier-grid">
          {
            SPONSOR_TIERS.map((tier) => (
              <div
                class={`sponsor-tier-card${tier.highlight ? " sponsor-tier-card--presenting" : ""}`}
                aria-label={`${tier.name} sponsorship tier`}
              >
                <div class="sponsor-tier-header">
                  <div class="sponsor-tier-name">{tier.name}</div>
                  <div class="sponsor-tier-price">{tier.priceRange}</div>
                </div>
                <p class="sponsor-tier-tagline">{tier.tagline}</p>
                <ul
                  class="sponsor-tier-perks"
                  aria-label={`${tier.name} tier perks`}
                >
                  {tier.perks.map((perk) => (
                    <li>{perk}</li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ── Who We Partner With ───────────────────────────────── -->
    <section
      class="sponsor-partners"
      aria-labelledby="sponsor-partners-heading"
    >
      <div class="sponsor-container sponsor-partners-inner">
        <div>
          <p class="sponsor-eyebrow">Who We Partner With</p>
          <h2 id="sponsor-partners-heading">
            Brands that want to be in the room.
          </h2>
          <p class="sponsor-partners-desc">
            We're selective about who we partner with because our audience is
            selective about what they pay attention to. The right brand in this
            room feels like a natural fit — not an ad.
          </p>
        </div>
        <div
          class="sponsor-categories"
          role="list"
          aria-label="Target sponsor categories"
        >
          {
            TARGET_CATEGORIES.map((cat) => (
              <div class="sponsor-category" role="listitem">
                <div class="sponsor-cat-label">{cat.category}</div>
                <div class="sponsor-cat-brands">{cat.brands}</div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ── FAQ ──────────────────────────────────────────────── -->
    <section class="sponsor-faq" aria-labelledby="sponsor-faq-heading">
      <div class="sponsor-container sponsor-faq-inner">
        <p class="sponsor-eyebrow">Common Questions</p>
        <h2 id="sponsor-faq-heading">FAQs</h2>
        <div class="sponsor-faq-list">
          {
            SPONSORSHIP_FAQS.map((faq) => (
              <details class="sponsor-faq-item">
                <summary class="sponsor-faq-q">
                  {faq.q}
                  <span class="sponsor-faq-toggle" aria-hidden="true">
                    +
                  </span>
                </summary>
                <p class="sponsor-faq-answer">{faq.a}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ── Contact CTA ───────────────────────────────────────── -->
    <section class="sponsor-cta" aria-labelledby="sponsor-cta-heading">
      <div class="sponsor-container sponsor-cta-inner">
        <p class="sponsor-eyebrow sponsor-eyebrow--light">Let's Talk</p>
        <h2 id="sponsor-cta-heading">Ready to be in the room?</h2>
        <p>
          Tell us your brand, your goal, and your budget. We'll come back within
          48 hours with the right package.
        </p>
        <a
          href={`mailto:${SPONSORSHIP_COPY.partnerEmail}?subject=Sponsorship%20Inquiry`}
          class="sponsor-btn sponsor-btn--dark"
          data-ph-capture="cta_clicked"
          data-ph-cta="contact_sponsor_footer"
          data-ph-section="sponsorship_cta"
        >
          {SPONSORSHIP_COPY.partnerEmail}
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ── Shared ─────────────────────────────────────────────── */
  .sponsor-page {
    font-family: var(--font-body), sans-serif;
  }

  .sponsor-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .sponsor-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--brand-red);
    margin-bottom: 14px;
  }
  .sponsor-eyebrow--light {
    color: rgba(255, 255, 255, 0.55);
  }

  .sponsor-btn {
    display: inline-flex;
    align-items: center;
    background: var(--brand-red);
    color: white;
    font-family: var(--font-body), sans-serif;
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    padding: 16px 36px;
    border-radius: 50px;
    text-decoration: none;
    transition: background 0.2s;
    min-height: var(--touch-target);
  }
  .sponsor-btn:hover {
    background: var(--brand-red-dark);
  }
  .sponsor-btn:focus-visible {
    outline: 2px solid var(--brand-red);
    outline-offset: 3px;
  }
  .sponsor-btn--dark {
    background: var(--charcoal);
  }
  .sponsor-btn--dark:hover {
    background: var(--ink);
  }

  /* ── Hero ─────────────────────────────────────────────── */
  .sponsor-hero {
    background: var(--off-white);
    padding: 56px 0 48px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }
  .sponsor-hero-inner {
    text-align: center;
  }
  .sponsor-hero h1 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(28px, 5vw, 54px);
    font-weight: 900;
    color: var(--charcoal);
    line-height: 1.08;
    margin-bottom: 20px;
  }
  .sponsor-hero-sub {
    font-family: var(--font-cormorant), serif;
    font-size: clamp(18px, 2.5vw, 22px);
    font-style: italic;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 580px;
    margin: 0 auto 32px;
  }

  /* ── Stats ───────────────────────────────────────────── */
  .sponsor-stats {
    background: var(--charcoal);
    padding: 56px 0;
    color: white;
  }
  .sponsor-stats-heading {
    font-family: var(--font-playfair), serif;
    font-size: clamp(22px, 3vw, 34px);
    font-weight: 800;
    color: white;
    margin-bottom: 36px;
    line-height: 1.2;
  }
  .sponsor-stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 36px;
  }
  .sponsor-stat {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 24px;
  }
  .sponsor-stat-num {
    font-family: var(--font-playfair), serif;
    font-size: clamp(30px, 4vw, 48px);
    font-weight: 900;
    color: var(--electric-yellow);
    line-height: 1;
    margin-bottom: 6px;
  }
  .sponsor-stat-label {
    font-size: 14px;
    font-weight: 700;
    color: white;
    margin-bottom: 4px;
    line-height: 1.3;
  }
  .sponsor-stat-sub {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.45);
  }
  .sponsor-demo-blurb {
    font-size: 15px;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.7);
    max-width: 760px;
    margin: 0;
  }

  /* ── Tiers ───────────────────────────────────────────── */
  .sponsor-tiers {
    background: var(--cream-warm);
    padding: 56px 0;
  }
  .sponsor-tiers h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 800;
    color: var(--charcoal);
    margin-bottom: 8px;
    line-height: 1.15;
  }
  .sponsor-tiers-sub {
    font-size: 15px;
    color: var(--text-secondary);
    margin-bottom: 36px;
  }
  .sponsor-tier-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  .sponsor-tier-card {
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 14px;
    padding: 28px;
  }
  .sponsor-tier-card--presenting {
    background: var(--charcoal);
    border-color: transparent;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.18);
  }
  .sponsor-tier-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 10px;
  }
  .sponsor-tier-name {
    font-family: var(--font-playfair), serif;
    font-size: 22px;
    font-weight: 900;
    color: var(--charcoal);
  }
  .sponsor-tier-card--presenting .sponsor-tier-name {
    color: var(--electric-yellow);
  }
  .sponsor-tier-price {
    font-size: 14px;
    font-weight: 700;
    color: var(--brand-red);
    white-space: nowrap;
  }
  .sponsor-tier-card--presenting .sponsor-tier-price {
    color: rgba(255, 255, 255, 0.75);
  }
  .sponsor-tier-tagline {
    font-family: var(--font-cormorant), serif;
    font-size: 16px;
    font-style: italic;
    color: var(--text-secondary);
    margin: 0 0 18px;
    line-height: 1.5;
  }
  .sponsor-tier-card--presenting .sponsor-tier-tagline {
    color: rgba(255, 255, 255, 0.65);
  }
  .sponsor-tier-perks {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin: 0;
    padding: 0;
  }
  .sponsor-tier-perks li {
    font-size: 14px;
    line-height: 1.5;
    color: var(--text-secondary);
    padding-left: 18px;
    position: relative;
  }
  .sponsor-tier-perks li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--brand-red);
    font-weight: 700;
    font-size: 12px;
  }
  .sponsor-tier-card--presenting .sponsor-tier-perks li {
    color: rgba(255, 255, 255, 0.75);
  }
  .sponsor-tier-card--presenting .sponsor-tier-perks li::before {
    color: var(--electric-yellow);
  }

  /* ── Who We Partner With ─────────────────────────────── */
  .sponsor-partners {
    background: var(--off-white);
    padding: 56px 0;
  }
  .sponsor-partners-inner {
    display: flex;
    flex-direction: column;
    gap: 36px;
  }
  .sponsor-partners h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 800;
    color: var(--charcoal);
    margin-bottom: 12px;
    line-height: 1.15;
  }
  .sponsor-partners-desc {
    font-size: 15px;
    line-height: 1.75;
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0;
  }
  .sponsor-categories {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sponsor-category {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 16px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.07);
  }
  .sponsor-category:first-child {
    border-top: 1px solid rgba(0, 0, 0, 0.07);
  }
  .sponsor-cat-label {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--brand-red);
  }
  .sponsor-cat-brands {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  /* ── FAQ ─────────────────────────────────────────────── */
  .sponsor-faq {
    background: var(--cream-warm);
    padding: 56px 0;
  }
  .sponsor-faq-inner {
    max-width: 760px;
  }
  .sponsor-faq h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 800;
    color: var(--charcoal);
    margin-bottom: 28px;
  }
  .sponsor-faq-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sponsor-faq-item {
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }
  .sponsor-faq-item:first-child {
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }
  .sponsor-faq-q {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 18px 0;
    font-size: 16px;
    font-weight: 700;
    color: var(--charcoal);
    cursor: pointer;
    list-style: none;
    line-height: 1.4;
  }
  .sponsor-faq-q::-webkit-details-marker {
    display: none;
  }
  .sponsor-faq-toggle {
    flex-shrink: 0;
    font-size: 22px;
    font-weight: 400;
    color: var(--brand-red);
    transition: transform 0.2s;
    line-height: 1;
  }
  .sponsor-faq-item[open] .sponsor-faq-toggle {
    transform: rotate(45deg);
  }
  .sponsor-faq-answer {
    font-size: 15px;
    line-height: 1.75;
    color: var(--text-secondary);
    padding: 0 0 18px;
    margin: 0;
  }

  /* ── CTA ─────────────────────────────────────────────── */
  .sponsor-cta {
    background: var(--brand-red);
    padding: 56px 0;
    text-align: center;
  }
  .sponsor-cta-inner {
    max-width: 640px;
  }
  .sponsor-cta h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 900;
    color: white;
    margin-bottom: 16px;
  }
  .sponsor-cta p {
    font-size: 16px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 28px;
  }

  /* ── Desktop ─────────────────────────────────────────── */
  @media (min-width: 768px) {
    .sponsor-hero {
      padding: 80px 0 72px;
    }
    .sponsor-stats {
      padding: 80px 0;
    }
    .sponsor-stats-grid {
      grid-template-columns: repeat(4, 1fr);
    }
    .sponsor-tiers {
      padding: 80px 0;
    }
    .sponsor-tier-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .sponsor-partners {
      padding: 80px 0;
    }
    .sponsor-partners-inner {
      flex-direction: row;
      gap: 64px;
      align-items: flex-start;
    }
    .sponsor-partners-inner > div:first-child {
      flex: 1;
    }
    .sponsor-categories {
      flex: 1;
    }
    .sponsor-category {
      flex-direction: row;
      align-items: baseline;
      gap: 20px;
    }
    .sponsor-cat-label {
      min-width: 220px;
    }
    .sponsor-faq {
      padding: 80px 0;
    }
    .sponsor-cta {
      padding: 80px 0;
    }
  }

  @media (min-width: 1024px) {
    .sponsor-tier-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
