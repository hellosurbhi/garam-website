---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buildBreadcrumbJsonLd } from "@/utils/breadcrumbs";
import FaqAccordion from "@/components/ui/FaqAccordion.astro";
import {
  SPONSORSHIP_COPY,
  SPONSOR_TIERS,
  MEDIA_KIT_STATS,
  TARGET_CATEGORIES,
  SPONSORSHIP_FAQS,
} from "@/data/sponsorship";

const TITLE =
  "Sponsor Garam Masala Dating | South Asian Live Show NYC — Media Kit";
const DESC =
  "Reach NYC's most engaged South Asian audience. Presenting ($3K–$5K), Gold ($1.5K–$2.5K), Silver ($500–$1K), and In-Kind sponsorship packages. 40+ shows, 10M+ views, 70%+ South Asian professionals 22–40. Email caleb@garammasaladating.com.";

const SITE_URL = "https://garammasaladating.com";

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: `${SITE_URL}/` },
  { name: "Sponsorship" },
]);

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: SPONSORSHIP_FAQS.map((faq) => ({
    "@type": "Question",
    name: faq.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.a,
    },
  })),
});

const speakableJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  url: `${SITE_URL}/sponsorship`,
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: [".sponsor-faq-answer"],
  },
});
---

<BaseLayout title={TITLE} description={DESC}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
    <script type="application/ld+json" set:html={faqJsonLd} />
    <script type="application/ld+json" set:html={speakableJsonLd} />
  </Fragment>

  <main id="main-content" class="sponsor-page">
    <!-- ── Hero ─────────────────────────────────────────────── -->
    <section class="sponsor-hero" aria-labelledby="sponsor-hero-heading">
      <div class="sponsor-container sponsor-hero-inner">
        <p class="sponsor-eyebrow">Brand Partnerships</p>
        <h1 id="sponsor-hero-heading">{SPONSORSHIP_COPY.heroHeadline}</h1>
        <p class="sponsor-hero-sub">{SPONSORSHIP_COPY.heroSub}</p>
        <div class="sponsor-email-cta">
          <p class="sponsor-email-label">
            Email our {SPONSORSHIP_COPY.contactTitle}, {
              SPONSORSHIP_COPY.contactName
            }:
          </p>
          <a
            href={`mailto:${SPONSORSHIP_COPY.contactEmail}?subject=Sponsorship%20Inquiry`}
            class="sponsor-email-link"
            data-ph-capture="cta_clicked"
            data-ph-cta="email_hero"
            data-ph-section="sponsorship_hero"
          >
            {SPONSORSHIP_COPY.contactEmail}
          </a>
        </div>
      </div>
    </section>

    <!-- ── Media Kit Stats ───────────────────────────────────── -->
    <section class="sponsor-stats" aria-labelledby="sponsor-stats-heading">
      <div class="sponsor-container">
        <p class="sponsor-eyebrow">By the Numbers</p>
        <h2 id="sponsor-stats-heading" class="sponsor-stats-heading">
          Why brands choose Garam Masala Dating
        </h2>
        <div class="sponsor-stats-grid" role="list">
          {
            MEDIA_KIT_STATS.map((stat) => (
              <div class="sponsor-stat" role="listitem">
                <div class="sponsor-stat-num">{stat.num}</div>
                <div class="sponsor-stat-label">{stat.label}</div>
                <p class="sponsor-stat-sub">{stat.sub}</p>
              </div>
            ))
          }
        </div>
        <p class="sponsor-demo-blurb">{SPONSORSHIP_COPY.demoBlurb}</p>
      </div>
    </section>

    <!-- ── Sponsorship Tiers ─────────────────────────────────── -->
    <section class="sponsor-tiers" aria-labelledby="sponsor-tiers-heading">
      <div class="sponsor-container">
        <p class="sponsor-eyebrow">Sponsorship Packages</p>
        <h2 id="sponsor-tiers-heading">Pick your level of involvement.</h2>
        <p class="sponsor-tiers-sub">
          All packages are per-show. Multi-show season discounts available —
          email us to discuss.
        </p>
        <div class="sponsor-tier-list">
          {
            SPONSOR_TIERS.map((tier) => (
              <div
                class={`sponsor-tier-card${tier.highlight ? " sponsor-tier-card--presenting" : ""}`}
                aria-label={`${tier.name} tier`}
              >
                <div class="sponsor-tier-header">
                  <div class="sponsor-tier-name">{tier.name}</div>
                  <div class="sponsor-tier-price">{tier.priceRange}</div>
                </div>
                <p class="sponsor-tier-tagline">{tier.tagline}</p>
                <ul
                  class="sponsor-tier-perks"
                  aria-label={`${tier.name} tier perks`}
                >
                  {tier.perks.map((perk) => (
                    <li>{perk}</li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ── Who We Partner With ───────────────────────────────── -->
    <section
      class="sponsor-partners"
      aria-labelledby="sponsor-partners-heading"
    >
      <div class="sponsor-container">
        <p class="sponsor-eyebrow">Who We Partner With</p>
        <h2 id="sponsor-partners-heading">
          Brands that want to be in the room.
        </h2>
        <p class="sponsor-partners-intro">
          We're selective about who we partner with because our audience is
          selective about what they pay attention to. The right brand in this
          room feels like a natural part of the night — not an interruption.
        </p>
        <div class="sponsor-categories">
          {
            TARGET_CATEGORIES.map((cat) => (
              <div class="sponsor-category">
                <div class="sponsor-cat-header">
                  <div class="sponsor-cat-label">{cat.category}</div>
                  <div class="sponsor-cat-brands">{cat.brands}</div>
                </div>
                <p class="sponsor-cat-why">{cat.why}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ── FAQ ──────────────────────────────────────────────── -->
    <section class="sponsor-faq" aria-labelledby="sponsor-faq-heading">
      <div class="sponsor-container sponsor-faq-inner">
        <p class="sponsor-eyebrow">Common Questions</p>
        <h2 id="sponsor-faq-heading">FAQs</h2>
        <FaqAccordion
          items={SPONSORSHIP_FAQS}
          groupId="sponsor-faq"
          answerClass="sponsor-faq-answer"
        />
      </div>
    </section>

    <!-- ── Contact CTA ───────────────────────────────────────── -->
    <section class="sponsor-cta" aria-labelledby="sponsor-cta-heading">
      <div class="sponsor-container sponsor-cta-inner">
        <h2 id="sponsor-cta-heading">{SPONSORSHIP_COPY.ctaHeadline}</h2>
        <p class="sponsor-cta-body">{SPONSORSHIP_COPY.ctaBody}</p>
        <div class="sponsor-email-cta">
          <a
            href={`mailto:${SPONSORSHIP_COPY.contactEmail}?subject=Sponsorship%20Inquiry`}
            class="sponsor-email-link sponsor-email-link--dark"
            data-ph-capture="cta_clicked"
            data-ph-cta="email_footer"
            data-ph-section="sponsorship_cta"
          >
            {SPONSORSHIP_COPY.contactEmail}
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ── Shared ─────────────────────────────────────────────── */
  .sponsor-page {
    font-family: var(--font-body), sans-serif;
  }

  .sponsor-container {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .sponsor-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--brand-red);
    margin-bottom: 14px;
  }
  .sponsor-eyebrow--light {
    color: rgba(255, 255, 255, 0.6);
  }

  /* ── Email CTA ──────────────────────────────────────────── */
  .sponsor-email-cta {
    margin-top: 28px;
  }
  .sponsor-email-label {
    font-size: 14px;
    color: var(--text-secondary);
    margin-bottom: 6px;
    font-weight: 600;
  }
  .sponsor-email-link {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-body), sans-serif;
    font-size: clamp(18px, 2.5vw, 24px);
    font-weight: 800;
    color: var(--brand-red);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
    transition: color 0.2s;
    min-height: var(--touch-target);
    padding: 4px 0;
  }
  .sponsor-email-link:hover {
    color: var(--brand-red-dark);
  }
  .sponsor-email-link:focus-visible {
    outline: 2px solid var(--brand-red);
    outline-offset: 3px;
  }
  .sponsor-email-link--dark {
    color: var(--charcoal);
    text-decoration-color: var(--charcoal);
  }
  .sponsor-email-link--dark:hover {
    color: var(--ink);
  }

  /* ── Hero ─────────────────────────────────────────────── */
  .sponsor-hero {
    background: var(--off-white);
    padding: 56px 0 48px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }
  .sponsor-hero-inner {
    text-align: center;
  }
  .sponsor-hero h1 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(26px, 5vw, 50px);
    font-weight: 900;
    color: var(--charcoal);
    line-height: 1.08;
    margin-bottom: 20px;
  }
  .sponsor-hero-sub {
    font-family: var(--font-cormorant), serif;
    font-size: clamp(16px, 2.2vw, 20px);
    font-style: italic;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 680px;
    margin: 0 auto;
  }

  /* ── Stats ───────────────────────────────────────────── */
  .sponsor-stats {
    background: var(--cream-warm);
    padding: 56px 0;
  }
  .sponsor-stats-heading {
    font-family: var(--font-playfair), serif;
    font-size: clamp(22px, 3vw, 34px);
    font-weight: 800;
    color: var(--charcoal);
    margin-bottom: 36px;
    line-height: 1.2;
  }
  .sponsor-stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 36px;
  }
  .sponsor-stat {
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 12px;
    padding: 24px;
  }
  .sponsor-stat-num {
    font-family: var(--font-playfair), serif;
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 900;
    color: var(--brand-red);
    line-height: 1;
    margin-bottom: 6px;
  }
  .sponsor-stat-label {
    font-size: 14px;
    font-weight: 700;
    color: var(--charcoal);
    margin-bottom: 8px;
    line-height: 1.3;
  }
  .sponsor-stat-sub {
    font-size: 13px;
    line-height: 1.5;
    color: var(--muted);
    margin: 0;
  }
  .sponsor-demo-blurb {
    font-size: 15px;
    line-height: 1.8;
    color: var(--text-secondary);
    margin: 0;
  }

  /* ── Tiers ───────────────────────────────────────────── */
  .sponsor-tiers {
    background: var(--off-white);
    padding: 56px 0;
  }
  .sponsor-tiers h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 800;
    color: var(--charcoal);
    margin-bottom: 8px;
    line-height: 1.15;
  }
  .sponsor-tiers-sub {
    font-size: 15px;
    color: var(--text-secondary);
    margin-bottom: 36px;
  }
  .sponsor-tier-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .sponsor-tier-card {
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 14px;
    padding: 28px;
  }
  .sponsor-tier-card--presenting {
    background: var(--brand-red);
    border-color: transparent;
    box-shadow: 0 4px 24px rgba(220, 38, 38, 0.2);
  }
  .sponsor-tier-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
  }
  .sponsor-tier-name {
    font-family: var(--font-playfair), serif;
    font-size: 22px;
    font-weight: 900;
    color: var(--charcoal);
  }
  .sponsor-tier-card--presenting .sponsor-tier-name {
    color: white;
  }
  .sponsor-tier-price {
    font-size: 14px;
    font-weight: 700;
    color: var(--brand-red);
    white-space: nowrap;
  }
  .sponsor-tier-card--presenting .sponsor-tier-price {
    color: rgba(255, 255, 255, 0.75);
  }
  .sponsor-tier-tagline {
    font-size: 15px;
    color: var(--text-secondary);
    margin: 0 0 20px;
    line-height: 1.7;
  }
  .sponsor-tier-card--presenting .sponsor-tier-tagline {
    color: rgba(255, 255, 255, 0.7);
  }
  .sponsor-tier-perks {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin: 0;
    padding: 0;
  }
  .sponsor-tier-perks li {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-secondary);
    padding-left: 20px;
    position: relative;
  }
  .sponsor-tier-perks li::before {
    content: "\2713";
    position: absolute;
    left: 0;
    color: var(--brand-red);
    font-weight: 700;
    font-size: 13px;
  }
  .sponsor-tier-card--presenting .sponsor-tier-perks li {
    color: rgba(255, 255, 255, 0.78);
  }
  .sponsor-tier-card--presenting .sponsor-tier-perks li::before {
    color: var(--electric-yellow);
  }

  /* ── Who We Partner With ─────────────────────────────── */
  .sponsor-partners {
    background: var(--cream-warm);
    padding: 56px 0;
  }
  .sponsor-partners h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 800;
    color: var(--charcoal);
    margin-bottom: 12px;
    line-height: 1.15;
  }
  .sponsor-partners-intro {
    font-size: 15px;
    line-height: 1.75;
    color: var(--text-secondary);
    max-width: 640px;
    margin-bottom: 36px;
  }
  .sponsor-categories {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .sponsor-category {
    padding: 20px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.07);
  }
  .sponsor-category:first-child {
    border-top: 1px solid rgba(0, 0, 0, 0.07);
  }
  .sponsor-cat-header {
    margin-bottom: 6px;
  }
  .sponsor-cat-label {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--brand-red);
    margin-bottom: 2px;
  }
  .sponsor-cat-brands {
    font-size: 15px;
    font-weight: 600;
    color: var(--charcoal);
  }
  .sponsor-cat-why {
    font-size: 14px;
    line-height: 1.65;
    color: var(--text-secondary);
    margin: 0;
  }

  /* ── FAQ ─────────────────────────────────────────────── */
  .sponsor-faq {
    background: var(--off-white);
    padding: 56px 0;
  }
  .sponsor-faq-inner {
    max-width: 760px;
  }
  .sponsor-faq h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 800;
    color: var(--charcoal);
    margin-bottom: 28px;
  }
  /* FAQ styling handled by FaqAccordion component */

  /* ── CTA ─────────────────────────────────────────────── */
  .sponsor-cta {
    background: var(--brand-red);
    padding: 56px 0;
    text-align: center;
  }
  .sponsor-cta-inner {
    max-width: 680px;
  }
  .sponsor-cta h2 {
    font-family: var(--font-playfair), serif;
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 900;
    color: white;
    margin-bottom: 20px;
  }
  .sponsor-cta-body {
    font-size: 16px;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 0;
  }
  .sponsor-cta .sponsor-email-link {
    color: white;
    text-decoration-color: white;
    font-size: clamp(20px, 3vw, 28px);
  }
  .sponsor-cta .sponsor-email-link:hover {
    color: var(--electric-yellow);
    text-decoration-color: var(--electric-yellow);
  }

  /* ── Desktop ─────────────────────────────────────────── */
  @media (min-width: 768px) {
    .sponsor-hero {
      padding: 80px 0 72px;
    }
    .sponsor-stats {
      padding: 80px 0;
    }
    .sponsor-stats-grid {
      grid-template-columns: repeat(4, 1fr);
    }
    .sponsor-tiers {
      padding: 80px 0;
    }
    .sponsor-partners {
      padding: 80px 0;
    }
    .sponsor-faq {
      padding: 80px 0;
    }
    .sponsor-cta {
      padding: 80px 0;
    }
  }
</style>
