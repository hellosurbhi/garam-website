---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { WAIVER_VERSION, WAIVER_TEXT } from "@/data/waiver";
import { events } from "@/data/events";
import { WaiverDocument } from "@/components/WaiverDocument";

const currentShow = events.find(
  (e) =>
    !e.hidden &&
    e.isoDate &&
    new Date(e.isoDate) >= new Date(new Date().toLocaleDateString("en-CA")),
);
---

<BaseLayout
  title="Stage Waiver"
  description="Quick waiver for audience participants going on stage."
  noindex={true}
>
  <main id="main-content" class="stage-waiver-page">
    <div class="sw-container">
      <div id="waiver-form-view">
        <h1 class="sw-title">Stage Waiver</h1>
        <p class="sw-subtitle">
          Quick sign before you go on. Takes 30 seconds.
        </p>
        <form id="stage-waiver-form" class="sw-form">
          <div class="sw-field-row">
            <input
              type="text"
              id="sw-first"
              placeholder="First name"
              required
              aria-label="First name"
            />
            <input
              type="text"
              id="sw-last"
              placeholder="Last name"
              required
              aria-label="Last name"
            />
          </div>
          <input
            type="email"
            id="sw-email"
            placeholder="Email"
            required
            aria-label="Email"
          />
          <input
            type="tel"
            id="sw-phone"
            placeholder="Phone (555) 123-4567"
            required
            aria-label="Phone number"
          />
          <div class="sw-waiver-scroll" aria-label="Waiver text" tabindex="0">
            <WaiverDocument text={WAIVER_TEXT} />
          </div>
          <label class="sw-checkbox">
            <input type="checkbox" id="sw-agree" required disabled />
            <span>I have read and agree to the terms and waiver above</span>
          </label>
          <p id="sw-scroll-note" class="sw-note">
            Scroll through the full waiver to enable agreement.
          </p>
          <div>
            <label class="sw-label" for="sw-sig"
              >Type your full legal name as your signature</label
            >
            <input
              type="text"
              id="sw-sig"
              placeholder="First Last"
              required
              aria-label="Signature"
            />
          </div>
          <label class="sw-checkbox sw-checkbox-muted">
            <input type="checkbox" id="sw-optin" />
            <span>Email me about future shows</span>
          </label>
          <input type="hidden" id="sw-version" value={WAIVER_VERSION} />
          {
            currentShow && (
              <input
                type="hidden"
                id="sw-show-id"
                value={`${currentShow.citySlug}-${currentShow.isoDate}`}
              />
            )
          }
          <p id="sw-error" class="sw-error" hidden role="alert"></p>
          <button type="submit" class="sw-submit">Sign Waiver</button>
        </form>
      </div>
      <div id="waiver-success" hidden>
        <div class="sw-success">
          <div class="sw-success-emoji">🌶️</div>
          <h2 class="sw-success-title">You're all set!</h2>
          <p class="sw-success-text">
            Have fun out there. The audience is rooting for you.
          </p>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  const form = document.getElementById(
    "stage-waiver-form",
  ) as HTMLFormElement | null;
  const waiverScroll =
    document.querySelector<HTMLDivElement>(".sw-waiver-scroll");
  const agreeInput = document.getElementById(
    "sw-agree",
  ) as HTMLInputElement | null;
  const scrollNote = document.getElementById("sw-scroll-note");
  let waiverScrolled = false;

  function updateWaiverScrolled(el: HTMLDivElement) {
    const canScroll = el.scrollHeight > el.clientHeight + 4;
    const reachedBottom = el.scrollTop + el.clientHeight >= el.scrollHeight - 8;
    if (!canScroll || !reachedBottom) return;
    waiverScrolled = true;
    if (agreeInput) agreeInput.disabled = false;
    scrollNote?.setAttribute("hidden", "");
  }

  if (waiverScroll) {
    waiverScroll.addEventListener("scroll", () => {
      updateWaiverScrolled(waiverScroll);
    });
  }

  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const errorEl = document.getElementById("sw-error");
      const submitBtn =
        form.querySelector<HTMLButtonElement>('[type="submit"]');
      const originalText = submitBtn?.textContent ?? "";
      const firstName = (
        document.getElementById("sw-first") as HTMLInputElement
      ).value.trim();
      const lastName = (
        document.getElementById("sw-last") as HTMLInputElement
      ).value.trim();
      const sig = (
        document.getElementById("sw-sig") as HTMLInputElement
      ).value.trim();
      if (!waiverScrolled) {
        if (errorEl) {
          errorEl.textContent =
            "Please scroll through the full waiver before signing.";
          errorEl.removeAttribute("hidden");
        }
        return;
      }
      if (sig.toLowerCase() !== `${firstName} ${lastName}`.toLowerCase()) {
        if (errorEl) {
          errorEl.textContent = "Signature must match your full name.";
          errorEl.removeAttribute("hidden");
        }
        return;
      }
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = "Signing...";
      }
      try {
        const res = await fetch("/api/stage-waiver", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            firstName,
            lastName,
            email: (
              document.getElementById("sw-email") as HTMLInputElement
            ).value.trim(),
            phone: (
              document.getElementById("sw-phone") as HTMLInputElement
            ).value.trim(),
            waiverAgreed: (
              document.getElementById("sw-agree") as HTMLInputElement
            ).checked,
            signature: sig,
            waiverVersion: (
              document.getElementById("sw-version") as HTMLInputElement
            ).value,
            mailingListOptIn: (
              document.getElementById("sw-optin") as HTMLInputElement
            ).checked,
            showId:
              (document.getElementById("sw-show-id") as HTMLInputElement | null)
                ?.value ?? "",
          }),
        });
        const text = await res.text();
        let data: { error?: string } = {};
        if (text.trim()) {
          try {
            data = JSON.parse(text) as { error?: string };
          } catch {
            data = {};
          }
        }
        if (!res.ok) throw new Error(data.error ?? "Something went wrong");
        document.getElementById("waiver-form-view")?.setAttribute("hidden", "");
        document.getElementById("waiver-success")?.removeAttribute("hidden");
      } catch (err) {
        if (errorEl) {
          errorEl.textContent =
            err instanceof Error
              ? err.message
              : "Something went wrong. Please try again.";
          errorEl.removeAttribute("hidden");
        }
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = originalText;
        }
      }
    });
  }
</script>

<style>
  .stage-waiver-page {
    min-height: 100vh;
    padding: 40px 16px;
    background: var(--off-white);
  }
  .sw-container {
    max-width: 520px;
    margin: 0 auto;
  }
  .sw-title {
    font-family: var(--font-playfair), serif;
    font-size: clamp(28px, 5vw, 40px);
    font-weight: 900;
    color: var(--charcoal);
    margin-bottom: 8px;
  }
  .sw-subtitle {
    font-size: 16px;
    color: var(--muted);
    margin-bottom: 32px;
    line-height: 1.5;
  }
  .sw-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .sw-field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .sw-form input[type="text"],
  .sw-form input[type="email"],
  .sw-form input[type="tel"] {
    padding: 14px 20px;
    border: 1.5px solid rgba(0, 0, 0, 0.1);
    border-radius: 12px;
    font-size: 16px;
    font-family: var(--font-body), sans-serif;
    outline: none;
    transition: border-color 0.2s;
    min-height: var(--touch-target);
  }
  .sw-form input:focus-visible {
    border-color: var(--brand-red);
    outline: 2px solid var(--brand-red);
    outline-offset: -2px;
  }
  .sw-waiver-scroll {
    max-height: 200px;
    overflow-y: auto;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 12px;
    padding: 0;
    background: #f7f1e8;
  }
  .sw-checkbox {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 15px;
    color: var(--charcoal);
    line-height: 1.4;
    cursor: pointer;
  }
  .sw-checkbox input[type="checkbox"] {
    margin-top: 3px;
    min-width: 20px;
    min-height: 20px;
    accent-color: var(--brand-red);
  }
  .sw-checkbox-muted {
    color: var(--muted);
    font-size: 14px;
  }
  .sw-note {
    margin: -8px 0 0;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.4;
  }
  .sw-label {
    display: block;
    font-size: 14px;
    color: var(--muted);
    margin-bottom: 8px;
  }
  .sw-error {
    color: var(--brand-red);
    font-size: 14px;
    text-align: center;
    margin: 0;
  }
  .sw-submit {
    background: var(--brand-red);
    color: #fff;
    border: none;
    padding: 16px;
    border-radius: 50px;
    font-family: var(--font-body), sans-serif;
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition:
      background 0.2s,
      transform 0.06s;
    min-height: var(--touch-target);
    width: 100%;
  }
  .sw-submit:hover {
    background: var(--brand-red-dark);
  }
  .sw-submit:active {
    transform: scale(0.97);
  }
  .sw-success {
    text-align: center;
    padding: 60px 0;
  }
  .sw-success-emoji {
    font-size: 48px;
    margin-bottom: 16px;
  }
  .sw-success-title {
    font-family: var(--font-playfair), serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--charcoal);
    margin-bottom: 12px;
  }
  .sw-success-text {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.6;
  }
</style>
