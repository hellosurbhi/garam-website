---
import BaseLayout from '@/layouts/BaseLayout.astro';
import NotifyModal from '@/components/NotifyModal.astro';
import { buildBreadcrumbJsonLd } from '@/utils/breadcrumbs';
import { events, allEvents } from '@/data/events';
import { isEventPast } from '@/utils/eventDate';
import { buildEventSchemas } from '@/utils/eventSchema';

const TITLE = "Tickets & Upcoming Shows | Garam Masala Dating";
const DESC =
  "Get tickets to upcoming Garam Masala Dating shows. NYC's #1 live South Asian dating show and singles mixer, now in LA, SF, San Diego, and more.";

const upcomingEvents = allEvents.filter((e) => !isEventPast(e.date) && !e.hidden);

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: "https://garammasaladating.com/" },
  { name: "Tickets" },
]);

// Individual Event JSON-LD blocks (one per upcoming show)
const today = new Date().toISOString().slice(0, 10);
const upcomingForSchema = events.filter((e) => !e.hidden && e.isoDate && e.isoDate >= today);
const eventSchemas = buildEventSchemas(upcomingForSchema);
---

<BaseLayout title={TITLE} description={DESC}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
    {eventSchemas.map((schema) => (
      <script type="application/ld+json" set:html={schema} />
    ))}
  </Fragment>

  <main id="main-content" class="tickets-page">
    <img class="tickets-bg" src="/images/higgs-field.webp" alt="" width="1200" height="800" aria-hidden="true" />
    <div class="tickets-container">
      {/* Header */}
      <div class="tickets-header">
        <p class="tickets-eyebrow">Tickets</p>
        <h1 class="tickets-h1">Upcoming Shows</h1>
        <p class="tickets-intro">
          Garam Masala Dating is a live South Asian dating show and singles mixer.
          Grab tickets on Eventbrite.
        </p>
        <p class="tickets-proof">40+ shows sold out · 2,000+ audience members</p>
      </div>

      {/* Divider */}
      <div class="tickets-divider" />

      {/* Event cards */}
      {upcomingEvents.length > 0 ? (
        <div class="tickets-list">
          {upcomingEvents.map((event, i) => {
            const isLive = event.url && event.url !== "#";
            const isSoldOut = event.tagline?.toLowerCase().includes('sold out');
            return isLive ? (
              <a
                href={event.url}
                target="_blank"
                rel="noopener noreferrer"
                class={`ticket-card ticket-card--live${isSoldOut ? ' ticket-card--soldout' : ''}`}
                style={`animation-delay: ${0.1 + i * 0.06}s`}
              >
                <div class="ticket-card__info">
                  <span class="ticket-card__date">{event.date}</span>
                  <span class="ticket-card__city">{event.city}</span>
                </div>
                <span class={`ticket-card__cta${isSoldOut ? ' ticket-card__cta--soldout' : ''}`}>
                  {isSoldOut ? 'Sold Out' : 'Get Tickets'}
                  {!isSoldOut && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  )}
                </span>
              </a>
            ) : (
              <button
                type="button"
                class="ticket-card ticket-card--tba"
                style={`animation-delay: ${0.1 + i * 0.06}s`}
                data-notify-city={event.city}
              >
                <div class="ticket-card__info">
                  <span class="ticket-card__date ticket-card__date--tba">{event.date}</span>
                  <span class="ticket-card__city ticket-card__city--tba">{event.city}</span>
                </div>
                <span class="ticket-card__cta ticket-card__cta--notify">
                  Notify Me
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
                </span>
              </button>
            );
          })}
        </div>
      ) : (
        <p class="tickets-empty">
          No upcoming shows. Follow us on{' '}
          <a href="https://www.instagram.com/garammasaladating/" target="_blank" rel="noopener noreferrer" class="tickets-empty__link">
            Instagram
          </a>{' '}
          for announcements.
        </p>
      )}

      <NotifyModal source="tickets-notify" />

      {/* Footer */}
      <div class="tickets-footer">
        <a href="/" class="tickets-footer__back">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
          Back to Home
        </a>
      </div>
    </div>
  </main>
</BaseLayout>


<style>
  @keyframes ticketsFadeIn {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .tickets-page {
    min-height: 100vh;
    position: relative;
    z-index: 1;
    animation: ticketsFadeIn 0.5s ease-out both;
    overflow: hidden;
  }
  .tickets-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
    z-index: 0;
    opacity: 0.06;
  }

  .tickets-container {
    max-width: 560px;
    margin: 0 auto;
    padding: 48px 24px 48px;
  }

  /* ─── Header ─────────────────────────────────────────── */

  .tickets-header {
    margin-bottom: 24px;
  }

  .tickets-eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--brand-red);
    margin-bottom: 12px;
  }

  .tickets-h1 {
    font-family: var(--font-playfair);
    font-size: 36px;
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.15;
    margin-bottom: 14px;
  }

  .tickets-intro {
    font-family: var(--font-cormorant);
    font-style: italic;
    font-size: 19px;
    color: var(--text-light);
    line-height: 1.55;
  }

  .tickets-proof {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-light);
    margin-top: 10px;
    letter-spacing: 0.5px;
  }

  .tickets-divider {
    width: 48px;
    height: 1px;
    background: rgba(var(--brand-red-rgb), 0.3);
    margin-bottom: 32px;
  }

  /* ─── Event Cards ────────────────────────────────────── */

  .tickets-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ticket-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 22px;
    border-radius: 12px;
    border: 1px solid;
    text-decoration: none;
    animation: ticketsFadeIn 0.5s ease-out both;
    transition: border-color 0.15s, background 0.15s;
  }

  .ticket-card--live {
    border-color: rgba(var(--brand-red-rgb), 0.35);
    background: white;
  }

  .ticket-card--live:hover {
    border-color: rgba(var(--brand-red-rgb), 0.55);
    background: rgba(var(--brand-red-rgb), 0.04);
  }

  .ticket-card--tba {
    border-color: rgba(0, 0, 0, 0.08);
    background: white;
    cursor: pointer;
    text-align: left;
    font: inherit;
  }

  .ticket-card--tba:hover {
    border-color: rgba(var(--brand-red-rgb), 0.3);
    background: rgba(var(--brand-red-rgb), 0.02);
  }

  .ticket-card__info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ticket-card__date {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brand-red);
  }

  .ticket-card__date--tba {
    color: var(--muted);
  }

  .ticket-card__city {
    font-family: var(--font-playfair);
    font-size: 20px;
    font-weight: 600;
    color: var(--charcoal);
    line-height: 1.25;
  }

  .ticket-card__city--tba {
    color: var(--text-light);
  }

  .ticket-card__cta {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--brand-red);
    padding: 8px 14px;
    border: 1px solid rgba(var(--brand-red-rgb), 0.35);
    border-radius: 8px;
    background: rgba(var(--brand-red-rgb), 0.08);
    white-space: nowrap;
    transition: background 0.15s, border-color 0.15s;
  }

  .ticket-card--live:hover .ticket-card__cta {
    background: rgba(var(--brand-red-rgb), 0.15);
    border-color: rgba(var(--brand-red-rgb), 0.5);
  }

  .ticket-card__cta--soldout {
    background: rgba(0, 0, 0, 0.04);
    color: var(--muted);
    border-color: rgba(0, 0, 0, 0.08);
  }

  .ticket-card--live:hover .ticket-card__cta--soldout {
    background: rgba(0, 0, 0, 0.04);
    border-color: rgba(0, 0, 0, 0.08);
  }

  .ticket-card__cta--notify {
    border-color: rgba(0, 0, 0, 0.1);
    background: rgba(0, 0, 0, 0.03);
    color: var(--text-light);
  }

  .ticket-card--tba:hover .ticket-card__cta--notify {
    background: rgba(var(--brand-red-rgb), 0.08);
    border-color: rgba(var(--brand-red-rgb), 0.35);
    color: var(--brand-red);
  }

  /* ─── Empty State ────────────────────────────────────── */

  .tickets-empty {
    font-family: var(--font-body);
    font-size: 17px;
    color: var(--text-light);
    line-height: 1.55;
    text-align: center;
    padding: 40px 0;
  }

  .tickets-empty__link {
    color: var(--brand-red);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ─── Footer ─────────────────────────────────────────── */

  .tickets-footer {
    margin-top: 48px;
    padding-top: 24px;
  }

  .tickets-footer__back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--text-light);
    text-decoration: none;
    transition: color 0.15s;
  }

  .tickets-footer__back:hover {
    color: var(--charcoal);
  }

</style>
