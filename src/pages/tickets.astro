---
import BaseLayout from "@/layouts/BaseLayout.astro";
import NotifyModal from "@/components/NotifyModal.astro";
import { buildBreadcrumbJsonLd } from "@/utils/breadcrumbs";
import { events, allEvents } from "@/data/events";
import { buildEventSchemas } from "@/utils/eventSchema";
import LeadCaptureModal from "@/components/LeadCaptureModal.astro";
import { buildTaglineMap } from "@/utils/eventTaglines";
import { getUpcomingDated } from "@/utils/eventFilters";
import { PAGES } from "@/data/copy";
import TicketCard from "@/components/tickets/TicketCard.astro";
import EventbriteWidgetInit from "@/components/EventbriteWidgetInit.astro";
import StickyCTA from "@/components/StickyCTA.astro";

const TITLE = "Tickets & Upcoming Shows";
const DESC =
  "Get tickets to Garam Masala Dating shows in New York and beyond. America's #1 live desi dating show and South Asian singles mixer. Now touring LA, SF, and San Diego.";

const today = new Date().toISOString().slice(0, 10);
const datedUpcoming = getUpcomingDated(allEvents, today);
const tbaEvents = allEvents.filter((e) => !e.hidden && !e.isoDate);
const upcomingEvents = [...datedUpcoming, ...tbaEvents];

const taglineMap = buildTaglineMap(upcomingEvents);

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: "https://garammasaladating.com/" },
  { name: "Tickets" },
]);

// Individual Event JSON-LD blocks (one per upcoming dated show)
const eventSchemas = buildEventSchemas(
  events.filter((e) => !e.hidden && e.isoDate && e.isoDate >= today),
);

// EventSeries JSON-LD — signals this is a recurring show, not a one-off
const eventSeriesJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "EventSeries",
  "@id": "https://garammasaladating.com/#event-series",
  name: "Garam Masala Dating",
  description:
    "America's #1 recurring live desi comedy dating show. Two real singles go on a blind date in front of a 250-person audience. Bi-weekly in Manhattan at Top Secret Comedy Club.",
  url: "https://garammasaladating.com",
  startDate: "2022",
  organizer: {
    "@type": "Organization",
    name: "Garam Masala Dating",
    url: "https://garammasaladating.com",
  },
  location: {
    "@type": "Place",
    name: "Top Secret Comedy Club",
    address: {
      "@type": "PostalAddress",
      streetAddress: "44 Avenue A",
      addressLocality: "New York",
      addressRegion: "NY",
      postalCode: "10009",
      addressCountry: "US",
    },
  },
  eventSchedule: {
    "@type": "Schedule",
    repeatFrequency: "P2W",
  },
});
---

<BaseLayout title={TITLE} description={DESC}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
    <script type="application/ld+json" set:html={eventSeriesJsonLd} />
    {
      eventSchemas.map((schema) => (
        <script type="application/ld+json" set:html={schema} />
      ))
    }
  </Fragment>

  <main id="main-content" class="tickets-page">
    <div class="tickets-container">
      {/* Header */}
      <div class="tickets-header">
        <p class="tickets-eyebrow">Tickets</p>
        <h1 class="tickets-h1">Upcoming Shows</h1>
        <p class="tickets-intro">{PAGES.tickets.intro}</p>
        <p class="tickets-proof">
          40+ shows sold out · 2,000+ audience members
        </p>
      </div>

      {/* Divider */}
      <div class="tickets-divider"></div>

      {/* Event cards */}
      {
        upcomingEvents.length > 0 ? (
          <div class="tickets-list" id="shows">
            {upcomingEvents.map((event, i) => {
              const isLive = !!event.url && event.url !== "#";
              const tagline =
                (isLive ? taglineMap.get(event.url!) : undefined) ??
                event.tagline ??
                undefined;
              return (
                <TicketCard
                  event={event}
                  index={i}
                  sourcePage="tickets"
                  tagline={tagline}
                />
              );
            })}
          </div>
        ) : (
          <p class="tickets-empty">
            No upcoming shows. Follow us on{" "}
            <a
              href="https://www.instagram.com/garammasaladating/"
              target="_blank"
              rel="noopener noreferrer"
              class="tickets-empty__link"
            >
              Instagram
            </a>{" "}
            for announcements.
          </p>
        )
      }

      <NotifyModal source="tickets-notify" />

      {/* Don't see your city? */}
      <div class="tickets-city-request" data-reveal>
        <p class="tickets-city-request__text">
          Don't see your city? We're expanding fast.
        </p>
        <button
          type="button"
          class="tickets-city-request__btn"
          data-open-modal="tickets-city-modal"
          data-ph-capture="waitlist_click"
          data-ph-cta="tickets_city_request"
          data-ph-section="tickets_city_request"
          data-cta-position="tickets_city_request"
          data-cta-text="Tell Us Where You Are"
          aria-haspopup="dialog"
        >
          Tell Us Where You Are
        </button>
      </div>

      <LeadCaptureModal
        id="tickets-city-modal"
        source="tickets-city-request"
        heading="Request Your City"
        subheading="Tell us where you are and we'll let you know when we're coming."
        submitLabel="Notify Me"
        successMessage="Got it! We'll reach out when we're headed your way."
      />

      {/* Footer */}
      <div class="tickets-footer">
        <a href="/" class="tickets-footer__back">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M19 12H5"></path><path d="m12 19-7-7 7-7"></path></svg
          >
          Back to Home
        </a>
      </div>
    </div>
  </main>

  <EventbriteWidgetInit />

  <script>
    import "@/lib/presaleReveal";
  </script>
  <StickyCTA
    triggerSelector=".tickets-header"
    label="Grab My Spot"
    href="#shows"
  />
</BaseLayout>

<style>
  @keyframes ticketsFadeIn {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .tickets-page {
    min-height: 100vh;
    position: relative;
    z-index: 1;
    overflow: hidden;
    background:
      radial-gradient(
        circle at top right,
        rgba(var(--brand-red-rgb), 0.08),
        transparent 34rem
      ),
      linear-gradient(180deg, var(--off-white) 0%, var(--cream-warm) 100%);
  }

  .tickets-container {
    position: relative;
    z-index: 1;
    max-width: 560px;
    margin: 0 auto;
    padding: 24px;
  }

  /* ─── Header ─────────────────────────────────────────── */

  .tickets-header {
    margin-bottom: 24px;
    animation: ticketsFadeIn 0.35s ease-out both;
  }

  .tickets-eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--brand-red);
    margin-bottom: 12px;
  }

  .tickets-h1 {
    font-family: var(--font-playfair);
    font-size: 36px;
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.15;
    margin-bottom: 14px;
  }

  .tickets-intro {
    font-family: var(--font-cormorant);
    font-style: italic;
    font-size: 19px;
    color: var(--text-light);
    line-height: 1.55;
  }

  .tickets-proof {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-light);
    margin-top: 10px;
    letter-spacing: 0.5px;
  }

  .tickets-divider {
    width: 48px;
    height: 1px;
    background: rgba(var(--brand-red-rgb), 0.3);
    margin-bottom: 32px;
  }

  /* ─── Event Cards ────────────────────────────────────── */

  .tickets-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* ─── Empty State ────────────────────────────────────── */

  .tickets-empty {
    font-family: var(--font-body);
    font-size: 17px;
    color: var(--text-light);
    line-height: 1.55;
    text-align: center;
    padding: 40px 0;
  }

  .tickets-empty__link {
    color: var(--brand-red);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ─── City Request ───────────────────────────────────── */

  .tickets-city-request {
    text-align: center;
    padding: 32px 0 16px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    margin-top: 24px;
  }

  .tickets-city-request__text {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--text-light);
    margin-bottom: 12px;
  }

  .tickets-city-request__btn {
    background: none;
    border: 1.5px solid var(--brand-red);
    color: var(--brand-red);
    padding: 12px 24px;
    border-radius: 50px;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition:
      background 0.2s,
      color 0.2s;
    min-height: var(--touch-target);
  }

  .tickets-city-request__btn:hover {
    background: var(--brand-red);
    color: white;
  }

  /* ─── Footer ─────────────────────────────────────────── */

  .tickets-footer {
    padding-top: 24px;
  }

  .tickets-footer__back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--text-light);
    text-decoration: none;
    transition: color 0.15s;
  }

  .tickets-footer__back:hover {
    color: var(--charcoal);
  }
</style>
