---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { buildBreadcrumbJsonLd } from '@/utils/breadcrumbs';
import { events, allEvents } from '@/data/events';
import { isEventPast } from '@/utils/eventDate';
import { buildEventSchemas } from '@/utils/eventSchema';

const TITLE = "Tickets & Upcoming Shows | Garam Masala Dating";
const DESC =
  "Get tickets to upcoming Garam Masala Dating shows. NYC's #1 live South Asian dating show and singles mixer, now in LA, SF, San Diego, and more.";

const upcomingEvents = allEvents.filter((e) => !isEventPast(e.date) && !e.hidden);

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "Home", url: "https://garammasaladating.com/" },
  { name: "Tickets" },
]);

// Individual Event JSON-LD blocks (one per upcoming show)
const today = new Date().toISOString().slice(0, 10);
const upcomingForSchema = events.filter((e) => !e.hidden && e.isoDate && e.isoDate >= today);
const eventSchemas = buildEventSchemas(upcomingForSchema);
---

<BaseLayout title={TITLE} description={DESC}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
    {eventSchemas.map((schema) => (
      <script type="application/ld+json" set:html={schema} />
    ))}
  </Fragment>

  <div class="tickets-page">
    <div class="tickets-container">
      {/* Header */}
      <div class="tickets-header">
        <p class="tickets-eyebrow">Tickets</p>
        <h1 class="tickets-h1">Upcoming Shows</h1>
        <p class="tickets-intro">
          Garam Masala Dating is a live South Asian dating show and singles mixer.
          Grab tickets on Eventbrite.
        </p>
      </div>

      {/* Divider */}
      <div class="tickets-divider" />

      {/* Event cards */}
      {upcomingEvents.length > 0 ? (
        <div class="tickets-list">
          {upcomingEvents.map((event, i) => {
            const isLive = event.url && event.url !== "#";
            return isLive ? (
              <a
                href={event.url}
                target="_blank"
                rel="noopener noreferrer"
                class="ticket-card ticket-card--live"
                style={`animation-delay: ${0.1 + i * 0.06}s`}
              >
                <div class="ticket-card__info">
                  <span class="ticket-card__date">{event.date}</span>
                  <span class="ticket-card__city">{event.city}</span>
                </div>
                <span class="ticket-card__cta">
                  Get Tickets
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </span>
              </a>
            ) : (
              <button
                type="button"
                class="ticket-card ticket-card--tba"
                style={`animation-delay: ${0.1 + i * 0.06}s`}
                data-notify-city={event.city}
              >
                <div class="ticket-card__info">
                  <span class="ticket-card__date ticket-card__date--tba">{event.date}</span>
                  <span class="ticket-card__city ticket-card__city--tba">{event.city}</span>
                </div>
                <span class="ticket-card__cta ticket-card__cta--notify">
                  Notify Me
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
                </span>
              </button>
            );
          })}
        </div>
      ) : (
        <p class="tickets-empty">
          No upcoming shows. Follow us on{' '}
          <a href="https://www.instagram.com/garammasaladating/" target="_blank" rel="noopener noreferrer" class="tickets-empty__link">
            Instagram
          </a>{' '}
          for announcements.
        </p>
      )}

      {/* Notify modal */}
      <dialog id="notify-modal" class="modal-dialog">
        <div class="modal-inner">
          <button type="button" class="modal-close" aria-label="Close">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          </button>
          <div id="notify-form-view">
            <h2 class="modal-title">Get Notified</h2>
            <p class="modal-subtitle">We'll email you when tickets drop for <strong id="notify-city-name"></strong>.</p>
            <form id="notify-form" class="modal-form">
              <input type="email" id="notify-email" placeholder="Your email" required aria-label="Email address" />
              <input type="hidden" id="notify-city" />
              <button type="submit" class="modal-submit">Notify Me</button>
            </form>
          </div>
          <div id="notify-success" class="modal-success" hidden>
            <p>You're on the list! We'll let you know.</p>
          </div>
        </div>
      </dialog>

      {/* Footer */}
      <div class="tickets-footer">
        <a href="/" class="tickets-footer__back">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
          Back to Home
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { getFirebaseDb } from '@/lib/firebase';
  import { collection, addDoc } from 'firebase/firestore';

  const dialog = document.getElementById('notify-modal') as HTMLDialogElement;
  if (dialog) {
    document.querySelectorAll<HTMLElement>('[data-notify-city]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const city = btn.dataset.notifyCity ?? '';
        (document.getElementById('notify-city') as HTMLInputElement).value = city;
        const nameEl = document.getElementById('notify-city-name');
        if (nameEl) nameEl.textContent = city;
        document.getElementById('notify-form-view')?.removeAttribute('hidden');
        document.getElementById('notify-success')?.setAttribute('hidden', '');
        dialog.showModal();
      });
    });
    dialog.querySelector('.modal-close')?.addEventListener('click', () => dialog.close());
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });

    document.getElementById('notify-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (document.getElementById('notify-email') as HTMLInputElement).value;
      const city = (document.getElementById('notify-city') as HTMLInputElement).value;
      try {
        const db = getFirebaseDb();
        await addDoc(collection(db, 'notifications'), {
          email,
          city,
          source: 'tickets-notify',
          createdAt: new Date().toISOString(),
        });
      } catch { /* fail silently */ }
      document.getElementById('notify-form-view')?.setAttribute('hidden', '');
      document.getElementById('notify-success')?.removeAttribute('hidden');
    });
  }
</script>

<style>
  @keyframes ticketsFadeIn {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .tickets-page {
    min-height: 100vh;
    position: relative;
    z-index: 1;
    animation: ticketsFadeIn 0.5s ease-out both;
  }

  .tickets-container {
    max-width: 560px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  /* ─── Header ─────────────────────────────────────────── */

  .tickets-header {
    margin-bottom: 40px;
  }

  .tickets-eyebrow {
    font-family: var(--font-jetbrains);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--hot-pink);
    margin-bottom: 12px;
  }

  .tickets-h1 {
    font-family: var(--font-playfair);
    font-size: 32px;
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.15;
    margin-bottom: 14px;
  }

  .tickets-intro {
    font-family: var(--font-cormorant);
    font-style: italic;
    font-size: 17px;
    color: #666;
    line-height: 1.55;
  }

  .tickets-divider {
    width: 48px;
    height: 1px;
    background: rgba(var(--hot-pink-rgb), 0.3);
    margin-bottom: 32px;
  }

  /* ─── Event Cards ────────────────────────────────────── */

  .tickets-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ticket-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 22px;
    border-radius: 12px;
    border: 1px solid;
    text-decoration: none;
    animation: ticketsFadeIn 0.5s ease-out both;
    transition: border-color 0.15s, background 0.15s;
  }

  .ticket-card--live {
    border-color: rgba(var(--hot-pink-rgb), 0.35);
    background: white;
  }

  .ticket-card--live:hover {
    border-color: rgba(var(--hot-pink-rgb), 0.55);
    background: rgba(var(--hot-pink-rgb), 0.04);
  }

  .ticket-card--tba {
    border-color: rgba(0, 0, 0, 0.08);
    background: white;
    cursor: pointer;
    text-align: left;
    font: inherit;
  }

  .ticket-card--tba:hover {
    border-color: rgba(var(--hot-pink-rgb), 0.3);
    background: rgba(var(--hot-pink-rgb), 0.02);
  }

  .ticket-card__info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ticket-card__date {
    font-family: var(--font-jetbrains);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--hot-pink);
  }

  .ticket-card__date--tba {
    color: var(--muted);
  }

  .ticket-card__city {
    font-family: var(--font-playfair);
    font-size: 20px;
    font-weight: 600;
    color: var(--charcoal);
    line-height: 1.25;
  }

  .ticket-card__city--tba {
    color: #666;
  }

  .ticket-card__cta {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--hot-pink);
    padding: 8px 14px;
    border: 1px solid rgba(var(--hot-pink-rgb), 0.35);
    border-radius: 8px;
    background: rgba(var(--hot-pink-rgb), 0.08);
    white-space: nowrap;
    transition: background 0.15s, border-color 0.15s;
  }

  .ticket-card--live:hover .ticket-card__cta {
    background: rgba(var(--hot-pink-rgb), 0.15);
    border-color: rgba(var(--hot-pink-rgb), 0.5);
  }

  .ticket-card__cta--notify {
    border-color: rgba(0, 0, 0, 0.1);
    background: rgba(0, 0, 0, 0.03);
    color: #666;
  }

  .ticket-card--tba:hover .ticket-card__cta--notify {
    background: rgba(var(--hot-pink-rgb), 0.08);
    border-color: rgba(var(--hot-pink-rgb), 0.35);
    color: var(--hot-pink);
  }

  /* ─── Empty State ────────────────────────────────────── */

  .tickets-empty {
    font-family: var(--font-body);
    font-size: 17px;
    color: #666;
    line-height: 1.55;
    text-align: center;
    padding: 40px 0;
  }

  .tickets-empty__link {
    color: var(--hot-pink);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ─── Footer ─────────────────────────────────────────── */

  .tickets-footer {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }

  .tickets-footer__back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: #666;
    text-decoration: none;
    transition: color 0.15s;
  }

  .tickets-footer__back:hover {
    color: var(--charcoal);
  }

  /* ─── Notify Modal ──────────────────────────────────── */

  .modal-dialog {
    border: none;
    background: transparent;
    padding: 24px;
    max-width: 100%;
    max-height: 100vh;
    width: 100%;
    height: 100%;
    overflow: visible;
  }
  .modal-dialog::backdrop { background: rgba(0, 0, 0, 0.5); }
  .modal-dialog[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .modal-inner {
    width: 100%;
    max-width: 400px;
    max-height: 80vh;
    overflow-y: auto;
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 20px;
    padding: 32px 24px;
    position: relative;
    animation: modalIn 0.25s ease-out both;
    text-align: center;
  }
  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.95) translateY(8px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
  .modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    color: #888;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
    cursor: pointer;
  }
  .modal-close:hover { color: var(--charcoal); }
  .modal-title {
    font-family: var(--font-playfair), serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--charcoal);
    margin-bottom: 8px;
  }
  .modal-subtitle {
    font-size: 15px;
    color: #666;
    margin-bottom: 24px;
    line-height: 1.5;
  }
  .modal-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .modal-form input {
    padding: 14px 20px;
    border: 1.5px solid rgba(0, 0, 0, 0.1);
    border-radius: 50px;
    font-size: 16px;
    font-family: var(--font-body), sans-serif;
    outline: none;
    transition: border-color 0.2s;
    min-height: 48px;
  }
  .modal-form input:focus { border-color: var(--hot-pink); }
  .modal-submit {
    background: var(--hot-pink);
    color: white;
    border: none;
    padding: 14px;
    border-radius: 50px;
    font-family: var(--font-body), sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: background 0.2s;
    min-height: 48px;
    white-space: nowrap;
    width: 100%;
    cursor: pointer;
  }
  .modal-submit:hover { background: var(--deep-magenta); }
  .modal-success {
    text-align: center;
    padding: 24px 0;
  }
  .modal-success p {
    font-family: var(--font-cormorant), serif;
    font-size: 18px;
    font-style: italic;
    color: var(--charcoal);
  }
</style>
