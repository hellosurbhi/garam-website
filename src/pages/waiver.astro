---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { WAIVER_VERSION, WAIVER_TEXT } from "@/data/waiver";
import { WaiverDocument } from "@/components/WaiverDocument";

const showId = Astro.url.searchParams.get("show")?.trim() ?? "";
---

<BaseLayout
  title="Waiver"
  description="Standalone Garam Masala Dating waiver signing page."
  noindex={true}
>
  <main id="main-content" class="waiver-page">
    <div class="waiver-container">
      <div id="waiver-form-view">
        <h1 class="waiver-title">Waiver</h1>
        <p class="waiver-subtitle">
          Complete this release before going on stage.
        </p>
        <form id="waiver-form" class="waiver-form">
          <div class="waiver-field-row">
            <input
              type="text"
              id="waiver-first"
              placeholder="First name"
              required
              aria-label="First name"
            />
            <input
              type="text"
              id="waiver-last"
              placeholder="Last name"
              required
              aria-label="Last name"
            />
          </div>
          <input
            type="email"
            id="waiver-email"
            placeholder="Email"
            required
            aria-label="Email"
          />
          <input
            type="tel"
            id="waiver-phone"
            placeholder="Phone (555) 123-4567"
            required
            aria-label="Phone number"
          />
          <div class="waiver-scroll" aria-label="Waiver text" tabindex="0">
            <WaiverDocument text={WAIVER_TEXT} />
          </div>
          <label class="waiver-checkbox">
            <input type="checkbox" id="waiver-agree" required disabled />
            <span>I have read and agree to the terms and waiver above</span>
          </label>
          <p id="waiver-scroll-note" class="waiver-note">
            Scroll through the full waiver to enable agreement.
          </p>
          <div>
            <label class="waiver-label" for="waiver-sig"
              >Type your full legal name as your signature</label
            >
            <input
              type="text"
              id="waiver-sig"
              placeholder="First Last"
              required
              aria-label="Signature"
            />
          </div>
          <label class="waiver-checkbox waiver-checkbox-muted">
            <input type="checkbox" id="waiver-optin" />
            <span>Email me about future shows</span>
          </label>
          <input type="hidden" id="waiver-version" value={WAIVER_VERSION} />
          {showId && <input type="hidden" id="waiver-show-id" value={showId} />}
          <p id="waiver-error" class="waiver-error" hidden role="alert"></p>
          <button type="submit" class="waiver-submit">Sign Waiver</button>
        </form>
      </div>
      <div id="waiver-success" hidden>
        <div class="waiver-success">
          <div class="waiver-success-emoji">🌶️</div>
          <h2 class="waiver-success-title">You're all set.</h2>
          <p class="waiver-success-text">
            Your waiver is complete. The host will take it from here.
          </p>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  const form = document.getElementById("waiver-form") as HTMLFormElement | null;
  const waiverScroll = document.querySelector<HTMLDivElement>(".waiver-scroll");
  const agreeInput = document.getElementById(
    "waiver-agree",
  ) as HTMLInputElement | null;
  const scrollNote = document.getElementById("waiver-scroll-note");
  let waiverScrolled = false;

  function updateWaiverScrolled(el: HTMLDivElement) {
    const canScroll = el.scrollHeight > el.clientHeight + 4;
    const reachedBottom = el.scrollTop + el.clientHeight >= el.scrollHeight - 8;
    if (!canScroll || !reachedBottom) return;
    waiverScrolled = true;
    if (agreeInput) agreeInput.disabled = false;
    scrollNote?.setAttribute("hidden", "");
  }

  if (waiverScroll) {
    waiverScroll.addEventListener("scroll", () => {
      updateWaiverScrolled(waiverScroll);
    });
  }

  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const errorEl = document.getElementById("waiver-error");
      const submitBtn =
        form.querySelector<HTMLButtonElement>('[type="submit"]');
      const originalText = submitBtn?.textContent ?? "";
      const firstName = (
        document.getElementById("waiver-first") as HTMLInputElement
      ).value.trim();
      const lastName = (
        document.getElementById("waiver-last") as HTMLInputElement
      ).value.trim();
      const sig = (
        document.getElementById("waiver-sig") as HTMLInputElement
      ).value.trim();

      if (!waiverScrolled) {
        if (errorEl) {
          errorEl.textContent =
            "Please scroll through the full waiver before signing.";
          errorEl.removeAttribute("hidden");
        }
        return;
      }
      if (sig.toLowerCase() !== `${firstName} ${lastName}`.toLowerCase()) {
        if (errorEl) {
          errorEl.textContent = "Signature must match your full name.";
          errorEl.removeAttribute("hidden");
        }
        return;
      }
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = "Signing...";
      }
      try {
        const res = await fetch("/api/stage-waiver", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            firstName,
            lastName,
            email: (
              document.getElementById("waiver-email") as HTMLInputElement
            ).value.trim(),
            phone: (
              document.getElementById("waiver-phone") as HTMLInputElement
            ).value.trim(),
            waiverAgreed: (
              document.getElementById("waiver-agree") as HTMLInputElement
            ).checked,
            signature: sig,
            waiverVersion: (
              document.getElementById("waiver-version") as HTMLInputElement
            ).value,
            mailingListOptIn: (
              document.getElementById("waiver-optin") as HTMLInputElement
            ).checked,
            showId:
              (
                document.getElementById(
                  "waiver-show-id",
                ) as HTMLInputElement | null
              )?.value ?? "",
          }),
        });
        const text = await res.text();
        let data: { error?: string } = {};
        if (text.trim()) {
          try {
            data = JSON.parse(text) as { error?: string };
          } catch {
            data = {};
          }
        }
        if (!res.ok) throw new Error(data.error ?? "Something went wrong");
        document.getElementById("waiver-form-view")?.setAttribute("hidden", "");
        document.getElementById("waiver-success")?.removeAttribute("hidden");
      } catch (err) {
        if (errorEl) {
          errorEl.textContent =
            err instanceof Error
              ? err.message
              : "Something went wrong. Please try again.";
          errorEl.removeAttribute("hidden");
        }
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = originalText;
        }
      }
    });
  }
</script>

<style>
  .waiver-page {
    min-height: 100vh;
    padding: 40px 16px;
    background: var(--off-white);
  }
  .waiver-container {
    max-width: 520px;
    margin: 0 auto;
  }
  .waiver-title {
    font-family: var(--font-playfair), serif;
    font-size: clamp(28px, 5vw, 40px);
    font-weight: 900;
    color: var(--charcoal);
    margin-bottom: 8px;
  }
  .waiver-subtitle {
    font-size: 16px;
    color: var(--muted);
    margin-bottom: 32px;
    line-height: 1.5;
  }
  .waiver-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .waiver-field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .waiver-form input[type="text"],
  .waiver-form input[type="email"],
  .waiver-form input[type="tel"] {
    width: 100%;
    box-sizing: border-box;
    min-height: var(--touch-target);
    padding: 14px 20px;
    border: 1.5px solid rgba(0, 0, 0, 0.12);
    border-radius: 12px;
    background: var(--white);
    color: var(--charcoal);
    font-family: var(--font-body), sans-serif;
    font-size: 16px;
  }
  .waiver-form input:focus-visible {
    border-color: var(--brand-red);
    outline: 2px solid var(--brand-red);
    outline-offset: -2px;
  }
  .waiver-scroll {
    max-height: 220px;
    overflow-y: auto;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 12px;
    background: #f7f1e8;
  }
  .waiver-checkbox {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: var(--charcoal);
    font-size: 15px;
    line-height: 1.5;
  }
  .waiver-checkbox input {
    min-width: 20px;
    min-height: 20px;
    margin-top: 3px;
    accent-color: var(--brand-red);
  }
  .waiver-checkbox-muted {
    color: var(--gray-mid);
  }
  .waiver-label {
    display: block;
    margin-bottom: 8px;
    color: var(--gray-mid);
    font-size: 14px;
  }
  .waiver-note {
    color: var(--gray-mid);
    font-size: 14px;
  }
  .waiver-error {
    color: var(--brand-red);
    font-size: 14px;
  }
  .waiver-submit {
    min-height: 48px;
    border: 0;
    border-radius: 50px;
    background: var(--brand-red);
    color: var(--white);
    cursor: pointer;
    font-family: var(--font-body), sans-serif;
    font-size: 16px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .waiver-submit:disabled {
    cursor: wait;
    opacity: 0.65;
  }
  .waiver-success {
    padding: 72px 0;
    text-align: center;
  }
  .waiver-success-emoji {
    font-size: 48px;
    margin-bottom: 16px;
  }
  .waiver-success-title {
    margin-bottom: 12px;
    color: var(--charcoal);
    font-family: var(--font-playfair), serif;
    font-size: clamp(28px, 5vw, 40px);
  }
  .waiver-success-text {
    color: var(--gray-mid);
    font-size: 16px;
    line-height: 1.6;
  }
  @media (max-width: 520px) {
    .waiver-field-row {
      grid-template-columns: 1fr;
    }
  }
</style>
