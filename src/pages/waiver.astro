---
import BaseLayout from "@/layouts/BaseLayout.astro";
import StandaloneWaiverForm from "@/components/waiver/StandaloneWaiverForm";
import { WAIVER_PAGE } from "@/data/waiverPage";
---

<BaseLayout
  title={WAIVER_PAGE.title}
  description={WAIVER_PAGE.metaDescription}
  noindex={true}
  hideSpiceList={true}
>
  <main id="main-content" class="waiver-page">
    <div class="waiver-container">
      <h1>{WAIVER_PAGE.heading}</h1>
      <StandaloneWaiverForm client:load />
    </div>
  </main>
</BaseLayout>

<style>
  .waiver-page {
    min-height: 100vh;
    padding: 24px;
    background: var(--off-white);
  }
  .waiver-container {
    max-width: 760px;
    margin: 0 auto;
  }
  .waiver-container h1 {
    font-family: var(--font-playfair), serif;
    font-size: 32px;
    font-weight: 700;
    color: var(--charcoal);
    margin-bottom: 24px;
  }
</style>
