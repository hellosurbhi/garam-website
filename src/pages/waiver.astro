---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Spinner from "@/components/ui/Spinner.astro";

const PAGE_TITLE = "Waiver";
const PAGE_DESC = "Garam Masala Dating show waiver";
---

<BaseLayout
  title={PAGE_TITLE}
  description={PAGE_DESC}
  noindex={true}
  hideSpiceList={true}
>
  <main id="main-content" class="waiver-page">
    <div class="waiver-container">
      <h1>Show Waiver</h1>
      <div class="form-wrapper">
        <div class="form-loader" id="waiver-loader">
          <Spinner label="Loading waiver form..." />
          <span class="loader-text">Loading form...</span>
        </div>
        <script
          is:inline
          type="text/javascript"
          src="https://form.jotform.com/jsform/261031391833047"></script>
      </div>
    </div>
  </main>
</BaseLayout>

<script is:inline>
  (function () {
    var loader = document.getElementById("waiver-loader");
    if (!loader) return;

    var hidden = false;
    function hideLoader() {
      if (hidden) return;
      hidden = true;
      loader.style.opacity = "0";
      setTimeout(function () {
        loader.style.display = "none";
      }, 200);
    }

    // JotForm sends postMessage events (setHeight, etc.) once the form renders
    var JOTFORM_ORIGINS = new Set([
      "https://form.jotform.com",
      "https://www.jotform.com",
    ]);
    var JOTFORM_FORM_ID = "261031391833047";
    window.addEventListener("message", function (e) {
      if (!JOTFORM_ORIGINS.has(e.origin)) return;
      try {
        var data = typeof e.data === "string" ? JSON.parse(e.data) : e.data;
        if (
          data &&
          (data.action === "setHeight" || data.fromJotForm) &&
          String(data.formID || "") === JOTFORM_FORM_ID
        ) {
          hideLoader();
        }
      } catch (_) {}
    });

    // Fallback: give up waiting after 10s and hide anyway
    setTimeout(hideLoader, 10000);
  })();
</script>

<style>
  .waiver-page {
    min-height: 100vh;
    padding: 24px;
    background: var(--off-white);
  }
  .waiver-container {
    max-width: 760px;
    margin: 0 auto;
  }
  .waiver-container h1 {
    font-family: var(--font-playfair), serif;
    font-size: 32px;
    font-weight: 700;
    color: var(--charcoal);
    margin-bottom: 32px;
  }
  .form-wrapper {
    width: 100%;
    position: relative;
  }
  .form-loader {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 64px 24px;
    transition: opacity 0.2s ease-out;
  }
  .loader-text {
    font-family: var(--font-nunito), sans-serif;
    font-size: 15px;
    color: var(--muted);
  }
</style>
